<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %> — DarkLion</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="DarkLion">
  <link rel="apple-touch-icon" href="/app-icon.png">
  <style>
    /* === RESET & BASE === */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0f1923; --shell: #141d26; --card: #1a2535; --charcoal: #1c2b3a;
      --gold: #c9a84c; --gold-light: #e2c068;
      --text: #e8edf2; --muted: #8fa3b8;
      --border: rgba(201,168,76,0.22);
      --green: #3ecf8e; --red: #f56565; --orange: #ed8936;
      --sidebar-w: 220px; --header-h: 58px;
    }
    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--navy); color: var(--text); min-height: 100vh; }
    /* Prevent page <style> blocks in body from taking visual space */
    body > style { display: none !important; }

    /* === TOP HEADER === */
    .top-header {
      position: fixed; top: 0; left: 0; right: 0;
      height: var(--header-h);
      background: var(--shell);
      border-bottom: 2px solid var(--gold);
      display: flex; align-items: center; gap: 1rem;
      padding: 0 1.25rem; z-index: 300;
    }
    .header-logo {
      width: var(--sidebar-w); flex-shrink: 0;
      display: flex; align-items: center; gap: 0.6rem;
      text-decoration: none; padding-right: 1rem;
    }
    .header-logo img { width: 30px; height: 30px; border-radius: 6px; flex-shrink: 0; }
    .header-logo .logo-name { font-size: 1.1rem; font-weight: 800; color: var(--text); }
    .header-logo .logo-name span { color: var(--gold); }
    .header-divider { width: 1px; height: 32px; background: var(--border); flex-shrink: 0; }
    .header-search-wrap { flex: 1; max-width: 540px; margin: 0 auto; position: relative; }
    .header-search-bar {
      width: 100%; height: 38px;
      background: rgba(255,255,255,0.05); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text);
      padding: 0 1rem 0 2.4rem; font-size: 0.88rem; outline: none;
      transition: border-color 0.2s;
    }
    .header-search-bar:focus, .header-search-bar.open { border-color: var(--gold); }
    .header-search-bar::placeholder { color: var(--muted); }
    .header-search-icon { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.9rem; pointer-events: none; }
    .header-client-dropdown { display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0; background: #13222f; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.5); z-index: 400; overflow: hidden; }
    .header-client-dropdown.open { display: block; }
    .hcd-list { max-height: 320px; overflow-y: auto; }
    .hcd-option { display: flex; align-items: center; gap: 0.7rem; padding: 0.6rem 1rem; cursor: pointer; transition: background 0.1s; font-size: 0.85rem; }
    .hcd-option:hover, .hcd-option.focused { background: rgba(201,168,76,0.07); }
    .hcd-info { flex: 1; min-width: 0; }
    .hcd-name { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .hcd-meta { font-size: 0.72rem; color: var(--muted); }
    .hcd-footer { padding: 0.4rem 1rem; border-top: 1px solid var(--border); font-size: 0.72rem; color: var(--muted); }
    .header-user { display: flex; align-items: center; gap: 0.75rem; margin-left: auto; flex-shrink: 0; cursor: pointer; padding: 0.3rem 0.5rem; border-radius: 8px; transition: background 0.15s; position: relative; }
    .header-user:hover { background: rgba(201,168,76,0.07); }
    .user-avatar { width: 38px; height: 38px; border-radius: 50%; background: rgba(201,168,76,0.15); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.85rem; flex-shrink: 0; overflow: hidden; border: 2px solid rgba(201,168,76,0.3); }
    .user-info { text-align: left; }
    .user-name { font-size: 0.88rem; font-weight: 600; line-height: 1.3; color: var(--text); letter-spacing: 0.01em; }
    .user-firm { font-size: 0.72rem; color: var(--muted); line-height: 1.2; }
    .user-caret { font-size: 0.6rem; color: var(--muted); margin-left: 0.15rem; }
    .user-dropdown { display: none; position: absolute; top: calc(100% + 6px); right: 0; background: var(--charcoal); border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.5); z-index: 400; min-width: 180px; overflow: hidden; }
    .user-dropdown.open { display: block; }
    .umd-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1rem; cursor: pointer; font-size: 0.85rem; color: var(--text); transition: background 0.1s; text-decoration: none; }
    .umd-item:hover { background: rgba(201,168,76,0.07); }
    .umd-item.danger { color: var(--red); }
    .umd-item.danger:hover { background: rgba(245,101,101,0.08); }
    .umd-divider { height: 1px; background: var(--border); margin: 0.25rem 0; }

    /* === SIDEBAR === */
    .sidebar { position: fixed; top: var(--header-h); left: 0; bottom: 0; width: var(--sidebar-w); background: var(--shell); border-right: 1px solid var(--border); overflow-y: auto; z-index: 200; padding: 0.5rem 0 1rem; }
    .nav-section { padding: 0.85rem 1rem 0.2rem; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
    .nav-item { display: flex; align-items: center; gap: 0.55rem; padding: 0.52rem 1rem; font-size: 0.85rem; color: var(--muted); text-decoration: none; border-left: 3px solid transparent; transition: all 0.12s; }
    .nav-item:hover { color: var(--text); background: rgba(201,168,76,0.05); }
    .nav-item.active { color: var(--gold); border-left-color: var(--gold); background: rgba(201,168,76,0.08); font-weight: 600; }
    .nav-item.nav-dim { opacity: 0.4; pointer-events: none; }

    /* === MAIN CONTENT === */
    .main { position: fixed; left: var(--sidebar-w); top: var(--header-h); right: 0; bottom: 0; overflow-y: auto; overflow-x: hidden; box-sizing: border-box; }

    /* ── Entity pages (person/company/relationship detail) ── */
    .entity-header { position: sticky; top: 0; z-index: 160; background: var(--shell); border-bottom: 1px solid var(--border); padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .entity-back { font-size: 0.8rem; color: var(--muted); text-decoration: none; flex-shrink: 0; }
    .entity-back:hover { color: var(--gold); }
    .entity-header-content { flex: 1; min-width: 0; }
    .entity-name { font-size: 1.05rem; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .entity-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.2rem; }
    .entity-meta { font-size: 0.78rem; color: var(--muted); margin-top: 0.15rem; }
    .entity-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
    .tab-bar { background: var(--navy); border-bottom: 1px solid var(--border); display: flex; gap: 0; padding: 0 1.5rem; position: sticky; top: var(--tab-bar-top, 58px); z-index: 150; overflow-x: auto; overflow-y: hidden; scrollbar-width: none; }
    .tab-bar::-webkit-scrollbar { display: none; }
    .tab-item { padding: 0.7rem 1.1rem; cursor: pointer; font-size: 0.86rem; font-weight: 500; color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: all 0.15s; }
    .tab-item:hover { color: var(--text); }
    .tab-item.active { color: var(--gold); border-bottom-color: var(--gold); font-weight: 600; }
    .tab-content { display: none; padding: 1.5rem; flex: 1; }
    .tab-content.active { display: block; }

    /* ── Person/company row in lists ── */
    .person-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .person-row:last-child { border-bottom: none; }
    .person-avatar { width: 34px; height: 34px; border-radius: 50%; background: rgba(201,168,76,0.15); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.78rem; flex-shrink: 0; }
    .person-info { flex: 1; min-width: 0; }
    .person-name { font-size: 0.88rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .person-meta { font-size: 0.74rem; color: var(--muted); }

    /* === COMMON COMPONENTS === */
    .btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 7px; border: none; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.2s, transform 0.1s; text-decoration: none; }
    .btn:active { transform: scale(0.97); }
    .btn-gold { background: var(--gold); color: var(--navy); }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--muted); }
    .btn-outline:hover { border-color: var(--gold); color: var(--text); }
    .btn-ghost { background: transparent; border: none; color: var(--muted); }
    .btn-ghost:hover { color: var(--text); }
    .btn-sm { padding: 0.35rem 0.75rem; font-size: 0.78rem; }
    .btn-xs { padding: 0.2rem 0.5rem; font-size: 0.72rem; border-radius: 5px; }
    .btn-danger { background: transparent; border: 1px solid var(--red); color: var(--red); }
    .badge { display: inline-flex; align-items: center; padding: 0.18rem 0.55rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; }
    .badge-green { background: rgba(62,207,142,0.12); color: var(--green); }
    .badge-gold { background: rgba(201,168,76,0.14); color: var(--gold); }
    .badge-muted { background: rgba(143,163,184,0.12); color: var(--muted); }
    .badge-red { background: rgba(245,101,101,0.12); color: var(--red); }
    .badge-orange { background: rgba(237,137,54,0.12); color: var(--orange); }
    .card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem; margin-bottom: 1rem; }
    .card-title { font-size: 0.88rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text); }
    .toast { position: fixed; bottom: 1.5rem; right: 1.5rem; background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 1.25rem; font-size: 0.85rem; z-index: 9000; opacity: 0; transition: opacity 0.2s; pointer-events: none; }
    .toast.show { opacity: 1; }
    .toast.error { border-color: var(--red); color: var(--red); }
    .loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem; color: var(--muted); gap: 0.75rem; }
    .loading-spinner { width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .empty-state { text-align: center; padding: 3rem 2rem; color: var(--muted); }
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.65); z-index: 1000; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; max-width: 480px; width: calc(100% - 2rem); }
    .modal h2 { font-size: 1.1rem; margin-bottom: 1.25rem; }
    .modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1.25rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-size: 0.78rem; font-weight: 600; color: var(--muted); margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .form-control { width: 100%; background: var(--charcoal); border: 1px solid var(--border); color: var(--text); padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.85rem; outline: none; transition: border-color 0.15s; }
    .form-control:focus { border-color: var(--gold); }
    .form-hint { font-size: 0.72rem; color: var(--muted); margin-top: 0.25rem; }

    @media (max-width: 768px) {
      :root { --sidebar-w: 56px; }
      .nav-item span, .nav-section { display: none; }
    }
    /* Mobile nav toggle */
    .mobile-nav-toggle {
      display: none;
      background: rgba(255,255,255,0.06);
      border-radius: 10px;
      padding: 3px;
      gap: 2px;
      flex: 1;
      justify-content: center;
    }
    .mobile-nav-toggle a {
      background: none;
      border: none;
      color: var(--muted);
      font-size: 1.2rem;
      padding: 0.35rem 0.9rem;
      border-radius: 7px;
      cursor: pointer;
      transition: all 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      min-height: 36px;
    }
    .mobile-nav-toggle a.active {
      background: var(--gold);
      color: var(--navy);
    }

    @media (max-width: 600px) {
      :root { --sidebar-w: 0px; }
      .sidebar { display: none; }
      .header-search-wrap, .header-divider { display: none; }
      .user-info, .user-caret { display: none; }
      .header-user { padding: 0.3rem; flex-shrink: 0; }
      .top-header { padding: 0 0.75rem; justify-content: space-between; }
      .header-logo { width: auto; flex-shrink: 0; padding: 0; }
      .header-logo .logo-name { display: none; }
      .mobile-nav-toggle { display: flex; flex: 1; margin: 0 0.75rem; }
      /* Docs tab — edge to edge on mobile */
      #tab-docs.tab-content { padding: 0.75rem 0; }
      #tab-docs .year-folder { border-radius: 0; margin-left: 0; margin-right: 0; }
      #tab-docs .docs-col-title { padding: 0 0.75rem; }
    }

  </style>
</head>
<body>

  <!-- TOP HEADER -->
  <header class="top-header">
    <% if (locals.firmBranding) { %>
    <a class="header-logo" id="header-logo-link" href="/dashboard">
      <img src="/sentinel-favicon.png" alt="<%= firmBranding.name %>" style="width:30px;height:30px;object-fit:contain;border-radius:6px;flex-shrink:0;">
      <div class="logo-name"><%= firmBranding.name %></div>
    </a>
    <% } else { %>
    <a class="header-logo" id="header-logo-link" href="/dashboard">
      <img src="/lion-logo.png" alt="DL">
      <div class="logo-name">Dark<span>Lion</span></div>
    </a>
    <% } %>
    <!-- Mobile toggle — Messages / Docs (visible only on small screens) -->
    <nav class="mobile-nav-toggle">
      <a href="/messages" class="<%= activeNav==='messages'?'active':'' %>">💬</a>
      <a href="/documents" class="<%= activeNav==='documents'?'active':'' %>">📁</a>
    </nav>

    <div class="header-divider"></div>
    <div class="header-search-wrap">
      <span class="header-search-icon">🔍</span>
      <input type="text" class="header-search-bar" id="header-search-bar"
        placeholder="Search relationships, companies, people…"
        autocomplete="off" readonly>
      <div class="header-client-dropdown" id="header-client-dropdown">
        <div class="hcd-list" id="hcd-list"></div>
        <div class="hcd-footer" id="hcd-footer"></div>
      </div>
    </div>
    <div class="header-user" id="header-user-btn">
      <div class="user-avatar" id="user-avatar">?</div>
      <div class="user-info">
        <div class="user-name" id="user-menu-name">Loading… <span class="user-caret">▼</span></div>
        <div class="user-firm" id="user-menu-firm"></div>
      </div>
      <div class="user-dropdown" id="user-dropdown">
        <a class="umd-item" href="/team">👥 Team</a>
        <div class="umd-divider"></div>
        <a class="umd-item danger" id="header-logout-btn">Sign Out</a>
      </div>
    </div>
  </header>

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar-el">
    <div class="nav-section">Clients</div>
    <a class="nav-item <%= ['relationships','people','companies'].includes(activeNav)?'active':'' %>" href="/crm">🗂️ <span>CRM</span></a>
    <div class="nav-section" style="margin-top:0.5rem;">Messages</div>
    <a class="nav-item <%= activeNav==='messages'?'active':'' %>" href="/messages">💬 <span>My Inbox</span></a>
    <a class="nav-item <%= activeNav==='conversation-summaries'?'active':'' %>" href="/conversation-summaries">🗒️ <span>Summaries</span></a>
    <a class="nav-item <%= activeNav==='templates'?'active':'' %>" href="/templates">📝 <span>Templates</span></a>
    <div class="nav-section" style="margin-top:0.5rem;">Engagements</div>
    <a class="nav-item <%= activeNav==='proposals'?'active':'' %>" href="/proposals">📄 <span>Proposals</span></a>
    <div class="nav-section" style="margin-top:0.5rem;">Work</div>
    <a class="nav-item <%- activeNav==='pipelines'?'active':'' %>" href="/pipelines">📋 <span>Pipelines</span></a>
    <a class="nav-item <%= activeNav==='statements-calendar'?'active':'' %>" href="/statements-calendar">📅 <span>Statement Calendar</span></a>
    <div class="nav-section" style="margin-top:0.5rem;">Forecast</div>
    <a class="nav-item <%= activeNav==='forecast'?'active':'' %>" href="/forecast">📈 <span>Revenue Forecast</span></a>
    <div class="nav-section" style="margin-top:0.5rem;">Account</div>
    <a class="nav-item <%= activeNav==='settings'?'active':'' %>" href="/settings">⚙️ <span>Settings</span></a>
    <a class="nav-item <%= activeNav==='webdav-help'?'active':'' %>" href="/webdav-help">🗂️ <span>WebDAV Drive</span></a>
  </aside>

  <script>
    (function() {
      const isPwa = window.navigator.standalone === true || window.matchMedia('(display-mode: standalone)').matches;
      if (isPwa) {
        const logo = document.getElementById('header-logo-link');
        if (logo) logo.href = '/messages';
      }
    })();
  </script>

  <main class="main">

