


  <!-- TOAST -->
  <div class="toast" id="toast"></div>

  <!-- SHARED JS: auth, search, user menu -->
  <script>
  (function() {
    'use strict';
    var token = localStorage.getItem('dl_token');
    if (!token) { window.location.replace('/login'); return; }

    function apiFetch(url, opts) {
      opts = opts || {};
      var headers = { 'Authorization': 'Bearer ' + token };
      if (!(opts.body instanceof FormData)) headers['Content-Type'] = 'application/json';
      return fetch(url, Object.assign({}, opts, { headers: Object.assign(headers, opts.headers || {}) }))
        .then(function(res) {
          if (res.status === 401) { localStorage.removeItem('dl_token'); window.location.replace('/login?expired=1'); throw new Error('Unauthorized'); }
          return res;
        });
    }

    function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    // ── User menu ──
    var userDropdown = document.getElementById('user-dropdown');
    var headerUserBtn = document.getElementById('header-user-btn');
    headerUserBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      userDropdown.classList.toggle('open');
    });
    document.addEventListener('click', function() { userDropdown.classList.remove('open'); });

    // ── Populate user info from JWT ──
    try {
      var payload = JSON.parse(atob(token.split('.')[1]));
      var name = payload.name || payload.email || '?';
      var firmName = payload.firmName || '';
      document.getElementById('user-menu-name').innerHTML = esc(name) + ' <span class="user-caret">▼</span>';
      document.getElementById('user-menu-firm').textContent = firmName;
      var initials = name.split(' ').map(function(w){return w[0];}).join('').toUpperCase().slice(0,2);
      document.getElementById('user-avatar').textContent = initials || '?';
      // Load avatar
      if (payload.userId) {
        apiFetch('/firms/team/' + payload.userId + '/avatar').then(function(r){return r.json();}).then(function(d){
          if (d.url) {
            var av = document.getElementById('user-avatar');
            var img = document.createElement('img');
            img.src = d.url;
            img.style.cssText = 'width:100%;height:100%;border-radius:50%;object-fit:cover;';
            img.onerror = function(){img.remove();};
            av.textContent = '';
            av.appendChild(img);
          }
        }).catch(function(){});
      }
    } catch(e) {}

    // ── Logout ──
    document.getElementById('header-logout-btn').addEventListener('click', function(e) {
      e.preventDefault();
      localStorage.removeItem('dl_token');
      localStorage.removeItem('dl_firm');
      window.location.replace('/login');
    });

    // ── Recent clients (localStorage) ──
    var RECENT_KEY = 'dl_recent_clients';
    function getRecentClients() {
      try { return JSON.parse(localStorage.getItem(RECENT_KEY) || '[]'); } catch(e) { return []; }
    }
    function addRecentClient(r) {
      var recents = getRecentClients().filter(function(x){ return !(x._type===r._type && x.id===r.id); });
      recents.unshift(r);
      recents = recents.slice(0, 5);
      try { localStorage.setItem(RECENT_KEY, JSON.stringify(recents)); } catch(e) {}
    }

    // ── Unified search ──
    var searchTimer = null;
    var searchResults = [];
    var hcdOpen = false;
    var searchBar = document.getElementById('header-search-bar');
    var searchDropdown = document.getElementById('header-client-dropdown');

    function openSearch() {
      hcdOpen = true;
      searchBar.removeAttribute('readonly');
      searchBar.placeholder = 'Search…';
      searchBar.value = '';
      searchDropdown.classList.add('open');
      renderSearchResults();
    }
    function closeSearch() {
      hcdOpen = false;
      searchDropdown.classList.remove('open');
      searchBar.setAttribute('readonly','');
      searchBar.value = '';
      searchBar.placeholder = 'Search relationships, companies, people…';
    }
    function navigateTo(r) {
      addRecentClient(r);
      closeSearch();
      if (r._type==='relationship') window.location.href='/crm/relationship/'+r.id;
      else if (r._type==='company') window.location.href='/crm/company/'+r.id;
      else window.location.href='/crm/person/'+r.id;
    }
    function renderSearchResults() {
      var list = document.getElementById('hcd-list');
      var footer = document.getElementById('hcd-footer');
      if (!searchResults.length) {
        // Show recent clients when blank
        var recents = getRecentClients();
        if (recents.length) {
          list.innerHTML = '<div style="padding:0.4rem 1rem 0.2rem;font-size:0.68rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.07em;">Recent</div>' +
            recents.map(function(r,i){
              var icon = r._type==='relationship'?'👥':r._type==='company'?'🏢':'👤';
              return '<div class="hcd-option" data-ridx="'+i+'">' +
                '<span style="font-size:1rem;">'+icon+'</span>' +
                '<span class="hcd-info"><span class="hcd-name">'+esc(r._label)+'</span>' +
                '<span class="hcd-meta" style="display:block;">'+esc(r._sub)+'</span></span></div>';
            }).join('');
          footer.textContent = 'Recently visited';
          list.querySelectorAll('.hcd-option[data-ridx]').forEach(function(el){
            el.addEventListener('click', function(){
              navigateTo(recents[parseInt(el.dataset.ridx)]);
            });
          });
        } else {
          list.innerHTML = '<div style="padding:1rem;text-align:center;color:var(--muted);font-size:0.82rem;">Type to search…</div>';
          footer.textContent = '';
        }
        return;
      }
      list.innerHTML = searchResults.map(function(r,i){
        var icon = r._type==='relationship'?'👥':r._type==='company'?'🏢':'👤';
        return '<div class="hcd-option" data-idx="'+i+'">' +
          '<span style="font-size:1rem;">'+icon+'</span>' +
          '<span class="hcd-info"><span class="hcd-name">'+esc(r._label)+'</span>' +
          '<span class="hcd-meta" style="display:block;">'+esc(r._sub)+'</span></span></div>';
      }).join('');
      footer.textContent = searchResults.length + ' result' + (searchResults.length!==1?'s':'');
      list.querySelectorAll('.hcd-option[data-idx]').forEach(function(el,i){
        el.addEventListener('click', function(){
          navigateTo(searchResults[i]);
        });
      });
    }
    searchBar.addEventListener('focus', openSearch);
    searchBar.addEventListener('input', function() {
      var q = searchBar.value.trim();
      clearTimeout(searchTimer);
      if (q.length < 2) { searchResults=[]; renderSearchResults(); return; }
      searchTimer = setTimeout(function(){
        apiFetch('/api/search?q='+encodeURIComponent(q)).then(function(r){return r.json();}).then(function(d){
          searchResults = [].concat(
            (d.relationships||[]).map(function(r){return Object.assign({},r,{_type:'relationship',_label:r.name,_sub:'Relationship'});}),
            (d.companies||[]).map(function(c){return Object.assign({},c,{_type:'company',_label:c.name||c.company_name,_sub:c.entity_type||'Company'});}),
            (d.people||[]).map(function(p){return Object.assign({},p,{_type:'person',_label:(p.first_name||'')+' '+(p.last_name||''),_sub:p.relationship_name||'Person'});})
          );
          renderSearchResults();
        }).catch(function(){});
      }, 200);
    });
    searchBar.addEventListener('keydown', function(e) {
      if (e.key==='Escape') closeSearch();
    });
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.header-search-wrap')) closeSearch();
    });

    // ── Toast ──
    window.toast = function(msg, type) {
      try {
        var t = document.getElementById('toast');
        if (!t) return;
        t.textContent = msg;
        t.className = 'toast show' + (type==='error'?' error':'');
        clearTimeout(t._timer);
        t._timer = setTimeout(function(){ t.className='toast'; }, 3000);
      } catch(e) { /* non-fatal */ }
    };

    // ── apiFetch exposed globally for page scripts ──
    window.apiFetch = apiFetch;
    window.esc = esc;
    window.addRecentClient = addRecentClient;

    // ── Styled confirm dialog (replaces browser native confirm()) ──
    window.dlConfirm = function(message, opts) {
      return new Promise(function(resolve) {
        opts = opts || {};
        var overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;display:flex;align-items:center;justify-content:center;';
        var box = document.createElement('div');
        box.style.cssText = 'background:var(--card,#1e2f40);border:1px solid var(--border,rgba(201,168,76,0.2));border-radius:12px;padding:1.75rem 2rem;max-width:420px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.5);';
        var title = opts.title ? '<div style="font-size:1rem;font-weight:700;margin-bottom:0.6rem;color:var(--text,#e8edf2);">' + esc(opts.title) + '</div>' : '';
        var icon = opts.icon ? '<div style="font-size:2rem;margin-bottom:0.75rem;">' + opts.icon + '</div>' : '';
        var confirmLabel = opts.confirmLabel || 'Confirm';
        var cancelLabel = opts.cancelLabel || 'Cancel';
        var confirmStyle = opts.danger
          ? 'background:var(--red,#f56565);color:#fff;border:none;'
          : 'background:var(--gold,#c9a84c);color:#0f1923;border:none;';
        box.innerHTML = icon + title +
          '<div style="font-size:0.92rem;color:var(--muted,#8fa3b8);line-height:1.6;margin-bottom:1.5rem;">' + message + '</div>' +
          '<div style="display:flex;gap:0.75rem;justify-content:flex-end;">' +
            '<button id="dl-confirm-cancel" style="background:transparent;border:1px solid var(--border,rgba(201,168,76,0.2));color:var(--text,#e8edf2);padding:0.5rem 1.1rem;border-radius:7px;cursor:pointer;font-size:0.88rem;font-weight:600;">' + cancelLabel + '</button>' +
            '<button id="dl-confirm-ok" style="' + confirmStyle + 'padding:0.5rem 1.25rem;border-radius:7px;cursor:pointer;font-size:0.88rem;font-weight:700;">' + confirmLabel + '</button>' +
          '</div>';
        overlay.appendChild(box);
        document.body.appendChild(overlay);
        function close(result) { document.body.removeChild(overlay); resolve(result); }
        overlay.addEventListener('click', function(e) { if (e.target === overlay) close(false); });
        box.querySelector('#dl-confirm-cancel').addEventListener('click', function() { close(false); });
        box.querySelector('#dl-confirm-ok').addEventListener('click', function() { close(true); });
        box.querySelector('#dl-confirm-ok').focus();
      });
    };

    // ── Dynamic tab-bar sticky offset (adjusts to entity-header height) ──
    function updateTabBarTop() {
      var eh = document.querySelector('.entity-header');
      if (!eh) return;
      // tab-bar sticky is relative to <main> which already starts below the top header
      // so offset = entity-header height only
      document.documentElement.style.setProperty('--tab-bar-top', eh.offsetHeight + 'px');
    }
    // Run on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateTabBarTop);
    } else {
      updateTabBarTop();
    }
    window.addEventListener('resize', updateTabBarTop);
    // Re-run whenever entity-header resizes (e.g. after data loads in)
    if (window.ResizeObserver) {
      var _ehObserver = new ResizeObserver(updateTabBarTop);
      function _observeEntityHeader() {
        var eh = document.querySelector('.entity-header');
        if (eh) _ehObserver.observe(eh);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', _observeEntityHeader);
      } else {
        _observeEntityHeader();
      }
    }
  })();
  </script>