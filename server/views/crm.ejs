async function loadCompanies() {
  try {
    const relRes = await apiFetch('/api/relationships');
    const rels = await relRes.json();
    let companies = [];
    for (const rel of rels) {
      try {
        const r = await apiFetch(`/api/relationships/${rel.id}/companies`);
        const cos = await r.json();
        cos.forEach(c => {
          if (!companies.find(x => x.id === c.id)) {
            companies.push({ ...c, relationship_name: rel.name });
          }
        });
      } catch(e) {}
    }
    allCompanies = companies;
    renderCompanies(companies);
  } catch(e) {
    document.getElementById('companies-list-container').innerHTML = `<div class="error-msg">Failed to load companies.</div>`;
  }
}

function renderCompanies(list) {
  const c = document.getElementById('companies-list-container');
  if (!list.length) {
    c.innerHTML = `<div class="empty-state"><div style="font-size:2.5rem;margin-bottom:0.75rem;opacity:0.5;">🏢</div><div>No companies found.</div></div>`;
    return;
  }
  c.innerHTML = `<div class="table-wrap"><table class="data-table">
    <thead><tr><th>Company</th><th>Entity Type</th><th>Relationship</th><th>Status</th></tr></thead>
    <tbody>${list.map(co => `
      <tr onclick="window.location.href='/crm/company/${co.id||co.company_id||0}'" style="cursor:pointer;">
        <td style="font-weight:600;">${esc(co.display_name||co.company_name||co.name||'Unknown')}${(co.city||co.state)?`<div style="font-size:0.74rem;font-weight:400;color:var(--muted);margin-top:0.15rem;">${[co.city,co.state].filter(Boolean).map(esc).join(', ')}</div>`:''}</td>
        <td>${co.entity_type ? `<span class="badge badge-muted">${esc(co.entity_type)}</span>` : '—'}</td>
        <td>${co.relationship_name ? `<span style="color:var(--gold);">${esc(co.relationship_name)}</span>` : '—'}</td>
        <td>${co.status === 'inactive' ? '<span class="badge badge-muted">Inactive</span>' : '<span class="badge badge-green">Active</span>'}</td>
      </tr>`).join('')}
    </tbody></table></div>`;
}

function filterCompanies(q) {
  const f = q.toLowerCase();
  renderCompanies(allCompanies.filter(c =>
    (c.display_name||c.company_name||c.name||'').toLowerCase().includes(f) ||
    (c.entity_type||'').toLowerCase().includes(f) ||
    (c.relationship_name||'').toLowerCase().includes(f)
  ));
}

