function editCurrentPerson() {
  if (currentPersonId) openEditPerson(currentPersonId);
}

async function submitPersonForm() {
  const fname = document.getElementById('person-form-fname').value.trim();
  const lname = document.getElementById('person-form-lname').value.trim();
  const relId = document.getElementById('person-form-rel-id').value;
  if (!fname || !lname) { showFormError('person-form-error', 'First and last name are required.'); return; }
  if (!relId) { showFormError('person-form-error', 'Please select a relationship.'); return; }
  const emailVal = document.getElementById('person-form-email').value.trim();
  if (!emailVal) { showFormError('person-form-error', 'Email is required.'); return; }
  const body = {
    first_name: fname,
    last_name: lname,
    relationship_id: parseInt(relId),
    email: document.getElementById('person-form-email').value.trim() || null,
    phone: document.getElementById('person-form-phone').value.trim() || null,
    filing_status: document.getElementById('person-form-filing').value || null,
    date_of_birth: document.getElementById('person-form-dob').value || null,
    stanford_tax_url: document.getElementById('person-form-stanford').value.trim() || null,
    notes: document.getElementById('person-form-notes').value || null,
    spouse_name: document.getElementById('person-form-spouse-name').value.trim() || null,
    spouse_email: document.getElementById('person-form-spouse-email').value.trim() || null,
    // spouse_portal_enabled only set via the portal invite flow, not creation form
    address_line1: document.getElementById('person-form-addr1').value.trim() || '',
    address_line2: document.getElementById('person-form-addr2').value.trim() || '',
    city: document.getElementById('person-form-city').value.trim() || '',
    state: document.getElementById('person-form-state').value.trim().toUpperCase() || '',
    zip: document.getElementById('person-form-zip').value.trim() || '',
  };
  const btn = document.getElementById('person-form-submit');
  btn.disabled = true;
  try {
    let res;
    if (editingPersonId) {
      res = await apiFetch(`/api/people/${editingPersonId}`, { method: 'PUT', body: JSON.stringify(body) });
    } else {
      res = await apiFetch('/api/people', { method: 'POST', body: JSON.stringify(body) });
    }
    if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Request failed'); }
    closeModal('person-modal');
    toast(editingPersonId ? 'Person updated' : 'Person created');
    await loadPeople();
    if (currentRelId) { loadRelPeople(); }
    if (currentPersonId && editingPersonId === currentPersonId) { loadPersonOverview(); }
  } catch(e) { showFormError('person-form-error', e.message); }
  btn.disabled = false;
}

async function deletePerson(id) {
  if (!await dlConfirm('Delete this person? This cannot be undone.', { danger: true, confirmLabel: 'Delete' })) return;
  try {
    await apiFetch(`/api/people/${id}`, { method: 'DELETE' });
    toast('Person deleted');
    if (currentPersonId === id) closePanel('person-panel');
    await loadPeople();
  } catch(e) { toast('Failed to delete', 'error'); }
}

