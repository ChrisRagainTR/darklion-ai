function openSearchableSelect(key) {
  const opts = document.getElementById(`ss-${key}-options`);
  if (key === 'rel') ssFiltered.rel = [...ssData.rel];
  renderSearchableOptions(key);
  opts.classList.add('open');
}

function searchableSelectFilter(key, q) {
  if (key === 'rel') {
    ssFiltered.rel = ssData.rel.filter(o => o.label.toLowerCase().includes(q.toLowerCase()));
    document.getElementById('person-form-rel-id').value = '';
  }
  renderSearchableOptions(key);
  document.getElementById(`ss-${key}-options`).classList.add('open');
}

function renderSearchableOptions(key) {
  const opts = document.getElementById(`ss-${key}-options`);
  const data = ssFiltered[key];
  if (!data.length) {
    opts.innerHTML = '<div class="ss-empty">No results</div>';
    return;
  }
  opts.innerHTML = data.map(o => `<div class="ss-option" onclick="selectSearchableOption('${key}',${o.id},'${o.label.replace(/'/g,"\\'")}' )">${esc(o.label)}</div>`).join('');
}

function selectSearchableOption(key, id, label) {
  if (key === 'rel') {
    document.getElementById('person-form-rel-id').value = id;
    document.getElementById('person-form-rel-search').value = label;
  }
  document.getElementById(`ss-${key}-options`).classList.remove('open');
}

function openRelByName(name) {
  const rel = allRelationships.find(r => r.name === name);
  if (rel) { switchTab('relationships', null); openRelationship(rel.id); }
}

// =====================================================================
//  HELPERS
// =====================================================================
function initials(first, last) {
  return ((first||'').charAt(0) + (last||'').charAt(0)).toUpperCase() || '?';
}

function tierBadge(tier) {
  if (!tier) return '<span class="badge badge-muted">—</span>';
  const labels = { standard: 'Standard', legacy_blueprint: 'Legacy Blueprint', tax_only: 'Tax Only', full_service: 'Full Service' };
  const classes = { standard: 'badge-muted', legacy_blueprint: 'badge-gold', tax_only: 'badge-blue', full_service: 'badge-green' };
  return `<span class="badge ${classes[tier]||'badge-muted'}">${labels[tier]||tier}</span>`;
}

function billingBadge(status) {
  if (!status) return '—';
  const map = { active: 'badge-green', past_due: 'badge-orange', cancelled: 'badge-red' };
  const labels = { active: 'Active', past_due: 'Past Due', cancelled: 'Cancelled' };
  return `<span class="badge ${map[status]||'badge-muted'}">${labels[status]||status}</span>`;
}

function portalBadge(status) {
  if (!status || status === 'none') return '<span class="badge badge-muted">Not Set Up</span>';
  if (status === 'enabled') return '<span class="badge badge-green">Enabled</span>';
  if (status === 'invited') return '<span class="badge badge-orange">Invited</span>';
  return `<span class="badge badge-muted">${esc(status)}</span>`;
}

function accessBadge(level) {
  const map = { view: 'badge-muted', full: 'badge-gold', sign: 'badge-green' };
  const labels = { view: 'View', full: 'Full', sign: 'Sign' };
  return `<span class="badge ${map[level]||'badge-muted'}">${labels[level]||esc(level)||'—'}</span>`;
}

function filingLabel(s) {
  const map = { single: 'Single', mfj: 'MFJ', mfs: 'MFS', hoh: 'HOH', qw: 'QW' };
  return map[s] || s;
}

function showFormError(elId, msg) {
  const el = document.getElementById(elId);
  el.textContent = msg;
  el.style.display = '';
}

// =====================================================================
//  DOCUMENTS
// =====================================================================
const DOC_ICONS = { tax_return: '📋', w2: '📄', '1099': '📄', engagement_letter: '✍️', organizer: '📝', statement: '🏦', other: '📎' };
function docIcon(type) { return DOC_ICONS[type] || '📎'; }
function fmtBytes(b) {
  if (!b) return '—';
  if (b < 1024) return b + ' B';
  if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
  return (b / (1024 * 1024)).toFixed(1) + ' MB';
}

function docCard(doc, showDeliver = true) {
  const icon = docIcon(doc.doc_type);
  const deliveredBadge = doc.is_delivered ? '<span class="badge badge-green" style="font-size:0.7rem;">Delivered</span>' : '<span class="badge badge-muted" style="font-size:0.7rem;">Not Delivered</span>';
  const yearBadge = doc.year ? `<span class="badge badge-muted" style="font-size:0.7rem;">${esc(doc.year)}</span>` : '';
  const typeBadge = `<span class="badge badge-muted" style="font-size:0.7rem;">${esc(doc.doc_type||'other')}</span>`;
  const deliverToggle = showDeliver ? `<button class="btn btn-ghost btn-xs" style="font-size:0.72rem;" onclick="toggleDelivered(${doc.id}, ${!doc.is_delivered})">${doc.is_delivered ? 'Undeliver' : 'Deliver'}</button>` : '';
  return `
    <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.7rem 0;border-bottom:1px solid var(--border);">
      <span style="font-size:1.4rem;flex-shrink:0;">${icon}</span>
      <div style="flex:1;min-width:0;">
        <div style="font-weight:600;font-size:0.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(doc.display_name||'Untitled')}</div>
        <div style="display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.25rem;">${yearBadge}${typeBadge}${deliveredBadge}</div>
        <div style="font-size:0.75rem;color:var(--muted);margin-top:0.2rem;">${fmtBytes(doc.size_bytes)}</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.3rem;flex-shrink:0;">
        <button class="btn btn-ghost btn-xs" onclick="downloadDoc(${doc.id})">⬇ Download</button>
        ${deliverToggle}
        <button class="btn btn-danger btn-xs" onclick="deleteDoc(${doc.id})">Delete</button>
      </div>
    </div>`;
}

async function downloadDoc(docId) {
  try {
    const res = await apiFetch(`/api/documents/${docId}/download`);
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');
    window.open(data.url, '_blank');
  } catch (e) { toast('Download failed: ' + e.message, 'error'); }
}

async function deleteDoc(docId) {
  if (!await dlConfirm('Delete this document? This cannot be undone.', { danger: true, confirmLabel: 'Delete' })) return;
  try {
    const res = await apiFetch(`/api/documents/${docId}`, { method: 'DELETE' });
    if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
    toast('Document deleted');
    loadPersonDocuments();
    if (currentRelId) loadRelDocuments();
  } catch (e) { toast('Failed to delete: ' + e.message, 'error'); }
}

async function toggleDelivered(docId, deliver) {
  try {
    let res;
    if (deliver) {
      res = await apiFetch(`/api/documents/${docId}/deliver`, { method: 'POST' });
    } else {
      res = await apiFetch(`/api/documents/${docId}`, { method: 'PUT', body: JSON.stringify({ is_delivered: false }) });
    }
    if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
    toast(deliver ? 'Marked as delivered' : 'Delivery revoked');
    loadPersonDocuments();
    if (currentRelId) loadRelDocuments();
  } catch (e) { toast('Failed: ' + e.message, 'error'); }
}

let currentDocSubTab = 'personal';

function switchDocSubTab(tab) {
  currentDocSubTab = tab;
  const personal = document.getElementById('pdoc-personal-content');
  const byco = document.getElementById('pdoc-bycompany-content');
  const btnP = document.getElementById('pdoc-tab-personal');
  const btnC = document.getElementById('pdoc-tab-bycompany');
  if (tab === 'personal') {
    personal.style.display = ''; byco.style.display = 'none';
    btnP.style.background = 'var(--gold)'; btnP.style.color = '#000';
    btnC.style.background = 'transparent'; btnC.style.color = 'var(--muted)';
    loadPersonDocsPersonal();
  } else {
    personal.style.display = 'none'; byco.style.display = '';
    btnP.style.background = 'transparent'; btnP.style.color = 'var(--muted)';
    btnC.style.background = 'var(--gold)'; btnC.style.color = '#000';
    loadPersonDocsByCompany();
  }
}

async function loadPersonDocuments() {
  if (!currentPersonId) return;
  switchDocSubTab(currentDocSubTab || 'personal');
}

async function loadPersonDocsPersonal() {
  if (!currentPersonId) return;
  const c = document.getElementById('pdoc-personal-content');
  c.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
  try {
    const res = await apiFetch(`/api/documents?owner_type=person&owner_id=${currentPersonId}`);
    const docs = await res.json();
    if (!docs.length) { c.innerHTML = '<div class="empty-state"><div style="font-size:2rem;opacity:0.5;">📄</div><div>No personal documents yet.</div></div>'; return; }
    c.innerHTML = docs.map(d => docCard(d)).join('');
  } catch (e) { c.innerHTML = '<div class="error-msg">Failed to load documents.</div>'; }
}

async function loadPersonDocsByCompany() {
  if (!currentPersonId) return;
  const c = document.getElementById('pdoc-bycompany-content');
  c.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
  try {
    const pRes = await apiFetch(`/api/people/${currentPersonId}`);
    const p = await pRes.json();
    const companies = p.company_access || p.companies || [];
    if (!companies.length) { c.innerHTML = '<div class="empty-state"><div style="font-size:2rem;opacity:0.5;">🏢</div><div>No company access.</div></div>'; return; }
    let html = '';
    for (const co of companies) {
      const coId = co.company_id || co.id;
      const coName = co.display_name || co.company_name || co.name || 'Unknown';
      try {
        const docsRes = await apiFetch(`/api/documents?owner_type=company&owner_id=${coId}`);
        const docs = await docsRes.json();
        html += `<div style="margin-bottom:1rem;"><div style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin-bottom:0.5rem;">${esc(coName)}</div>`;
        html += !docs.length ? '<div style="color:var(--muted);font-size:0.83rem;padding:0.5rem 0;">No documents.</div>' : docs.map(d => docCard(d)).join('');
        html += '</div>';
      } catch (e) {}
    }
    c.innerHTML = html || '<div class="empty-state">No documents found.</div>';
  } catch (e) { c.innerHTML = '<div class="error-msg">Failed to load documents.</div>'; }
}

async function loadRelDocuments() {
  if (!currentRelId) return;
  const c = document.getElementById('rel-docs-content');
  c.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
  try {
    const [peopleRes, companiesRes] = await Promise.all([
      apiFetch(`/api/relationships/${currentRelId}/people`),
      apiFetch(`/api/relationships/${currentRelId}/companies`),
    ]);
    const people = await peopleRes.json();
    const companies = await companiesRes.json();
    let html = '';
    for (const p of people) {
      const pName = `${p.first_name} ${p.last_name}`.trim();
      try {
        const docsRes = await apiFetch(`/api/documents?owner_type=person&owner_id=${p.id}`);
        const docs = await docsRes.json();
        html += `<div style="margin-bottom:1rem;"><div style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin-bottom:0.5rem;">👤 ${esc(pName)}</div>`;
        html += !docs.length ? '<div style="color:var(--muted);font-size:0.83rem;padding:0.5rem 0;">No documents.</div>' : docs.map(d => docCard(d)).join('');
        html += '</div>';
      } catch (e) {}
    }
    for (const co of companies) {
      const coId = co.id || co.company_id;
      const coName = co.display_name || co.company_name || co.name || 'Unknown';
      try {
        const docsRes = await apiFetch(`/api/documents?owner_type=company&owner_id=${coId}`);
        const docs = await docsRes.json();
        html += `<div style="margin-bottom:1rem;"><div style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin-bottom:0.5rem;">🏢 ${esc(coName)}</div>`;
        html += !docs.length ? '<div style="color:var(--muted);font-size:0.83rem;padding:0.5rem 0;">No documents.</div>' : docs.map(d => docCard(d)).join('');
        html += '</div>';
      } catch (e) {}
    }
    c.innerHTML = html || '<div class="empty-state"><div style="font-size:2rem;opacity:0.5;">📄</div><div>No documents in this relationship.</div></div>';
  } catch (e) { c.innerHTML = '<div class="error-msg">Failed to load documents.</div>'; }
}

// ── Upload Modal ──
let uploadOwnerType = null;
let uploadOwnerId = null;
let uploadFile = null;

function openUploadModal(ownerType, ownerId) {
  uploadOwnerType = ownerType;
  uploadOwnerId = ownerId;
  uploadFile = null;
  document.getElementById('upload-file-input').value = '';
  document.getElementById('upload-display-name').value = '';
  document.getElementById('upload-year').value = new Date().getFullYear().toString();
  document.getElementById('upload-doc-type').value = 'other';
  document.getElementById('upload-form-error').style.display = 'none';
  document.getElementById('upload-progress-wrap').style.display = 'none';
  document.getElementById('upload-submit-btn').disabled = false;
  document.getElementById('upload-dropzone-text').style.display = '';
  document.getElementById('upload-file-name').style.display = 'none';
  document.getElementById('upload-dropzone').style.borderColor = 'var(--border)';
  openModal('upload-modal');
}

function uploadDragOver(e) { e.preventDefault(); document.getElementById('upload-dropzone').style.borderColor = 'var(--gold)'; }
function uploadDragLeave(e) { document.getElementById('upload-dropzone').style.borderColor = 'var(--border)'; }
function uploadDrop(e) {
  e.preventDefault();
  document.getElementById('upload-dropzone').style.borderColor = 'var(--border)';
  const file = e.dataTransfer.files[0];
  if (file) setUploadFile(file);
}
function uploadFileSelected(input) { const file = input.files[0]; if (file) setUploadFile(file); }
function setUploadFile(file) {
  uploadFile = file;
  document.getElementById('upload-dropzone-text').style.display = 'none';
  const nameEl = document.getElementById('upload-file-name');
  nameEl.textContent = `📎 ${file.name}  (${fmtBytes(file.size)})`;
  nameEl.style.display = '';
  const displayName = document.getElementById('upload-display-name');
  if (!displayName.value) { displayName.value = file.name.replace(/\.[^.]+$/, ''); }
}

async function submitUpload() {
  if (!uploadFile) {
    document.getElementById('upload-form-error').textContent = 'Please select a file.';
    document.getElementById('upload-form-error').style.display = '';
    return;
  }
  document.getElementById('upload-form-error').style.display = 'none';
  document.getElementById('upload-submit-btn').disabled = true;
  const progressWrap = document.getElementById('upload-progress-wrap');
  const progressBar = document.getElementById('upload-progress-bar');
  const progressLabel = document.getElementById('upload-progress-label');
  progressWrap.style.display = '';
  progressBar.style.width = '20%';
  progressLabel.textContent = 'Uploading…';
  const formData = new FormData();
  formData.append('file', uploadFile);
  formData.append('owner_type', uploadOwnerType);
  formData.append('owner_id', uploadOwnerId);
  formData.append('year', document.getElementById('upload-year').value.trim());
  formData.append('doc_type', document.getElementById('upload-doc-type').value);
  formData.append('display_name', document.getElementById('upload-display-name').value.trim() || uploadFile.name);
  try {
    const token = localStorage.getItem('dl_token');
    const res = await fetch('/api/documents/upload', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${token}` },
      body: formData,
    });
    progressBar.style.width = '90%';
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Upload failed');
    progressBar.style.width = '100%';
    progressLabel.textContent = 'Done!';
    setTimeout(() => {
      closeModal('upload-modal');
      toast('Document uploaded');
      loadPersonDocuments();
      if (currentRelId) loadRelDocuments();
    }, 500);
  } catch (e) {
    document.getElementById('upload-form-error').textContent = e.message;
    document.getElementById('upload-form-error').style.display = '';
    document.getElementById('upload-submit-btn').disabled = false;
    progressWrap.style.display = 'none';
  }
}
</script>

