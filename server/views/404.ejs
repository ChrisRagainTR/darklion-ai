<%- include('partials/shell-top', { title: '404 — Not Found', activeNav: '' }) %>

<style>
  .not-found-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-h));
    text-align: center;
    padding: 3rem 2rem;
    color: var(--muted);
  }
  .not-found-code {
    font-size: 6rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
  }
  .not-found-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }
  .not-found-desc {
    font-size: 0.92rem;
    color: var(--muted);
    max-width: 400px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .not-found-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>

<main class="main">
  <div class="not-found-wrap">
    <div class="not-found-code">404</div>
    <div class="not-found-title">Page Not Found</div>
    <div class="not-found-desc">
      This record doesn't exist, was deleted, or you don't have access to it.
    </div>
    <div class="not-found-actions">
      <button class="btn btn-outline" onclick="history.back()">← Go Back</button>
      <a href="/crm/relationships" class="btn btn-gold">Go to CRM</a>
    </div>
  </div>
</main>

<%- include('partials/shell-globals') %>
<script>
  // No-op — static page
</script>
<%- include('partials/shell-close') %>
