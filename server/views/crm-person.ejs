  // ── Notes auto-save ──
  async function autoSaveNotes(val, force = false) {
    if (!personData && !force) return;
    try {
      await apiFetch(`/api/people/${personId}`, { method: 'PUT', body: JSON.stringify({ notes: val }) });
      if (personData) personData.notes = val;
      const ta1 = document.getElementById('notes-ta');
      const ta2 = document.getElementById('notes-ta-full');
      if (ta1) ta1.value = val;
      if (ta2) ta2.value = val;
      const s1 = document.getElementById('notes-saved');
      const s2 = document.getElementById('notes-saved-full');
      if (s1) { s1.textContent = '✓ Saved'; setTimeout(() => s1.textContent = '', 2000); }
      if (s2) { s2.textContent = '✓ Saved'; setTimeout(() => s2.textContent = '', 2000); }
      if (force) toast('Notes saved');
    } catch(e) { toast('Failed to save notes', 'error'); }
  }

  // ── Portal Invite ──
  async function sendPortalInvite() {
    try {
      const res = await apiFetch(`/portal-auth/send-invite`, {
        method: 'POST',
        body: JSON.stringify({ personId })
      });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Portal invite sent! Client will receive an email shortly.');
      loadPerson();
    } catch(e) { toast('Could not send invite: ' + e.message, 'error'); }
  }

  async function disablePortal() {
    if (!confirm('Disable portal access for this person? They will not be able to log in until re-invited.')) return;
    try {
      const res = await apiFetch(`/api/people/${personId}`, {
        method: 'PUT',
        body: JSON.stringify({ portal_enabled: false })
      });
      if (!res.ok) throw new Error('Failed');
      toast('Portal access disabled.');
      loadPerson();
    } catch(e) { toast('Could not disable portal: ' + e.message, 'error'); }
  }

  // ── Edit Modal ──
  function openEditModal() {
    if (!personData) return;
    document.getElementById('ef-fname').value = personData.first_name || '';
    document.getElementById('ef-lname').value = personData.last_name || '';
    document.getElementById('ef-email').value = personData.email || '';
    document.getElementById('ef-phone').value = personData.phone || '';
    document.getElementById('ef-filing').value = personData.filing_status || '';
    document.getElementById('ef-stanford').value = personData.stanford_tax_url || '';
    document.getElementById('edit-error').style.display = 'none';
    document.getElementById('edit-modal').classList.add('open');
  }

  function closeModal() { document.getElementById('edit-modal').classList.remove('open'); }

  async function submitEdit() {
    const body = {
      first_name: document.getElementById('ef-fname').value.trim(),
      last_name: document.getElementById('ef-lname').value.trim(),
      email: document.getElementById('ef-email').value.trim() || null,
      phone: document.getElementById('ef-phone').value.trim() || null,
      filing_status: document.getElementById('ef-filing').value || null,
      stanford_tax_url: document.getElementById('ef-stanford').value.trim() || null,
    };
    if (!body.first_name || !body.last_name) {
      const e = document.getElementById('edit-error');
      e.textContent = 'First and last name are required.';
      e.style.display = '';
      return;
    }
    const btn = document.getElementById('ef-submit');
    btn.disabled = true;
    try {
      const res = await apiFetch(`/api/people/${personId}`, { method: 'PUT', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      const updated = await res.json();
      personData = { ...personData, ...updated };
      closeModal();
      toast('Person updated');
      renderHeader(personData);
      renderOverview(personData);
    } catch(e) {
      const err = document.getElementById('edit-error');
      err.textContent = e.message;
      err.style.display = '';
    }
    btn.disabled = false;
  }

  // Init
  loadPerson();

  // ── Communication Tab ──────────────────────────────────────────────────────
  let commPersonId = null;
  let commActiveThreadId = null;
  let commAttachFiles = [];

  function initComm(pid) {
    commPersonId = pid;
    loadThreads();
  }

  async function loadThreads() {
    const el = document.getElementById('comm-threads');
    if (!el) return;
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
    try {
      const res = await apiFetch(`/api/messages/person/${commPersonId}`);
      const threads = await res.json();
      if (!threads.length) {
        el.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;padding:1rem 0;">No messages yet.</div>';
        return;
      }
      el.innerHTML = threads.map(t => `
        <div class="comm-thread-card" onclick="loadThread(${t.id})" style="padding:0.6rem 0.75rem;border:1px solid var(--border);border-radius:6px;margin-bottom:0.5rem;cursor:pointer;background:var(--charcoal);transition:background 0.15s;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div style="font-size:0.82rem;font-weight:600;color:var(--text);">${esc(t.subject || '(no subject)')}</div>
            ${t.unreadCount > 0 ? `<span style="background:var(--gold);color:var(--navy);border-radius:10px;padding:0.1rem 0.4rem;font-size:0.7rem;font-weight:700;">${t.unreadCount}</span>` : ''}
          </div>
          <div style="font-size:0.75rem;color:var(--muted);margin-top:0.2rem;">${esc(t.lastPreview)}</div>
          <div style="display:flex;gap:0.5rem;margin-top:0.3rem;">
            <span style="font-size:0.7rem;padding:0.1rem 0.4rem;border-radius:4px;background:${statusColor(t.status)};color:#fff;">${t.status}</span>
            <span style="font-size:0.7rem;color:var(--muted);">${relTime(t.lastMessageAt)}</span>
          </div>
        </div>
      `).join('');
    } catch(e) {
      el.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;">Failed to load messages.</div>';
    }
  }

  async function loadThread(threadId) {
    commActiveThreadId = threadId;
    document.getElementById('comm-compose').style.display = 'none';
    document.getElementById('comm-thread-detail').style.display = 'flex';
    document.getElementById('comm-thread-detail').style.flexDirection = 'column';
    document.getElementById('comm-messages-list').innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
    try {
      const res = await apiFetch(`/api/messages/${threadId}`);
      const data = await res.json();
      document.getElementById('comm-thread-header').innerHTML = `
        <div style="display:flex;align-items:center;gap:1rem;">
          <div style="font-size:1rem;font-weight:700;color:var(--text);">${esc(data.subject || '(no subject)')}</div>
          <span style="font-size:0.75rem;padding:0.15rem 0.5rem;border-radius:4px;background:${statusColor(data.status)};color:#fff;">${data.status}</span>
        </div>
      `;
      document.getElementById('comm-status-select').value = data.status;
      const msgEl = document.getElementById('comm-messages-list');
      msgEl.innerHTML = data.messages.map(m => {
        const isStaff = m.senderType === 'staff';
        const isInternal = m.isInternal;
        const attachmentsHtml = (m.attachments || []).length > 0
          ? `<div style="display:flex;flex-wrap:wrap;gap:0.35rem;margin-top:0.4rem;">${(m.attachments).map(a => {
              const size = a.sizeBytes ? ' (' + commFormatBytes(a.sizeBytes) + ')' : '';
              return `<a href="#" onclick="commDownloadAttachment(${a.documentId});return false;" style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);border-radius:4px;padding:0.15rem 0.5rem;font-size:0.73rem;color:inherit;text-decoration:none;">📎 ${esc(a.displayName)}${esc(size)}</a>`;
            }).join('')}</div>`
          : '';
        return `<div style="display:flex;flex-direction:column;align-items:${isStaff ? 'flex-end' : 'flex-start'};">
          <div style="max-width:80%;padding:0.5rem 0.75rem;border-radius:8px;background:${isInternal ? 'rgba(255,200,0,0.1)' : isStaff ? 'var(--gold)' : 'var(--charcoal)'};color:${isStaff && !isInternal ? 'var(--navy)' : 'var(--text)'};border:${isInternal ? '1px dashed var(--gold)' : 'none'};">
            ${isInternal ? '<div style="font-size:0.65rem;color:var(--gold);margin-bottom:0.2rem;">🔒 Internal note</div>' : ''}
            <div style="font-size:0.85rem;">${m.body ? esc(m.body) : ''}${attachmentsHtml}</div>
          </div>
          <div style="font-size:0.68rem;color:var(--muted);margin-top:0.15rem;">${m.senderName} · ${relTime(m.createdAt)}</div>
        </div>`;
      }).join('');
      msgEl.scrollTop = msgEl.scrollHeight;
    } catch(e) {
      document.getElementById('comm-messages-list').innerHTML = '<div style="color:var(--muted);">Failed to load thread.</div>';
    }
  }

  function commFormatBytes(b) {
    if (!b) return '0 B';
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
    return (b/1048576).toFixed(1) + ' MB';
  }

  function handleCommAttach(fileList) {
    for (const f of Array.from(fileList)) {
      if (commAttachFiles.length >= 8) { alert('Maximum 8 files per message'); break; }
      commAttachFiles.push(f);
    }
    document.getElementById('comm-attach-input').value = '';
    renderCommAttachChips();
  }

  function removeCommAttachFile(idx) {
    commAttachFiles.splice(idx, 1);
    renderCommAttachChips();
  }

  function renderCommAttachChips() {
    const el = document.getElementById('comm-attach-chips');
    if (!el) return;
    el.innerHTML = commAttachFiles.map((f, i) =>
      `<span style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:4px;padding:0.15rem 0.5rem;font-size:0.75rem;color:var(--text);">📎 ${esc(f.name)} <button onclick="removeCommAttachFile(${i})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.8rem;padding:0;line-height:1;">×</button></span>`
    ).join('');
  }

  async function commDownloadAttachment(documentId) {
    try {
      const res = await apiFetch(`/api/messages/attachments/${documentId}/download`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
      else alert('Download failed');
    } catch(e) { alert('Failed to download attachment'); }
  }

  async function sendReply() {
    const body = document.getElementById('comm-reply-body').value.trim();
    if ((!body && commAttachFiles.length === 0) || !commActiveThreadId) return;
    const isInternal = document.getElementById('comm-internal-toggle').checked;
    try {
      const fd = new FormData();
      fd.append('body', body);
      fd.append('is_internal', isInternal ? 'true' : 'false');
      commAttachFiles.forEach(f => fd.append('files', f));
      await apiFetch(`/api/messages/${commActiveThreadId}/reply`, { method: 'POST', body: fd });
      document.getElementById('comm-reply-body').value = '';
      document.getElementById('comm-internal-toggle').checked = false;
      commAttachFiles = [];
      renderCommAttachChips();
      await loadThread(commActiveThreadId);
      await loadThreads();
    } catch(e) { alert('Failed to send reply'); }
  }

  async function updateThreadStatus() {
    if (!commActiveThreadId) return;
    const status = document.getElementById('comm-status-select').value;
    await apiFetch(`/api/messages/${commActiveThreadId}/status`, { method: 'PUT', body: JSON.stringify({ status }) });
    await loadThreads();
  }

  function openNewThread() {
    document.getElementById('comm-thread-detail').style.display = 'none';
    document.getElementById('comm-compose').style.display = 'block';
    document.getElementById('comm-new-subject').value = '';
    document.getElementById('comm-new-body').value = '';
  }

  function closeCompose() {
    document.getElementById('comm-compose').style.display = 'none';
  }

  async function sendNewThread() {
    const subject = document.getElementById('comm-new-subject').value.trim();
    const body = document.getElementById('comm-new-body').value.trim();
    if (!body) { alert('Message body is required'); return; }
    try {
      const res = await apiFetch('/api/messages', { method: 'POST', body: JSON.stringify({ person_id: commPersonId, subject, body, is_internal: false }) });
      const data = await res.json();
      closeCompose();
      await loadThreads();
      if (data.threadId) loadThread(data.threadId);
    } catch(e) { alert('Failed to send message'); }
  }

  function statusColor(s) {
    if (s === 'open') return '#c9a84c';
    if (s === 'waiting') return '#4a90d9';
    if (s === 'resolved') return '#4caf50';
    return '#666';
  }

  function relTime(ts) {
    if (!ts) return '';
    const d = new Date(ts);
    const diff = Date.now() - d;
    if (diff < 60000) return 'just now';
    if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
    if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
    return d.toLocaleDateString();
  }

  // ── Page-level drag-and-drop for Docs tab ──
  let dragCounter = 0;
  const pageDragOverlay = document.createElement('div');
  pageDragOverlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(201,168,76,0.08);border:3px dashed var(--gold);pointer-events:none;align-items:center;justify-content:center;font-size:1.5rem;color:var(--gold);font-weight:700;';
  pageDragOverlay.innerHTML = '📄 Drop to upload document';
  document.body.appendChild(pageDragOverlay);
  function isDocTabActive() { return document.getElementById('tab-docs')?.classList.contains('active'); }
  document.addEventListener('dragenter', (e) => { if (!isDocTabActive()) return; dragCounter++; pageDragOverlay.style.display = 'flex'; });
  document.addEventListener('dragleave', (e) => { if (!isDocTabActive()) return; dragCounter--; if (dragCounter <= 0) { dragCounter = 0; pageDragOverlay.style.display = 'none'; } });
  document.addEventListener('dragover', (e) => { if (!isDocTabActive()) return; e.preventDefault(); });
  document.addEventListener('drop', (e) => {
    if (!isDocTabActive()) return;
    e.preventDefault(); dragCounter = 0; pageDragOverlay.style.display = 'none';
    const file = e.dataTransfer?.files?.[0];
    if (!file) return;
    openUploadModal();
    setTimeout(() => {
      uploadFile = file; showUploadFile(file);
      const n = document.getElementById('upload-display-name');
      if (n && !n.value) n.value = file.name.replace(/\.[^/.]+$/, '');
    }, 50);
  });

  // ── Grant Company Access Modal ──
  async function openGrantCompanyModal() {
    if (!personData) return;
    const relId = personData.relationship_id;
    if (!relId) { toast('Person has no relationship assigned', 'error'); return; }
    try {
      const res = await apiFetch(`/api/relationships/${relId}/companies`);
      const companies = await res.json();
      const existing = (personData.company_access || []).map(a => a.company_id);
      const available = companies.filter(c => !existing.includes(c.id));
      if (!available.length) { toast('All companies in this relationship are already linked', 'error'); return; }
      const opts = available.map(c => `<option value="${c.id}">${esc(c.company_name||'Unknown')}</option>`).join('');
      const html = `<div class="modal-overlay open" id="grant-company-modal" onclick="if(event.target===this)this.remove()">
        <div class="modal" onclick="event.stopPropagation()" style="max-width:400px;">
          <h2 style="margin-bottom:1rem;">Grant Company Access</h2>
          <div class="form-group"><label>Company</label><select id="gc-company" class="form-control">${opts}</select></div>
          <div class="form-group"><label>Access Level</label>
            <select id="gc-access" class="form-control">
              <option value="full">Full (upload + message)</option>
              <option value="view">View only</option>
              <option value="sign">Sign only</option>
            </select>
          </div>
          <div class="form-group"><label>Ownership % (optional)</label><input type="number" id="gc-ownership" class="form-control" placeholder="e.g. 50" min="0" max="100" step="0.01"></div>
          <div class="modal-actions">
            <button class="btn btn-outline" onclick="document.getElementById('grant-company-modal').remove()">Cancel</button>
            <button class="btn btn-gold" onclick="submitGrantCompany()">Grant Access</button>
          </div>
        </div></div>`;
      document.body.insertAdjacentHTML('beforeend', html);
    } catch(e) { toast('Failed to load companies: ' + e.message, 'error'); }
  }

  async function submitGrantCompany() {
    const companyId = parseInt(document.getElementById('gc-company').value);
    const accessLevel = document.getElementById('gc-access').value;
    const ownershipPct = document.getElementById('gc-ownership').value;
    try {
      const res = await apiFetch(`/api/people/${personId}/company-access`, {
        method: 'POST',
        body: JSON.stringify({ company_id: companyId, access_level: accessLevel, ownership_pct: ownershipPct || null })
      });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      document.getElementById('grant-company-modal').remove();
      toast('Company access granted');
      const freshRes = await apiFetch(`/api/people/${personId}`);
      personData = await freshRes.json();
      renderOverview(personData);
    } catch(e) { toast('Failed: ' + e.message, 'error'); }
  }

  async function revokeCompanyAccess(companyId) {
    if (!confirm('Remove access to this company?')) return;
    try {
      const res = await apiFetch(`/api/people/${personId}/company-access/${companyId}`, { method: 'DELETE' });
      if (!res.ok) throw new Error('Failed');
      toast('Access revoked');
      const freshRes = await apiFetch(`/api/people/${personId}`);
      personData = await freshRes.json();
      renderOverview(personData);
    } catch(e) { toast('Failed: ' + e.message, 'error'); }
  }
</script>

<!-- Move Document Modal -->
<div class="modal-overlay" id="move-doc-modal" onclick="if(event.target===this)closeMoveDocModal()">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:380px;">
    <div class="modal-header">
      <div class="modal-title">Move Document</div>
      <button class="modal-close" onclick="closeMoveDocModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Tax Year</label>
        <select id="move-doc-year" class="form-control">
          <% for (let y = new Date().getFullYear(); y >= new Date().getFullYear() - 8; y--) { %>
            <option value="<%= y %>"><%= y %></option>
          <% } %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Section</label>
        <select id="move-doc-section" class="form-control">
          <option value="firm_uploaded">Delivered by Advisor</option>
          <option value="client_uploaded">Client Uploaded</option>
          <option value="private">Private (Staff Only)</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Category</label>
        <select id="move-doc-category" class="form-control">
          <option value="tax">Tax</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeMoveDocModal()">Cancel</button>
      <button class="btn btn-gold" onclick="submitMoveDoc()">Move</button>
    </div>
  </div>
</div>

