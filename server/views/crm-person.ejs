  // ── Docs Tab ──
  const CURRENT_YEAR = new Date().getFullYear();

  const DOC_CATS_PERSON = [
    { key: 'tax',   label: 'Tax',   icon: '🧾' },
    { key: 'other', label: 'Other', icon: '📎' },
  ];

  function docTypeBadge(mimeType, displayName) {
    const mime = (mimeType || '').toLowerCase();
    const name = (displayName || '').toLowerCase();
    const ext = name.includes('.') ? name.split('.').pop() : '';
    let label, color;
    if (mime === 'application/pdf' || ext === 'pdf') { label = 'PDF'; color = '#e53e3e'; }
    else if (mime.includes('spreadsheet') || mime.includes('excel') || ext === 'xlsx' || ext === 'xls' || ext === 'csv') { label = ext === 'csv' ? 'CSV' : 'Excel'; color = '#38a169'; }
    else if (mime.includes('word') || ext === 'docx' || ext === 'doc') { label = 'Word'; color = '#3182ce'; }
    else if (mime.includes('presentation') || mime.includes('powerpoint') || ext === 'pptx' || ext === 'ppt') { label = 'PPT'; color = '#dd6b20'; }
    else if (mime.startsWith('image/') || ['jpg','jpeg','png','gif','webp','heic'].includes(ext)) { label = 'Image'; color = '#805ad5'; }
    else if (mime.includes('zip') || ext === 'zip') { label = 'ZIP'; color = '#718096'; }
    else if (mime.startsWith('text/') || ext === 'txt') { label = 'TXT'; color = '#718096'; }
    else { label = ext ? ext.toUpperCase().slice(0,4) : 'FILE'; color = '#718096'; }
    return `<span style="flex-shrink:0;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.65rem;font-weight:700;color:#fff;background:${color};letter-spacing:0.03em;">${label}</span>`;
  }

  function fmtBytes(b) {
    if (!b) return '';
    if (b < 1024) return b + ' B';
    if (b < 1024*1024) return (b/1024).toFixed(1) + ' KB';
    return (b/(1024*1024)).toFixed(1) + ' MB';
  }

  function buildDocsSection(sectionDocs, title, icon, isClient) {
    const allYears = [];
    for (let y = CURRENT_YEAR; y >= 2018; y--) allYears.push(String(y));
    const recentYears = allYears.slice(0, 2);
    const priorYears  = allYears.slice(2);
    const byYearCat = {};
    sectionDocs.forEach(d => {
      const y   = d.year || String(CURRENT_YEAR);
      const cat = d.folder_category || 'other';
      if (!byYearCat[y]) byYearCat[y] = {};
      if (!byYearCat[y][cat]) byYearCat[y][cat] = [];
      byYearCat[y][cat].push(d);
    });
    const statusBadge = isClient
      ? `<span class="doc-badge doc-badge-client">✓ Uploaded</span>`
      : `<span class="doc-badge doc-badge-viewed">✓ Delivered</span>`;

    function renderOneYear(yr, openByDefault) {
      const yrDocs = sectionDocs.filter(d => (d.year || String(CURRENT_YEAR)) === yr);
      return `<div class="year-folder${openByDefault ? ' open' : ''}" style="margin-bottom:0.4rem;">
        <div class="year-header">
          <span class="yr-label">📅 ${yr} <span class="yr-count">${yrDocs.length}</span></span>
          <span class="yr-chevron">▼</span>
        </div>
        <div class="year-body" style="padding-left:1rem;">
          ${DOC_CATS_PERSON.map(cat => {
            const files = (byYearCat[yr] || {})[cat.key] || [];
            return `<div class="cat-folder${files.length > 0 ? ' open' : ''}">
              <div class="cat-folder-header" onclick="this.closest('.cat-folder').classList.toggle('open')">
                <span class="cat-folder-label">${cat.icon} ${cat.label}</span>
                <span style="display:flex;align-items:center;gap:0.5rem;"><span class="cat-folder-meta">${files.length} file${files.length !== 1 ? 's' : ''}</span><span class="cat-chevron">▼</span></span>
              </div>
              <div class="cat-folder-body">
                ${files.length === 0
                  ? `<div style="color:var(--muted);font-size:0.78rem;font-style:italic;padding:0.2rem 0;">Empty</div>`
                  : files.map(f => `<div class="doc-row" data-docid="${f.id}">
                      ${docTypeBadge(f.mime_type, f.display_name)}
                      <div class="doc-info">
                        <div class="doc-name doc-name-link" data-docid="${f.id}">${esc((f.display_name||'Untitled').replace(/_/g,' ').trim())}</div>
                        <div class="doc-badges">
                          ${statusBadge}
                          ${f.size_bytes ? `<span class="doc-badge doc-badge-type">${fmtBytes(f.size_bytes)}</span>` : ''}
                          ${f.created_at ? `<span style="font-size:0.67rem;color:var(--muted);opacity:0.7;">${new Date(f.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit',timeZone:'America/New_York',timeZoneName:'short'})}</span>` : ''}
                        </div>
                      </div>
                      <div style="display:flex;gap:0.4rem;flex-shrink:0;align-items:center;">
                        <button class="btn-dl" data-docid="${f.id}">⬇</button>
                        <button class="btn btn-ghost btn-xs" onclick="openMoveDocModal(${f.id},${JSON.stringify(f.folder_section||'firm_uploaded')},${JSON.stringify(f.folder_category||'other')},event,${JSON.stringify(f.year||'')})" title="Move">↕</button>
                        <button class="btn btn-ghost btn-xs" style="color:var(--red)" onclick="deleteDoc(${f.id},event)" title="Delete">🗑</button>
                      </div>
                    </div>`).join('')}
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>`;
    }

    const priorCount = priorYears.reduce((n,y) => n + sectionDocs.filter(d => (d.year||String(CURRENT_YEAR)) === y).length, 0);
    let html = `<div class="docs-col-title">${icon} ${title} <span style="font-size:0.75rem;font-weight:400;color:var(--muted);">(${sectionDocs.length})</span></div>`;
    recentYears.forEach(y => { html += renderOneYear(y, true); });
    html += `<div class="year-folder" style="margin-bottom:0.4rem;">
      <div class="year-header">
        <span class="yr-label">📂 Prior Years <span class="yr-count">${priorCount}</span></span>
        <span class="yr-chevron">▼</span>
      </div>
      <div class="year-body" style="padding-left:0.5rem;">${priorYears.map(y => renderOneYear(y, false)).join('')}</div>
    </div>`;
    return html;
  }

  let docsData = [];

  async function loadDocs() {
    const el = document.getElementById('docs-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/documents?owner_type=person&owner_id=${personId}`);
      docsData = await res.json();
      renderDocs();
    } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load documents.</div>'; }
  }

  function renderDocs() {
    const el = document.getElementById('docs-content');
    const firmDocs   = docsData.filter(d => !d.folder_section || d.folder_section === 'firm_uploaded');
    const clientDocs = docsData.filter(d => d.folder_section === 'client_uploaded');
    el.innerHTML = `<div style="display:flex;justify-content:flex-end;padding:1rem 1.5rem 0;"><button class="btn btn-gold btn-sm" onclick="openUploadModal()">+ Upload Document</button></div>
      <div class="docs-layout">
        <div>${buildDocsSection(firmDocs, 'Delivered by Advisor', '📁', false)}</div>
        <div>${buildDocsSection(clientDocs, 'Uploaded by Client', '📤', true)}</div>
      </div>`;
    el.querySelectorAll('.year-header').forEach(h => {
      h.addEventListener('click', () => h.closest('.year-folder').classList.toggle('open'));
    });
    el.querySelectorAll('.doc-name-link').forEach(nameEl => {
      nameEl.addEventListener('click', e => { e.stopPropagation(); downloadDoc(parseInt(nameEl.dataset.docid)); });
    });
    el.querySelectorAll('.btn-dl').forEach(btn => {
      btn.addEventListener('click', e => { e.stopPropagation(); downloadDoc(parseInt(btn.dataset.docid), btn); });
    });
  }

  function reloadDocs() {
    const el = document.getElementById('docs-content');
    if (el) delete el.dataset.loaded;
    loadDocs();
  }

  async function downloadDoc(id, btn) {
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    try {
      const res = await apiFetch(`/api/documents/${id}/url`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      if (data.url) window.location.href = data.url;
    } catch(e) { toast('Download failed: ' + e.message, 'error'); }
    if (btn) { btn.disabled = false; btn.textContent = '⬇'; }
  }

  async function deleteDoc(id, e) {
    if (e) e.stopPropagation();
    if (!await window.dlConfirm('Delete this document? This cannot be undone.', {title:'Delete Document', confirmLabel:'Delete', danger:true, icon:'🗑️'})) return;
    try {
      const res = await apiFetch(`/api/documents/${id}`, { method: 'DELETE' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Document deleted');
      reloadDocs();
    } catch(e) { toast(e.message, 'error'); }
  }

  let _moveDocId = null;
  function openMoveDocModal(id, currentSection, currentCategory, e, currentYear) {
    if (e) e.stopPropagation();
    _moveDocId = id;
    const modal = document.getElementById('move-doc-modal');
    if (!modal) return;
    document.getElementById('move-doc-year').value = currentYear || String(CURRENT_YEAR - 1);
    document.getElementById('move-doc-section').value = currentSection || 'firm_uploaded';
    document.getElementById('move-doc-category').value = currentCategory || 'other';
    modal.classList.add('open');
  }
  function closeMoveDocModal() {
    const modal = document.getElementById('move-doc-modal');
    if (modal) modal.classList.remove('open');
    _moveDocId = null;
  }
  async function submitMoveDoc() {
    if (!_moveDocId) return;
    const year = document.getElementById('move-doc-year').value;
    const section = document.getElementById('move-doc-section').value;
    const category = document.getElementById('move-doc-category').value;
    try {
      const res = await apiFetch(`/api/documents/${_moveDocId}`, { method: 'PUT', body: JSON.stringify({ year, folder_section: section, folder_category: category }) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Document moved');
      closeMoveDocModal();
      reloadDocs();
    } catch(e) { toast(e.message, 'error'); }
  }

  // Upload modal state
  let uploadFile = null;
  function openUploadModal() {
    document.getElementById('upload-modal').classList.add('open');
    document.getElementById('upload-year').value = CURRENT_YEAR;
    document.getElementById('upload-section').value = 'firm_uploaded';
    document.getElementById('upload-category').value = 'other';
    document.getElementById('upload-display-name').value = '';
    document.getElementById('upload-error').style.display = 'none';
    uploadFile = null;
    document.getElementById('upload-file-name').style.display = 'none';
    document.getElementById('upload-dropzone-text').style.display = '';
  }

  function openUploadModalWith(section, category, year) {
    openUploadModal();
    document.getElementById('upload-year').value = year || CURRENT_YEAR;
    document.getElementById('upload-section').value = section || 'firm_uploaded';
    document.getElementById('upload-category').value = category || 'other';
  }

  function showUploadFile(f) {
    if (!f) return;
    document.getElementById('upload-dropzone-text').style.display = 'none';
    document.getElementById('upload-file-name').style.display = '';
    document.getElementById('upload-file-name').textContent = f.name;
    if (!document.getElementById('upload-display-name').value) {
      document.getElementById('upload-display-name').value = f.name.replace(/\.[^.]+$/, '');
    }
  }

  async function submitUpload() {
    if (!uploadFile) { document.getElementById('upload-error').textContent = 'Select a file first.'; document.getElementById('upload-error').style.display=''; return; }
    const formData = new FormData();
    formData.append('file', uploadFile);
    formData.append('owner_type', 'person');
    formData.append('owner_id', personId);
    formData.append('display_name', document.getElementById('upload-display-name').value || uploadFile.name);
    formData.append('year', document.getElementById('upload-year').value || String(CURRENT_YEAR));
    formData.append('folder_section', document.getElementById('upload-section').value);
    formData.append('folder_category', document.getElementById('upload-category').value);
    try {
      const res = await apiFetch('/api/documents/upload', { method: 'POST', body: formData });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Upload failed'); }
      document.getElementById('upload-modal').classList.remove('open');
      toast('Document uploaded');
      reloadDocs();
    } catch(e) {
      document.getElementById('upload-error').textContent = e.message;
      document.getElementById('upload-error').style.display = '';
    }
  }

