    const id = document.getElementById('ed-id').value;
    const reviewDocId = document.getElementById('ed-review-doc').value;
    const sigDocId = document.getElementById('ed-sig-doc').value;
    const body = {};
    if (reviewDocId) body.review_doc_id = parseInt(reviewDocId);
