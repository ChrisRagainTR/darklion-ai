<%- include('partials/shell-top', {title: 'Person', activeNav: 'people'}) %>

<style>
  /* ── 2-col layout ── */
  .detail-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 1.25rem; align-items: start; }
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }

  /* ── Stanford link ── */
  .stanford-card { background: rgba(201,168,76,0.06); border: 1px solid rgba(201,168,76,0.25); border-radius: 8px; padding: 1rem 1.2rem; display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
  .stanford-card .sc-text { flex: 1; min-width: 0; }
  .stanford-card .sc-label { font-size: 0.7rem; font-weight: 700; color: var(--gold); text-transform: uppercase; letter-spacing: 0.07em; }
  .stanford-card .sc-url { font-size: 0.82rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 0.1rem; }

  /* ── Notes save indicator ── */
  .save-indicator { font-size: 0.78rem; color: var(--green); margin-top: 0.35rem; min-height: 1.1em; }

  .info-row { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.4rem; }
  .info-label { font-size: 0.76rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; min-width: 90px; flex-shrink: 0; }
  .info-val { font-size: 0.88rem; color: var(--text); word-break: break-word; }
  .info-val a { color: var(--gold); text-decoration: none; }
  .info-val a:hover { text-decoration: underline; }

  .placeholder-section { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 3rem; text-align: center; color: var(--muted); }
  .ph-icon { font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.4; }
  .ph-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; opacity: 0.75; }
  .ph-desc { font-size: 0.84rem; }

  /* ── Docs tab — portal-matched styles ── */
  .docs-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .docs-layout { grid-template-columns: 1fr; } }
  .docs-col-title { font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; }
  .year-folder { background: var(--card); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .year-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.1rem; cursor: pointer; user-select: none; transition: background 0.15s; }
  .year-header:hover { background: rgba(255,255,255,0.03); }
  .year-header .yr-label { font-weight: 700; font-size: 0.95rem; color: var(--text); display: flex; align-items: center; gap: 0.5rem; }
  .yr-count { font-size: 0.72rem; background: rgba(201,168,76,0.12); color: var(--gold); border: 1px solid rgba(201,168,76,0.25); border-radius: 20px; padding: 0.1rem 0.5rem; font-weight: 600; }
  .yr-chevron { color: var(--muted); font-size: 0.8rem; transition: transform 0.2s; }
  .year-folder.open .yr-chevron { transform: rotate(180deg); }
  .year-body { display: none; border-top: 1px solid var(--border); }
  .year-folder.open .year-body { display: block; }
  .cat-folder { margin-bottom: 0.35rem; border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; overflow: hidden; }
  .cat-folder-header { display: flex; align-items: center; justify-content: space-between; padding: 0.4rem 0.7rem; cursor: pointer; user-select: none; background: rgba(201,168,76,0.04); border-left: 3px solid var(--gold); }
  .cat-folder-header:hover { background: rgba(201,168,76,0.08); }
  .cat-folder-label { font-size: 0.82rem; font-weight: 700; color: var(--text); }
  .cat-folder-meta { font-size: 0.72rem; color: var(--muted); }
  .cat-chevron { color: var(--muted); font-size: 0.75rem; transition: transform 0.15s; }
  .cat-folder.open .cat-chevron { transform: rotate(180deg); }
  .cat-folder-body { display: none; padding: 0.4rem 0.5rem; }
  .cat-folder.open .cat-folder-body { display: block; }
  .doc-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1.1rem; border-top: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
  .doc-row:hover { background: rgba(255,255,255,0.03); }
  .doc-info { flex: 1; min-width: 0; }
  .doc-name { font-weight: 600; font-size: 0.9rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .doc-name-link { cursor: pointer; text-decoration: underline; text-underline-offset: 2px; }
  .doc-name-link:hover { color: var(--gold); }
  .doc-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
  .doc-badge { font-size: 0.68rem; border-radius: 20px; padding: 0.1rem 0.45rem; font-weight: 600; }
  .doc-badge-type { background: rgba(138,143,168,0.12); color: var(--muted); border: 1px solid rgba(138,143,168,0.2); }
  .doc-badge-viewed { background: rgba(62,207,142,0.1); color: var(--green); border: 1px solid rgba(62,207,142,0.25); }
  .doc-badge-client { background: rgba(66,153,225,0.1); color: #63b3ed; border: 1px solid rgba(66,153,225,0.25); }
  .btn-dl { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 0.78rem; border-radius: 6px; padding: 0.3rem 0.65rem; cursor: pointer; transition: border-color 0.2s, color 0.2s; flex-shrink: 0; white-space: nowrap; }
  .btn-dl:hover { border-color: var(--gold); color: var(--gold); }
  @media (max-width: 600px) {
    .doc-name { white-space: normal; word-break: break-word; font-size: 0.82rem; }
    .btn-dl { font-size: 0.72rem; padding: 0.25rem 0.5rem; }
    .doc-row { gap: 0.5rem; padding: 0.55rem 0.75rem; }
    .docs-layout { grid-template-columns: 1fr; }
  }
</style>

  <!-- ── Entity Header ── -->
  <div class="entity-header" id="entity-header">
    <a href="/crm?tab=people" class="entity-back">← People</a>
    <div class="entity-header-content">
      <div class="entity-name" id="entity-name">Loading…</div>
      <div class="entity-badges" id="entity-badges"></div>
      <div class="entity-meta" id="entity-meta"></div>
    </div>
    <div class="entity-actions">
      <button class="btn btn-outline btn-sm" id="edit-btn" onclick="openEditModal()">Edit</button>
    </div>
  </div>

  <!-- ── Tab Bar ── -->
  <div class="tab-bar" id="tab-bar">
    <div class="tab-item active" onclick="switchTab('overview', this)">Overview</div>
    <div class="tab-item" onclick="switchTab('docs', this)">Docs</div>
    <div class="tab-item" onclick="switchTab('tax', this)">Tax</div>
    <div class="tab-item" onclick="switchTab('communication', this)">Communication</div>
    <div class="tab-item" onclick="switchTab('organizers', this)">Organizers</div>
    <div class="tab-item" onclick="switchTab('workflow', this)">Workflow</div>
    <div class="tab-item" onclick="switchTab('notes', this)">Notes</div>
    <div class="tab-item" onclick="switchTab('billing', this)">Billing</div>
  </div>

  <!-- ── Tab: Overview ── -->
  <div id="tab-overview" class="tab-content active">
    <div class="detail-grid" id="overview-grid">
      <div id="overview-left">
        <div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>
      </div>
      <div id="overview-right">
        <div class="card">
          <div class="card-title">Internal Notes</div>
          <textarea class="form-control" id="notes-ta" rows="6" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
          <div class="save-indicator" id="notes-saved"></div>
        </div>
        <div class="card">
          <div class="card-title">Quick Actions</div>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <button class="btn btn-outline btn-sm" onclick="openEditModal()">✏️ Edit Person</button>
            <button class="btn btn-outline btn-sm" id="invite-btn" onclick="sendPortalInvite()" style="display:none;">📧 Send Portal Invite</button>
            <button class="btn btn-outline btn-sm" id="resend-invite-btn" onclick="sendPortalInvite()" style="display:none;">🔄 Reset Portal Password</button>
            <button class="btn btn-outline btn-sm" id="disable-portal-btn" onclick="disablePortal()" style="display:none;">🚫 Disable Portal</button>
            <a href="/portal-login" target="_blank" class="btn btn-outline btn-sm">🔗 Open Portal Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Tab: Docs ── -->
  <div id="tab-docs" class="tab-content">
    <div id="docs-content">
      <div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>
    </div>
  </div>

  <!-- ── Tab: Tax ── -->
  <div id="tab-tax" class="tab-content">
    <div id="tax-content">
      <div class="loading-state"><div class="loading-spinner"></div></div>
    </div>
  </div>

  <!-- ── Tab: Communication ── -->
  <div id="tab-communication" class="tab-content">
    <div id="comm-content" style="display:flex;gap:1.5rem;max-width:1100px;">
      <!-- Thread list -->
      <div id="comm-thread-list" style="width:280px;flex-shrink:0;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
          <div style="font-size:0.8rem;font-weight:700;color:var(--text);text-transform:uppercase;letter-spacing:0.05em;">Messages</div>
          <button class="btn btn-gold btn-sm" onclick="openNewThread()">+ New Message</button>
        </div>
        <div id="comm-threads"><div class="loading-state"><div class="loading-spinner"></div></div></div>
      </div>
      <!-- Thread detail -->
      <div id="comm-thread-detail" style="flex:1;display:none;">
        <div id="comm-thread-header" style="margin-bottom:1rem;"></div>
        <div id="comm-messages-list" style="display:flex;flex-direction:column;gap:0.75rem;max-height:420px;overflow-y:auto;padding:0.5rem;background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:8px;margin-bottom:1rem;"></div>
        <div class="card" style="padding:1rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
            <label style="font-size:0.8rem;color:var(--muted);display:flex;align-items:center;gap:0.3rem;cursor:pointer;">
              <input type="checkbox" id="comm-internal-toggle" style="cursor:pointer;"> Internal note
            </label>
            <div style="flex:1;"></div>
            <select id="comm-status-select" onchange="updateThreadStatus()" style="font-size:0.78rem;background:var(--charcoal);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:0.2rem 0.4rem;">
              <option value="open">Open</option>
              <option value="waiting">Waiting</option>
              <option value="resolved">Resolved</option>
            </select>
          </div>
          <textarea id="comm-reply-body" rows="3" class="form-control" placeholder="Reply…" style="margin-bottom:0.5rem;"></textarea>
          <div id="comm-attach-chips" style="display:flex;flex-wrap:wrap;gap:0.35rem;margin-bottom:0.4rem;"></div>
          <input type="file" id="comm-attach-input" multiple style="display:none;" onchange="handleCommAttach(this.files)">
          <div style="display:flex;gap:0.5rem;align-items:center;">
            <button class="btn btn-gold btn-sm" onclick="sendReply()">Send Reply</button>
            <button class="btn btn-outline btn-sm" onclick="document.getElementById('comm-attach-input').click()" title="Attach files">📎 Attach</button>
          </div>
        </div>
      </div>
      <!-- New thread compose -->
      <div id="comm-compose" style="flex:1;display:none;">
        <div style="font-size:0.9rem;font-weight:700;color:var(--text);margin-bottom:1rem;">New Message</div>
        <div class="form-group" style="margin-bottom:0.75rem;">
          <label>Subject</label>
          <input type="text" id="comm-new-subject" class="form-control" placeholder="Subject…">
        </div>
        <div class="form-group" style="margin-bottom:0.75rem;">
          <label>Message</label>
          <textarea id="comm-new-body" rows="5" class="form-control" placeholder="Write your message…"></textarea>
        </div>
        <div style="display:flex;gap:0.5rem;">
          <button class="btn btn-gold btn-sm" onclick="sendNewThread()">Send</button>
          <button class="btn btn-outline btn-sm" onclick="closeCompose()">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Tab: Organizers ── -->
  <div id="tab-organizers" class="tab-content">
    <div class="placeholder-section">
      <div class="ph-icon">📝</div>
      <div class="ph-title">Tax Organizers</div>
      <div class="ph-desc">Tax organizers coming soon.</div>
      <div id="org-stanford-link" style="margin-top:1rem;"></div>
    </div>
  </div>

  <!-- ── Tab: Workflow ── -->
  <div id="tab-workflow" class="tab-content">
    <div style="max-width:860px;">
      <div style="font-size:1.05rem;font-weight:700;margin-bottom:1.25rem;">Active Pipelines</div>
      <div id="workflow-loading" style="color:var(--muted);padding:2rem 0;">Loading…</div>
      <div id="workflow-list" style="display:none;"></div>
    </div>
  </div>

  <!-- ── Tab: Notes ── -->
  <div id="tab-notes" class="tab-content">
    <div class="card" style="max-width:800px;">
      <div class="card-title">Internal Notes</div>
      <textarea class="form-control" id="notes-ta-full" rows="12" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
      <div style="display:flex;align-items:center;gap:1rem;margin-top:0.75rem;">
        <button class="btn btn-gold btn-sm" onclick="autoSaveNotes(document.getElementById('notes-ta-full').value, true)">Save Notes</button>
        <div class="save-indicator" id="notes-saved-full"></div>
      </div>
    </div>
  </div>

  <!-- ── Tab: Billing ── -->
  <div id="tab-billing" class="tab-content">
    <div id="billing-content">
      <div class="loading-state"><div class="loading-spinner"></div></div>
    </div>
  </div>

<!-- ── Edit Modal ── -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Edit Person</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div id="edit-error" class="error-msg" style="display:none;"></div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">First Name</label>
          <input type="text" class="form-control" id="ef-fname">
        </div>
        <div class="form-group">
          <label class="form-label">Last Name</label>
          <input type="text" class="form-control" id="ef-lname">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" class="form-control" id="ef-email">
        </div>
        <div class="form-group">
          <label class="form-label">Phone</label>
          <input type="text" class="form-control" id="ef-phone">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Filing Status</label>
          <select class="form-control" id="ef-filing">
            <option value="">— Select —</option>
            <option value="single">Single</option>
            <option value="mfj">MFJ</option>
            <option value="mfs">MFS</option>
            <option value="hoh">HOH</option>
            <option value="qw">QW</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Stanford Tax URL</label>
          <input type="url" class="form-control" id="ef-stanford">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" id="ef-submit" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<!-- ── Upload Document Modal ── -->
<div class="modal-overlay" id="upload-modal">
  <div class="modal" style="width:480px;">
    <div class="modal-header">
      <div class="modal-title">Upload Document</div>
      <button class="modal-close" onclick="document.getElementById('upload-modal').classList.remove('open')">✕</button>
    </div>
    <div class="modal-body">
      <div id="upload-error" class="error-msg" style="display:none;"></div>
      <div id="upload-dropzone" style="border:2px dashed var(--border);border-radius:10px;padding:2rem;text-align:center;cursor:pointer;margin-bottom:1rem;"
           onclick="document.getElementById('upload-file-input').click()"
           ondragover="event.preventDefault()"
           ondrop="event.preventDefault();uploadFile=event.dataTransfer.files[0];showUploadFile(uploadFile);">
        <div id="upload-dropzone-text" style="color:var(--muted);">
          <div style="font-size:2rem;margin-bottom:0.5rem;">📂</div>
          <div>Drag &amp; drop or <span style="color:var(--gold);text-decoration:underline;">click to browse</span></div>
          <div style="font-size:0.78rem;margin-top:0.4rem;">Max 50 MB</div>
        </div>
        <div id="upload-file-name" style="display:none;font-weight:600;color:var(--text);"></div>
      </div>
      <input type="file" id="upload-file-input" style="display:none;" onchange="uploadFile=this.files[0];showUploadFile(uploadFile);">
      <div class="form-group">
        <label class="form-label">Display Name</label>
        <input type="text" class="form-control" id="upload-display-name" placeholder="Friendly name">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Year</label>
          <input type="text" class="form-control" id="upload-year" maxlength="4">
        </div>
        <div class="form-group">
          <label class="form-label">Section</label>
          <select class="form-control" id="upload-section">
            <option value="firm_uploaded">Firm Uploaded</option>
            <option value="client_uploaded">Client Uploaded</option>
            <option value="private">Private (Staff Only)</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Category</label>
        <select class="form-control" id="upload-category">
          <option value="other">Other</option>
          <option value="tax">Tax</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="document.getElementById('upload-modal').classList.remove('open')">Cancel</button>
      <button class="btn btn-gold" onclick="submitUpload()">Upload</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const personId = location.pathname.split('/').pop();
  let personData = null;

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    else {
      document.querySelectorAll('.tab-item').forEach(t => {
        if (t.getAttribute('onclick') && t.getAttribute('onclick').includes(`'${name}'`)) t.classList.add('active');
      });
    }
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    // Lazy-load on demand
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax();
    if (name === 'billing') loadBilling();
    if (name === 'communication' && personData) {
      initComm(personData.id || personId);
    }
    if (name === 'organizers' && personData && personData.stanford_tax_url) {
      const el = document.getElementById('org-stanford-link');
      if (el) el.innerHTML = `<a href="${esc(personData.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">🔗 Open Stanford Tax Organizer →</a>`;
    }
    if (name === 'notes' && personData) {
      const ta = document.getElementById('notes-ta-full');
      if (ta) ta.value = personData.notes || '';
    }
    if (name === 'workflow') loadWorkflow();
  }

  function filingLabel(s) {
    const m = { single:'Single',mfj:'MFJ',mfs:'MFS',hoh:'HOH',qw:'QW' };
    return m[s] || s || '';
  }

  function portalStatusLabel(p) {
    if (p.portal_enabled) return { label: 'Portal Enabled', cls: 'badge-green' };
    if (p.portal_invite_token) return { label: 'Invited', cls: 'badge-orange' };
    return { label: 'Not Set Up', cls: 'badge-muted' };
  }

  async function loadWorkflow() {
    const loading = document.getElementById('workflow-loading');
    const list = document.getElementById('workflow-list');
    loading.style.display = ''; list.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/entity-jobs?entity_type=person&entity_id=${personId}`);
      const jobs = await res.json();
      loading.style.display = 'none'; list.style.display = '';
      if (!jobs.length) {
        list.innerHTML = '<div style="color:var(--muted);padding:2rem 0;">This person is not in any pipelines yet.</div>';
        return;
      }
      list.innerHTML = jobs.map(j => {
        const stageColor = j.stage_color || 'var(--gold)';
        const yearBadge = j.tax_year ? `<span style="font-size:0.72rem;background:rgba(255,255,255,0.06);border-radius:4px;padding:0.1rem 0.45rem;margin-left:0.5rem;color:var(--muted);">${j.tax_year}</span>` : '';
        const statusColor = j.job_status === 'blocked' ? 'var(--red)' : j.job_status === 'waiting_client' || j.job_status === 'missing_info' ? 'var(--orange)' : 'var(--green)';
        const statusLabels = { active:'Active', waiting_client:'Waiting on Client', missing_info:'Missing Info', blocked:'Blocked', under_extension:'Under Extension', on_hold:'On Hold' };
        const statusLabel = statusLabels[j.job_status] || 'Active';
        const updateText = j.last_update ? (j.last_update.length > 80 ? j.last_update.substring(0,80)+'…' : j.last_update) : null;
        const updateDate = j.last_update_at ? new Date(j.last_update_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '';
        const updateAuthor = j.last_update_author || '';
        const lastUpdate = updateText ? `<div style="font-size:0.78rem;color:var(--muted);margin-top:0.3rem;">${esc(updateText)}<span style="font-size:0.72rem;color:rgba(143,163,184,0.6);margin-left:0.4rem;">— ${esc(updateAuthor)}${updateDate ? ', '+updateDate : ''}</span></div>` : '';
        return `<div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:1rem 1.25rem;margin-bottom:0.75rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
          <div style="flex:1;min-width:180px;">
            <div style="font-weight:700;font-size:0.95rem;">${esc(j.pipeline_name)}${yearBadge}</div>
            ${lastUpdate}
          </div>
          <div style="text-align:center;min-width:140px;">
