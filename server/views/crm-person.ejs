<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
  .detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
  .overview-grid { display: grid; grid-template-columns: 1fr 1fr 320px; gap: 0.85rem; align-items: start; }
  @media (max-width: 900px) { .overview-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) {
    .detail-grid { grid-template-columns: 1fr; padding: 0.75rem; gap: 0.75rem; }
    .overview-grid { grid-template-columns: 1fr; }
  }
  .info-row { display: flex; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.86rem; }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); width: 140px; flex-shrink: 0; font-size: 0.8rem; }
  .info-val { flex: 1; }
  .save-indicator { font-size: 0.75rem; color: var(--green); margin-top: 0.3rem; height: 1rem; }
  .placeholder-section { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; color: var(--muted); text-align: center; }
  .ph-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .ph-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .ph-desc { font-size: 0.86rem; }
  .portal-btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem; }

  /* ── Docs: folder hierarchy (exact portal match) ── */
  .docs-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding: 1.5rem; }
  @media (max-width: 800px) { .docs-layout { grid-template-columns: 1fr; } }
  .docs-col-title { font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--border); }
  .year-folder { background: var(--card); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .year-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.1rem; cursor: pointer; user-select: none; transition: background 0.15s; }
  .year-header:hover { background: rgba(255,255,255,0.03); }
  .year-header .yr-label { font-weight: 700; font-size: 0.95rem; color: var(--text); display: flex; align-items: center; gap: 0.5rem; }
  .yr-count { font-size: 0.72rem; background: rgba(201,168,76,0.12); color: var(--gold); border: 1px solid rgba(201,168,76,0.25); border-radius: 20px; padding: 0.1rem 0.5rem; font-weight: 600; }
  .yr-chevron { color: var(--muted); font-size: 0.8rem; transition: transform 0.2s; }
  .year-folder.open .yr-chevron { transform: rotate(180deg); }
  .year-body { display: none; border-top: 1px solid var(--border); }
  .year-folder.open .year-body { display: block; }
  .cat-folder { margin-bottom: 0.35rem; border: 1px solid rgba(255,255,255,0.05); border-radius: 6px; overflow: hidden; }
  .cat-folder-header { display: flex; align-items: center; justify-content: space-between; padding: 0.4rem 0.7rem; cursor: pointer; user-select: none; background: rgba(201,168,76,0.04); border-left: 3px solid var(--gold); }
  .cat-folder-header:hover { background: rgba(201,168,76,0.08); }
  .cat-folder-label { font-size: 0.82rem; font-weight: 700; color: var(--text); }
  .cat-folder-meta { font-size: 0.72rem; color: var(--muted); }
  .cat-chevron { color: var(--muted); font-size: 0.75rem; transition: transform 0.15s; }
  .cat-folder.open .cat-chevron { transform: rotate(180deg); }
  .cat-folder-body { display: none; padding: 0.4rem 0.5rem; }
  .cat-folder.open .cat-folder-body { display: block; }
  .section-heading { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); padding: 0.6rem 1.1rem 0.3rem; }
  .doc-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1.1rem; border-top: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
  .doc-row:hover { background: rgba(255,255,255,0.03); }
  .doc-info { flex: 1; min-width: 0; }
  .doc-name { font-weight: 600; font-size: 0.9rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .doc-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
  .doc-badge { font-size: 0.68rem; border-radius: 20px; padding: 0.1rem 0.45rem; font-weight: 600; }
  .doc-badge-type { background: rgba(138,143,168,0.12); color: var(--muted); border: 1px solid rgba(138,143,168,0.2); }
  .doc-badge-new { background: rgba(201,168,76,0.16); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }
  .doc-badge-viewed { background: rgba(62,207,142,0.1); color: var(--green); border: 1px solid rgba(62,207,142,0.25); }
  .doc-badge-client { background: rgba(99,102,241,0.12); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.25); }
  .btn-dl { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 0.78rem; border-radius: 6px; padding: 0.3rem 0.65rem; cursor: pointer; transition: border-color 0.2s, color 0.2s; flex-shrink: 0; white-space: nowrap; }
  @media (max-width: 600px) {
    .doc-name { white-space: normal; overflow-wrap: break-word; word-break: break-word; font-size: 0.82rem; }
    .doc-badges { flex-wrap: wrap; }
    .btn-dl { font-size: 0.72rem; padding: 0.25rem 0.5rem; }
    .doc-row { gap: 0.5rem; padding: 0.55rem 0.75rem; align-items: flex-start; }
    .docs-page-wrap { padding: 0.75rem 0; }
    .year-folder { border-radius: 0; margin-bottom: 0.5rem; }
    .docs-col-title { padding: 0 0.75rem; }
  }
  .btn-dl:hover { border-color: var(--gold); color: var(--gold); }
  .btn-dl:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Upload modal (exact portal match) ── */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 5000; padding: 1rem; }
  .modal-overlay.hidden { display: none; }
  .modal { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 1.75rem 1.75rem; width: 100%; max-width: 440px; box-shadow: 0 20px 60px rgba(0,0,0,0.6); }
  .modal h2 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 1.25rem; }
  .modal .form-group { margin-bottom: 1rem; }
  .modal .form-group label { display: block; font-size: 0.8rem; color: var(--muted); margin-bottom: 0.35rem; letter-spacing: 0.03em; }
  .modal .form-group select { width: 100%; background: var(--charcoal); border: 1px solid var(--border); border-radius: 7px; color: var(--text); font-size: 0.93rem; padding: 0.6rem 0.8rem; outline: none; transition: border-color 0.2s; appearance: none; }
  .modal .form-group select:focus { border-color: var(--gold); }
  .file-drop { border: 2px dashed var(--border); border-radius: 9px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; color: var(--muted); font-size: 0.88rem; position: relative; }
  .file-drop:hover, .file-drop.drag-over { border-color: var(--gold); background: rgba(201,168,76,0.04); }
  .file-drop input[type="file"] { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .selected-file { margin-top: 0.5rem; font-size: 0.8rem; color: var(--gold); }
  .modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.25rem; }
  .btn-cancel { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 0.88rem; border-radius: 7px; padding: 0.55rem 1rem; cursor: pointer; }
  .btn-cancel:hover { border-color: var(--text); color: var(--text); }
  .btn-submit { background: var(--gold); color: #0f1117; font-weight: 700; font-size: 0.88rem; border: none; border-radius: 7px; padding: 0.55rem 1.25rem; cursor: pointer; transition: background 0.2s; }
  .btn-submit:hover { background: var(--gold-light); }
  .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .upload-msg { font-size: 0.8rem; color: var(--green); margin-top: 0.5rem; }
  .upload-err { font-size: 0.8rem; color: var(--red); margin-top: 0.5rem; }
</style>

<div class="entity-header">
  <a href="/crm/people" class="entity-back">← People</a>
  <div class="entity-header-content">
    <div class="entity-name" id="entity-name">Loading…</div>
    <div class="entity-meta" id="entity-meta"></div>
  </div>
  <div style="display:flex;align-items:center;gap:0.75rem;flex-shrink:0;flex-wrap:wrap;">
    <div class="entity-badges" id="entity-badges"></div>
    <div class="entity-actions" id="entity-actions">
      <button class="btn btn-outline btn-sm" onclick="openEditModal()">Edit</button>
    </div>
  </div>
</div>

<div class="tab-bar">
  <div class="tab-item active" onclick="switchTab('overview', this)">Overview</div>
  <div class="tab-item" onclick="switchTab('docs', this)">Docs</div>
  <div class="tab-item" onclick="switchTab('tax', this)">Tax</div>
  <div class="tab-item" onclick="switchTab('communication', this)">Communication</div>
  <div class="tab-item" onclick="switchTab('organizers', this)">Organizers</div>
  <div class="tab-item" onclick="switchTab('workflow', this)">Workflow</div>
  <div class="tab-item" onclick="switchTab('notes', this)">Notes</div>
</div>

<div id="tab-overview" class="tab-content active">
  <div style="padding:0.85rem;display:flex;flex-direction:column;gap:0.85rem;">
    <!-- 3-COL LAYOUT -->
    <div class="overview-grid">
      <!-- LEFT col -->
      <div style="display:flex;flex-direction:column;gap:0.85rem;min-width:0;width:100%;">
        <div id="overview-contact-panel" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div class="loading-state"><div class="loading-spinner"></div></div>
        </div>
        <div id="overview-messages-panel" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div class="loading-state"><div class="loading-spinner"></div></div>
        </div>
      </div>
      <!-- CENTER col -->
      <div style="display:flex;flex-direction:column;gap:0.85rem;min-width:0;width:100%;">
        <div id="overview-spouse-panel" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div class="loading-state"><div class="loading-spinner"></div></div>
        </div>
        <div id="overview-tax-panel" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div class="loading-state"><div class="loading-spinner"></div></div>
        </div>
      </div>
      <!-- RIGHT col -->
      <div style="display:flex;flex-direction:column;gap:0.85rem;min-width:0;width:100%;">
        <div id="overview-companies-panel" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div class="loading-state"><div class="loading-spinner"></div></div>
        </div>
        <div style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Internal Notes</div>
          <textarea class="form-control" id="notes-ta" rows="5" placeholder="Internal staff notes…" style="width:100%;box-sizing:border-box;" onblur="autoSaveNotes(this.value)"></textarea>
          <div class="save-indicator" id="notes-saved"></div>
        </div>
        <div id="overview-portal-panel" style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:0.85rem 1rem;width:100%;box-sizing:border-box;">
          <div class="loading-state"><div class="loading-spinner"></div></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="tab-docs" class="tab-content">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem 0;">
    <div style="font-size:0.85rem;color:var(--muted);">Drag a file anywhere on the page to upload.</div>
    <button class="btn btn-gold btn-sm" onclick="openUploadModal()">↑ Upload Document</button>
  </div>
  <div id="docs-content"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>
</div>

<!-- Upload Modal (portal-matched) -->
<div class="modal-overlay hidden" id="upload-modal">
  <div class="modal" onclick="event.stopPropagation()">
    <h2>Upload a Document</h2>
    <div class="form-group">
      <label>Tax Year</label>
      <select id="upload-year"></select>
    </div>
    <div class="form-group">
      <label>Category</label>
      <select id="upload-doc-type">
        <option value="tax">Tax</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div class="form-group">
      <label>Section</label>
      <select id="upload-section">
        <option value="firm_uploaded">Delivered by Advisor</option>
        <option value="client_uploaded">Client Uploaded</option>
      </select>
    </div>
    <div class="form-group">
      <label>File</label>
      <div class="file-drop" id="upload-file-drop">
        <input type="file" id="upload-file-input">
        <span>Click to select or drag a file here</span>
        <div class="selected-file" id="upload-selected-name"></div>
      </div>
    </div>
    <div class="upload-err" id="upload-error" style="display:none;"></div>
    <div class="upload-msg" id="upload-msg" style="display:none;"></div>
    <div class="modal-actions">
      <button class="btn-cancel" id="upload-cancel-btn">Cancel</button>
      <button class="btn-submit" id="upload-submit-btn" disabled>Upload</button>
    </div>
  </div>
</div>

<div id="tab-tax" class="tab-content">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem 0;">
    <span style="font-size:0.84rem;color:var(--muted);">Tax return deliveries &amp; e-signatures</span>
    <button class="btn btn-gold btn-sm" onclick="openPersonDeliveryModal()">+ New Delivery</button>
  </div>
  <div id="tax-content" style="padding:1.5rem;"></div>

  <!-- Edit Delivery Docs Modal -->
  <div class="modal-overlay hidden" id="edit-delivery-modal">
    <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
      <h2>Update Delivery Documents</h2>
      <p style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem;">Select new documents to replace the existing ones, then resend.</p>
      <input type="hidden" id="ed-id" />
      <div class="form-group"><label>Review Document (PDF for client to review)</label>
        <select class="form-control" id="ed-review-doc"><option value="">— No change —</option></select>
      </div>
      <div class="form-group"><label>Signature Document (8879 / signature pages)</label>
        <select class="form-control" id="ed-sig-doc"><option value="">— No change —</option></select>
      </div>
      <div id="ed-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.5rem;"></div>
      <div class="modal-actions">
        <button class="btn btn-outline" onclick="closeEditDeliveryModal()">Cancel</button>
        <button class="btn btn-gold" onclick="submitEditDelivery()">Save & Ready to Send</button>
      </div>
    </div>
  </div>

  <!-- New Delivery Modal (person) -->
  <div class="modal-overlay hidden" id="person-delivery-modal">
    <div class="modal" onclick="event.stopPropagation()" style="max-width:680px;">
      <h2>New Tax Delivery</h2>
      <div id="pd-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
        <div class="form-group"><label>Tax Year *</label>
          <select class="form-control" id="pd-year" onchange="pdFilterDocsByYear(); document.getElementById('pd-title').value = this.value + ' Tax Return Delivery';"></select>
        </div>
        <div class="form-group"><label>Title</label><input type="text" class="form-control" id="pd-title" placeholder="e.g. 2024 Individual Return"></div>
      </div>
      <div class="form-group"><label>Message to Client <span style="font-weight:400;color:var(--muted);">(shown in the portal — edit as needed)</span></label><textarea class="form-control" id="pd-intro" rows="9" style="font-size:0.88rem;line-height:1.6;"></textarea></div>
      <div class="form-group"><label>Review Document (PDF for client to review)</label>
        <select class="form-control" id="pd-review-doc"><option value="">— Select document —</option></select>
      </div>
      <div class="form-group"><label>Signature Document (8879 / signature pages)</label>
        <select class="form-control" id="pd-sig-doc"><option value="">— Select document —</option></select>
      </div>
      <div class="form-group">
        <label>Signers <span style="font-weight:400;color:var(--muted);">(who needs to sign — e.g. both spouses)</span></label>
        <div id="pd-signers-list" style="display:flex;flex-direction:column;gap:0.4rem;margin-top:0.25rem;"></div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-outline" onclick="closePersonDeliveryModal()">Cancel</button>
        <button class="btn btn-gold" onclick="submitPersonDelivery()">Create Draft</button>
      </div>
    </div>
  </div>
</div>

<style>
    #tab-communication.active { display:flex !important; flex-direction:column; }
    /* Height = viewport minus top header, entity header, and tab bar */
    #tab-communication {
      overflow:hidden;
      height: calc(100vh - var(--header-h, 58px) - var(--tab-bar-top, 58px) - 42px);
    }
    /* Prevent .main scrollbar when comm tab is active */
    body:has(#tab-communication.active) .main { overflow-y: hidden !important; }

    /* Layout */
    #tab-communication .crm-inbox-wrap { display:flex; flex:1; min-height:0; overflow:hidden; }
    /* AI Summary panel */
    #tab-communication .comm-summary-panel { width:400px; flex-shrink:0; border-left:1px solid var(--border); display:flex; flex-direction:column; overflow:hidden; background:var(--card); }
    #tab-communication .comm-summary-header { padding:0.85rem 1rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
    #tab-communication .comm-summary-header h3 { font-size:0.85rem; font-weight:700; color:var(--text); margin:0; }
    #tab-communication .comm-summary-body { flex:1; overflow-y:auto; padding:1rem; font-size:0.82rem; line-height:1.6; color:var(--muted); }
    #tab-communication .comm-summary-body strong { color:var(--gold); display:block; margin-top:0.75rem; margin-bottom:0.2rem; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; }
    #tab-communication .comm-summary-body strong:first-child { margin-top:0; }
    /* Thread cards — same as team inbox */
    #tab-communication .thread-card { padding:0.85rem 1rem; border-bottom:1px solid rgba(255,255,255,0.04); cursor:pointer; transition:background 0.12s; }
    #tab-communication .thread-card:hover { background:rgba(255,255,255,0.03); }
    #tab-communication .thread-card.active { background:rgba(201,168,76,0.07); border-left:3px solid var(--gold); padding-left:calc(1rem - 3px); }
    #tab-communication .thread-card-name { font-size:0.85rem; font-weight:600; color:var(--text); }
    #tab-communication .thread-card-preview { font-size:0.76rem; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-top:0.1rem; }
    #tab-communication .thread-card-meta { display:flex; align-items:center; gap:0.4rem; margin-top:0.3rem; font-size:0.7rem; color:var(--muted); }
    #tab-communication .unread-dot { width:8px; height:8px; border-radius:50%; background:var(--gold); flex-shrink:0; }
    /* Detail panel */
    #tab-communication .crm-detail-panel { flex:1; display:flex; flex-direction:column; min-width:0; min-height:0; overflow:hidden; position:relative; }
    #tab-communication .detail-header { padding:1rem 1.5rem; border-bottom:1px solid var(--border); background:var(--card); flex-shrink:0; }
    #tab-communication .detail-header-person { font-size:1rem; font-weight:700; color:var(--text); }
    #tab-communication .detail-header-subject { font-size:0.85rem; color:var(--muted); margin-top:0.15rem; }
    #tab-communication .detail-messages { flex:1; overflow-y:auto; min-height:0; padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:1rem; }
    /* Bubbles — same as team inbox */
    #tab-communication .msg-bubble-wrap { display:flex; flex-direction:column; }
    #tab-communication .msg-bubble-wrap.staff { align-items:flex-end; }
    #tab-communication .msg-bubble-wrap.client { align-items:flex-start; }
    #tab-communication .msg-bubble-wrap.internal { align-items:flex-start; }
    #tab-communication .msg-bubble { max-width:75%; padding:0.6rem 0.9rem; border-radius:12px; font-size:0.875rem; line-height:1.5; word-break:break-word; }
    #tab-communication .msg-bubble.staff { background:var(--gold); color:var(--navy); }
    #tab-communication .msg-bubble.client { background:var(--charcoal); color:var(--text); border:1px solid var(--border); }
    #tab-communication .msg-bubble.internal { background:rgba(255,200,0,0.1); border:1px dashed var(--gold); color:var(--text); }
    #tab-communication .msg-meta { font-size:0.68rem; color:var(--muted); margin-top:0.15rem; }
    #tab-communication .msg-internal-label { font-size:0.62rem; color:var(--gold); margin-bottom:0.15rem; }
    /* Attachments */
    #tab-communication .msg-attachments { display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.5rem; }
    #tab-communication .attachment-chip { display:inline-flex; align-items:center; gap:0.35rem; background:rgba(0,0,0,0.25); border:1px solid rgba(0,0,0,0.2); border-radius:6px; padding:0.25rem 0.6rem; font-size:0.75rem; color:#fff; text-decoration:none; font-weight:500; }
    #tab-communication .attachment-chip:hover { background:rgba(0,0,0,0.4); }
    /* Reply box — identical to team inbox */
    #tab-communication .reply-box { padding:1rem 1.5rem; border-top:1px solid var(--border); background:var(--card); flex-shrink:0; }
    #tab-communication .reply-box-controls { display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem; }
    #tab-communication .reply-box-controls label { font-size:0.78rem; color:var(--muted); display:flex; align-items:center; gap:0.3rem; cursor:pointer; }
