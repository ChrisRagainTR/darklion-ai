<script>
  const personId = location.pathname.split('/').pop();
  const token = localStorage.getItem('dl_token');
  if (!token) window.location.href = '/login';

  let personData = null;

  function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }; }
  async function apiFetch(url, opts = {}) {
    const isFormData = opts.body instanceof FormData;
    const headers = isFormData
      ? { 'Authorization': 'Bearer ' + token, ...(opts.headers||{}) }
      : { ...authHeaders(), ...(opts.headers||{}) };
    const res = await fetch(url, { ...opts, headers });
    if (res.status === 401) window.location.href = '/login';
    return res;
  }
  function esc(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  // Format phone as 239.297.2988 and wrap in tel: link
  function fmtPhone(raw) {
    if (!raw) return '—';
    const digits = raw.replace(/\D/g, '');
    let formatted = raw; // fallback to raw if can't parse
    if (digits.length === 10) {
      formatted = `${digits.slice(0,3)}.${digits.slice(3,6)}.${digits.slice(6)}`;
    } else if (digits.length === 11 && digits[0] === '1') {
      formatted = `${digits.slice(1,4)}.${digits.slice(4,7)}.${digits.slice(7)}`;
    }
    return `<a href="tel:${formatted}" style="color:var(--gold);text-decoration:none;">${esc(formatted)}</a>`;
  }

  // Format date_of_birth as mm/dd/yyyy
  function fmtDOB(raw) {
    if (!raw) return '—';
    // raw may be ISO date string like "1955-04-12" or "1955-04-12T00:00:00.000Z"
    const d = new Date(raw);
    if (isNaN(d)) return esc(raw);
    // Use UTC parts to avoid timezone shift
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const yyyy = d.getUTCFullYear();
    return `${mm}/${dd}/${yyyy}`;
  }
  const _shellToast = window.toast;
  function toast(msg, type) { if (_shellToast) _shellToast(msg, type === 'error' ? 'error' : undefined); }

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    // Hide main scrollbar on comm tab, restore on others
    const mainEl = document.querySelector('.main');
    if (mainEl) mainEl.style.overflowY = (name === 'communication') ? 'hidden' : 'auto';
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax(true);
    if (name === 'communication') initComm(personData?.id || personId);
    if (name === 'organizers') {
      const urlInput = document.getElementById('stanford-url-input');
      if (urlInput && personData) urlInput.value = personData.stanford_tax_url || '';
      const el = document.getElementById('org-stanford-link');
      if (el && personData && personData.stanford_tax_url) {
        el.innerHTML = `<a href="${esc(personData.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">🔗 Open Stanford Tax Organizer →</a>`;
      }
    }
    if (name === 'notes' && personData) document.getElementById('notes-ta-full').value = personData.notes || '';
    if (name === 'workflow') loadWorkflow();
  }

  async function loadWorkflow() {
    const loading = document.getElementById('workflow-loading');
    const list = document.getElementById('workflow-list');
    loading.style.display = ''; list.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/entity-jobs?entity_type=person&entity_id=${personId}`);
      const jobs = await res.json();
      loading.style.display = 'none'; list.style.display = '';
      if (!jobs.length) { list.innerHTML = '<div style="color:var(--muted);">This person is not in any pipelines yet.</div>'; return; }
      list.innerHTML = jobs.map(j => {
        const stageColor = j.stage_color || 'var(--gold)';
        const yearBadge = j.tax_year ? `<span style="font-size:0.72rem;background:rgba(255,255,255,0.06);border-radius:4px;padding:0.1rem 0.45rem;margin-left:0.5rem;color:var(--muted);">${j.tax_year}</span>` : '';
        const statusColor = j.job_status === 'blocked' ? 'var(--red)' : (j.job_status === 'waiting_client' || j.job_status === 'missing_info') ? 'var(--orange)' : 'var(--green)';
        const statusLabel = {active:'Active',waiting_client:'Waiting on Client',missing_info:'Missing Info',blocked:'Blocked',under_extension:'Under Extension',on_hold:'On Hold'}[j.job_status] || 'Active';
        const updateText = j.last_update ? (j.last_update.length > 80 ? j.last_update.substring(0,80)+'…' : j.last_update) : null;
        const updateDate = j.last_update_at ? new Date(j.last_update_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '';
        const updateAuthor = j.last_update_author || '';
        const lastUpdate = updateText ? `<div style="font-size:0.78rem;color:var(--muted);margin-top:0.3rem;">${esc(updateText)}<span style="font-size:0.72rem;color:rgba(143,163,184,0.6);margin-left:0.4rem;">— ${esc(updateAuthor)}${updateDate ? ', '+updateDate : ''}</span></div>` : '';
        return `<div class="workflow-job-card" onclick="window.location.href='/pipelines?job=${j.id}'">
          <div style="flex:1;min-width:180px;"><div style="font-weight:700;font-size:0.95rem;">${esc(j.pipeline_name)}${yearBadge}</div>${lastUpdate}</div>
          <div style="text-align:center;min-width:140px;"><div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Current Stage</div><div style="font-weight:700;color:${stageColor};font-size:0.9rem;">${esc(j.stage_name)}</div></div>
          <div style="text-align:center;min-width:100px;"><div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Status</div><div style="font-weight:600;font-size:0.82rem;color:${statusColor};">${statusLabel}</div></div>
          ${j.assigned_name ? `<div style="text-align:center;min-width:80px;"><div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Assigned</div><div style="font-size:0.82rem;">${esc(j.assigned_name)}</div></div>` : ''}
        </div>`;
      }).join('');
    } catch(e) { loading.textContent = 'Failed to load pipelines: ' + e.message; }

    // Load pipeline history
    loadPipelineHistory();
  }

  async function loadPipelineHistory() {
    const loading = document.getElementById('pipeline-history-loading');
    const list = document.getElementById('pipeline-history-list');
    if (!loading || !list) return;
    loading.style.display = ''; list.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/completions?entity_type=person&entity_id=${personId}`);
      const data = await res.json();
      loading.style.display = 'none'; list.style.display = '';
      const completions = data.completions || [];
      const activeJobs = data.active_jobs || [];
      if (!completions.length && !activeJobs.length) {
        list.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;">No pipeline history yet.</div>';
        return;
      }
      const rows = [];
      completions.forEach(c => {
        const yr = c.tax_year ? ` ${c.tax_year}` : '';
        const date = new Date(c.completed_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
        rows.push(`<div style="display:flex;align-items:center;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="font-size:1rem;">✅</span>
          <span style="flex:1;font-size:0.88rem;font-weight:600;">${esc(c.pipeline_name)}${yr}</span>
          <span style="font-size:0.78rem;color:var(--muted);">completed ${date}</span>
        </div>`);
      });
      activeJobs.forEach(j => {
        const yr = j.tax_year ? ` ${j.tax_year}` : '';
        const stage = j.current_stage_name ? ` → ${j.current_stage_name}` : '';
        rows.push(`<div style="display:flex;align-items:center;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="font-size:1rem;">🔄</span>
          <span style="flex:1;font-size:0.88rem;font-weight:600;">${esc(j.pipeline_name)}${yr}</span>
          <span style="font-size:0.78rem;color:var(--muted);">in progress${esc(stage)}</span>
        </div>`);
      });
      list.innerHTML = rows.join('') || '<div style="color:var(--muted);font-size:0.85rem;">No pipeline history yet.</div>';
    } catch(e) { loading.textContent = 'Failed to load pipeline history.'; }
  }

  // ── Fire Trigger Modal ────────────────────────────────
  let availableTriggers = [];

  async function openFireTriggerModal() {
    const modal = document.getElementById('fire-trigger-modal');
    const select = document.getElementById('ft-trigger-select');
    const result = document.getElementById('ft-result');
    result.style.display = 'none';
    modal.classList.remove('hidden');

    if (!availableTriggers.length) {
      try {
        const res = await apiFetch('/api/pipeline-triggers');
        availableTriggers = await res.json();
        // Group by category
        const byCategory = {};
        availableTriggers.forEach(t => {
          if (!byCategory[t.category]) byCategory[t.category] = [];
          byCategory[t.category].push(t);
        });
        let html = '<option value="">— Select a trigger —</option>';
        Object.keys(byCategory).sort().forEach(cat => {
          html += `<optgroup label="${esc(cat)}">`;
          byCategory[cat].forEach(t => {
            html += `<option value="${esc(t.key)}">${esc(t.label)}</option>`;
          });
          html += '</optgroup>';
        });
        select.innerHTML = html;
      } catch(e) {
        select.innerHTML = '<option value="">Failed to load triggers</option>';
      }
    }
  }

  function closeFireTriggerModal() {
    document.getElementById('fire-trigger-modal').classList.add('hidden');
    document.getElementById('ft-result').style.display = 'none';
    document.getElementById('ft-trigger-select').value = '';
  }

  async function submitFireTrigger() {
    const key = document.getElementById('ft-trigger-select').value;
    const result = document.getElementById('ft-result');
    const btn = document.getElementById('ft-submit');
    if (!key) { toast('Select a trigger first', 'error'); return; }

    btn.disabled = true;
    btn.textContent = 'Firing…';
    result.style.display = 'none';

    try {
      const res = await apiFetch('/api/pipeline-triggers/fire', {
        method: 'POST',
        body: JSON.stringify({ trigger_key: key, person_id: parseInt(personId) }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');

      if (data.moved && data.moved.length) {
        const lines = data.moved.map(m =>
          `<div style="margin-bottom:0.3rem;">📌 <strong>${esc(m.pipeline)}</strong>: ${m.from_stage ? esc(m.from_stage) + ' → ' : ''}${esc(m.to_stage)}</div>`
        ).join('');
        result.style.background = 'rgba(34,197,94,0.1)';
        result.style.border = '1px solid rgba(34,197,94,0.3)';
        result.style.color = 'var(--text)';
        result.innerHTML = `<div style="font-weight:700;margin-bottom:0.5rem;">✅ Moved ${data.moved.length} card${data.moved.length !== 1 ? 's' : ''}:</div>${lines}`;
        result.style.display = 'block';
        // Refresh workflow list
        loadWorkflow();
      } else {
        result.style.background = 'rgba(255,255,255,0.05)';
        result.style.border = '1px solid var(--border)';
        result.style.color = 'var(--muted)';
        result.innerHTML = 'ℹ️ No cards moved — this person has no active pipeline jobs with a smart stage configured for this trigger.';
        result.style.display = 'block';
      }
    } catch(e) {
      result.style.background = 'rgba(239,68,68,0.1)';
      result.style.border = '1px solid rgba(239,68,68,0.3)';
      result.style.color = 'var(--red)';
      result.innerHTML = '❌ ' + esc(e.message);
      result.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Fire ⚡';
    }
  }
  // ── End Fire Trigger Modal ────────────────────────

  async function loadPerson() {
    try {
      const res = await apiFetch(`/api/people/${personId}`);
      if (res.status === 404 || res.status === 403) { window.location.href = '/404'; return; }
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Error loading'; return; }
      personData = await res.json();
      renderHeader(personData);
      renderOverview(personData);
    } catch(e) {
      document.getElementById('entity-name').textContent = 'Error loading';
    }
  }

  function renderHeader(p) {
    const name = `${p.first_name || ''} ${p.last_name || ''}`.trim() || 'Unnamed';
    document.title = `${name} — DarkLion`;
    document.getElementById('entity-name').textContent = name;
    let html = `<span class="badge badge-muted">Person</span>`;
    if (p.filing_status) {
      const fsColors = { MFJ:'rgba(74,144,217,0.18)', Single:'rgba(143,163,184,0.2)', HOH:'rgba(237,137,54,0.18)', MFS:'rgba(138,99,241,0.18)' };
      const fsTextColors = { MFJ:'#4a90d9', Single:'#8fa3b8', HOH:'#ed8936', MFS:'#a78bfa' };
      const fsKey = p.filing_status.toUpperCase() === 'MFJ' ? 'MFJ' : p.filing_status === 'single' ? 'Single' : p.filing_status === 'hoh' ? 'HOH' : p.filing_status === 'mfs' ? 'MFS' : null;
      const fsLabel = { mfj:'MFJ', single:'Single', hoh:'HOH', mfs:'MFS' }[p.filing_status] || p.filing_status.replace(/_/g,' ');
      const bg = fsColors[fsKey] || 'rgba(143,163,184,0.2)';
      const tc = fsTextColors[fsKey] || '#8fa3b8';
      html += ` <span class="badge" style="background:${bg};color:${tc};">${esc(fsLabel)}</span>`;
    }
    if (p.portal_enabled) html += ` <span class="badge badge-green">Portal Active</span>`;
    else if (p.portal_invite_token) html += ` <span class="badge badge-orange">Portal Invited</span>`;
    document.getElementById('entity-badges').innerHTML = html;
    const meta = [];
    if (p.email) meta.push(esc(p.email));
    if (p.phone) meta.push(fmtPhone(p.phone));
    if (p.relationship_name) meta.push(`👥 <a href="#" style="color:var(--gold);text-decoration:none;">${esc(p.relationship_name)}</a>`);
    document.getElementById('entity-meta').innerHTML = meta.join('  ·  ');
    // Track recent visit
    if (window.addRecentClient) window.addRecentClient({ _type:'person', id: p.id, _label: name, _sub: p.relationship_name || 'Person' });
  }

