  // ── AI Summary ──────────────────────────────────────────────────────────────
  let _commSummaryLoaded = false;
  async function loadCommSummary(force = false) {
    if (!commPersonId) return;
    const body = document.getElementById('comm-summary-body');
    const btn = document.getElementById('comm-summary-refresh-btn');
    if (!body) return;
    body.innerHTML = '<div style="display:flex;align-items:center;gap:0.5rem;color:var(--muted);"><div class="loading-spinner" style="width:16px;height:16px;border-width:2px;"></div> Generating summary…</div>';
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    try {
      const res = await apiFetch(`/api/messages/person/${commPersonId}/summary`, { method: 'POST' });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      _commSummaryLoaded = true;
      if (!data.summary) {
        body.innerHTML = `<div style="color:var(--muted);font-style:italic;">${data.message || 'No messages in the last 30 days.'}</div>`;
      } else {
        // Format markdown-style bold headers
        const html = data.summary
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\n/g, '<br>');
        body.innerHTML = `<div>${html}</div>
          <div style="margin-top:1rem;font-size:0.72rem;color:var(--muted);border-top:1px solid var(--border);padding-top:0.5rem;">
            Based on ${data.messageCount} message${data.messageCount !== 1 ? 's' : ''} · ${new Date(data.generatedAt).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}
          </div>`;
      }
    } catch(e) {
      body.innerHTML = `<div style="color:var(--red);font-size:0.8rem;">Failed: ${e.message}</div>`;
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = '↺ Refresh'; }
    }
  }

