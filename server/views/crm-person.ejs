  function commFilterTemplates(q) {
    if (!_commTemplates) return;
    const filtered = q ? _commTemplates.filter(t => t.name.toLowerCase().includes(q.toLowerCase()) || t.body.toLowerCase().includes(q.toLowerCase())) : _commTemplates;
    commRenderTemplates(filtered);
  }
  function commRenderTemplates(list) {
    const el = document.getElementById('comm-tmpl-list');
    if (!list.length) {
      el.innerHTML = '<div style="padding:1.5rem;text-align:center;color:var(--muted);font-style:italic;">No templates found</div>';
      return;
    }
    el.innerHTML = list.map(t => `
      <div style="padding:0.75rem 1.25rem;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s;"
        onmouseover="this.style.background='rgba(201,168,76,0.07)'" onmouseout="this.style.background=''"
        onclick="commLoadTemplate(${t.id})">
        <div style="font-weight:600;font-size:0.88rem;margin-bottom:0.25rem;">${esc(t.name)}</div>
        <div style="font-size:0.78rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(t.body.slice(0,100))}${t.body.length>100?'…':''}</div>
      </div>`).join('');
  }
  function resolveTemplateVars(body) {
    const p = personData || {};
    const firmName = (() => { try { return JSON.parse(atob(localStorage.getItem('dl_token').split('.')[1])).firmName || ''; } catch(e) { return ''; } })();
    const companies = p.company_access || [];
    let companyResolved;
    if (companies.length === 1) {
      companyResolved = companies[0].company_name || '{Company Name}';
    } else if (companies.length > 1) {
      // List all company names separated by " / " — staff deletes the ones they don't want
      companyResolved = companies.map(c => c.company_name).filter(Boolean).join(' / ');
    } else {
      companyResolved = '{Company Name}';
    }
    return body
      .replace(/\{First Name\}/g, p.first_name || '')
      .replace(/\{Last Name\}/g, p.last_name || '')
      .replace(/\{Full Name\}/g, [p.first_name, p.last_name].filter(Boolean).join(' ') || '')
      .replace(/\{Company Name\}/g, companyResolved)
      .replace(/\{Firm Name\}/g, firmName);
  }

  function commLoadTemplate(id) {
    const t = _commTemplates && _commTemplates.find(x => x.id === id);
    if (!t) return;
    document.getElementById('comm-new-body').value = resolveTemplateVars(t.body);
    commCloseTemplatePicker();
    document.getElementById('comm-new-body').focus();
  }

