  function closeModal() {
    const m = document.getElementById('edit-modal');
    m.classList.add('hidden');
    m.style.display = '';
  }

  async function submitEdit() {
    const btn = document.getElementById('ef-submit');
    const errEl = document.getElementById('edit-error');
    errEl.style.display = 'none';
    btn.disabled = true; btn.textContent = 'Saving…';
    const spouseIdRaw = document.getElementById('ef-spouse-id').value;
    const body = {
      first_name: document.getElementById('ef-fname').value.trim(),
      last_name: document.getElementById('ef-lname').value.trim(),
      email: document.getElementById('ef-email').value.trim(),
      phone: document.getElementById('ef-phone').value.trim(),
      date_of_birth: document.getElementById('ef-dob').value || null,
      billing_method: document.getElementById('ef-billing-method').value || null,
      filing_status: document.getElementById('ef-filing').value,
      spouse_id: spouseIdRaw ? parseInt(spouseIdRaw) : null,
    };
    try {
      const res = await apiFetch(`/api/people/${personId}`, { method: 'PUT', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error||'Failed'); }
      btn.textContent = '✓ Saved';
      setTimeout(() => { closeModal(); window.location.reload(); }, 600);
    } catch(e) {
      errEl.textContent = e.message; errEl.style.display = '';
