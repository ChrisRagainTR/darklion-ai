<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
  .detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
  .info-row { display: flex; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.86rem; }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); width: 140px; flex-shrink: 0; font-size: 0.8rem; }
  .info-val { flex: 1; }
  .save-indicator { font-size: 0.75rem; color: var(--green); margin-top: 0.3rem; height: 1rem; }
  .placeholder-section { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; color: var(--muted); text-align: center; }
  .ph-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .ph-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .ph-desc { font-size: 0.86rem; }
  .portal-btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem; }

  /* ── Docs: folder hierarchy (exact portal match) ── */
  .docs-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding: 1.5rem; }
  @media (max-width: 800px) { .docs-layout { grid-template-columns: 1fr; } }
  .docs-col-title { font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--border); }
  .year-folder { background: var(--card); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .year-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.1rem; cursor: pointer; user-select: none; transition: background 0.15s; }
  .year-header:hover { background: rgba(255,255,255,0.03); }
  .year-header .yr-label { font-weight: 700; font-size: 0.95rem; color: var(--text); display: flex; align-items: center; gap: 0.5rem; }
  .yr-count { font-size: 0.72rem; background: rgba(201,168,76,0.12); color: var(--gold); border: 1px solid rgba(201,168,76,0.25); border-radius: 20px; padding: 0.1rem 0.5rem; font-weight: 600; }
  .yr-chevron { color: var(--muted); font-size: 0.8rem; transition: transform 0.2s; }
  .year-folder.open .yr-chevron { transform: rotate(180deg); }
  .year-body { display: none; border-top: 1px solid var(--border); }
  .year-folder.open .year-body { display: block; }
  .section-heading { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); padding: 0.6rem 1.1rem 0.3rem; }
  .doc-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1.1rem; border-top: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
  .doc-row:hover { background: rgba(255,255,255,0.03); }
  .doc-info { flex: 1; min-width: 0; }
  .doc-name { font-weight: 600; font-size: 0.9rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .doc-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
  .doc-badge { font-size: 0.68rem; border-radius: 20px; padding: 0.1rem 0.45rem; font-weight: 600; }
  .doc-badge-type { background: rgba(138,143,168,0.12); color: var(--muted); border: 1px solid rgba(138,143,168,0.2); }
  .doc-badge-new { background: rgba(201,168,76,0.16); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }
  .doc-badge-viewed { background: rgba(62,207,142,0.1); color: var(--green); border: 1px solid rgba(62,207,142,0.25); }
  .doc-badge-client { background: rgba(99,102,241,0.12); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.25); }
  .btn-dl { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 0.78rem; border-radius: 6px; padding: 0.3rem 0.65rem; cursor: pointer; transition: border-color 0.2s, color 0.2s; flex-shrink: 0; white-space: nowrap; }
  .btn-dl:hover { border-color: var(--gold); color: var(--gold); }
  .btn-dl:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Upload modal (exact portal match) ── */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
  .modal-overlay.hidden { display: none; }
  .modal { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 1.75rem 1.75rem; width: 100%; max-width: 440px; box-shadow: 0 20px 60px rgba(0,0,0,0.6); }
  .modal h2 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 1.25rem; }
  .modal .form-group { margin-bottom: 1rem; }
  .modal .form-group label { display: block; font-size: 0.8rem; color: var(--muted); margin-bottom: 0.35rem; letter-spacing: 0.03em; }
  .modal .form-group select { width: 100%; background: var(--charcoal); border: 1px solid var(--border); border-radius: 7px; color: var(--text); font-size: 0.93rem; padding: 0.6rem 0.8rem; outline: none; transition: border-color 0.2s; appearance: none; }
  .modal .form-group select:focus { border-color: var(--gold); }
  .file-drop { border: 2px dashed var(--border); border-radius: 9px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; color: var(--muted); font-size: 0.88rem; position: relative; }
  .file-drop:hover, .file-drop.drag-over { border-color: var(--gold); background: rgba(201,168,76,0.04); }
  .file-drop input[type="file"] { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .selected-file { margin-top: 0.5rem; font-size: 0.8rem; color: var(--gold); }
  .modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.25rem; }
  .btn-cancel { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 0.88rem; border-radius: 7px; padding: 0.55rem 1rem; cursor: pointer; }
  .btn-cancel:hover { border-color: var(--text); color: var(--text); }
  .btn-submit { background: var(--gold); color: #0f1117; font-weight: 700; font-size: 0.88rem; border: none; border-radius: 7px; padding: 0.55rem 1.25rem; cursor: pointer; transition: background 0.2s; }
  .btn-submit:hover { background: var(--gold-light); }
  .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .upload-msg { font-size: 0.8rem; color: var(--green); margin-top: 0.5rem; }
  .upload-err { font-size: 0.8rem; color: var(--red); margin-top: 0.5rem; }
</style>

<div class="entity-header">
  <a href="/crm/people" class="entity-back">← People</a>
  <div class="entity-header-content">
    <div class="entity-name" id="entity-name">Loading…</div>
    <div class="entity-badges" id="entity-badges"></div>
    <div class="entity-meta" id="entity-meta"></div>
  </div>
  <div class="entity-actions" id="entity-actions">
    <button class="btn btn-outline btn-sm" onclick="openEditModal()">Edit</button>
  </div>
</div>

<div class="tab-bar">
  <div class="tab-item active" onclick="switchTab('overview', this)">Overview</div>
  <div class="tab-item" onclick="switchTab('docs', this)">Docs</div>
  <div class="tab-item" onclick="switchTab('tax', this)">Tax</div>
  <div class="tab-item" onclick="switchTab('communication', this)">Communication</div>
  <div class="tab-item" onclick="switchTab('organizers', this)">Organizers</div>
  <div class="tab-item" onclick="switchTab('workflow', this)">Workflow</div>
  <div class="tab-item" onclick="switchTab('notes', this)">Notes</div>
</div>

<div id="tab-overview" class="tab-content active">
  <div class="detail-grid">
    <div id="overview-left"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>
    <div id="overview-right">
      <div class="card">
        <div class="card-title">Internal Notes</div>
        <textarea class="form-control" id="notes-ta" rows="6" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
        <div class="save-indicator" id="notes-saved"></div>
      </div>
    </div>
  </div>
</div>

<div id="tab-docs" class="tab-content">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem 0;">
    <div style="font-size:0.85rem;color:var(--muted);">Drag a file anywhere on the page to upload.</div>
    <button class="btn btn-gold btn-sm" onclick="openUploadModal()">↑ Upload Document</button>
  </div>
  <div id="docs-content"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>
</div>

<!-- Upload Modal (portal-matched) -->
<div class="modal-overlay hidden" id="upload-modal">
  <div class="modal" onclick="event.stopPropagation()">
    <h2>Upload a Document</h2>
    <div class="form-group">
      <label>Tax Year</label>
      <select id="upload-year"></select>
    </div>
    <div class="form-group">
      <label>Category</label>
      <select id="upload-doc-type">
        <option value="tax">Tax</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div class="form-group">
      <label>Section</label>
      <select id="upload-section">
        <option value="firm_uploaded">Delivered by Advisor</option>
        <option value="client_uploaded">Client Uploaded</option>
      </select>
    </div>
    <div class="form-group">
      <label>File</label>
      <div class="file-drop" id="upload-file-drop">
        <input type="file" id="upload-file-input">
        <span>Click to select or drag a file here</span>
        <div class="selected-file" id="upload-selected-name"></div>
      </div>
    </div>
    <div class="upload-err" id="upload-error" style="display:none;"></div>
    <div class="upload-msg" id="upload-msg" style="display:none;"></div>
    <div class="modal-actions">
      <button class="btn-cancel" id="upload-cancel-btn">Cancel</button>
      <button class="btn-submit" id="upload-submit-btn" disabled>Upload</button>
    </div>
  </div>
</div>

<div id="tab-tax" class="tab-content">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem 0;">
    <span style="font-size:0.84rem;color:var(--muted);">Tax return deliveries &amp; e-signatures</span>
    <button class="btn btn-gold btn-sm" onclick="openPersonDeliveryModal()">+ New Delivery</button>
  </div>
  <div id="tax-content" style="padding:1.5rem;"></div>

  <!-- New Delivery Modal (person) -->
  <div class="modal-overlay hidden" id="person-delivery-modal">
    <div class="modal" onclick="event.stopPropagation()" style="max-width:520px;">
      <h2>New Tax Delivery</h2>
      <div id="pd-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
        <div class="form-group"><label>Tax Year *</label>
          <select class="form-control" id="pd-year" onchange="pdFilterDocsByYear(); document.getElementById('pd-title').value = this.value + ' Tax Return Delivery';"></select>
        </div>
        <div class="form-group"><label>Title</label><input type="text" class="form-control" id="pd-title" placeholder="e.g. 2024 Individual Return"></div>
      </div>
      <div class="form-group"><label>Intro Note (shown to client)</label><textarea class="form-control" id="pd-intro" rows="3" placeholder="Please review and sign your tax return…"></textarea></div>
      <div class="form-group"><label>Review Document (PDF for client to review)</label>
        <select class="form-control" id="pd-review-doc"><option value="">— Select document —</option></select>
      </div>
      <div class="form-group"><label>Signature Document (PDF to sign)</label>
        <select class="form-control" id="pd-sig-doc"><option value="">— Select document —</option></select>
      </div>
      <div class="modal-actions">
        <button class="btn btn-outline" onclick="closePersonDeliveryModal()">Cancel</button>
        <button class="btn btn-gold" onclick="submitPersonDelivery()">Create Draft</button>
      </div>
    </div>
  </div>
</div>

<div id="tab-communication" class="tab-content" style="padding:0;display:flex;flex-direction:column;overflow:hidden;">
  <style>
    #tab-communication.active { display:flex !important; flex-direction:column; }
    .comm-layout { display:flex; flex:1; overflow:hidden; min-height:0; }
    .comm-left { width:320px; flex-shrink:0; border-right:1px solid var(--border); display:flex; flex-direction:column; }
    .comm-left-header { padding:0.85rem 1rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
    .comm-left-header h3 { font-size:0.9rem; font-weight:700; color:var(--text); margin:0; }
    .comm-thread-list-inner { flex:1; overflow-y:auto; }
    .comm-thread-item { display:flex; align-items:flex-start; gap:0.75rem; padding:0.85rem 1rem; border-bottom:1px solid rgba(255,255,255,0.04); cursor:pointer; transition:background 0.12s; }
    .comm-thread-item:hover { background:rgba(255,255,255,0.03); }
    .comm-thread-item.active { background:rgba(201,168,76,0.07); border-left:3px solid var(--gold); padding-left:calc(1rem - 3px); }
    .comm-avatar { width:36px; height:36px; border-radius:50%; background:rgba(201,168,76,0.15); color:var(--gold); display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.8rem; flex-shrink:0; }
    .comm-thread-info { flex:1; min-width:0; }
    .comm-thread-subject { font-size:0.85rem; font-weight:600; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .comm-thread-preview { font-size:0.76rem; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-top:0.15rem; }
    .comm-thread-meta { display:flex; align-items:center; gap:0.4rem; margin-top:0.3rem; }
    .comm-thread-date { font-size:0.7rem; color:var(--muted); margin-left:auto; flex-shrink:0; }
    .comm-status-pill { font-size:0.65rem; font-weight:700; padding:0.1rem 0.4rem; border-radius:3px; text-transform:uppercase; }
    .comm-right { flex:1; display:flex; flex-direction:column; min-width:0; }
    .comm-right-header { padding:0.85rem 1.25rem; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:1rem; flex-shrink:0; background:var(--shell); }
    .comm-right-subject { font-size:1rem; font-weight:700; color:var(--text); flex:1; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .comm-messages-area { flex:1; overflow-y:auto; min-height:0; padding:1.25rem; display:flex; flex-direction:column; gap:0.75rem; }
    .comm-bubble-wrap { display:flex; flex-direction:column; }
    .comm-bubble-wrap.staff { align-items:flex-start; }
    .comm-bubble-wrap.client { align-items:flex-end; }
    .comm-bubble-wrap.internal { align-items:flex-start; }
    .comm-bubble { max-width:75%; padding:0.6rem 0.9rem; border-radius:14px; font-size:0.9rem; line-height:1.5; word-break:break-word; }
    .comm-bubble.staff { background:var(--card); color:var(--text); border:1px solid var(--border); }
    .comm-bubble.client { background:var(--gold); color:#0f1117; }
    .comm-bubble.internal { background:rgba(201,168,76,0.08); color:var(--text); border:1px dashed rgba(201,168,76,0.4); }
    .comm-bubble-meta { font-size:0.68rem; color:var(--muted); margin-top:0.15rem; }
    .comm-msg-attachments { display:flex; flex-wrap:wrap; gap:0.35rem; margin-top:0.5rem; }
    .comm-attach-chip { display:inline-flex; align-items:center; gap:0.35rem; background:rgba(0,0,0,0.25); border:1px solid rgba(0,0,0,0.2); border-radius:6px; padding:0.25rem 0.6rem; font-size:0.73rem; color:#fff; text-decoration:none; cursor:pointer; font-weight:500; }
    .comm-attach-chip:hover { background:rgba(0,0,0,0.4); }
    .comm-compose-area { border-top:1px solid var(--border); padding:1rem 1.25rem; flex-shrink:0; background:var(--shell); }
    .comm-compose-toolbar { display:flex; align-items:center; gap:0.5rem; margin-bottom:0.6rem; flex-wrap:wrap; }
    .comm-toolbar-btn { background:transparent; border:1px solid var(--border); color:var(--muted); border-radius:4px; padding:0.2rem 0.5rem; font-size:0.78rem; cursor:pointer; transition:border-color 0.15s,color 0.15s; }
    .comm-toolbar-btn:hover { border-color:var(--gold); color:var(--gold); }
    .comm-reply-input { width:100%; background:var(--card); border:1px solid var(--border); border-radius:8px; color:var(--text); padding:0.7rem 0.9rem; font-size:0.88rem; resize:vertical; min-height:80px; outline:none; font-family:inherit; transition:border-color 0.15s; }
    .comm-reply-input:focus { border-color:var(--gold); }
    .comm-attach-preview { display:flex; flex-wrap:wrap; gap:0.35rem; margin-top:0.4rem; }
    .comm-compose-footer { display:flex; align-items:center; gap:0.75rem; margin-top:0.6rem; }
    .comm-internal-label { display:flex; align-items:center; gap:0.4rem; font-size:0.8rem; color:var(--muted); cursor:pointer; user-select:none; }
    .comm-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; flex:1; color:var(--muted); gap:0.5rem; }
    .comm-empty-icon { font-size:2.5rem; }
    @media(max-width:700px) { .comm-left { width:240px; } }
  </style>
  <div class="comm-layout">
    <!-- Left: thread list -->
    <div class="comm-left">
      <div class="comm-left-header">
        <h3>Messages</h3>
        <button class="btn btn-gold btn-sm" onclick="openNewThread()">+ New</button>
      </div>
      <div class="comm-thread-list-inner" id="comm-threads">
        <div class="loading-state"><div class="loading-spinner"></div></div>
      </div>
    </div>
    <!-- Right: thread detail or compose -->
    <div class="comm-right">
      <!-- Thread detail view -->
      <div id="comm-thread-detail" style="display:none;flex-direction:column;flex:1;min-height:0;">
        <div class="comm-right-header">
          <div class="comm-right-subject" id="comm-thread-subject">—</div>
          <select id="comm-status-select" onchange="updateThreadStatus()" style="font-size:0.78rem;background:var(--charcoal);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:0.25rem 0.5rem;flex-shrink:0;">
            <option value="open">Active</option>
            <option value="resolved">Resolved</option>
          </select>
        </div>
        <div class="comm-messages-area" id="comm-messages-list"></div>
        <div class="comm-compose-area">
          <textarea class="comm-reply-input" id="comm-reply-body" placeholder="Write a reply…" style="min-height:70px;max-height:160px;resize:none;"></textarea>
          <div class="comm-attach-preview" id="comm-attach-chips"></div>
          <input type="file" id="comm-attach-input" multiple style="display:none;" onchange="handleCommAttach(this.files)">
          <div class="comm-compose-footer">
            <button class="btn btn-gold btn-sm" onclick="sendReply()">Send Reply</button>
            <button class="comm-toolbar-btn" onclick="document.getElementById('comm-attach-input').click()">📎 Attach</button>
            <label class="comm-internal-label" style="margin-left:auto;">
              <input type="checkbox" id="comm-internal-toggle" style="cursor:pointer;">
              <span>Internal note</span>
            </label>
          </div>
        </div>
      </div>
      <!-- New thread compose view -->
      <div id="comm-compose" style="display:none;flex-direction:column;flex:1;min-height:0;">
        <div class="comm-right-header">
          <div class="comm-right-subject">New Message</div>
          <button class="btn btn-outline btn-sm" onclick="closeCompose()">Cancel</button>
        </div>
        <div style="padding:1.25rem;flex:1;min-height:0;display:flex;flex-direction:column;">
          <textarea id="comm-new-body" class="comm-reply-input" placeholder="Write your message…" style="flex:1;resize:none;min-height:0;"></textarea>
        </div>
        <div class="comm-compose-area">
          <div class="comm-compose-footer">
            <button class="btn btn-gold btn-sm" onclick="sendNewThread()">Send Message</button>
          </div>
        </div>
      </div>
      <!-- Empty state -->
      <div id="comm-empty-state" class="comm-empty">
        <div class="comm-empty-icon">💬</div>
        <div style="font-weight:600;color:var(--text);">No message selected</div>
        <div style="font-size:0.84rem;">Select a message or start a new one</div>
      </div>
    </div>
  </div>
</div>

<div id="tab-organizers" class="tab-content">
  <div style="max-width:700px;">
    <div class="card">
      <div class="card-title">Stanford Tax Organizer</div>
      <div id="org-stanford-link">
        <div style="color:var(--muted);font-size:0.86rem;">No Stanford Tax URL set. Edit the person to add one.</div>
      </div>
    </div>
  </div>
</div>

<div id="tab-workflow" class="tab-content">
  <div class="placeholder-section"><div class="ph-icon">⚙️</div><div class="ph-title">Pipelines</div><div class="ph-desc">Pipeline jobs for this person will appear here.</div></div>
</div>

<div id="tab-notes" class="tab-content">
  <div class="card" style="max-width:800px;margin:1.5rem;">
    <div class="card-title">Internal Notes</div>
    <textarea class="form-control" id="notes-ta-full" rows="12" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:0.75rem;">
      <button class="btn btn-gold btn-sm" onclick="autoSaveNotes(document.getElementById('notes-ta-full').value, true)">Save Notes</button>
      <div class="save-indicator" id="notes-saved-full"></div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay hidden" id="edit-modal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:520px;">
    <h2>Edit Person</h2>
    <div id="edit-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>First Name</label><input type="text" class="form-control" id="ef-fname"></div>
      <div class="form-group"><label>Last Name</label><input type="text" class="form-control" id="ef-lname"></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Email</label><input type="email" class="form-control" id="ef-email"></div>
      <div class="form-group"><label>Phone</label><input type="text" class="form-control" id="ef-phone"></div>
    </div>
    <div class="form-group"><label>Date of Birth</label><input type="date" class="form-control" id="ef-dob"></div>
    <div class="form-group"><label>Filing Status</label>
      <select class="form-control" id="ef-filing">
        <option value="">— Select —</option>
        <option value="single">Single</option><option value="married_joint">Married Filing Jointly</option>
        <option value="married_separate">Married Filing Separately</option><option value="head_household">Head of Household</option>
        <option value="widow">Qualifying Widow(er)</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const personId = location.pathname.split('/').pop();
  const token = localStorage.getItem('dl_token');
  if (!token) window.location.href = '/login';

  let personData = null;

  function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }; }
  async function apiFetch(url, opts = {}) {
    const res = await fetch(url, { ...opts, headers: { ...authHeaders(), ...(opts.headers||{}) } });
    if (res.status === 401) window.location.href = '/login';
    return res;
  }
  function esc(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  // Format phone as 239.297.2988 and wrap in tel: link
  function fmtPhone(raw) {
    if (!raw) return '—';
    const digits = raw.replace(/\D/g, '');
    let formatted = raw; // fallback to raw if can't parse
    if (digits.length === 10) {
      formatted = `${digits.slice(0,3)}.${digits.slice(3,6)}.${digits.slice(6)}`;
    } else if (digits.length === 11 && digits[0] === '1') {
      formatted = `${digits.slice(1,4)}.${digits.slice(4,7)}.${digits.slice(7)}`;
    }
    return `<a href="tel:${formatted}" style="color:var(--gold);text-decoration:none;">${esc(formatted)}</a>`;
  }

  // Format date_of_birth as mm/dd/yyyy
  function fmtDOB(raw) {
    if (!raw) return '—';
    // raw may be ISO date string like "1955-04-12" or "1955-04-12T00:00:00.000Z"
    const d = new Date(raw);
    if (isNaN(d)) return esc(raw);
    // Use UTC parts to avoid timezone shift
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const yyyy = d.getUTCFullYear();
    return `${mm}/${dd}/${yyyy}`;
  }
  function toast(msg, type='success') { window.toast(msg, type === 'error' ? 'error' : undefined); }

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax();
    if (name === 'communication') initComm(personData?.id || personId);
    if (name === 'organizers' && personData && personData.stanford_tax_url) {
      const el = document.getElementById('org-stanford-link');
      if (el) el.innerHTML = `<a href="${esc(personData.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">🔗 Open Stanford Tax Organizer →</a>`;
    }
    if (name === 'notes' && personData) document.getElementById('notes-ta-full').value = personData.notes || '';
  }

  async function loadPerson() {
    try {
      const res = await apiFetch(`/api/people/${personId}`);
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Not Found'; return; }
      personData = await res.json();
      renderHeader(personData);
      renderOverview(personData);
    } catch(e) {
      document.getElementById('entity-name').textContent = 'Error loading';
    }
  }

  function renderHeader(p) {
    const name = `${p.first_name || ''} ${p.last_name || ''}`.trim() || 'Unnamed';
    document.title = `${name} — DarkLion`;
    document.getElementById('entity-name').textContent = name;
    let html = `<span class="badge badge-muted">Person</span>`;
    if (p.filing_status) html += ` <span class="badge badge-muted">${esc(p.filing_status.replace(/_/g,' '))}</span>`;
    if (p.portal_enabled) html += ` <span class="badge badge-green">Portal Active</span>`;
    else if (p.portal_invite_token) html += ` <span class="badge badge-orange">Portal Invited</span>`;
    document.getElementById('entity-badges').innerHTML = html;
    const meta = [];
    if (p.relationship_name) meta.push(`👥 <a href="#" style="color:var(--gold);text-decoration:none;">${esc(p.relationship_name)}</a>`);
    if (p.email) meta.push(esc(p.email));
    if (p.phone) meta.push(fmtPhone(p.phone));
    document.getElementById('entity-meta').innerHTML = meta.join('  ·  ');
    // Track recent visit
    if (window.addRecentClient) window.addRecentClient({ _type:'person', id: p.id, _label: name, _sub: p.relationship_name || 'Person' });
  }

  function renderOverview(p) {
    document.getElementById('notes-ta').value = p.notes || '';
    const left = document.getElementById('overview-left');

    let html = `<div class="card">
      <div class="card-title">Contact Details</div>
      <div class="info-row"><span class="info-label">Email</span><span class="info-val">${p.email ? `<a href="mailto:${esc(p.email)}" style="color:var(--gold);">${esc(p.email)}</a>` : '—'}</span></div>
      <div class="info-row"><span class="info-label">Phone</span><span class="info-val">${fmtPhone(p.phone)}</span></div>
      <div class="info-row"><span class="info-label">Date of Birth</span><span class="info-val">${fmtDOB(p.date_of_birth)}</span></div>
      <div class="info-row"><span class="info-label">Filing Status</span><span class="info-val">${esc((p.filing_status||'—').replace(/_/g,' '))}</span></div>
      <div class="info-row"><span class="info-label">Relationship</span><span class="info-val">${esc(p.relationship_name || '—')}</span></div>
    </div>`;

    // Portal management
    html += `<div class="card">
      <div class="card-title">Client Portal</div>
      <div style="font-size:0.84rem;color:var(--muted);margin-bottom:0.75rem;">
        ${p.portal_enabled ? '✅ Portal active' : p.portal_invite_token ? '📧 Invite sent' : '⭕ Not set up'}
      </div>
      <div class="portal-btn-row">
        ${!p.portal_enabled ? `<button class="btn btn-gold btn-sm" onclick="sendPortalInvite()">Send Invite</button>` : ''}
        ${p.portal_enabled ? `<button class="btn btn-outline btn-sm" onclick="resetPortalPassword()">Reset Password</button>` : ''}
        ${p.portal_enabled ? `<button class="btn btn-outline btn-sm" onclick="disablePortal()">Disable Portal</button>` : ''}
      </div>
    </div>`;

    // Companies
    const companies = p.company_access || p.companies || [];
    if (companies.length) {
      html += `<div class="card"><div class="card-title">Companies</div>`;
      companies.forEach(c => {
        html += `<div class="person-row">
          <div class="person-info"><div class="person-name"><a href="/crm/company/${c.company_id}" style="color:var(--text);text-decoration:none;">🏢 ${esc(c.company_name)}</a></div></div>
          <button class="btn btn-ghost btn-xs" onclick="window.location.href='/crm/company/${c.company_id}'">→</button>
        </div>`;
      });
      html += `</div>`;
    }

    left.innerHTML = html;
  }

  // ── Docs: helpers ──
  function fileTypeBadge(mimeType, displayName) {
    const mime = (mimeType || '').toLowerCase();
    const name = (displayName || '').toLowerCase();
    const ext = name.includes('.') ? name.split('.').pop() : '';
    if (mime === 'application/pdf' || ext === 'pdf') return { label: 'PDF', color: '#e53e3e' };
    if (mime.includes('spreadsheet') || mime.includes('excel') || ext === 'xlsx' || ext === 'xls' || ext === 'csv')
      return { label: ext === 'csv' ? 'CSV' : 'Excel', color: '#38a169' };
    if (mime.includes('word') || ext === 'docx' || ext === 'doc')
      return { label: 'Word', color: '#3182ce' };
    if (mime.includes('presentation') || mime.includes('powerpoint') || ext === 'pptx' || ext === 'ppt')
      return { label: 'PPT', color: '#dd6b20' };
    if (mime.startsWith('image/') || ['jpg','jpeg','png','gif','webp','heic'].includes(ext))
      return { label: 'Image', color: '#805ad5' };
    if (mime.includes('zip') || ext === 'zip') return { label: 'ZIP', color: '#718096' };
    if (mime.startsWith('text/') || ext === 'txt') return { label: 'TXT', color: '#718096' };
    return { label: ext ? ext.toUpperCase().slice(0, 4) : 'FILE', color: '#718096' };
  }

  function fmtBytes(b) {
    if (!b) return '';
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }

  let docsData = [];
  const PERSON_CATS = [{ key: 'tax', label: 'Tax', icon: '🧾' }, { key: 'other', label: 'Other', icon: '📎' }];
  const DOCS_YEARS = (() => { const a = []; for (let y = new Date().getFullYear(); y >= 2018; y--) a.push(String(y)); return a; })();

  function buildDocsSection(docs, sectionKey, sectionTitle, sectionIcon) {
    const sectionDocs = docs.filter(d => (d.folder_section || 'firm_uploaded') === sectionKey);
    let s = `<div class="docs-col-title">${sectionIcon} ${sectionTitle} <span style="font-size:0.75rem;font-weight:400;color:var(--muted);">(${sectionDocs.length})</span></div>`;
    const recentYears = DOCS_YEARS.slice(0, 2);
    const prevYears = DOCS_YEARS.slice(2);

    function renderOneYear(yr) {
      const yrDocs = sectionDocs.filter(d => (d.year || '') === yr);
      const open = yrDocs.length > 0;
      let y = `<div class="year-folder${open ? ' open' : ''}" style="margin-bottom:0.4rem;">
        <div class="year-header"><span class="yr-label">📅 ${yr} <span class="yr-count">${yrDocs.length}</span></span><span class="yr-chevron">▼</span></div>
        <div class="year-body" style="padding-left:1rem;">`;
      PERSON_CATS.forEach(cat => {
        const catDocs = yrDocs.filter(d => (d.folder_category || 'other') === cat.key);
        y += `<div style="margin-bottom:0.5rem;"><div style="font-size:0.82rem;font-weight:700;color:var(--text);padding:0.4rem 0.5rem;margin-bottom:0.25rem;border-left:3px solid var(--gold);background:rgba(201,168,76,0.06);">${cat.icon} ${cat.label} <span style="font-size:0.72rem;font-weight:400;color:var(--muted);">(${catDocs.length})</span></div><div style="padding-left:0.5rem;">`;
        if (!catDocs.length) {
          y += `<div style="color:var(--muted);font-size:0.78rem;font-style:italic;padding:0.2rem 0;">Empty</div>`;
        } else {
          catDocs.forEach(doc => {
            const ftb = fileTypeBadge(doc.mime_type, doc.display_name);
            const statusBadge = sectionKey === 'firm_uploaded'
              ? `<span class="doc-badge doc-badge-viewed">✓ Delivered</span>`
              : `<span class="doc-badge doc-badge-client">✓ Uploaded</span>`;
            y += `<div class="doc-row" data-docid="${doc.id}"><span style="flex-shrink:0;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.65rem;font-weight:700;color:#fff;background:${ftb.color};letter-spacing:0.03em;">${ftb.label}</span><div class="doc-info"><div class="doc-name doc-name-link" data-docid="${doc.id}" style="cursor:pointer;text-decoration:underline;text-underline-offset:2px;">${esc(doc.display_name || 'Document')}</div><div class="doc-badges">${statusBadge}${doc.size_bytes ? `<span class="doc-badge doc-badge-type">${fmtBytes(doc.size_bytes)}</span>` : ''}</div></div><button class="btn-dl" data-docid="${doc.id}">⬇ Download</button></div>`;
          });
        }
        y += `</div></div>`;
      });
      y += `</div></div>`;
      return y;
    }

    recentYears.forEach(yr => { s += renderOneYear(yr); });
    const prevCount = prevYears.reduce((n, yr) => n + sectionDocs.filter(d => (d.year || '') === yr).length, 0);
    s += `<div class="year-folder" style="margin-bottom:0.4rem;">
      <div class="year-header"><span class="yr-label">📂 Prior Years <span class="yr-count">${prevCount}</span></span><span class="yr-chevron">▼</span></div>
      <div class="year-body" style="padding-left:0.5rem;">${prevYears.map(yr => renderOneYear(yr)).join('')}</div>
    </div>`;
    return s;
  }

  async function loadDocs() {
    const el = document.getElementById('docs-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading documents…</div></div>';
    try {
      const res = await apiFetch(`/api/documents?owner_type=person&owner_id=${personId}`);
      docsData = await res.json();
      renderDocs();
    } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load documents.</div>'; }
  }

  function renderDocs() {
    const el = document.getElementById('docs-content');
    el.innerHTML = `<div class="docs-layout">
      <div>${buildDocsSection(docsData, 'firm_uploaded', 'Delivered by Advisor', '📁')}</div>
      <div>${buildDocsSection(docsData, 'client_uploaded', 'Uploaded by Client', '📤')}</div>
    </div>`;
    // Wire year folder toggles
    el.querySelectorAll('.year-header').forEach(h => {
      h.addEventListener('click', () => h.closest('.year-folder').classList.toggle('open'));
    });
    // Wire doc name click to open
    el.querySelectorAll('.doc-name-link').forEach(nameEl => {
      nameEl.addEventListener('click', e => {
        e.stopPropagation();
        const btn = nameEl.closest('.doc-row').querySelector('.btn-dl');
        downloadDoc(parseInt(nameEl.dataset.docid), btn);
      });
    });
    // Wire download buttons
    el.querySelectorAll('.btn-dl').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        downloadDoc(parseInt(btn.dataset.docid), btn);
      });
    });
  }

  async function downloadDoc(id, btn) {
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    try {
      const res = await apiFetch(`/api/documents/${id}/url`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
    } catch(e) { toast('Failed to get download link', 'error'); }
    if (btn) { btn.disabled = false; btn.textContent = '⬇ Download'; }
  }

  // ── Upload modal wiring ──
  (function() {
    var modal     = document.getElementById('upload-modal');
    var yearSel   = document.getElementById('upload-year');
    var fileDrop  = document.getElementById('upload-file-drop');
    var fileInput = document.getElementById('upload-file-input');
    var submitBtn = document.getElementById('upload-submit-btn');
    var cancelBtn = document.getElementById('upload-cancel-btn');
    var errEl     = document.getElementById('upload-error');
    var msgEl     = document.getElementById('upload-msg');
    if (!modal) return;

    var _uploadFile = null;
    var CY = new Date().getFullYear();
    for (var y = CY; y >= 2018; y--) {
      var o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      if (y === CY - 1) o.selected = true;
      yearSel.appendChild(o);
    }

    function setFile(f) {
      _uploadFile = f;
      document.getElementById('upload-selected-name').textContent = f.name;
      submitBtn.disabled = false;
    }

    fileDrop.addEventListener('click', function() { fileInput.click(); });
    fileDrop.addEventListener('dragover', function(e) { e.preventDefault(); fileDrop.classList.add('drag-over'); });
    fileDrop.addEventListener('dragleave', function() { fileDrop.classList.remove('drag-over'); });
    fileDrop.addEventListener('drop', function(e) { e.preventDefault(); fileDrop.classList.remove('drag-over'); if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files[0]) setFile(fileInput.files[0]); });
    cancelBtn.addEventListener('click', function() { window.closeUploadModal(); });
    modal.addEventListener('click', function(e) { if (e.target === modal) window.closeUploadModal(); });

    submitBtn.addEventListener('click', async function() {
      if (!_uploadFile) return;
      submitBtn.disabled = true; submitBtn.textContent = 'Uploading…';
      errEl.style.display = 'none'; msgEl.style.display = 'none';
      try {
        var fd = new FormData();
        fd.append('file', _uploadFile);
        fd.append('owner_type', 'person');
        fd.append('owner_id', personId);
        fd.append('year', yearSel.value);
        fd.append('doc_type', document.getElementById('upload-doc-type').value);
        fd.append('folder_category', document.getElementById('upload-doc-type').value);
        fd.append('folder_section', document.getElementById('upload-section').value);
        var res = await fetch('/api/documents/upload', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token }, body: fd });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');
        msgEl.textContent = 'Uploaded!'; msgEl.style.display = 'block';
        var docEl = document.getElementById('docs-content');
        delete docEl.dataset.loaded;
        docsData = [];
        await loadDocs();
        setTimeout(function() { window.closeUploadModal(); toast('Document uploaded'); }, 800);
      } catch(e2) {
        errEl.textContent = e2.message; errEl.style.display = 'block';
        submitBtn.disabled = false; submitBtn.textContent = 'Upload';
      }
    });

    window.openUploadModal = function(preloadFile) {
      _uploadFile = null;
      document.getElementById('upload-selected-name').textContent = '';
      submitBtn.disabled = true; submitBtn.textContent = 'Upload';
      errEl.style.display = 'none'; msgEl.style.display = 'none';
      modal.classList.remove('hidden');
      if (preloadFile) setFile(preloadFile);
    };
    window.closeUploadModal = function() { modal.classList.add('hidden'); };
  })();

  // ── Page-wide drag-and-drop (opens upload modal when Docs tab active) ──
  (function() {
    var dragCounter = 0;
    var dragOverlay = document.createElement('div');
    dragOverlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(201,168,76,0.08);border:3px dashed var(--gold);pointer-events:none;align-items:center;justify-content:center;font-size:1.5rem;color:var(--gold);font-weight:700;';
    dragOverlay.textContent = '📄 Drop to upload document';
    document.body.appendChild(dragOverlay);

    function isDocsTabActive() {
      var t = document.getElementById('tab-docs');
      return t && t.classList.contains('active');
    }

    document.addEventListener('dragenter', function(e) {
      if (!isDocsTabActive()) return;
      dragCounter++;
      dragOverlay.style.display = 'flex';
    });
    document.addEventListener('dragleave', function(e) {
      if (!isDocsTabActive()) return;
      dragCounter--;
      if (dragCounter <= 0) { dragCounter = 0; dragOverlay.style.display = 'none'; }
    });
    document.addEventListener('dragover', function(e) {
      if (!isDocsTabActive()) return;
      e.preventDefault();
    });
    document.addEventListener('drop', function(e) {
      if (!isDocsTabActive()) return;
      e.preventDefault();
      dragCounter = 0;
      dragOverlay.style.display = 'none';
      var file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (!file) return;
      window.openUploadModal(file);
    });
  })();

  async function autoSaveNotes(val, force) {
    try {
      await apiFetch(`/api/people/${personId}`, { method: 'PUT', body: JSON.stringify({ notes: val }) });
      const ind = document.getElementById('notes-saved-full') || document.getElementById('notes-saved');
      if (ind) { ind.textContent = '✓ Saved'; setTimeout(() => { ind.textContent = ''; }, 2000); }
      if (personData) personData.notes = val;
    } catch(e) { toast('Failed to save notes', 'error'); }
  }

  function openEditModal() {
    if (!personData) return;
    document.getElementById('ef-fname').value = personData.first_name || '';
    document.getElementById('ef-lname').value = personData.last_name || '';
    document.getElementById('ef-email').value = personData.email || '';
    document.getElementById('ef-phone').value = personData.phone || '';
    document.getElementById('ef-dob').value = personData.date_of_birth || '';
    document.getElementById('ef-filing').value = personData.filing_status || '';
    document.getElementById('edit-modal').classList.remove('hidden');
  }
  function closeModal() { document.getElementById('edit-modal').classList.add('hidden'); }

  async function submitEdit() {
    const body = {
      first_name: document.getElementById('ef-fname').value.trim(),
      last_name: document.getElementById('ef-lname').value.trim(),
      email: document.getElementById('ef-email').value.trim(),
      phone: document.getElementById('ef-phone').value.trim(),
      date_of_birth: document.getElementById('ef-dob').value || null,
      filing_status: document.getElementById('ef-filing').value,
    };
    try {
      const res = await apiFetch(`/api/people/${personId}`, { method: 'PUT', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error||'Failed'); }
      closeModal();
      toast('Person updated');
      await loadPerson();
    } catch(e) { document.getElementById('edit-error').textContent = e.message; document.getElementById('edit-error').style.display = ''; }
  }

  async function sendPortalInvite() {
    try {
      const res = await apiFetch('/portal-auth/send-invite', { method: 'POST', body: JSON.stringify({ person_id: parseInt(personId) }) });
      if (!res.ok) throw new Error((await res.json()).error || 'Failed');
      toast('Invite sent');
      await loadPerson();
    } catch(e) { toast(e.message, 'error'); }
  }

  async function resetPortalPassword() {
    try {
      const res = await apiFetch(`/api/people/${personId}/portal-reset`, { method: 'POST', body: '{}' });
      if (!res.ok) throw new Error((await res.json()).error || 'Failed');
      toast('Password reset email sent');
    } catch(e) { toast(e.message, 'error'); }
  }

  async function disablePortal() {
    if (!confirm('Disable portal access for this person?')) return;
    try {
      const res = await apiFetch(`/api/people/${personId}/portal-disable`, { method: 'POST', body: '{}' });
      if (!res.ok) throw new Error((await res.json()).error || 'Failed');
      toast('Portal disabled');
      await loadPerson();
    } catch(e) { toast(e.message, 'error'); }
  }

  // ── Tax delivery JS ──
  function statusPill(status) {
    return `<span class="status-pill status-${status}" style="display:inline-block;padding:0.15rem 0.5rem;border-radius:20px;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;background:rgba(201,168,76,0.12);color:var(--gold);">${(status||'draft').replace(/_/g,' ')}</span>`;
  }

  function renderTaxDeliveries(deliveries) {
    const el = document.getElementById('tax-content');
    if (!deliveries.length) {
      el.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--muted);">
        <div style="font-size:2.5rem;margin-bottom:1rem;">📄</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:0.5rem;">No tax deliveries yet</div>
        <div style="font-size:0.84rem;margin-bottom:1.5rem;">Create a delivery to send the tax return for review and e-signature</div>
        <button class="btn btn-gold" onclick="openPersonDeliveryModal()">+ New Delivery</button>
      </div>`;
      return;
    }
    el.innerHTML = deliveries.map(d => {
      const signers = d.signers || [];
      const signerChips = signers.map(s => {
        const name = esc(s.person_name || ('Person #' + s.person_id));
        if (s.signed_at) return '<span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.72rem;background:rgba(62,207,142,0.1);color:var(--green);border:1px solid rgba(62,207,142,0.25);">✓ ' + name + '</span>';
        return '<span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.72rem;background:rgba(237,137,54,0.1);color:var(--orange);border:1px solid rgba(237,137,54,0.25);">⏳ ' + name + '</span>';
      }).join(' ');
      return `<div style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:1.25rem;margin-bottom:0.75rem;display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <div>
          <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.25rem;">${esc(d.title || d.tax_year + ' Tax Return')} ${statusPill(d.status)}</div>
          <div style="font-size:0.78rem;color:var(--muted);margin-bottom:0.4rem;">Tax Year: ${esc(d.tax_year)}${d.company_name ? ' · ' + esc(d.company_name) : ''} · Created ${new Date(d.created_at).toLocaleDateString()}</div>
          ${signerChips ? `<div style="display:flex;gap:0.35rem;flex-wrap:wrap;">${signerChips}</div>` : ''}
        </div>
        <div style="display:flex;gap:0.5rem;flex-shrink:0;">
          ${d.status === 'draft' ? `<button class="btn btn-gold btn-sm" onclick="personSendDelivery(${d.id})">Send →</button>` : ''}
          ${d.status === 'draft' ? `<button class="btn btn-outline btn-sm" onclick="personDeleteDelivery(${d.id})">Delete</button>` : ''}
          ${d.status === 'complete' ? `<button class="btn btn-outline btn-sm" onclick="personDownloadSigned(${d.id})">⬇ Signed</button>` : ''}
        </div>
      </div>`;
    }).join('');
  }

  async function loadTax() {
    const el = document.getElementById('tax-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/tax-deliveries?person_id=${personId}`);
      const deliveries = await res.json();
      renderTaxDeliveries(deliveries);
    } catch(e) { el.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Failed to load.</div>'; }
  }

  let _pdAllDocs = [];
  async function openPersonDeliveryModal() {
    const modal = document.getElementById('person-delivery-modal');
    // Populate year dropdown
    const yearSel = document.getElementById('pd-year');
    const cy = new Date().getFullYear();
    yearSel.innerHTML = '';
    for (let y = cy - 1; y >= cy - 6; y--) {
      const o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      yearSel.appendChild(o);
    }
    yearSel.value = String(cy - 1);
    const titleEl = document.getElementById('pd-title'); if (titleEl) titleEl.value = String(cy - 1) + ' Tax Return Delivery';

    // Load personal docs for this person
    _pdAllDocs = [];
    try {
      const res = await apiFetch(`/api/documents?owner_type=person&owner_id=${personId}`);
      _pdAllDocs = await res.json();
      pdFilterDocsByYear();
    } catch(e) { _pdAllDocs = []; }
    document.getElementById('pd-error').style.display = 'none';
    document.getElementById('pd-error').style.display = 'none';
    modal.classList.remove('hidden');
  }

  function pdFilterDocsByYear() {
    const year = document.getElementById('pd-year').value;
    const filtered = _pdAllDocs.filter(d =>
      (d.year || '') === year &&
      (d.folder_section === 'firm_uploaded' || !d.folder_section) &&
      (d.folder_category === 'tax') &&
      d.mime_type && d.mime_type.includes('pdf')
    );
    const opts = filtered.length
      ? '<option value="">— None —</option>' + filtered.map(d => `<option value="${d.id}">${esc(d.display_name || 'Untitled')}</option>`).join('')
      : '<option value="">— No Tax PDFs for ' + year + ' —</option>';
    document.getElementById('pd-review-doc').innerHTML = opts;
    document.getElementById('pd-sig-doc').innerHTML = opts;
  }

  document.addEventListener('change', function(e) {
    if (e.target.id === 'pd-year') pdFilterDocsByYear();
  });

  function closePersonDeliveryModal() { document.getElementById('person-delivery-modal').classList.add('hidden'); }

  async function submitPersonDelivery() {
    const year = document.getElementById('pd-year').value.trim();
    if (!year) { document.getElementById('pd-error').textContent = 'Tax year is required'; document.getElementById('pd-error').style.display = ''; return; }
    const body = {
      company_id: null,
      person_id: parseInt(personId),
      tax_year: year,
      title: document.getElementById('pd-title').value.trim(),
      intro_note: document.getElementById('pd-intro').value.trim(),
      review_doc_id: document.getElementById('pd-review-doc').value ? parseInt(document.getElementById('pd-review-doc').value) : null,
      signature_doc_id: document.getElementById('pd-sig-doc').value ? parseInt(document.getElementById('pd-sig-doc').value) : null,
      signer_person_ids: [parseInt(personId)],
    };
    try {
      const res = await apiFetch('/api/tax-deliveries', { method: 'POST', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      closePersonDeliveryModal();
      toast('Delivery created');
      const el = document.getElementById('tax-content');
      delete el.dataset.loaded;
      loadTax();
    } catch(e) { document.getElementById('pd-error').textContent = e.message; document.getElementById('pd-error').style.display = ''; }
  }

  async function personSendDelivery(id) {
    if (!confirm('Send this tax return to the client for review and signature?')) return;
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/send', { method: 'POST', body: '{}' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Delivery sent to client');
      const el = document.getElementById('tax-content'); delete el.dataset.loaded; loadTax();
    } catch(e) { toast(e.message, 'error'); }
  }

  async function personDeleteDelivery(id) {
    if (!confirm('Delete this draft delivery?')) return;
    try {
      await apiFetch('/api/tax-deliveries/' + id, { method: 'DELETE' });
      toast('Deleted');
      const el = document.getElementById('tax-content'); delete el.dataset.loaded; loadTax();
    } catch(e) { toast(e.message, 'error'); }
  }

  async function personDownloadSigned(id) {
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/download-signature');
      const d = await res.json();
      if (d.url) window.open(d.url, '_blank');
    } catch(e) { toast('Failed to download', 'error'); }
  }

  // ── Communication JS ──
  let commPersonId = null;
  let commActiveThreadId = null;
  let commAttachFiles = [];

  function initComm(pid) {
    if (!pid) { console.error('[comm] initComm called with no personId'); return; }
    if (commPersonId === pid) return; // already initialized for this person
    commPersonId = pid;
    commActiveThreadId = null;
    commShowEmpty();
    loadThreads();
  }

  function commShowEmpty() {
    document.getElementById('comm-thread-detail').style.display = 'none';
    document.getElementById('comm-compose').style.display = 'none';
    document.getElementById('comm-empty-state').style.display = 'flex';
  }
  function commShowDetail() {
    document.getElementById('comm-thread-detail').style.display = 'flex';
    document.getElementById('comm-compose').style.display = 'none';
    document.getElementById('comm-empty-state').style.display = 'none';
  }
  function commShowCompose() {
    document.getElementById('comm-thread-detail').style.display = 'none';
    document.getElementById('comm-compose').style.display = 'flex';
    document.getElementById('comm-empty-state').style.display = 'none';
  }

  function commInitials(name) {
    return (name||'?').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) || '?';
  }

  async function loadThreads() {
    const el = document.getElementById('comm-threads');
    if (!el) return;
    if (!commPersonId) { el.innerHTML = '<div style="color:var(--muted);padding:1rem;font-size:0.84rem;">No person ID.</div>'; return; }
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
    try {
      const res = await apiFetch(`/api/messages/person/${commPersonId}`);
      if (!res.ok) { const err = await res.json().catch(()=>({})); throw new Error(err.error || `HTTP ${res.status}`); }
      const threads = await res.json();
      if (!threads.length) {
        el.innerHTML = '<div style="color:var(--muted);font-size:0.84rem;padding:1.5rem 1rem;text-align:center;">No messages yet.</div>';
        return;
      }
      el.innerHTML = threads.map(t => {
        const initials = commInitials(t.lastSenderName || t.subject || '?');
        const statusColors = { open:'#3ecf8e', waiting:'#ed8936', resolved:'#718096' };
        const sc = statusColors[t.status] || '#718096';
        return `<div class="comm-thread-item" id="comm-item-${t.id}" onclick="loadThread(${t.id})">
          <div class="comm-avatar">${initials}</div>
          <div class="comm-thread-info">
            <div class="comm-thread-subject">${esc(t.subject || '(no subject)')}${t.unreadCount > 0 ? ` <span style="background:var(--gold);color:var(--navy);border-radius:10px;padding:0.05rem 0.35rem;font-size:0.65rem;font-weight:700;margin-left:0.3rem;">${t.unreadCount}</span>` : ''}</div>
            <div class="comm-thread-preview">${esc(t.lastPreview || '')}</div>
            <div class="comm-thread-meta">
              <span class="comm-status-pill" style="background:${sc};color:#fff;">${t.status}</span>
              <span class="comm-thread-date">${relTime(t.lastMessageAt)}</span>
            </div>
          </div>
        </div>`;
      }).join('');
    } catch(e) {
      console.error('[comm] loadThreads error:', e);
      el.innerHTML = `<div style="color:#e55;font-size:0.84rem;padding:1rem;">Failed to load messages: ${e.message}</div>`;
    }
  }

  async function loadThread(threadId) {
    commActiveThreadId = threadId;
    // Mark active
    document.querySelectorAll('.comm-thread-item').forEach(el => el.classList.remove('active'));
    const item = document.getElementById('comm-item-' + threadId);
    if (item) item.classList.add('active');
    commShowDetail();
    document.getElementById('comm-messages-list').innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
    try {
      const res = await apiFetch(`/api/messages/${threadId}`);
      const data = await res.json();
      document.getElementById('comm-thread-subject').textContent = data.subject || '(no subject)';
      document.getElementById('comm-status-select').value = data.status;
      const msgEl = document.getElementById('comm-messages-list');
      if (!data.messages || !data.messages.length) {
        msgEl.innerHTML = '<div style="color:var(--muted);text-align:center;padding:2rem;">No messages in this thread.</div>';
        return;
      }
      msgEl.innerHTML = data.messages.map(m => {
        const isInternal = m.isInternal;
        const isStaff = m.senderType === 'staff';
        const side = isInternal ? 'internal' : isStaff ? 'staff' : 'client';
        const attachmentsHtml = (m.attachments || []).length > 0
          ? `<div class="comm-msg-attachments">${m.attachments.map(a => {
              const size = a.sizeBytes ? ' · ' + commFormatBytes(a.sizeBytes) : '';
              return `<a href="#" class="comm-attach-chip" onclick="commDownloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}${esc(size)}</a>`;
            }).join('')}</div>`
          : '';
        return `<div class="comm-bubble-wrap ${side}">
          ${isInternal ? '<div style="font-size:0.68rem;color:var(--gold);font-weight:600;margin-bottom:0.2rem;">🔒 Internal note</div>' : ''}
          <div class="comm-bubble ${side}">${esc(m.body || '')}${attachmentsHtml}</div>
          <div class="comm-bubble-meta">${esc(m.senderName || '')} · ${relTime(m.createdAt)}</div>
        </div>`;
      }).join('');
      // Scroll to bottom after paint
      requestAnimationFrame(() => { msgEl.scrollTop = msgEl.scrollHeight; });
    } catch(e) {
      document.getElementById('comm-messages-list').innerHTML = '<div style="color:var(--muted);padding:1rem;">Failed to load thread.</div>';
    }
  }

  function commFormatBytes(b) {
    if (!b) return '0 B';
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
    return (b/1048576).toFixed(1) + ' MB';
  }

  function handleCommAttach(fileList) {
    for (const f of Array.from(fileList)) {
      if (commAttachFiles.length >= 8) { alert('Maximum 8 files per message'); break; }
      commAttachFiles.push(f);
    }
    document.getElementById('comm-attach-input').value = '';
    renderCommAttachChips();
  }

  function removeCommAttachFile(idx) {
    commAttachFiles.splice(idx, 1);
    renderCommAttachChips();
  }

  function renderCommAttachChips() {
    const el = document.getElementById('comm-attach-chips');
    if (!el) return;
    el.innerHTML = commAttachFiles.map((f, i) =>
      `<span style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:4px;padding:0.15rem 0.5rem;font-size:0.75rem;color:var(--text);">📎 ${esc(f.name)} <button onclick="removeCommAttachFile(${i})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.8rem;padding:0;line-height:1;">×</button></span>`
    ).join('');
  }

  async function commDownloadAttachment(documentId) {
    try {
      const res = await apiFetch(`/api/messages/attachments/${documentId}/download`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
      else alert('Download failed');
    } catch(e) { alert('Failed to download attachment'); }
  }

  async function sendReply() {
    const body = document.getElementById('comm-reply-body').value.trim();
    if (!commActiveThreadId) { toast('No thread selected', 'error'); return; }
    if (!body && commAttachFiles.length === 0) return;
    const isInternal = document.getElementById('comm-internal-toggle').checked;
    try {
      const fd = new FormData();
      fd.append('body', body);
      fd.append('is_internal', isInternal ? 'true' : 'false');
      commAttachFiles.forEach(f => fd.append('files', f));
      await apiFetch(`/api/messages/${commActiveThreadId}/reply`, { method: 'POST', body: fd });
      document.getElementById('comm-reply-body').value = '';
      document.getElementById('comm-internal-toggle').checked = false;
      commAttachFiles = [];
      renderCommAttachChips();
      await loadThread(commActiveThreadId);
      await loadThreads();
    } catch(e) { console.error('[comm] sendReply error:', e); toast('Failed to send reply: ' + e.message, 'error'); }
  }

  async function updateThreadStatus() {
    if (!commActiveThreadId) return;
    const status = document.getElementById('comm-status-select').value;
    await apiFetch(`/api/messages/${commActiveThreadId}/status`, { method: 'PUT', body: JSON.stringify({ status }) });
    await loadThreads();
  }

  function openNewThread() {
    commShowCompose();
    document.getElementById('comm-new-body').value = '';
  }

  function closeCompose() {
    commShowEmpty();
  }

  async function sendNewThread() {
    const body = document.getElementById('comm-new-body').value.trim();
    if (!body) { toast('Message body is required', 'error'); return; }
    try {
      const res = await apiFetch('/api/messages', { method: 'POST', body: JSON.stringify({ person_id: commPersonId, subject: '', body, is_internal: false }) });
      const data = await res.json();
      closeCompose();
      await loadThreads();
      if (data.threadId) loadThread(data.threadId);
      toast('Message sent');
    } catch(e) { toast('Failed to send message', 'error'); }
  }

  function statusColor(s) {
    if (s === 'open') return '#c9a84c';
    if (s === 'waiting') return '#4a90d9';
    if (s === 'resolved') return '#4caf50';
    return '#666';
  }

  function relTime(ts) {
    if (!ts) return '';
    const d = new Date(ts); const diff = Date.now() - d;
    if (diff < 60000) return 'just now';
    if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
    if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
    return d.toLocaleDateString();
  }


  loadPerson();
</script>

<%- include('partials/shell-close') %>
