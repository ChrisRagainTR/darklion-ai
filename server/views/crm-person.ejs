  async function loadThreads() {
    if (!commPersonId) return;
    try {
      const res = await apiFetch(`/api/messages/person/${commPersonId}`);
      if (!res.ok) return;
      const threads = await res.json();
      if (threads.length && !commActiveThreadId) {
        // Auto-open the most recent thread (no list panel — always single thread view)
        await loadThread(threads[0].id);
      } else if (!threads.length) {
        commShowEmpty();
        document.getElementById('comm-no-thread').innerHTML = '<div class="nts-icon">💬</div><div style="color:var(--muted);">No messages yet.</div>';
      }
    } catch(e) {
      console.error('[comm] loadThreads error:', e);
    }
  }

  async function loadThread(threadId, silent = false) {
    commActiveThreadId = threadId;
    // Mark active
    document.querySelectorAll('#comm-threads .thread-card').forEach(el => el.classList.remove('active'));
    const item = document.getElementById('comm-item-' + threadId);
    if (item) item.classList.add('active');
    if (!silent) {
      document.getElementById('comm-detail-messages').innerHTML = '<div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>';
      document.getElementById('comm-detail-header').innerHTML = '';
    }
    commShowDetail();
    try {
      const res = await apiFetch(`/api/messages/${threadId}`);
      const data = await res.json();

      // Header — same as team inbox
      document.getElementById('comm-detail-header').innerHTML = `
        <div class="detail-header-person">${esc((data.person?.firstName||'')+' '+(data.person?.lastName||''))}</div>
        <div class="detail-header-subject">${esc(data.subject || '(no subject)')} · <span style="color:var(--gold);font-size:0.75rem;">${data.category || ''}</span></div>`;

      // Messages — same render as team inbox
      const msgEl = document.getElementById('comm-detail-messages');
      const msgs = data.messages || [];

      function buildCommBubble(m) {
        const isInternal = m.isInternal;
        const isStaff = m.senderType === 'staff';
        const side = isInternal ? 'internal' : isStaff ? 'staff' : 'client';
        const bubbleClass = isInternal ? 'internal' : side;
        const attachmentsHtml = (m.attachments||[]).length > 0
          ? `<div class="msg-attachments">${m.attachments.map(a => {
              const size = a.sizeBytes ? ` <span style="font-size:0.7rem;opacity:0.7;">(${commFormatBytes(a.sizeBytes)})</span>` : '';
              return `<a href="#" class="attachment-chip" onclick="commDownloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}${size}</a>`;
            }).join('')}</div>` : '';
        return `<div class="msg-bubble-wrap ${side}" data-msg-id="${m.id}">
          ${isInternal ? '<div class="msg-internal-label">🔒 Internal note</div>' : ''}
          <div class="msg-bubble ${bubbleClass}">${esc(m.body||'').replace(/\n/g,'<br>')}${attachmentsHtml}</div>
          <div class="msg-meta">${esc(m.senderName||'')} · ${relTime(m.createdAt)}</div>
        </div>`;
      }

      if (!msgs.length) {
        if (!silent) msgEl.innerHTML = '<div style="color:var(--muted);text-align:center;padding:2rem;">No messages yet.</div>';
      } else if (silent) {
        // Append-only — only add new messages
        const existingIds = new Set([...msgEl.querySelectorAll('[data-msg-id]')].map(el => parseInt(el.dataset.msgId)));
        let appended = false;
        for (const m of msgs) {
          if (!existingIds.has(m.id)) { msgEl.insertAdjacentHTML('beforeend', buildCommBubble(m)); appended = true; }
        }
        if (appended) msgEl.scrollTop = msgEl.scrollHeight;
      } else {
        msgEl.innerHTML = msgs.map(buildCommBubble).join('');
        msgEl.scrollTop = msgEl.scrollHeight;
      }
    } catch(e) {
      document.getElementById('comm-detail-messages').innerHTML = '<div style="color:var(--muted);padding:1rem;">Failed to load thread.</div>';
    }
  }

  function commFormatBytes(b) {
    if (!b) return '0 B';
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
    return (b/1048576).toFixed(1) + ' MB';
  }

    function handleCommAttach(fileList) {
    for (const f of Array.from(fileList)) {
      if (commAttachFiles.length >= 8) { alert('Maximum 8 files per message'); break; }
      commAttachFiles.push(f);
    }
    document.getElementById('comm-attach-input').value = '';
    renderCommAttachChips();
  }

  function handleNewCommAttach(fileList) {
    for (const f of Array.from(fileList)) {
      if (commNewAttachFiles.length >= 8) { alert('Maximum 8 files per message'); break; }
      commNewAttachFiles.push(f);
    }
    document.getElementById('comm-new-attach-input').value = '';
    renderNewCommAttachChips();
  }

  function removeNewCommAttachFile(idx) {
    commNewAttachFiles.splice(idx, 1);
    renderNewCommAttachChips();
  }

  function renderNewCommAttachChips() {
    const el = document.getElementById('comm-new-attach-chips');
    if (!el) return;
    el.innerHTML = commNewAttachFiles.map((f, i) =>
      `<span style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:4px;padding:0.15rem 0.5rem;font-size:0.75rem;color:var(--text);">📎 ${esc(f.name)} <button onclick="removeNewCommAttachFile(${i})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.8rem;padding:0;line-height:1;">×</button></span>`
    ).join('');
  }

  function removeCommAttachFile(idx) {
    commAttachFiles.splice(idx, 1);
    renderCommAttachChips();
  }

  function renderCommAttachChips() {
    const el = document.getElementById('comm-attach-chips');
    if (!el) return;
    el.innerHTML = commAttachFiles.map((f, i) =>
      `<span style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(255,255,255,0.07);border:1px solid var(--border);border-radius:4px;padding:0.15rem 0.5rem;font-size:0.75rem;color:var(--text);">📎 ${esc(f.name)} <button onclick="removeCommAttachFile(${i})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.8rem;padding:0;line-height:1;">×</button></span>`
    ).join('');
  }

  async function commDownloadAttachment(documentId) {
    try {
      const res = await apiFetch(`/api/messages/attachments/${documentId}/download`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
      else alert('Download failed');
    } catch(e) { alert('Failed to download attachment'); }
  }

  // Wire SMS toggle to update button label
  document.addEventListener('change', function(e) {
    if (e.target.id === 'comm-sms-toggle') {
      const btn = document.getElementById('comm-send-reply-btn');
      if (btn) btn.textContent = e.target.checked ? '📱 Send Text' : 'Send Reply';
    }
    if (e.target.id === 'comm-internal-toggle' && e.target.checked) {
      // Internal note can't be SMS
      const smsToggle = document.getElementById('comm-sms-toggle');
      if (smsToggle) smsToggle.checked = false;
      const btn = document.getElementById('comm-send-reply-btn');
      if (btn) btn.textContent = 'Send Reply';
    }
  });

  async function commSendAsSms() {
    const toggle = document.getElementById('comm-sms-toggle');
    if (toggle) toggle.checked = true;
    await commSendReply();
    if (toggle) toggle.checked = false;
  }

  async function commSendReply() {
    const body = document.getElementById('comm-reply-body').value.trim();
    if (!commActiveThreadId) { toast('No thread selected', 'error'); return; }
    if (!body && commAttachFiles.length === 0) return;
    const isInternal = document.getElementById('comm-internal-toggle').checked;
    const isSms = document.getElementById('comm-sms-toggle')?.checked && !isInternal;

    if (isSms) {
      // Send as SMS via Twilio
      try {
        const res = await apiFetch('/api/messages/sms', {
          method: 'POST',
          body: JSON.stringify({ person_id: personId, body, thread_id: commActiveThreadId })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to send SMS');
        document.getElementById('comm-reply-body').value = '';
        // Use returned thread_id in case a new thread was created
        const useThreadId = data.thread_id || commActiveThreadId;
        if (useThreadId !== commActiveThreadId) {
          commActiveThreadId = useThreadId;
          await loadThreads();
          await loadThread(useThreadId, false);
        } else {
          await loadThread(useThreadId, true);
          await loadThreads();
        }
        toast('Text message sent ✓');
      } catch(e) { toast(e.message, 'error'); }
      return;
    }

    try {
      const fd = new FormData();
      fd.append('body', body);
      fd.append('is_internal', isInternal ? 'true' : 'false');
      commAttachFiles.forEach(f => fd.append('files', f));
      const replyRes = await apiFetch(`/api/messages/${commActiveThreadId}/reply`, { method: 'POST', body: fd });
      if (!replyRes.ok) {
        const errData = await replyRes.json().catch(() => ({}));
        throw new Error(errData.error || `Server error ${replyRes.status}`);
      }
      document.getElementById('comm-reply-body').value = '';
      document.getElementById('comm-internal-toggle').checked = false;
      commAttachFiles = [];
      renderCommAttachChips();
      await loadThread(commActiveThreadId, false); // full reload so new message is guaranteed visible
      await loadThreads();
    } catch(e) { console.error('[comm] sendReply error:', e); toast('Failed to send reply: ' + e.message, 'error'); }
  }

  async function commArchive() {
    if (!commActiveThreadId) return;
    await apiFetch(`/api/messages/${commActiveThreadId}/archive`, { method: 'PUT' });
    commShowEmpty();
    commActiveThreadId = null;
    await loadThreads();
  }

  async function commSendNew() {
    const body = document.getElementById('comm-new-body').value.trim();
    if (!body && commNewAttachFiles.length === 0) { toast('Message body is required', 'error'); return; }
    try {
      // Create thread first
      const res = await apiFetch('/api/messages', { method: 'POST', body: JSON.stringify({ person_id: commPersonId, subject: '', body, is_internal: false }) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      // Send attachments as a reply if any
      if (commNewAttachFiles.length > 0 && data.threadId) {
        const fd = new FormData();
        fd.append('body', '');
        commNewAttachFiles.forEach(f => fd.append('files', f));
        await apiFetch(`/api/messages/${data.threadId}/reply`, { method: 'POST', body: fd });
      }
      document.getElementById('comm-new-body').value = '';
      commNewAttachFiles = [];
      renderNewCommAttachChips();
      commCloseNew();
      await loadThreads();
      if (data.threadId) loadThread(data.threadId);
      toast('Message sent');
    } catch(e) { toast('Failed to send message', 'error'); }
  }

  function statusColor(s) {
    if (s === 'open') return '#c9a84c';
    if (s === 'waiting') return '#4a90d9';
    if (s === 'resolved') return '#4caf50';
    return '#666';
  }

  function relTime(ts) {
    if (!ts) return '';
    const d = new Date(ts); const diff = Date.now() - d;
    if (diff < 60000) return 'just now';
    if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
    if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
    return d.toLocaleDateString();
  }


  loadPerson().then(function() {
    var openTab = sessionStorage.getItem('openTab');
    sessionStorage.removeItem('openTab');
    if (openTab) {
      var tabEl = null;
      document.querySelectorAll('.tab-item').forEach(function(t) {
        if (t.getAttribute('onclick') && t.getAttribute('onclick').indexOf("'" + openTab + "'") !== -1) tabEl = t;
      });
      switchTab(openTab, tabEl);
    }
  });

  // ── SMS ──────────────────────────────────────────────────────────────────
  let _smsThreadId = null;

  async function openSmsModal(threadId) {
    _smsThreadId = threadId || null;
    const phoneDisplay = document.getElementById('sms-phone-display');
    if (phoneDisplay) {
      try {
        const r = await apiFetch(`/api/people/${personId}`);
        const p = await r.json();
        phoneDisplay.textContent = p.phone ? `To: ${p.phone}` : '⚠️ No phone number on file for this person';
        phoneDisplay.style.color = p.phone ? 'var(--muted)' : 'var(--red)';
      } catch(e) { phoneDisplay.textContent = 'Loading phone…'; }
    }
    document.getElementById('sms-body').value = '';
    document.getElementById('sms-char-count').textContent = '0 / 160';
    document.getElementById('sms-error').style.display = 'none';
    document.getElementById('sms-modal').classList.remove('hidden');
    setTimeout(() => document.getElementById('sms-body').focus(), 100);
  }

  function closeSmsModal() {
    document.getElementById('sms-modal').classList.add('hidden');
    _smsThreadId = null;
  }

  async function submitSms() {
    const body = document.getElementById('sms-body').value.trim();
    const btn = document.getElementById('sms-submit-btn');
    const errEl = document.getElementById('sms-error');
    if (!body) { errEl.textContent = 'Please enter a message.'; errEl.style.display = ''; return; }
    btn.disabled = true; btn.textContent = 'Sending…';
    errEl.style.display = 'none';
    try {
      const res = await apiFetch('/api/messages/sms', {
        method: 'POST',
        body: JSON.stringify({ person_id: personId, body, thread_id: _smsThreadId })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to send');
      closeSmsModal();
      toast('Text message sent ✓');
      if (typeof loadThreads === 'function') await loadThreads();
      if (data.thread_id && typeof loadThread === 'function') loadThread(data.thread_id);
    } catch(e) {
      errEl.textContent = e.message;
      errEl.style.display = '';
    } finally {
      btn.disabled = false; btn.textContent = 'Send Text';
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const smsBody = document.getElementById('sms-body');
    const smsCount = document.getElementById('sms-char-count');
    if (smsBody && smsCount) {
      smsBody.addEventListener('input', function() {
        const len = this.value.length;
        smsCount.textContent = `${len} / 160`;
        smsCount.style.color = len > 160 ? 'var(--red)' : 'var(--muted)';
      });
    }
  });
</script>

<!-- Tax Summary Modal -->
<div class="tax-summary-modal hidden" id="tax-summary-modal">
  <div class="tax-summary-box" onclick="event.stopPropagation()">
    <div class="tsm-header">
      <div>
        <h2 id="tsm-title">Tax Summary</h2>
        <div id="tsm-subtitle" style="font-size:0.8rem;color:rgba(255,255,255,0.65);margin-top:0.2rem;"></div>
      </div>
      <button class="tsm-close" onclick="closeTaxSummary()">✕</button>
    </div>
    <div class="tsm-body" id="tsm-body">
      <div class="tsm-processing">
        <div class="tsm-spinner"></div>
        <div>Analyzing return with Claude…</div>
        <div style="font-size:0.75rem;opacity:0.6;">This takes about 30–60 seconds</div>
      </div>
    </div>
    <div class="tsm-footer" id="tsm-footer" style="display:none;">
      <button class="btn btn-outline btn-sm" id="tsm-reanalyze-btn" onclick="retrySummary(_tsmPendingDeliveryId)" style="margin-right:auto;">↺ Re-analyze</button>
      <button class="btn btn-outline btn-sm" onclick="closeTaxSummary()">Close</button>
      <button class="btn btn-gold" id="tsm-send-btn" onclick="confirmAndSendDelivery()" style="display:none;">Send to Client →</button>
    </div>
  </div>
</div>

<!-- SMS Modal -->
<div class="modal-overlay hidden" id="sms-modal" onclick="closeSmsModal()">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:440px;">
    <h2>📱 Send Text Message</h2>
    <div id="sms-phone-display" style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem;"></div>
    <div class="form-group">
      <label>Message</label>
      <textarea class="form-control" id="sms-body" rows="4" placeholder="Type your SMS message… (160 chars recommended)" maxlength="1600" style="width:100%;box-sizing:border-box;"></textarea>
      <div id="sms-char-count" style="font-size:0.72rem;color:var(--muted);text-align:right;margin-top:0.25rem;">0 / 160</div>
    </div>
    <div id="sms-error" style="color:var(--red);font-size:0.82rem;display:none;margin-bottom:0.5rem;"></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeSmsModal()">Cancel</button>
      <button class="btn-submit" id="sms-submit-btn" onclick="submitSms()">Send Text</button>
    </div>
  </div>
</div>

