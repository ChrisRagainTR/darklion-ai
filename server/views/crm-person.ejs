        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.65rem 1rem;">${contactRowsHtml}</div>`;

    // ── LEFT COL: Client Portal ──
    const portalEl = document.getElementById('overview-portal-panel');
    portalEl.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Client Portal</div>
      <div style="font-size:0.84rem;color:var(--muted);margin-bottom:0.75rem;">
        ${p.portal_enabled ? '✅ Portal active' : p.portal_invite_token ? '📧 Invite sent' : '⭕ Not set up'}
      </div>
      <div class="portal-btn-row">
        ${!p.portal_enabled ? `<button class="btn btn-gold btn-sm" onclick="sendPortalInvite()">Send Invite</button>` : ''}
        ${p.portal_enabled ? `<button class="btn btn-outline btn-sm" onclick="resetPortalPassword()">Reset Password</button>` : ''}
        ${p.portal_enabled ? `<button class="btn btn-outline btn-sm" onclick="disablePortal()">Disable Portal</button>` : ''}
      </div>`;

    // ── CENTER COL: Spouse ──
    const spouseEl = document.getElementById('overview-spouse-panel');
    if (p.spouse) {
      const sp = p.spouse;
      const spInitials = ((sp.first_name||'').charAt(0)+(sp.last_name||'').charAt(0)).toUpperCase() || '?';
      spouseEl.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Spouse</div>
        <div style="background:var(--charcoal);border:1px solid var(--border);border-radius:8px;padding:0.75rem;display:flex;align-items:flex-start;gap:0.65rem;">
          <div style="width:38px;height:38px;border-radius:50%;background:rgba(201,168,76,0.18);color:var(--gold);font-weight:700;font-size:0.95rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">${spInitials}</div>
          <div style="flex:1;min-width:0;">
