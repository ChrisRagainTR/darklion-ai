  async function openEditDeliveryModal(deliveryId, currentReviewDocId, currentSigDocId, taxYear) {
    document.getElementById('ed-id').value = deliveryId;
    document.getElementById('ed-error').style.display = 'none';
    try {
      const res = await apiFetch(`/api/documents?owner_type=person&owner_id=${personId}`);
      const docs = await res.json();
      // Filter to tax PDFs matching the delivery's tax year (strict) — fall back to all tax PDFs if none match
      const taxPdfs = docs.filter(d =>
        (d.folder_category === 'tax' || d.doc_type === 'tax') &&
        ((d.mime_type||'').includes('pdf') || (d.display_name||'').toLowerCase().endsWith('.pdf'))
      );
      const yearFiltered = taxYear ? taxPdfs.filter(d => String(d.year||'') === String(taxYear)) : taxPdfs;
      const pdfDocs = yearFiltered.length ? yearFiltered : taxPdfs; // fall back if no year match
      const makeOpts = (selectedId) => '<option value="">— None —</option>' + pdfDocs.map(d =>
        `<option value="${d.id}" ${d.id == selectedId ? 'selected' : ''}>${esc(d.display_name||'Document')}</option>`
      ).join('');
      document.getElementById('ed-review-doc').innerHTML = makeOpts(currentReviewDocId);
      document.getElementById('ed-sig-doc').innerHTML = makeOpts(currentSigDocId);
    } catch(e) {}
    document.getElementById('edit-delivery-modal').classList.remove('hidden');
  }

