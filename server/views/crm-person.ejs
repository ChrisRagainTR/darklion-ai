  // ── Tax delivery JS ──
  function statusPill(status) {
    return `<span class="status-pill status-${status}" style="display:inline-block;padding:0.15rem 0.5rem;border-radius:20px;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;background:rgba(201,168,76,0.12);color:var(--gold);">${(status||'draft').replace(/_/g,' ')}</span>`;
  }

  function renderTaxDeliveries(deliveries) {
    const el = document.getElementById('tax-content');
    if (!deliveries.length) {
      el.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--muted);">
        <div style="font-size:2.5rem;margin-bottom:1rem;">📄</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:0.5rem;">No tax deliveries yet</div>
        <div style="font-size:0.84rem;margin-bottom:1.5rem;">Create a delivery to send the tax return for review and e-signature</div>
        <button class="btn btn-gold" onclick="openPersonDeliveryModal()">+ New Delivery</button>
      </div>`;
      return;
    }
    el.innerHTML = deliveries.map(d => {
      const signers = d.signers || [];
      const signerChips = signers.map(s => {
        const name = esc(s.person_name || ('Person #' + s.person_id));
        if (s.signed_at) return '<span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.72rem;background:rgba(62,207,142,0.1);color:var(--green);border:1px solid rgba(62,207,142,0.25);">✓ ' + name + '</span>';
        if (s.needs_changes_at) return '<span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.72rem;background:rgba(245,101,101,0.1);color:var(--red);border:1px solid rgba(245,101,101,0.3);">↩ ' + name + ' — Changes Requested</span>';
        return '<span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.72rem;background:rgba(237,137,54,0.1);color:var(--orange);border:1px solid rgba(237,137,54,0.25);">⏳ ' + name + '</span>';
      }).join(' ');
      // Show change request notes — check signer record first, fall back to delivery-level note
      const changeNoteText = (signers.find(s => s.needs_changes_note) || {}).needs_changes_note || d.needs_changes_note || '';
      const changeNoteAuthor = (signers.find(s => s.needs_changes_at) || {}).person_name || 'Client';
      const changeNotes = changeNoteText
        ? '<div style="margin-top:0.5rem;padding:0.6rem 0.85rem;background:rgba(245,101,101,0.07);border:1px solid rgba(245,101,101,0.2);border-radius:6px;font-size:0.82rem;">' +
            '<span style="font-weight:700;color:var(--red);">↩ ' + esc(changeNoteAuthor) + ':</span> ' +
            '<span style="color:var(--text);">' + esc(changeNoteText) + '</span>' +
          '</div>'
        : '';
      // Doc links for signed/sent deliveries
      const signedDocs = signers.filter(s => s.signed_doc_id).map(s =>
        `<button class="btn btn-outline btn-sm" onclick="downloadDeliveryDoc(${s.signed_doc_id})" title="Signed by ${esc(s.person_name)}">⬇ Signed (${esc((s.person_name||'').split(' ')[0])})</button>`
      ).join('');
      const reviewDocLink = d.review_doc_id && d.status !== 'draft'
        ? `<button class="btn btn-outline btn-sm" onclick="downloadDeliveryDoc(${d.review_doc_id})">📄 Review Copy</button>`
        : '';

      return `<div style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:1.25rem;margin-bottom:0.75rem;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:${(signedDocs||reviewDocLink)?'0.75rem':'0'}">
          <div>
            <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.25rem;">${esc(d.title || d.tax_year + ' Tax Return')} ${statusPill(d.status)}</div>
            <div style="font-size:0.78rem;color:var(--muted);margin-bottom:0.4rem;">Tax Year: ${esc(d.tax_year)}${d.company_name ? ' · ' + esc(d.company_name) : ''} · Created ${new Date(d.created_at).toLocaleDateString()}</div>
            ${signerChips ? `<div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-bottom:${changeNotes?'0.4rem':'0'}">${signerChips}</div>` : ''}
            ${changeNotes}
          </div>
          <div style="display:flex;gap:0.5rem;flex-shrink:0;flex-wrap:wrap;">
            ${d.status === 'draft' ? `<button class="btn btn-gold btn-sm" onclick="personSendDelivery(${d.id})">Send →</button>` : ''}
            ${d.status === 'draft' ? `<button class="btn btn-outline btn-sm" onclick="openEditDeliveryModal(${d.id},${d.review_doc_id||'null'},${d.sig_doc_id||d.signature_doc_id||'null'},${JSON.stringify(d.tax_year||'')})">✏️ Edit Docs</button>` : ''}
            ${d.status === 'draft' ? `<button class="btn btn-outline btn-sm" onclick="personDeleteDelivery(${d.id})">Delete</button>` : ''}
            ${['sent','approved','needs_changes'].includes(d.status) ? `<button class="btn btn-outline btn-sm" onclick="personCancelDelivery(${d.id})" style="color:var(--orange);border-color:var(--orange);">↩ Cancel & Revise</button>` : ''}
            ${d.review_doc_id ? `<button class="btn btn-outline btn-sm" onclick="openTaxSummary(${d.id})">📊 Tax Summary</button>` : ''}
          </div>
        </div>
        ${(signedDocs || reviewDocLink) ? `<div style="display:flex;gap:0.5rem;flex-wrap:wrap;padding-top:0.75rem;border-top:1px solid var(--border);">${reviewDocLink}${signedDocs}</div>` : ''}
      </div>`;
    }).join('');
  }

  async function loadTax(force) {
    const el = document.getElementById('tax-content');
    if (el.dataset.loaded && !force) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/tax-deliveries?person_id=${personId}`);
      const deliveries = await res.json();
      renderTaxDeliveries(deliveries);
    } catch(e) { el.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Failed to load.</div>'; }
  }

  let _pdAllDocs = [];
  async function openPersonDeliveryModal() {
    const modal = document.getElementById('person-delivery-modal');
    // Populate year dropdown
    const yearSel = document.getElementById('pd-year');
    const cy = new Date().getFullYear();
    yearSel.innerHTML = '';
    for (let y = cy - 1; y >= cy - 6; y--) {
      const o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      yearSel.appendChild(o);
    }
    yearSel.value = String(cy - 1);
    const titleEl = document.getElementById('pd-title'); if (titleEl) titleEl.value = String(cy - 1) + ' Tax Return Delivery';
    const introEl = document.getElementById('pd-intro');
    if (introEl && !introEl.value) {
      introEl.value = 'Dear Client,\n\nYour ' + String(cy - 1) + ' tax return has been prepared and is ready for your review. Please take a moment to carefully review all information for accuracy.\n\nOnce you have reviewed the return, you will have the opportunity to either approve it and provide your electronic signature, or request changes if anything needs to be corrected.\n\nIf you have any questions prior to signing, please don\'t hesitate to reach out to our office directly.\n\nThank you for trusting Sentinel Wealth & Tax with your tax preparation.';
    }

    // Load personal docs
    _pdAllDocs = [];
    try {
      const res = await apiFetch(`/api/documents?owner_type=person&owner_id=${personId}`);
      _pdAllDocs = await res.json();
      pdFilterDocsByYear();
    } catch(e) { _pdAllDocs = []; }

    // Load relationship members for signer selection
    const signersList = document.getElementById('pd-signers-list');
    signersList.innerHTML = '';
    try {
      if (personData && personData.relationship_id) {
        const relRes = await apiFetch(`/api/relationships/${personData.relationship_id}/people`);
        const relPeople = await relRes.json();
        relPeople.forEach(function(p) {
          const div = document.createElement('div');
          div.style.cssText = 'display:flex;align-items:center;gap:0.5rem;padding:0.35rem 0.5rem;background:rgba(255,255,255,0.03);border-radius:6px;';
          const checked = p.id == personId; // current person always checked
          div.innerHTML = '<input type="checkbox" class="pd-signer-cb" value="' + p.id + '"' + (checked ? ' checked' : '') + (checked ? ' disabled' : '') + ' style="cursor:pointer;width:16px;height:16px;accent-color:var(--gold);"> ' +
            '<label style="cursor:pointer;font-size:0.88rem;">' + esc((p.first_name || '') + ' ' + (p.last_name || '')) + (p.portal_enabled ? ' <span style="font-size:0.72rem;color:var(--green);">✓ Portal</span>' : ' <span style="font-size:0.72rem;color:var(--orange);">No portal</span>') + '</label>';
          signersList.appendChild(div);
        });
      } else {
        signersList.innerHTML = '<div style="font-size:0.82rem;color:var(--muted);">' + esc((personData && (personData.first_name + ' ' + personData.last_name)) || 'This person') + ' <span style="color:var(--green);">✓</span></div>';
      }
    } catch(e) {
      signersList.innerHTML = '<div style="font-size:0.82rem;color:var(--muted);">Could not load relationship members.</div>';
    }

    document.getElementById('pd-error').style.display = 'none';
    modal.classList.remove('hidden');
  }

  function pdFilterDocsByYear() {
    const year = document.getElementById('pd-year').value;
    const filtered = _pdAllDocs.filter(d =>
      (d.year || '') === year &&
      (d.folder_section === 'firm_uploaded' || !d.folder_section) &&
      (d.folder_category === 'tax') &&
      d.mime_type && d.mime_type.includes('pdf')
    );
    const opts = filtered.length
      ? '<option value="">— None —</option>' + filtered.map(d => `<option value="${d.id}">${esc(d.display_name || 'Untitled')}</option>`).join('')
      : '<option value="">— No Tax PDFs for ' + year + ' —</option>';
    document.getElementById('pd-review-doc').innerHTML = opts;
    document.getElementById('pd-sig-doc').innerHTML = opts;
  }

  document.addEventListener('change', function(e) {
    if (e.target.id === 'pd-year') pdFilterDocsByYear();
  });

  function closePersonDeliveryModal() { document.getElementById('person-delivery-modal').classList.add('hidden'); }

  async function submitPersonDelivery() {
    const year = document.getElementById('pd-year').value.trim();
    if (!year) { document.getElementById('pd-error').textContent = 'Tax year is required'; document.getElementById('pd-error').style.display = ''; return; }
    const body = {
      company_id: null,
      person_id: parseInt(personId),
      tax_year: year,
      title: document.getElementById('pd-title').value.trim(),
      intro_note: document.getElementById('pd-intro').value.trim(),
      review_doc_id: document.getElementById('pd-review-doc').value ? parseInt(document.getElementById('pd-review-doc').value) : null,
      signature_doc_id: document.getElementById('pd-sig-doc').value ? parseInt(document.getElementById('pd-sig-doc').value) : null,
      signer_person_ids: (function() {
        var checked = Array.from(document.querySelectorAll('.pd-signer-cb:checked')).map(function(cb){ return parseInt(cb.value); });
        if (checked.length === 0) checked = [parseInt(personId)]; // always include current person
        return checked;
      })(),
    };
    try {
      const res = await apiFetch('/api/tax-deliveries', { method: 'POST', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      closePersonDeliveryModal();
      var _tabEl = null; document.querySelectorAll('.tab-item').forEach(function(t){ if(t.getAttribute('onclick')&&t.getAttribute('onclick').indexOf("'tax'")!==-1) _tabEl=t; }); switchTab('tax', _tabEl);
    } catch(e) { document.getElementById('pd-error').textContent = e.message; document.getElementById('pd-error').style.display = ''; }
  }

  async function personSendDelivery(id) {
    try {
      const summaryRes = await apiFetch('/api/tax-deliveries/' + id + '/summary');
      const summary = await summaryRes.json();
      openTaxSummary(id, { sendAfter: true });
      return;
    } catch(e) {
      // Fall through to direct send if summary check fails
    }
    if (!await window.dlConfirm('Send this tax return to the client for review and e-signature?', {title:'Send Tax Return', confirmLabel:'Send', icon:'📤'})) return;
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/send', { method: 'POST', body: '{}' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      sessionStorage.setItem('openTab','tax');
      window.location.reload();
    } catch(e) { toast(e.message, 'error'); }
  }

  // ── Tax Summary Modal ──
  let _tsmPendingDeliveryId = null;
  let _tsmPollTimer = null;

  function openTaxSummary(deliveryId, opts) {
    const sendAfter = opts && opts.sendAfter;
    _tsmPendingDeliveryId = deliveryId;
    const modal = document.getElementById('tax-summary-modal');
    const body = document.getElementById('tsm-body');
    const footer = document.getElementById('tsm-footer');
    const sendBtn = document.getElementById('tsm-send-btn');
    modal.classList.remove('hidden');
    body.innerHTML = '<div class="tsm-processing"><div class="tsm-spinner"></div><div>Loading summary…</div></div>';
    footer.style.display = 'none';
    if (sendAfter) sendBtn.style.display = ''; else sendBtn.style.display = 'none';

    apiFetch('/api/tax-deliveries/' + deliveryId + '/summary').then(function(r) { return r.json(); }).then(function(s) {
      if (s.status === 'completed' && s.data) {
        renderTaxSummary(s.data);
        footer.style.display = '';
      } else if (s.status === 'processing') {
        showSummaryProcessing();
        pollSummary(deliveryId);
      } else {
        apiFetch('/api/tax-deliveries/' + deliveryId + '/generate-summary', { method: 'POST' })
          .then(function() { showSummaryProcessing(); pollSummary(deliveryId); })
          .catch(function(e) { showSummaryError(e.message); });
      }
    }).catch(function(e) { showSummaryError(e.message); });
  }

  function showSummaryProcessing() {
    document.getElementById('tsm-body').innerHTML = '<div class="tsm-processing"><div class="tsm-spinner"></div><div style="font-weight:600;">Analyzing return with Claude…</div><div style="font-size:0.75rem;opacity:0.6;">This usually takes 30–60 seconds</div></div>';
    document.getElementById('tsm-footer').style.display = 'none';
  }

  function showSummaryError(msg, deliveryId) {
    var retryBtn = deliveryId ? '<button class="btn btn-gold btn-sm" style="margin-top:1rem;" onclick="retrySummary(' + deliveryId + ')">↺ Retry</button>' : '';
    document.getElementById('tsm-body').innerHTML = '<div style="padding:2rem;text-align:center;color:var(--red,#f56565);"><div style="font-size:1.5rem;margin-bottom:0.5rem;">⚠️</div><div style="font-weight:700;">Failed to generate summary</div><div style="font-size:0.8rem;margin-top:0.4rem;color:var(--muted);">' + esc(msg || 'Unknown error') + '</div>' + retryBtn + '</div>';
    document.getElementById('tsm-footer').style.display = '';
  }

  function retrySummary(deliveryId) {
    apiFetch('/api/tax-deliveries/' + deliveryId + '/generate-summary', { method: 'POST' })
      .then(function() { showSummaryProcessing(); pollSummary(deliveryId); })
      .catch(function(e) { showSummaryError(e.message, deliveryId); });
  }

  function pollSummary(deliveryId) {
    if (_tsmPollTimer) clearInterval(_tsmPollTimer);
    _tsmPollTimer = setInterval(function() {
      apiFetch('/api/tax-deliveries/' + deliveryId + '/summary').then(function(r) { return r.json(); }).then(function(s) {
        if (s.status === 'completed' && s.data) {
          clearInterval(_tsmPollTimer);
          renderTaxSummary(s.data);
          document.getElementById('tsm-footer').style.display = '';
        } else if (s.status === 'error') {
          clearInterval(_tsmPollTimer);
          showSummaryError(s.error || 'Claude analysis failed — check Railway logs for details.', deliveryId);
          document.getElementById('tsm-footer').style.display = '';
        }
      }).catch(function() {});
    }, 3000);
  }

  function closeTaxSummary() {
    if (_tsmPollTimer) clearInterval(_tsmPollTimer);
    document.getElementById('tax-summary-modal').classList.add('hidden');
    _tsmPendingDeliveryId = null;
  }

  function confirmAndSendDelivery() {
    if (!_tsmPendingDeliveryId) return;
    var id = _tsmPendingDeliveryId;
    closeTaxSummary();
    apiFetch('/api/tax-deliveries/' + id + '/send', { method: 'POST', body: '{}' }).then(function(res) {
      if (!res.ok) return res.json().then(function(d) { throw new Error(d.error || 'Failed'); });
      sessionStorage.setItem('openTab', 'tax');
      window.location.reload();
    }).catch(function(e) { toast(e.message, 'error'); });
  }

  function fmt$(n) {
    if (n === null || n === undefined) return '—';
    var abs = Math.abs(n);
    var formatted = '$' + Math.round(abs).toLocaleString();
    return n < 0 ? '(' + formatted + ')' : formatted;
  }

  function renderTaxSummary(d) {
    var title = document.getElementById('tsm-title');
    var subtitle = document.getElementById('tsm-subtitle');
    if (title) title.textContent = (d.client && d.client.tax_year ? d.client.tax_year + ' ' : '') + 'Tax Return Summary';
    if (subtitle) subtitle.textContent = (d.client ? (d.client.names || '') + ' · ' + (d.client.filing_status || '') : '');

    var refundColor = d.is_refund ? 'var(--green,#3ecf8e)' : 'var(--red,#f56565)';
    var refundLabel = d.is_refund ? 'Refund' : 'Balance Due';

    var html = '<div class="tsm-stat-row">' +
      '<div class="tsm-stat"><div class="tsm-stat-val">' + fmt$(d.total_income) + '</div><div class="tsm-stat-label">Total Income</div></div>' +
      '<div class="tsm-stat"><div class="tsm-stat-val">' + fmt$(d.taxable_income) + '</div><div class="tsm-stat-label">Taxable Income</div></div>' +
      '<div class="tsm-stat"><div class="tsm-stat-val">' + fmt$(d.total_tax) + '</div><div class="tsm-stat-label">Total Federal Tax</div></div>' +
      '<div class="tsm-stat"><div class="tsm-stat-val" style="color:' + refundColor + '">' + fmt$(d.refund_or_owed_amount) + '</div><div class="tsm-stat-label">' + refundLabel + '</div></div>' +
      '</div>';

    // Rate pills
    html += '<div><div class="tsm-section-title">Tax Rates</div><div class="tsm-rate-row">';
    html += '<div class="tsm-rate-pill">Effective Rate: <strong>' + (d.effective_rate || 0) + '%</strong></div>';
    html += '<div class="tsm-rate-pill">Marginal Bracket: <strong>' + (d.marginal_bracket || 0) + '%</strong></div>';
    if (d.key_stats && d.key_stats.capital_loss_carryover) html += '<div class="tsm-rate-pill">Cap Loss C/O: <strong>' + fmt$(d.key_stats.capital_loss_carryover) + '</strong></div>';
    if (d.social_security && d.social_security.percent_taxable) html += '<div class="tsm-rate-pill">SS Taxable: <strong>' + d.social_security.percent_taxable + '%</strong></div>';
    html += '</div></div>';

    // Income sources
    if (d.income_sources && d.income_sources.length) {
      html += '<div><div class="tsm-section-title">📊 Income Breakdown</div><table class="tsm-table"><thead><tr><th>Source</th><th style="text-align:right">Amount</th></tr></thead><tbody>';
      d.income_sources.forEach(function(s) {
        html += '<tr><td>' + esc(s.source) + (s.note ? ' <span style="color:var(--muted);font-size:0.75em">(' + esc(s.note) + ')</span>' : '') + '</td><td>' + fmt$(s.amount) + '</td></tr>';
      });
      html += '<tr><td><strong>Total Income (AGI)</strong></td><td><strong>' + fmt$(d.adjusted_gross_income || d.total_income) + '</strong></td></tr></tbody></table></div>';
    }

    // Tax Computation — two-column layout
    html += '<div><div class="tsm-section-title">🧾 Tax Computation</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">';
    html += '<table class="tsm-table"><tbody>';
    html += '<tr><td>Adjusted Gross Income</td><td>' + fmt$(d.adjusted_gross_income || d.total_income) + '</td></tr>';
    (d.deductions || []).forEach(function(ded) {
      html += '<tr><td style="color:var(--green,#3ecf8e)">' + esc(ded.name) + '</td><td style="color:var(--green,#3ecf8e)">(' + fmt$(ded.amount) + ')</td></tr>';
    });
    html += '<tr style="border-top:1px solid var(--border)"><td><strong>Taxable Income</strong></td><td><strong>' + fmt$(d.taxable_income) + '</strong></td></tr>';
    html += '</tbody></table>';
    html += '<table class="tsm-table"><tbody>';
    html += '<tr><td>Federal Income Tax</td><td>' + fmt$(d.tax_before_credits) + '</td></tr>';
    if (d.credits > 0) html += '<tr><td style="color:var(--green,#3ecf8e)">Less: Credits</td><td style="color:var(--green,#3ecf8e)">(' + fmt$(d.credits) + ')</td></tr>';
    html += '<tr><td><strong>Total Tax</strong></td><td><strong>' + fmt$(d.total_tax) + '</strong></td></tr>';
    html += '<tr><td style="color:var(--muted)">Less: Payments &amp; Withholding</td><td style="color:var(--muted)">(' + fmt$(d.total_payments) + ')</td></tr>';
    var refColor = d.is_refund ? 'var(--green,#3ecf8e)' : 'var(--red,#f56565)';
    html += '<tr style="border-top:1px solid var(--border)"><td style="color:' + refColor + '"><strong>' + (d.is_refund ? 'Refund' : 'Balance Due') + '</strong></td><td style="color:' + refColor + '"><strong>' + fmt$(d.refund_or_owed_amount) + '</strong></td></tr>';
    html += '</tbody></table>';
    html += '</div></div>';

    // Savings highlights
    if (d.savings_highlights && d.savings_highlights.length) {
      html += '<div><div class="tsm-section-title">💰 How We Saved You Money</div><div class="tsm-savings-grid">';
      d.savings_highlights.forEach(function(s) {
        html += '<div class="tsm-savings-card"><div class="tsm-savings-amount">' + esc(s.amount) + '</div><div class="tsm-savings-title">' + esc(s.title) + '</div><div class="tsm-savings-desc">' + esc(s.description) + '</div></div>';
      });
      html += '</div></div>';
    }

    // Strategies
    if (d.strategies && d.strategies.length) {
      html += '<div><div class="tsm-section-title">🔭 Forward-Looking Strategies</div><div class="tsm-strategies-grid">';
      d.strategies.forEach(function(s) {
        html += '<div class="tsm-strategy-card"><div class="tsm-strategy-title">' + esc(s.title) + (s.category ? '<span class="tsm-strategy-badge ' + s.category + '">' + s.category + '</span>' : '') + '</div>';
        if (s.potential_savings) html += '<div class="tsm-strategy-savings">Potential savings: ' + esc(s.potential_savings) + '</div>';
        html += '<div class="tsm-strategy-desc">' + esc(s.description) + '</div></div>';
      });
      html += '</div></div>';
    }

    // Estimated payments
    if (d.estimated_payments_required && (d.federal_estimated_payments && d.federal_estimated_payments.length || d.state_estimated_payments && d.state_estimated_payments.length)) {
      html += '<div><div class="tsm-section-title">📅 Estimated Tax Payments</div>';
      if (d.federal_estimated_payments && d.federal_estimated_payments.length) {
        html += '<div style="font-size:0.78rem;font-weight:700;color:var(--text);margin-bottom:0.4rem;">Federal</div><table class="tsm-est-table"><thead><tr><th>Quarter</th><th>Due Date</th><th>Amount</th><th>Method</th></tr></thead><tbody>';
        d.federal_estimated_payments.forEach(function(p) {
          html += '<tr><td>' + esc(p.quarter) + '</td><td>' + esc(p.due_date) + '</td><td style="font-weight:600;color:var(--gold)">' + esc(p.amount) + '</td><td style="color:var(--muted)">' + esc(p.method || '') + '</td></tr>';
        });
        html += '</tbody></table>';
      }
      if (d.state_estimated_payments && d.state_estimated_payments.length) {
        html += '<div style="font-size:0.78rem;font-weight:700;color:var(--text);margin:0.75rem 0 0.4rem;">State</div><table class="tsm-est-table"><thead><tr><th>State</th><th>Quarter</th><th>Due Date</th><th>Amount</th></tr></thead><tbody>';
        d.state_estimated_payments.forEach(function(p) {
          html += '<tr><td>' + esc(p.state) + '</td><td>' + esc(p.quarter) + '</td><td>' + esc(p.due_date) + '</td><td style="font-weight:600;color:var(--gold)">' + esc(p.amount) + '</td></tr>';
        });
        html += '</tbody></table>';
      }
      html += '</div>';
    }

    // YOY comparison
    if (d.prior_year_comparison) {
      var yoy = d.prior_year_comparison;
      var nonZero = (yoy.items || []).filter(function(item) { return item.prior_year !== 0 || item.current_year !== 0; });
      var totalRows = ['Total Income','Total Adjusted Gross Income','Taxable Income','Total Tax','Effective tax rate (%)'];
      html += '<div><div class="tsm-section-title">📊 Year-Over-Year (' + esc(yoy.prior_tax_year) + ' → ' + esc(yoy.current_tax_year) + ')</div>';
      if (yoy.highlights && yoy.highlights.length) {
        html += '<div style="margin-bottom:0.75rem;">';
        yoy.highlights.forEach(function(h) {
          var arrow = h.direction === 'increase' ? '▲' : h.direction === 'decrease' ? '▼' : h.direction === 'new' ? '✦' : '✕';
          var color = h.direction === 'increase' ? 'var(--red,#f56565)' : h.direction === 'decrease' ? 'var(--green,#3ecf8e)' : 'var(--gold,#c9a84c)';
          html += '<span class="tsm-highlight-pill"><span style="color:' + color + ';font-weight:700">' + arrow + '</span> <span style="font-weight:600">' + esc(h.title) + '</span></span>';
        });
        html += '</div>';
      }
      html += '<table class="tsm-yoy-table"><thead><tr><th>Line Item</th><th>' + esc(yoy.prior_tax_year) + '</th><th>' + esc(yoy.current_tax_year) + '</th><th>Change</th></tr></thead><tbody>';
      nonZero.forEach(function(item) {
        var isTotal = totalRows.indexOf(item.label) >= 0;
        var isRate = item.label.indexOf('rate') >= 0 || item.label.indexOf('Rate') >= 0;
        var fmtV = function(v) { if (v === null || v === undefined) return '—'; return isRate ? v + '%' : fmt$(v); };
        var diffColor = item.difference > 0 ? 'var(--red,#f56565)' : item.difference < 0 ? 'var(--green,#3ecf8e)' : 'var(--muted)';
        var diffStr = item.difference !== null ? (item.difference > 0 ? '+' : '') + (isRate ? parseFloat(item.difference).toFixed(2) + '%' : fmt$(item.difference)) : '—';
        html += '<tr' + (isTotal ? ' class="total-row"' : '') + '><td>' + esc(item.label) + '</td><td>' + fmtV(item.prior_year) + '</td><td>' + fmtV(item.current_year) + '</td><td style="color:' + diffColor + '">' + diffStr + '</td></tr>';
      });
      html += '</tbody></table></div>';
    }

    // Carryovers
    if (d.carryovers && d.carryovers.length) {
      html += '<div><div class="tsm-section-title">Carryovers</div><div style="display:flex;flex-wrap:wrap;gap:0.5rem;">';
      d.carryovers.forEach(function(c) { html += '<div class="tsm-rate-pill">' + esc(c.item) + ': <strong>' + esc(c.amount) + '</strong></div>'; });
      html += '</div></div>';
    }

    document.getElementById('tsm-body').innerHTML = html;
    document.getElementById('tsm-footer').style.display = '';
  }

