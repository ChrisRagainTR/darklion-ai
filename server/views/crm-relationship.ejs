<%- include('partials/shell-top', {title: 'Relationship', activeNav: 'relationships'}) %>

<style>
  /* Entity row — used for both people and companies */
  .entity-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .entity-row:last-child { border-bottom: none; }
  .entity-avatar { width: 34px; height: 34px; border-radius: 50%; background: rgba(201,168,76,0.15); display: flex; align-items: center; justify-content: center; font-size: 0.82rem; font-weight: 700; color: var(--gold); flex-shrink: 0; }
  .entity-row-info { flex: 1; min-width: 0; }
  .entity-row-name { font-size: 0.88rem; font-weight: 600; }
  .entity-row-name a { color: var(--text); text-decoration: none; }
  .entity-row-name a:hover { color: var(--gold); }
  .entity-row-meta { font-size: 0.74rem; color: var(--muted); }

  .save-indicator { font-size: 0.78rem; color: var(--green); margin-top: 0.35rem; min-height: 1.1em; }

  .toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999; display: flex; flex-direction: column; gap: 0.5rem; }
  .toast-local { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 0.7rem 1rem; font-size: 0.84rem; color: var(--text); box-shadow: 0 4px 16px rgba(0,0,0,0.4); display: flex; align-items: center; gap: 0.5rem; animation: slideIn 0.2s; min-width: 240px; max-width: 360px; }
  .toast-local.success { border-color: rgba(62,207,142,0.4); }
  .toast-local.error { border-color: rgba(245,101,101,0.4); }
  @keyframes slideIn { from { transform: translateX(40px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

  .placeholder-section { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 3rem; text-align: center; color: var(--muted); }
  .ph-icon { font-size: 2.5rem; margin-bottom: 0.75rem; opacity: 0.4; }
  .ph-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; opacity: 0.75; }
  .ph-desc { font-size: 0.84rem; }
  .info-row { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.4rem; }
  .info-label { font-size: 0.76rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; min-width: 100px; flex-shrink: 0; }
  .info-val { font-size: 0.88rem; color: var(--text); word-break: break-word; }
</style>

  <div class="entity-header">
    <a href="/crm?tab=relationships" class="entity-back">← Relationships</a>
    <div class="entity-header-content">
      <div class="entity-name" id="entity-name">Loading…</div>
      <div class="entity-badges" id="entity-badges"></div>
    </div>
    <div class="entity-actions">
      <button class="btn btn-outline btn-sm" onclick="openEditModal()">Edit</button>
    </div>
  </div>

  <!-- Tab Bar: Overview · Notes · Billing -->
  <div class="tab-bar">
    <div class="tab-item active" onclick="switchTab('overview', this)">Overview</div>
    <div class="tab-item" onclick="switchTab('notes', this)">Notes</div>
    <div class="tab-item" onclick="switchTab('billing', this)">Billing</div>
  </div>

  <!-- ── Tab: Overview ── -->
  <div id="tab-overview" class="tab-content active">
    <div id="overview-content">
      <div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>
    </div>
  </div>

  <!-- ── Tab: Notes ── -->
  <div id="tab-notes" class="tab-content">
    <div class="card" style="max-width:800px;">
      <div class="card-title" style="display:block;">Internal Notes</div>
      <textarea class="form-control" id="notes-ta" rows="14" placeholder="Internal staff notes for this relationship…" onblur="autoSaveNotes(this.value)"></textarea>
      <div style="display:flex;align-items:center;gap:1rem;margin-top:0.75rem;">
        <button class="btn btn-gold btn-sm" onclick="autoSaveNotes(document.getElementById('notes-ta').value, true)">Save Notes</button>
        <div class="save-indicator" id="notes-saved"></div>
      </div>
    </div>
  </div>

  <!-- ── Tab: Billing ── -->
  <div id="tab-billing" class="tab-content">
    <div id="billing-content">
      <div class="loading-state"><div class="loading-spinner"></div></div>
    </div>
  </div>

<!-- ── Edit Modal ── -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Edit Relationship</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div id="edit-error" class="error-msg" style="display:none;"></div>
      <div class="form-group">
        <label class="form-label">Name</label>
        <input type="text" class="form-control" id="ef-name">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Service Tier</label>
          <select class="form-control" id="ef-tier">
            <option value="">— Select —</option>
            <option value="standard">Standard</option>
            <option value="legacy_blueprint">Legacy Blueprint</option>
            <option value="tax_only">Tax Only</option>
            <option value="full_service">Full Service</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Billing Status</label>
          <select class="form-control" id="ef-billing">
            <option value="active">Active</option>
            <option value="past_due">Past Due</option>
            <option value="cancelled">Cancelled</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" id="ef-submit" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const relId = location.pathname.split('/').pop();
  let relData = null;

  function tierBadge(tier) {
    const labels = { standard:'Standard', legacy_blueprint:'Legacy Blueprint', tax_only:'Tax Only', full_service:'Full Service' };
    const cls = { standard:'badge-muted', legacy_blueprint:'badge-gold', tax_only:'badge-blue', full_service:'badge-green' };
    if (!tier) return '<span class="badge badge-muted">—</span>';
    return `<span class="badge ${cls[tier]||'badge-muted'}">${labels[tier]||esc(tier)}</span>`;
  }
  function billingBadge(status) {
    const cls = { active:'badge-green', past_due:'badge-orange', cancelled:'badge-red' };
    const lbl = { active:'Active', past_due:'Past Due', cancelled:'Cancelled' };
    if (!status) return '—';
    return `<span class="badge ${cls[status]||'badge-muted'}">${lbl[status]||esc(status)}</span>`;
  }
  function filingLabel(s) {
    return { single:'Single', mfj:'MFJ', mfs:'MFS', hoh:'HOH', qw:'QW' }[s] || s || '';
  }

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    document.getElementById('tab-' + name).classList.add('active');
    if (name === 'notes' && relData) {
      document.getElementById('notes-ta').value = relData.notes || '';
    }
    if (name === 'billing') renderBilling();
  }

  async function loadRelationship() {
    try {
      const res = await apiFetch(`/api/relationships/${relId}`);
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Not Found'; return; }
      relData = await res.json();
      renderHeader(relData);
      renderOverview(relData);
    } catch(e) {
      document.getElementById('entity-name').textContent = 'Error loading relationship';
    }
  }

  function renderHeader(r) {
    document.title = `${r.name} — DarkLion CRM`;
    document.getElementById('entity-name').textContent = r.name || 'Unnamed Relationship';
    let html = `<span class="badge badge-muted">Relationship</span>`;
    if (r.service_tier) html += ` ${tierBadge(r.service_tier)}`;
    if (r.billing_status) html += ` ${billingBadge(r.billing_status)}`;
    document.getElementById('entity-badges').innerHTML = html;
  }

  function renderOverview(r) {
    const people = r.people || [];
    const companies = r.companies || [];
    const c = document.getElementById('overview-content');

    let html = `<div style="max-width:900px;">`;

    // ── People ──
    html += `<div class="card">
      <div class="card-title">
        <span>👤 People <span style="font-size:0.72rem;font-weight:400;color:var(--muted);">(${people.length})</span></span>
        <a href="/crm?tab=people&add=1&rel=${relId}" class="btn btn-ghost btn-xs">+ Add Person</a>
      </div>`;
    if (!people.length) {
      html += `<div style="color:var(--muted);font-size:0.84rem;padding:0.5rem 0;">No people in this relationship.</div>`;
    } else {
      people.forEach(p => {
        const initials = ((p.first_name||'').charAt(0)+(p.last_name||'').charAt(0)).toUpperCase()||'?';
        const portal = p.portal_enabled
          ? '<span class="badge badge-green" style="font-size:0.65rem;">Portal</span>'
          : '';
        const filing = p.filing_status ? `<span class="badge badge-muted" style="font-size:0.65rem;">${filingLabel(p.filing_status)}</span>` : '';
        html += `<div class="entity-row">
          <div class="entity-avatar">${initials}</div>
          <div class="entity-row-info">
            <div class="entity-row-name"><a href="/crm/person/${p.id}">${esc(p.first_name)} ${esc(p.last_name)}</a></div>
            <div class="entity-row-meta">${p.email ? esc(p.email) : ''}${p.phone ? (p.email ? ' · ' : '') + esc(p.phone) : ''}</div>
          </div>
          ${filing}${portal}
          <a href="/crm/person/${p.id}" class="btn btn-ghost btn-xs">View →</a>
        </div>`;
      });
    }
    html += `</div>`;

    // ── Companies ──
    html += `<div class="card">
      <div class="card-title">
        <span>🏢 Companies <span style="font-size:0.72rem;font-weight:400;color:var(--muted);">(${companies.length})</span></span>
        <a href="/crm?tab=companies&add=1&rel=${relId}" class="btn btn-ghost btn-xs">+ Add Company</a>
      </div>`;
    if (!companies.length) {
      html += `<div style="color:var(--muted);font-size:0.84rem;padding:0.5rem 0;">No companies in this relationship.</div>`;
    } else {
      companies.forEach(co => {
        const entityTypeLabels = { llc:'LLC', s_corp:'S-Corp', c_corp:'C-Corp', partnership:'Partnership', sole_prop:'Sole Prop', trust:'Trust', nonprofit:'Non-Profit', other:'Other' };
        const entityBadge = co.entity_type ? `<span class="badge badge-blue" style="font-size:0.65rem;">${entityTypeLabels[co.entity_type]||esc(co.entity_type)}</span>` : '';
        const qboBadge = co.realm_id ? '<span class="badge badge-green" style="font-size:0.65rem;">QBO</span>' : '';
        const name = (co.company_name || co.name || 'Unknown').charAt(0).toUpperCase();
        html += `<div class="entity-row">
          <div class="entity-avatar" style="border-radius:6px;">${name}</div>
          <div class="entity-row-info">
            <div class="entity-row-name"><a href="/crm/company/${co.id}">${esc(co.company_name||co.name||'Unknown')}</a></div>
            <div class="entity-row-meta">${co.entity_type ? entityTypeLabels[co.entity_type]||co.entity_type : ''}</div>
          </div>
          ${entityBadge}${qboBadge}
          <a href="/crm/company/${co.id}" class="btn btn-ghost btn-xs">View →</a>
        </div>`;
      });
    }
    html += `</div>`;

    html += `</div>`;
    c.innerHTML = html;
  }

  function renderBilling() {
    if (!relData) return;
    const r = relData;
    const c = document.getElementById('billing-content');
    const tierLabels = { standard:'Standard', legacy_blueprint:'Legacy Blueprint', tax_only:'Tax Only', full_service:'Full Service' };
    const tierCls = { standard:'badge-muted', legacy_blueprint:'badge-gold', tax_only:'badge-blue', full_service:'badge-green' };
    const billCls = { active:'badge-green', past_due:'badge-orange', cancelled:'badge-red' };
    const billLbl = { active:'Active', past_due:'Past Due', cancelled:'Cancelled' };

    let html = `<div style="max-width:600px;">
      <div class="card">
        <div class="card-title" style="display:block;">Service &amp; Billing</div>
        <div class="info-row"><span class="info-label">Service Tier</span><span class="info-val"><span class="badge ${tierCls[r.service_tier]||'badge-muted'}">${tierLabels[r.service_tier]||r.service_tier||'—'}</span></span></div>
        <div class="info-row"><span class="info-label">Billing</span><span class="info-val"><span class="badge ${billCls[r.billing_status]||'badge-muted'}">${billLbl[r.billing_status]||r.billing_status||'—'}</span></span></div>
        ${r.stripe_customer_id ? `<div class="info-row"><span class="info-label">Stripe Customer</span><span class="info-val" style="font-family:monospace;font-size:0.8rem;">${esc(r.stripe_customer_id)}</span></div>` : ''}
        ${r.stripe_subscription_id ? `<div class="info-row"><span class="info-label">Stripe Sub</span><span class="info-val" style="font-family:monospace;font-size:0.8rem;">${esc(r.stripe_subscription_id)}</span></div>` : ''}
        <div style="margin-top:1rem;">
          <button class="btn btn-outline btn-sm" onclick="openEditModal()">✏️ Edit Billing Info</button>
        </div>
      </div>
      <div class="placeholder-section">
        <div class="ph-icon">💳</div>
        <div class="ph-title">Stripe Integration</div>
        <div class="ph-desc">Automated billing, invoice generation, and payment tracking coming soon.</div>
      </div>
    </div>`;
    c.innerHTML = html;
  }

  // ── Notes ──
  async function autoSaveNotes(val, force=false) {
    try {
      await apiFetch(`/api/relationships/${relId}`, { method: 'PUT', body: JSON.stringify({ notes: val }) });
      if (relData) relData.notes = val;
      const s = document.getElementById('notes-saved');
      if (s) { s.textContent = '✓ Saved'; setTimeout(() => s.textContent='', 2000); }
      if (force) toast('Notes saved');
    } catch(e) { toast('Failed to save notes', 'error'); }
  }

  // ── Edit Modal ──
  function openEditModal() {
    if (!relData) return;
    document.getElementById('ef-name').value = relData.name || '';
    document.getElementById('ef-tier').value = relData.service_tier || '';
    document.getElementById('ef-billing').value = relData.billing_status || 'active';
    document.getElementById('edit-error').style.display = 'none';
    document.getElementById('edit-modal').classList.add('open');
  }
  function closeModal() { document.getElementById('edit-modal').classList.remove('open'); }

  async function submitEdit() {
    const name = document.getElementById('ef-name').value.trim();
    if (!name) { const e=document.getElementById('edit-error'); e.textContent='Name is required.'; e.style.display=''; return; }
    const body = {
      name,
      service_tier: document.getElementById('ef-tier').value || null,
      billing_status: document.getElementById('ef-billing').value || null,
    };
    const btn = document.getElementById('ef-submit');
    btn.disabled = true;
    try {
      const res = await apiFetch(`/api/relationships/${relId}`, { method: 'PUT', body: JSON.stringify(body) });
      if (!res.ok) { const d=await res.json(); throw new Error(d.error||'Failed'); }
      const updated = await res.json();
      relData = { ...relData, ...updated };
      closeModal();
      toast('Relationship updated');
      renderHeader(relData);
      // Re-render billing if active
      if (document.getElementById('tab-billing').classList.contains('active')) renderBilling();
    } catch(e) { const err=document.getElementById('edit-error'); err.textContent=e.message; err.style.display=''; }
    btn.disabled = false;
  }

  loadRelationship();
</script>

<%- include('partials/shell-close') %>
