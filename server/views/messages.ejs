<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
    .main { display: flex; flex-direction: row; height: calc(100vh - var(--header-h)); overflow: hidden; }

    .inbox-panel {
      width: 300px; flex-shrink: 0; border-right: 1px solid var(--border);
      display: flex; flex-direction: column; height: 100%; overflow: hidden;
    }
    .inbox-header {
      padding: 1.25rem 1rem 0.75rem;
      border-bottom: 1px solid var(--border);
      background: var(--card);
    }
    .inbox-header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
    .inbox-header h2 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0; }
    .inbox-search {
      width: 100%; background: var(--input-bg); border: 1px solid var(--border);
      color: var(--text); border-radius: 6px; padding: 0.4rem 0.6rem; font-size: 0.82rem;
      margin-bottom: 0.5rem;
    }
    .inbox-search:focus { outline: none; border-color: var(--gold); }

    .inbox-list { flex: 1; overflow-y: auto; padding: 0.5rem 0; }
    .thread-card {
      padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.12s;
    }
    .thread-card:hover { background: rgba(201,168,76,0.05); }
    .thread-card.active { background: rgba(201,168,76,0.1); border-left: 3px solid var(--gold); }
    .thread-card.mentioned { border-left: 3px solid #3ecf8e; background: rgba(62,207,142,0.05); }
    .thread-card.mentioned .thread-card-subject { color: #3ecf8e; }
    .thread-card-name { font-size: 0.85rem; font-weight: 600; color: var(--text); display: flex; justify-content: space-between; }
    .thread-card-subject { font-size: 0.78rem; color: var(--muted); margin-top: 0.1rem; }
    .thread-card-preview { font-size: 0.75rem; color: var(--muted); margin-top: 0.15rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .thread-card-meta { display: flex; gap: 0.4rem; align-items: center; margin-top: 0.3rem; flex-wrap: wrap; }
    .thread-card-actions { display: none; gap: 0.35rem; margin-top: 0.4rem; justify-content: flex-end; }
    .thread-card:hover .thread-card-actions { display: flex; }
    .unread-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); margin-left: auto; flex-shrink: 0; }
    .unread-count-badge { background: var(--gold); color: var(--navy); font-size: 0.65rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 10px; }

    .archive-btn {
      font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 4px; cursor: pointer; border: 1px solid;
      background: transparent; border-color: var(--muted); color: var(--muted);
    }
    .archive-btn:hover { border-color: #e05555; color: #e05555; }

    /* ── AI SUMMARY PANEL ── */
    .summary-panel {
      width: 380px; flex-shrink: 0; border-left: 1px solid var(--border);
      display: flex; flex-direction: column; height: 100%; overflow: hidden; background: var(--card);
    }
    .summary-panel-header {
      padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
    }
    .summary-panel-header h3 { font-size: 0.88rem; font-weight: 700; color: var(--text); margin: 0; }
    .summary-panel-body {
      flex: 1; overflow-y: auto; padding: 1rem 1.25rem;
      font-size: 0.82rem; line-height: 1.7; color: var(--muted);
    }
    .summary-panel-body strong {
      color: var(--gold); display: block;
      margin-top: 0.85rem; margin-bottom: 0.2rem;
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em;
    }
    .summary-panel-body strong:first-child { margin-top: 0; }
    .summary-panel-body p { margin: 0 0 0.4rem; color: var(--text); }

    /* ── THREAD DETAIL ── */
    .detail-panel {
      flex: 1; display: flex; flex-direction: column; height: 100%; overflow: hidden;
    }
    .detail-header {
      padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--card);
      display: flex; align-items: flex-start; gap: 1rem; flex-wrap: wrap;
    }
    .detail-header-left { flex: 1; }
    .detail-header-person { font-size: 1rem; font-weight: 700; color: var(--text); }
    .detail-header-person a { color: var(--gold); text-decoration: none; }
    .detail-header-person a:hover { text-decoration: underline; }
    .detail-header-subject { font-size: 0.85rem; color: var(--muted); margin-top: 0.15rem; }
    .detail-header-controls { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }

    .detail-messages {
      flex: 1; overflow-y: auto; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1rem;
    }
    .msg-bubble-wrap { display: flex; flex-direction: column; }
    .msg-bubble-wrap.staff { align-items: flex-end; }
    .msg-bubble-wrap.client { align-items: flex-start; }
    .msg-bubble {
      max-width: 75%; padding: 0.6rem 0.9rem; border-radius: 12px; font-size: 0.875rem; line-height: 1.5; word-break: break-word;
    }
    .msg-bubble.staff { background: var(--gold); color: var(--navy); }
    .msg-bubble.client { background: var(--charcoal); color: var(--text); border: 1px solid var(--border); }
    .msg-bubble.internal { background: rgba(255,200,0,0.1); border: 1px dashed var(--gold); color: var(--text); }
    .msg-meta { font-size: 0.68rem; color: var(--muted); margin-top: 0.15rem; }
    .msg-internal-label { font-size: 0.62rem; color: var(--gold); margin-bottom: 0.15rem; }

    .no-thread-selected {
      flex: 1; display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 0.75rem; color: var(--muted);
    }
    .no-thread-selected .nts-icon { font-size: 3rem; opacity: 0.4; }

    /* ── REPLY BOX ── */
    .reply-box {
      padding: 1rem 1.5rem; border-top: 1px solid var(--border); background: var(--card);
      position: relative;
    }
    .reply-box-controls { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    .reply-box-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; cursor: pointer; }
    .reply-box textarea {
      width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text);
      border-radius: 8px; padding: 0.6rem 0.75rem; font-size: 0.88rem; font-family: inherit;
      resize: none; min-height: 80px; margin-bottom: 0.5rem;
    }
    .reply-box textarea:focus { outline: none; border-color: var(--gold); }
    .reply-box-actions { display: flex; gap: 0.5rem; align-items: stretch; }
    .btn { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.4rem 0.85rem; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: opacity 0.15s; }
    .btn:hover { opacity: 0.88; }
    .btn-gold { background: var(--gold); color: var(--navy); }
    .btn-outline { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-outline:hover { color: var(--text); border-color: var(--gold); }
    .btn-sm { padding: 0.3rem 0.65rem; font-size: 0.77rem; }
    .btn-danger { background: transparent; color: #e05555; border: 1px solid #e05555; }
    .btn-danger:hover { background: rgba(224,85,85,0.1); }

    /* ── ATTACHMENTS ── */
    .attach-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.4rem; }
    .attach-chip-input { display: inline-flex; align-items: center; gap: 0.3rem; background: rgba(255,255,255,0.07); border: 1px solid var(--border); border-radius: 4px; padding: 0.15rem 0.5rem; font-size: 0.75rem; color: var(--text); }
    .attach-chip-input button { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.8rem; padding: 0; line-height: 1; }
    .attach-chip-input button:hover { color: #e55; }
    .btn-attach { background: transparent; border: 1px solid var(--border); color: var(--muted); border-radius: 6px; padding: 0.3rem 0.65rem; font-size: 0.77rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
    .btn-attach:hover { color: var(--text); border-color: var(--gold); }
    .msg-attachments { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
    .attachment-chip { display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(0,0,0,0.25); border: 1px solid rgba(0,0,0,0.2); border-radius: 6px; padding: 0.25rem 0.6rem; font-size: 0.75rem; color: #fff; text-decoration: none; font-weight: 500; }
    .attachment-chip:hover { background: rgba(0,0,0,0.4); color: #fff; }
    .att-size { color: var(--muted); font-size: 0.7rem; }

    .spinner { display: inline-block; width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── NEW CONVERSATION MODAL ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000;
      align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: var(--card); border: 1px solid var(--border); border-radius: 12px;
      padding: 1.5rem; width: 420px; max-width: 95vw; display: flex; flex-direction: column; gap: 1rem;
    }
    .modal-box h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0; }
    .modal-field label { display: block; font-size: 0.78rem; color: var(--muted); margin-bottom: 0.3rem; }
    .modal-field input, .modal-field select, .modal-field textarea {
      width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text);
      border-radius: 6px; padding: 0.5rem 0.65rem; font-size: 0.85rem; font-family: inherit;
    }
    .modal-field input:focus, .modal-field select:focus, .modal-field textarea:focus {
      outline: none; border-color: var(--gold);
    }
    .modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 0.25rem; }
    .person-search-results {
      position: absolute; z-index: 1100; background: var(--charcoal); border: 1px solid var(--gold);
      border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); width: 100%; max-height: 200px; overflow-y: auto;
    }
    .person-search-item {
      padding: 0.5rem 0.75rem; cursor: pointer; font-size: 0.85rem; transition: background 0.1s;
    }
    .person-search-item:hover { background: rgba(201,168,76,0.1); }
    .modal-field-wrap { position: relative; }

    @media (max-width: 1100px) { .summary-panel { display: none !important; } }
    @media (max-width: 768px) {
      .inbox-panel { width: 240px; }
    }
    @media (max-width: 600px) {
      .main {
        position: fixed !important; left: 0 !important; top: var(--header-h) !important;
        right: 0 !important; bottom: 0 !important; overflow: hidden !important;
        display: flex !important; flex-direction: column !important;
      }
      .inbox-panel {
        width: 100% !important; flex: 1 !important; overflow-y: auto !important;
        -webkit-overflow-scrolling: touch !important; border-right: none !important;
        display: flex !important; flex-direction: column !important; height: 100% !important;
      }
      .inbox-list { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
      .inbox-panel.mobile-hidden { display: none !important; }
      .detail-panel {
        width: 100% !important; flex: 1 !important; overflow: hidden !important;
        display: none !important; flex-direction: column !important; height: 100% !important;
      }
      .detail-panel.mobile-visible { display: flex !important; }
      #threadView { flex: 1 !important; display: flex !important; flex-direction: column !important; overflow: hidden !important; min-height: 0 !important; }
      .detail-messages { flex: 1 !important; overflow-y: auto !important; -webkit-overflow-scrolling: touch !important; padding: 1rem !important; min-height: 0 !important; }
      .detail-header { flex-shrink: 0 !important; padding: 0.6rem 1rem; flex-wrap: wrap; }
      .detail-header-subject { display: none; }
      .detail-header-controls { display: none; }
      .reply-box { flex-shrink: 0 !important; padding: 0.75rem 1rem; }
      .reply-box textarea { min-height: 60px; font-size: 1rem; }
      .mobile-back-btn {
        display: flex !important; flex-shrink: 0 !important; align-items: center; gap: 0.4rem;
        background: none; border: none; color: var(--gold); font-size: 0.95rem; font-weight: 600;
        cursor: pointer; padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); width: 100%;
      }
      .thread-card { padding: 1rem; }
      .thread-card-actions { display: flex !important; }
      .btn { padding: 0.55rem 1rem; }
    }
</style>

<main class="main">

  <!-- Inbox panel -->
  <div class="inbox-panel" id="inboxPanel">
    <div class="inbox-header">
      <div class="inbox-header-row">
        <h2>💬 My Inbox</h2>

      </div>
      <input type="text" class="inbox-search" id="searchBox" placeholder="Search by name…" oninput="filterThreads()">
    </div>
    <div class="inbox-list" id="inboxList">
      <div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>
    </div>
  </div>

  <!-- Thread detail -->
  <div class="detail-panel" id="detailPanel">
    <button class="mobile-back-btn" id="mobileBackBtn" style="display:none;" onclick="closeMobileThread()">← Back to Inbox</button>
    <div class="no-thread-selected" id="noThreadSelected">
      <div class="nts-icon">💬</div>
      <div>Select a thread to read messages</div>
    </div>

    <div id="threadView" style="display:none;flex:1;display:none;flex-direction:column;height:100%;">
      <div class="detail-header" id="detailHeader"></div>
      <div class="detail-messages" id="detailMessages">
        <div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>
      </div>
      <div id="typingIndicator" style="display:none;padding:0.3rem 1rem;font-size:0.78rem;color:var(--muted);font-style:italic;"></div>
      <div class="reply-box" id="replyBox">
        <div class="reply-box-controls">
          <!-- Internal note checkbox hidden — auto-set for shared threads, not needed for direct threads -->
          <input type="checkbox" id="internalToggle" style="display:none;">
          <div style="flex:1;"></div>
        </div>
        <textarea id="replyBody" placeholder="Write a reply… (use @Name to loop in a colleague)" rows="3"></textarea>
        <div id="mention-picker" style="display:none;position:absolute;z-index:500;background:var(--charcoal);border:1px solid var(--gold);border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,0.4);min-width:200px;max-height:220px;overflow-y:auto;"></div>
        <div class="attach-chips" id="attachChips"></div>
        <input type="file" id="attachFileInput" multiple style="display:none;" onchange="handleAttachFiles(this.files)">
        <div class="reply-box-actions">
          <button class="btn btn-gold btn-sm" onclick="sendReply()">Send Reply</button>
          <button class="btn btn-outline btn-sm" onclick="sendReplyAsSms()">📱 Send as Text</button>
          <button class="btn-attach" onclick="document.getElementById('attachFileInput').click()">📎 Attach</button>
          <button class="btn btn-outline btn-sm" onclick="archiveCurrentThread()">Archive</button>
        </div>
      </div>
    </div>
  </div>

  <!-- AI Summary panel -->
  <div class="summary-panel" id="inboxSummaryPanel" style="display:none;">
    <div class="summary-panel-header">
      <h3>🤖 30-Day Summary</h3>
      <button class="btn btn-ghost btn-xs" id="inboxSummaryRefreshBtn" onclick="loadInboxSummary(true)">↺ Refresh</button>
    </div>
    <div class="summary-panel-body" id="inboxSummaryBody">
      <div style="color:var(--muted);font-style:italic;font-size:0.8rem;">Select a thread to see the summary.</div>
    </div>
  </div>

</main>

<!-- New Conversation Modal -->
<div class="modal-overlay" id="newConvModal">
  <div class="modal-box">
    <h3>New Conversation</h3>
    <div class="modal-field">
      <label>Person</label>
      <div class="modal-field-wrap">
        <input type="text" id="personSearch" placeholder="Search by name or email…" autocomplete="off" oninput="searchPeople(this.value)">
        <div class="person-search-results" id="personSearchResults" style="display:none;"></div>
      </div>
      <input type="hidden" id="selectedPersonId">
    </div>
    <div class="modal-field">
      <label>Staff Member</label>
      <select id="staffSelect"></select>
    </div>
    <div class="modal-field">
      <label>Subject (optional)</label>
      <input type="text" id="newConvSubject" placeholder="e.g. Tax planning question">
    </div>
    <div class="modal-field">
      <label>First Message</label>
      <textarea id="newConvBody" rows="3" placeholder="Type your message…"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline btn-sm" onclick="closeNewConversationModal()">Cancel</button>
      <button class="btn btn-gold btn-sm" onclick="submitNewConversation()">Send</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>
<script src="https://js.pusher.com/8.3.0/pusher.min.js"></script>

<script>
const token = localStorage.getItem('dl_token');
if (!token) window.location.href = '/login';

let allThreads = [];
let activeThreadId = null;
let firmUsers = [];
let attachedFiles = [];

const _jwtPayload = JSON.parse(atob(token.split('.')[1]));
const _firmId = _jwtPayload.firmId || _jwtPayload.id;
const _myUserId = _jwtPayload.userId || _jwtPayload.sub || null;

// Pusher
const _pusher = new Pusher('6ee61a25e438d5bc4751', {
  cluster: 'us2',
  authEndpoint: '/pusher/auth/staff?token=' + encodeURIComponent(token),
});
const _firmChannel = _pusher.subscribe(`private-firm-${_firmId}`);
_firmChannel.bind('pusher:subscription_succeeded', () => console.log('[pusher] subscribed'));
_firmChannel.bind('message-new', ({ threadId, senderType }) => {
  loadInbox();
  const replyBox = document.getElementById('replyBody');
  if (activeThreadId === threadId && !(replyBox && replyBox.value.trim()) && !_justSent && senderType !== 'staff') {
    loadThread(threadId, true);
  }
});
_firmChannel.bind('thread-new', () => loadInbox());

// Typing emit
let _staffTypingTimer = null;
document.addEventListener('input', (e) => {
  if (e.target.id !== 'replyBody' || !activeThreadId) return;
  clearTimeout(_staffTypingTimer);
  _staffTypingTimer = setTimeout(() => {
    if (window._activePersonId) {
      const portalCh = _pusher.channel(`private-portal-${_firmId}-${window._activePersonId}`);
      if (portalCh) portalCh.trigger('client-typing', { threadId: activeThreadId, name: 'Advisor' });
    }
  }, 300);
});

// Poll fallback
setInterval(() => loadInbox(), 30000);

async function apiFetch(url, opts = {}) {
  const isFormData = opts.body instanceof FormData;
  return fetch(url, {
    ...opts,
    headers: {
      'Authorization': 'Bearer ' + token,
      ...(isFormData ? {} : { 'Content-Type': 'application/json' }),
      ...(opts.headers || {}),
    },
  });
}

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function relTime(ts) {
  if (!ts) return '';
  const d = new Date(ts), diff = Date.now() - d;
  if (diff < 60000) return 'just now';
  if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
  if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
  if (diff < 604800000) return Math.floor(diff/86400000) + 'd ago';
  return d.toLocaleDateString();
}

let _inboxLoading = false;

async function loadInbox(showSpinner = false) {
  if (_inboxLoading) return;
  _inboxLoading = true;
  try {
    if (showSpinner) {
      document.getElementById('inboxList').innerHTML = '<div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>';
    }
    const res = await apiFetch('/api/messages');
    const freshThreads = await res.json();
    const freshJson = JSON.stringify(freshThreads);
    if (freshJson !== JSON.stringify(allThreads)) {
      allThreads = freshThreads;
      renderInbox();
      // Auto-open first thread if none selected yet
      if (!activeThreadId && freshThreads.length) {
        loadThread(freshThreads[0].id);
      }
    }
    // firmUsers loaded separately at init
  } catch(e) {
    if (showSpinner) {
      document.getElementById('inboxList').innerHTML = '<div style="color:var(--muted);padding:1rem;font-size:0.85rem;">Failed to load inbox.</div>';
    }
  } finally {
    _inboxLoading = false;
  }
}

function filterThreads() {
  renderInbox();
}

function renderInbox() {
  const q = (document.getElementById('searchBox').value || '').toLowerCase();
  let threads = allThreads;

  if (q) threads = threads.filter(t => {
    const name = ((t.person?.firstName || '') + ' ' + (t.person?.lastName || '')).toLowerCase();
    return name.includes(q) || (t.subject || '').toLowerCase().includes(q);
  });

  if (!threads.length) {
    document.getElementById('inboxList').innerHTML = '<div style="color:var(--muted);padding:1.5rem 1rem;font-size:0.85rem;">No active threads.</div>';
    return;
  }

  document.getElementById('inboxList').innerHTML = threads.map(t => {
    const name = esc((t.person?.firstName || '') + ' ' + (t.person?.lastName || ''));
    const sharedBadge = t.isParticipant
      ? `<span style="font-size:0.65rem;background:rgba(138,99,241,0.15);color:#a78bfa;border:1px solid rgba(138,99,241,0.3);border-radius:4px;padding:0.1rem 0.4rem;font-weight:600;">Shared${t.sharedByName ? ' by ' + esc(t.sharedByName.split(' ')[0]) : ''}</span>`
      : '';
    const archiveLabel = t.isParticipant ? 'Remove' : 'Archive';
    const archiveTitle = t.isParticipant ? 'Remove from your inbox' : 'Archive this thread';
    return `<div class="thread-card${t.id === activeThreadId ? ' active' : ''}" onclick="loadThread(${t.id})">
      <div class="thread-card-name">
        <span>${name} ${sharedBadge}</span>
        <span style="font-size:0.7rem;color:var(--muted);">${relTime(t.lastMessageAt)}</span>
      </div>
      <div class="thread-card-subject">${esc(t.subject || '(no subject)')}</div>
      <div class="thread-card-preview">${esc(t.lastPreview || '')}</div>
      <div class="thread-card-meta">
        ${t.unreadCount > 0 ? `<span class="unread-count-badge">${t.unreadCount} new</span>` : ''}
      </div>
      <div class="thread-card-actions" onclick="event.stopPropagation();">
        <button class="archive-btn" onclick="archiveThread(${t.id})" title="${archiveTitle}">${archiveLabel}</button>
      </div>
    </div>`;
  }).join('');
}

async function archiveThread(threadId) {
  try {
    await apiFetch(`/api/messages/${threadId}/archive`, { method: 'PUT' });
    allThreads = allThreads.filter(t => t.id !== threadId);
    if (activeThreadId === threadId) {
      activeThreadId = null;
      document.getElementById('threadView').style.display = 'none';
      document.getElementById('noThreadSelected').style.display = '';
    }
    renderInbox();
  } catch(e) { window.toast && window.toast(e.message, 'error'); }
}

async function archiveCurrentThread() {
  if (!activeThreadId) return;
  const t = allThreads.find(x => x.id === activeThreadId);
  const msg = t?.isParticipant
    ? 'Remove this thread from your inbox? The original owner\'s thread is unaffected.'
    : 'Archive this thread? It will be removed from your inbox.';
  if (!confirm(msg)) return;
  await archiveThread(activeThreadId);
}

let _inboxSummaryPersonId = null;

async function loadInboxSummary(force = false) {
  const personId = _inboxSummaryPersonId;
  if (!personId) return;
  const panel = document.getElementById('inboxSummaryPanel');
  const body = document.getElementById('inboxSummaryBody');
  const btn = document.getElementById('inboxSummaryRefreshBtn');
  if (!panel || !body) return;
  panel.style.display = '';
  body.innerHTML = '<div style="display:flex;align-items:center;gap:0.5rem;color:var(--muted);"><div class="loading-spinner" style="width:16px;height:16px;border-width:2px;margin-bottom:0;"></div> Generating…</div>';
  if (btn) { btn.disabled = true; btn.textContent = '…'; }
  try {
    const res = await apiFetch(`/api/messages/person/${personId}/summary`, { method: 'POST' });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed');
    if (!data.summary) {
      body.innerHTML = `<div style="color:var(--muted);font-style:italic;">${data.message || 'No messages in the last 30 days.'}</div>`;
    } else {
      const html = data.summary
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br>');
      body.innerHTML = `<div>${html}</div>
        <div style="margin-top:1rem;font-size:0.72rem;color:var(--muted);border-top:1px solid var(--border);padding-top:0.5rem;">
          Based on ${data.messageCount} message${data.messageCount !== 1 ? 's' : ''} · ${new Date(data.generatedAt).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}
        </div>`;
    }
  } catch(e) {
    body.innerHTML = `<div style="color:var(--red);font-size:0.8rem;">Failed: ${e.message}</div>`;
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = '↺ Refresh'; }
  }
}

async function loadThread(threadId, silent = false) {
  activeThreadId = threadId;
  renderInbox();

  document.getElementById('noThreadSelected').style.display = 'none';
  const tv = document.getElementById('threadView');
  tv.style.display = 'flex';
  tv.style.flexDirection = 'column';
  tv.style.flex = '1';
  tv.style.height = '100%';

  if (!silent) {
    document.getElementById('detailMessages').innerHTML = '<div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>';
    document.getElementById('detailHeader').innerHTML = '';
  }

  try {
    const res = await apiFetch(`/api/messages/${threadId}`);
    const data = await res.json();

    if (data.person?.id && data.person.id !== window._activePersonId) {
      window._activePersonId = data.person.id;
      const portalChName = `private-portal-${_firmId}-${data.person.id}`;
      if (!_pusher.channel(portalChName)) {
        const ch = _pusher.subscribe(portalChName);
        ch.bind('client-typing', ({ name }) => {
          const el = document.getElementById('typingIndicator');
          if (el) { el.textContent = `${name || 'Client'} is typing…`; el.style.display = 'block'; }
          clearTimeout(window._typingTimer);
          window._typingTimer = setTimeout(() => { if (el) el.style.display = 'none'; }, 3000);
        });
      }
    }

    // Load summary for this person (only if person changed)
    if (data.person?.id && data.person.id !== _inboxSummaryPersonId) {
      _inboxSummaryPersonId = data.person.id;
      loadInboxSummary();
    } else if (!_inboxSummaryPersonId && data.person?.id) {
      _inboxSummaryPersonId = data.person.id;
      loadInboxSummary();
    }

    document.getElementById('detailHeader').innerHTML = `
      <div class="detail-header-left">
        <div class="detail-header-person">
          <a href="/crm/person/${data.person?.id}">${esc((data.person?.firstName||'')+' '+(data.person?.lastName||''))}</a>
        </div>
        <div class="detail-header-subject">${esc(data.subject || '(no subject)')}${data.staffName ? ` · <span style="color:var(--gold);">${esc(data.staffName)}</span>` : ''}</div>
      </div>
      <div class="detail-header-controls">
        ${data.isParticipant ? `<span style="font-size:0.72rem;background:rgba(138,99,241,0.15);color:#a78bfa;border:1px solid rgba(138,99,241,0.3);border-radius:4px;padding:0.2rem 0.6rem;font-weight:600;">Shared thread — internal notes only</span>` : ''}
        <button class="btn btn-sm btn-outline" onclick="archiveCurrentThread()">${data.isParticipant ? 'Remove' : 'Archive'}</button>
      </div>
    `;
    // Auto-set internal for shared threads (checkbox is hidden but still drives is_internal on send)
    const internalToggle = document.getElementById('internalToggle');
    if (internalToggle) {
      internalToggle.checked = !!data.isParticipant;
      internalToggle.disabled = !!data.isParticipant;
    }

    const msgs = data.messages || [];
    const msgContainer = document.getElementById('detailMessages');
    if (!msgs.length) {
      if (!silent) msgContainer.innerHTML = '<div style="color:var(--muted);padding:1rem;font-size:0.85rem;">No messages yet.</div>';
    } else if (silent) {
      const existingIds = new Set([...msgContainer.querySelectorAll('[data-msg-id]')].map(el => parseInt(el.dataset.msgId)));
      let appended = false;
      for (const m of msgs) {
        if (!existingIds.has(m.id)) {
          const side = m.senderType === 'staff' ? 'staff' : 'client';
          const bubbleClass = m.isInternal ? 'internal' : side;
          const attachmentsHtml = (m.attachments||[]).length > 0
            ? `<div class="msg-attachments">${m.attachments.map(a => `<a class="attachment-chip" href="#" onclick="downloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}</a>`).join('')}</div>` : '';
          msgContainer.insertAdjacentHTML('beforeend', `<div class="msg-bubble-wrap ${side}" data-msg-id="${m.id}">
            ${m.isInternal ? '<div class="msg-internal-label">🔒 Internal note</div>' : ''}
            <div class="msg-bubble ${bubbleClass}">${m.body ? esc(m.body).replace(/\n/g,'<br>') : ''}${attachmentsHtml}</div>
            <div class="msg-meta">${esc(m.senderName||'')} · ${relTime(m.createdAt)}</div>
          </div>`);
          appended = true;
        }
      }
      if (appended) msgContainer.scrollTop = msgContainer.scrollHeight;
    } else {
      msgContainer.innerHTML = msgs.map(m => {
        const side = m.senderType === 'staff' ? 'staff' : 'client';
        const bubbleClass = m.isInternal ? 'internal' : side;
        const attachmentsHtml = (m.attachments || []).length > 0
          ? `<div class="msg-attachments">${(m.attachments).map(a => {
              const size = a.sizeBytes ? ' <span class="att-size">(' + formatBytes(a.sizeBytes) + ')</span>' : '';
              return `<a class="attachment-chip" href="#" onclick="downloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}${size}</a>`;
            }).join('')}</div>` : '';
        return `<div class="msg-bubble-wrap ${side}" data-msg-id="${m.id}">
          ${m.isInternal ? '<div class="msg-internal-label">🔒 Internal note</div>' : ''}
          <div class="msg-bubble ${bubbleClass}">${m.body ? esc(m.body).replace(/\n/g,'<br>') : ''}${attachmentsHtml}</div>
          <div class="msg-meta">${esc(m.senderName || '')} · ${relTime(m.createdAt)}</div>
        </div>`;
      }).join('');
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    if (!silent) {
      document.getElementById('replyBody').value = '';
      attachedFiles = [];
      renderAttachChips();
    }
  } catch(e) {
    document.getElementById('detailMessages').innerHTML = '<div style="color:var(--muted);padding:1rem;">Failed to load thread.</div>';
  }
}

function handleAttachFiles(fileList) {
  for (const f of Array.from(fileList)) {
    if (attachedFiles.length >= 8) { alert('Maximum 8 files per message'); break; }
    attachedFiles.push(f);
  }
  document.getElementById('attachFileInput').value = '';
  renderAttachChips();
}

function removeAttachFile(idx) {
  attachedFiles.splice(idx, 1);
  renderAttachChips();
}

function renderAttachChips() {
  const el = document.getElementById('attachChips');
  if (!el) return;
  el.innerHTML = attachedFiles.map((f, i) =>
    `<span class="attach-chip-input">📎 ${esc(f.name)} <button onclick="removeAttachFile(${i})">×</button></span>`
  ).join('');
}

function formatBytes(b) {
  if (!b) return '0 B';
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
  return (b/1048576).toFixed(1) + ' MB';
}

async function downloadAttachment(documentId) {
  try {
    const res = await apiFetch(`/api/messages/attachments/${documentId}/download`);
    const data = await res.json();
    if (data.url) window.open(data.url, '_blank');
    else alert('Download failed');
  } catch(e) { alert('Failed to download attachment'); }
}

async function sendReply() {
  if (!activeThreadId) return;
  const body = document.getElementById('replyBody').value.trim();
  if (!body && attachedFiles.length === 0) return;
  const isInternal = document.getElementById('internalToggle').checked;
  try {
    const fd = new FormData();
    fd.append('body', body);
    fd.append('is_internal', isInternal ? 'true' : 'false');
    attachedFiles.forEach(f => fd.append('files', f));
    await apiFetch(`/api/messages/${activeThreadId}/reply`, { method: 'POST', body: fd });
    document.getElementById('replyBody').value = '';
    document.getElementById('internalToggle').checked = false;
    attachedFiles = [];
    renderAttachChips();
    _justSent = true;
    setTimeout(() => { _justSent = false; }, 3000);
    await loadThread(activeThreadId, true);
    await loadInbox();
  } catch(e) { alert('Failed to send reply'); }
}
async function sendReplyAsSms() {
  if (!activeThreadId) return;
  const body = document.getElementById('replyBody').value.trim();
  if (!body) { alert('Write a message first'); return; }
  const thread = allThreads.find(t => t.id === activeThreadId);
  const personId = thread?.person?.id;
  if (!personId) { alert('No person linked to this thread'); return; }
  try {
    // Send SMS
    const smsRes = await apiFetch('/api/messages/sms', { method: 'POST', body: JSON.stringify({ person_id: personId, body }) });
    const smsData = await smsRes.json();
    if (!smsRes.ok) throw new Error(smsData.error || 'SMS failed');
    // Also save as a reply in the thread so it shows in conversation history
    const fd = new FormData();
    fd.append('body', `📱 [Sent as text] ${body}`);
    fd.append('is_internal', 'false');
    await apiFetch(`/api/messages/${activeThreadId}/reply`, { method: 'POST', body: fd });
    document.getElementById('replyBody').value = '';
    attachedFiles = []; renderAttachChips();
    await loadThread(activeThreadId, true);
    await loadInbox();
    window.toast && window.toast('Text message sent');
  } catch(e) { alert('Failed to send text: ' + e.message); }
}

let _justSent = false;

// ── NEW CONVERSATION MODAL ─────────────────────────────────────────────────
let _staffListCache = [];
let _personSearchTimer = null;

async function openNewConversationModal() {
  // Load staff list
  if (!_staffListCache.length) {
    try {
      const res = await apiFetch('/api/messages/staff-list');
      _staffListCache = await res.json();
    } catch(e) { _staffListCache = []; }
  }

  const staffSelect = document.getElementById('staffSelect');
  staffSelect.innerHTML = _staffListCache.map(s =>
    `<option value="${s.id}">${esc(s.name)}</option>`
  ).join('');

  // Default to current user if possible
  if (_myUserId) {
    const myOpt = [...staffSelect.options].find(o => parseInt(o.value) === _myUserId);
    if (myOpt) myOpt.selected = true;
  }

  document.getElementById('selectedPersonId').value = '';
  document.getElementById('personSearch').value = '';
  document.getElementById('personSearchResults').style.display = 'none';
  document.getElementById('newConvSubject').value = '';
  document.getElementById('newConvBody').value = '';
  document.getElementById('newConvModal').classList.add('open');
}

function closeNewConversationModal() {
  document.getElementById('newConvModal').classList.remove('open');
}

async function searchPeople(q) {
  clearTimeout(_personSearchTimer);
  document.getElementById('selectedPersonId').value = '';
  if (!q || q.length < 2) {
    document.getElementById('personSearchResults').style.display = 'none';
    return;
  }
  _personSearchTimer = setTimeout(async () => {
    try {
      const res = await apiFetch(`/api/people?search=${encodeURIComponent(q)}&limit=8`);
      const data = await res.json();
      const people = Array.isArray(data) ? data : (data.rows || data.people || []);
      const el = document.getElementById('personSearchResults');
      if (!people.length) {
        el.innerHTML = '<div class="person-search-item" style="color:var(--muted);">No results</div>';
        el.style.display = 'block';
        return;
      }
      el.innerHTML = people.map(p => {
        const name = esc((p.first_name || p.firstName || '') + ' ' + (p.last_name || p.lastName || ''));
        const email = esc(p.email || '');
        return `<div class="person-search-item" onclick="selectPerson(${p.id}, '${name}')">${name}${email ? ` <span style="color:var(--muted);font-size:0.78rem;">${email}</span>` : ''}</div>`;
      }).join('');
      el.style.display = 'block';
    } catch(e) { /* silent */ }
  }, 300);
}

function selectPerson(id, name) {
  document.getElementById('selectedPersonId').value = id;
  document.getElementById('personSearch').value = name.replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>');
  document.getElementById('personSearchResults').style.display = 'none';
}

async function submitNewConversation() {
  const personId = document.getElementById('selectedPersonId').value;
  const staffUserId = document.getElementById('staffSelect').value;
  const subject = document.getElementById('newConvSubject').value.trim();
  const body = document.getElementById('newConvBody').value.trim();

  if (!personId) { alert('Please select a person'); return; }
  if (!body) { alert('Please enter a message'); return; }

  try {
    const res = await apiFetch('/api/messages', {
      method: 'POST',
      body: JSON.stringify({ person_id: parseInt(personId), staff_user_id: parseInt(staffUserId), subject, body }),
    });
    const data = await res.json();
    if (!res.ok) { alert(data.error || 'Failed to create thread'); return; }
    closeNewConversationModal();
    await loadInbox(false);
    if (data.threadId) loadThread(data.threadId);
  } catch(e) { alert('Failed to create conversation'); }
}

// Close modal on overlay click
document.getElementById('newConvModal').addEventListener('click', function(e) {
  if (e.target === this) closeNewConversationModal();
});

// Close person search on outside click
document.addEventListener('click', function(e) {
  const wrap = document.querySelector('.modal-field-wrap');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('personSearchResults').style.display = 'none';
  }
});

// ── MOBILE ────────────────────────────────────────────────────────────────────
const _isMobile = () => window.innerWidth <= 600;

function openMobileThread() {
  if (!_isMobile()) return;
  document.getElementById('inboxPanel').classList.add('mobile-hidden');
  document.getElementById('detailPanel').classList.add('mobile-visible');
  document.getElementById('mobileBackBtn').style.display = 'flex';
  window.scrollTo(0, 0);
}

function closeMobileThread() {
  document.getElementById('inboxPanel').classList.remove('mobile-hidden');
  document.getElementById('detailPanel').classList.remove('mobile-visible');
  document.getElementById('mobileBackBtn').style.display = 'none';
  activeThreadId = null;
  renderInbox();
  window.scrollTo(0, 0);
}

const _origLoadThread = loadThread;
window.loadThread = async (threadId, silent = false) => {
  await _origLoadThread(threadId, silent);
  if (!silent) openMobileThread();
};

// ── @ MENTION PICKER ──────────────────────────────────────────────────────────
(function() {
  const textarea = document.getElementById('replyBody');
  const picker = document.getElementById('mention-picker');
  let mentionStart = -1;

  textarea.addEventListener('keyup', function(e) {
    const val = textarea.value;
    const pos = textarea.selectionStart;
    const textBefore = val.slice(0, pos);
    const atIdx = textBefore.lastIndexOf('@');

    if (atIdx === -1 || (atIdx > 0 && /\S/.test(val[atIdx - 1]))) { hidePicker(); return; }

    const query = textBefore.slice(atIdx + 1).toLowerCase();
    if (query.includes(' ') && query.split(' ').length > 2) { hidePicker(); return; }

    mentionStart = atIdx;
    const matches = firmUsers.filter(u => {
      const name = (u.name || u.email || '').toLowerCase();
      return name.includes(query);
    }).slice(0, 8);

    if (!matches.length) { hidePicker(); return; }

    picker.innerHTML = matches.map(u => {
      const name = u.name || u.email;
      const initials = name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
      return `<div class="mention-item" data-name="${name.replace(/"/g,'')}" style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.75rem;cursor:pointer;font-size:0.85rem;transition:background 0.1s;">
        <div style="width:28px;height:28px;border-radius:50%;background:rgba(201,168,76,0.15);color:var(--gold);display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0;">${initials}</div>
        <span>${name}</span>
      </div>`;
    }).join('');

    // Position above the textarea, anchored to its bottom edge via fixed coords
    const taRect = textarea.getBoundingClientRect();
    picker.style.position = 'fixed';
    picker.style.left = taRect.left + 'px';
    picker.style.width = taRect.width + 'px';
    picker.style.display = 'block';
    // Place above — after display so we know picker height
    requestAnimationFrame(() => {
      const ph = picker.offsetHeight;
      picker.style.top = (taRect.top - ph - 6) + 'px';
    });

    picker.querySelectorAll('.mention-item').forEach(item => {
      item.addEventListener('mouseenter', () => item.style.background = 'rgba(201,168,76,0.1)');
      item.addEventListener('mouseleave', () => item.style.background = '');
      item.addEventListener('mousedown', (ev) => { ev.preventDefault(); insertMention(item.dataset.name); });
    });
  });

  textarea.addEventListener('keydown', function(e) {
    if (picker.style.display === 'none') return;
    if (e.key === 'Escape') { hidePicker(); e.preventDefault(); }
  });

  textarea.addEventListener('blur', function() { setTimeout(hidePicker, 150); });

  function hidePicker() { picker.style.display = 'none'; mentionStart = -1; }

  function insertMention(name) {
    const val = textarea.value;
    const pos = textarea.selectionStart;
    const before = val.slice(0, mentionStart);
    const after = val.slice(pos);
    textarea.value = before + '@' + name + ' ' + after;
    const newPos = mentionStart + name.length + 2;
    textarea.setSelectionRange(newPos, newPos);
    textarea.focus();
    hidePicker();
  }
})();

// ── Shift+Enter to send ───────────────────────────────────────────────────────
document.getElementById('replyBody').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && e.shiftKey) { e.preventDefault(); sendReply(); }
});

// ── Service Worker ─────────────────────────────────────────────────────────────
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(() => {});
}

// Load firm users for @mention picker immediately
apiFetch('/firms/team').then(r => r.json()).then(users => { firmUsers = users || []; }).catch(() => {});

// Show empty state immediately — no spinner on initial load
document.getElementById('inboxList').innerHTML = '<div style="color:var(--muted);padding:1.5rem 1rem;font-size:0.85rem;">No active threads.</div>';
loadInbox(false);
</script>

