<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
    /* Messages needs the main area to be a side-by-side flex row */
    .main { display: flex; flex-direction: row; height: calc(100vh - var(--header-h)); overflow: hidden; }

    .inbox-panel {
      width: 300px; flex-shrink: 0; border-right: 1px solid var(--border);
      display: flex; flex-direction: column; height: 100%; overflow: hidden;
    }
    .inbox-header {
      padding: 1.25rem 1rem 0.75rem;
      border-bottom: 1px solid var(--border);
      background: var(--card);
    }
    .inbox-header h2 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; }
    .inbox-search {
      width: 100%; background: var(--input-bg); border: 1px solid var(--border);
      color: var(--text); border-radius: 6px; padding: 0.4rem 0.6rem; font-size: 0.82rem;
      margin-bottom: 0.75rem;
    }
    .inbox-search:focus { outline: none; border-color: var(--gold); }
    .filter-tabs { display: flex; gap: 0.25rem; flex-wrap: wrap; }
    .filter-tab {
      padding: 0.2rem 0.6rem; font-size: 0.72rem; border-radius: 4px; cursor: pointer;
      border: 1px solid var(--border); color: var(--muted); background: transparent; transition: all 0.15s;
    }
    .filter-tab.active { background: var(--gold); color: var(--navy); border-color: var(--gold); font-weight: 700; }
    .filter-tab:hover:not(.active) { color: var(--text); }

    .inbox-list { flex: 1; overflow-y: auto; padding: 0.5rem 0; }
    .thread-card {
      padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.12s;
    }
    .thread-card:hover { background: rgba(201,168,76,0.05); }
    .thread-card.active { background: rgba(201,168,76,0.1); border-left: 3px solid var(--gold); }
    .thread-card-name { font-size: 0.85rem; font-weight: 600; color: var(--text); display: flex; justify-content: space-between; }
    .thread-card-subject { font-size: 0.78rem; color: var(--muted); margin-top: 0.1rem; }
    .thread-card-preview { font-size: 0.75rem; color: var(--muted); margin-top: 0.15rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .thread-card-meta { display: flex; gap: 0.4rem; align-items: center; margin-top: 0.3rem; flex-wrap: wrap; }
    .thread-card-actions { display: none; gap: 0.35rem; margin-top: 0.4rem; justify-content: flex-end; }
    .thread-card:hover .thread-card-actions { display: flex; }
    .resolve-btn { font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 4px; cursor: pointer; border: 1px solid; }
    .resolve-me { background: transparent; border-color: var(--muted); color: var(--muted); }
    .resolve-me:hover { border-color: var(--gold); color: var(--gold); }
    .resolve-all { background: transparent; border-color: var(--green); color: var(--green); }
    .resolve-all:hover { background: rgba(62,207,142,0.1); }
    .status-badge { font-size: 0.65rem; padding: 0.1rem 0.35rem; border-radius: 4px; color: #fff; }
    .status-badge.active { background: #c9a84c; }
    .status-badge.open { background: #c9a84c; }
    .status-badge.waiting { background: #c9a84c; }
    .status-badge.resolved { background: #4caf50; }
    .co-tag { font-size: 0.65rem; padding: 0.1rem 0.35rem; border-radius: 4px; background: rgba(255,255,255,0.08); color: var(--muted); }
    .unread-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); margin-left: auto; flex-shrink: 0; }

    /* ── THREAD DETAIL ── */
    .detail-panel {
      flex: 1; display: flex; flex-direction: column; height: 100%; overflow: hidden;
    }
    .detail-header {
      padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--card);
      display: flex; align-items: flex-start; gap: 1rem; flex-wrap: wrap;
    }
    .detail-header-left { flex: 1; }
    .detail-header-person { font-size: 1rem; font-weight: 700; color: var(--text); }
    .detail-header-person a { color: var(--gold); text-decoration: none; }
    .detail-header-person a:hover { text-decoration: underline; }
    .detail-header-subject { font-size: 0.85rem; color: var(--muted); margin-top: 0.15rem; }
    .detail-header-controls { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
    .detail-header-controls select {
      font-size: 0.78rem; background: var(--charcoal); color: var(--text);
      border: 1px solid var(--border); border-radius: 4px; padding: 0.25rem 0.4rem;
    }
    .company-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; align-items: center; margin-top: 0.5rem; }
    .co-tag-rm { font-size: 0.65rem; padding: 0.1rem 0.35rem; border-radius: 4px; background: rgba(255,255,255,0.08); color: var(--muted); display: flex; align-items: center; gap: 0.2rem; }
    .co-tag-rm button { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.75rem; padding: 0; line-height: 1; }
    .co-tag-rm button:hover { color: #e55; }


    .detail-messages {
      flex: 1; overflow-y: auto; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1rem;
    }
    .msg-bubble-wrap { display: flex; flex-direction: column; }
    .msg-bubble-wrap.staff { align-items: flex-end; }
    .msg-bubble-wrap.client { align-items: flex-start; }
    .msg-bubble {
      max-width: 75%; padding: 0.6rem 0.9rem; border-radius: 12px; font-size: 0.875rem; line-height: 1.5; word-break: break-word;
    }
    .msg-bubble.staff { background: var(--gold); color: var(--navy); }
    .msg-bubble.client { background: var(--charcoal); color: var(--text); border: 1px solid var(--border); }
    .msg-bubble.internal { background: rgba(255,200,0,0.1); border: 1px dashed var(--gold); color: var(--text); }
    .msg-meta { font-size: 0.68rem; color: var(--muted); margin-top: 0.15rem; }
    .msg-internal-label { font-size: 0.62rem; color: var(--gold); margin-bottom: 0.15rem; }
    .detail-empty { flex: 1; display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 0.9rem; flex-direction: column; gap: 0.5rem; }
    .detail-empty .de-icon { font-size: 2.5rem; }

    /* ── REPLY BOX ── */
    .reply-box {
      padding: 1rem 1.5rem; border-top: 1px solid var(--border); background: var(--card);
    }
    .reply-box-controls { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    .reply-box-controls label { font-size: 0.78rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; cursor: pointer; }
    .reply-box textarea {
      width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text);
      border-radius: 8px; padding: 0.6rem 0.75rem; font-size: 0.88rem; font-family: inherit;
      resize: none; min-height: 80px; margin-bottom: 0.5rem;
    }
    .reply-box textarea:focus { outline: none; border-color: var(--gold); }
    .reply-box-actions { display: flex; gap: 0.5rem; }
    .btn { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.4rem 0.85rem; border-radius: 6px; font-size: 0.82rem; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: opacity 0.15s; }
    .btn:hover { opacity: 0.88; }
    .btn-gold { background: var(--gold); color: var(--navy); }
    .btn-outline { background: transparent; color: var(--muted); border: 1px solid var(--border); }
    .btn-outline:hover { color: var(--text); border-color: var(--gold); }
    .btn-sm { padding: 0.3rem 0.65rem; font-size: 0.77rem; }

    /* ── ATTACHMENT CHIPS ── */
    .attach-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.4rem; }
    .attach-chip-input { display: inline-flex; align-items: center; gap: 0.3rem; background: rgba(255,255,255,0.07); border: 1px solid var(--border); border-radius: 4px; padding: 0.15rem 0.5rem; font-size: 0.75rem; color: var(--text); }
    .attach-chip-input button { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.8rem; padding: 0; line-height: 1; }
    .attach-chip-input button:hover { color: #e55; }
    .btn-attach { background: transparent; border: 1px solid var(--border); color: var(--muted); border-radius: 6px; padding: 0.4rem 0.7rem; font-size: 0.82rem; cursor: pointer; transition: all 0.15s; }
    .btn-attach:hover { color: var(--text); border-color: var(--gold); }
    .msg-attachments { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
    .attachment-chip { display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(0,0,0,0.25); border: 1px solid rgba(0,0,0,0.2); border-radius: 6px; padding: 0.25rem 0.6rem; font-size: 0.75rem; color: #fff; text-decoration: none; font-weight: 500; }
    .attachment-chip:hover { background: rgba(0,0,0,0.4); color: #fff; }
    .att-size { color: var(--muted); font-size: 0.7rem; }

    /* ── EMPTY STATE ── */
    .no-thread-selected {
      flex: 1; display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 0.75rem; color: var(--muted);
    }
    .no-thread-selected .nts-icon { font-size: 3rem; opacity: 0.4; }

    /* ── LOADING ── */
    .spinner { display: inline-block; width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 768px) {
      .header-logo .hl-name { display: none; }
      .inbox-panel { width: 240px; }
    }

    /* ── MOBILE (iPhone) ── */
    @media (max-width: 600px) {
      /* Fixed full-screen container */
      .main {
        position: fixed !important;
        left: 0 !important;
        top: var(--header-h) !important;
        right: 0 !important;
        bottom: 0 !important;
        overflow: hidden !important;
        display: flex !important;
        flex-direction: column !important;
      }

      /* Inbox: fills container, scrolls internally */
      .inbox-panel {
        width: 100% !important;
        flex: 1 !important;
        overflow-y: auto !important;
        -webkit-overflow-scrolling: touch !important;
        border-right: none !important;
        display: flex !important;
        flex-direction: column !important;
        height: 100% !important;
      }
      .inbox-list { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
      .inbox-panel.mobile-hidden { display: none !important; }

      /* Detail: fills container, flex column so reply box stays pinned */
      .detail-panel {
        width: 100% !important;
        flex: 1 !important;
        overflow: hidden !important;
        display: none !important;
        flex-direction: column !important;
        height: 100% !important;
      }
      .detail-panel.mobile-visible { display: flex !important; }

      /* Thread view fills remaining space */
      #threadView {
        flex: 1 !important;
        display: flex !important;
        flex-direction: column !important;
        overflow: hidden !important;
        min-height: 0 !important;
      }

      /* Messages scroll, reply box stays at bottom */
      .detail-messages {
        flex: 1 !important;
        overflow-y: auto !important;
        -webkit-overflow-scrolling: touch !important;
        padding: 1rem !important;
        min-height: 0 !important;
      }
      .detail-header { flex-shrink: 0 !important; padding: 0.75rem 1rem; flex-wrap: wrap; }
      .reply-box { flex-shrink: 0 !important; padding: 0.75rem 1rem; }
      .reply-box textarea { min-height: 60px; font-size: 1rem; }

      /* Back button */
      .mobile-back-btn {
        display: flex !important;
        flex-shrink: 0 !important;
        align-items: center;
        gap: 0.4rem;
        background: none;
        border: none;
        color: var(--gold);
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border);
        width: 100%;
      }

      .thread-card { padding: 1rem; }
      .thread-card-actions { display: flex !important; }
      .btn { padding: 0.55rem 1rem; }
    }
</style>

<main class="main">

  <!-- Inbox panel -->
  <div class="inbox-panel" id="inboxPanel">
    <div class="inbox-header">
      <h2>💬 Messages</h2>
      <input type="text" class="inbox-search" id="searchBox" placeholder="Search by name…" oninput="filterThreads()">
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="active" onclick="setFilter('active', this)">Active</button>
        <button class="filter-tab" data-filter="resolved" onclick="setFilter('resolved', this)">Resolved</button>
      </div>
    </div>
    <div class="inbox-list" id="inboxList">
      <div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>
    </div>
  </div>

  <!-- Thread detail -->
  <div class="detail-panel" id="detailPanel">
    <button class="mobile-back-btn" id="mobileBackBtn" style="display:none;" onclick="closeMobileThread()">← Back to Messages</button>
    <div class="no-thread-selected" id="noThreadSelected">
      <div class="nts-icon">💬</div>
      <div>Select a thread to read messages</div>
    </div>

    <!-- Thread view (hidden until thread selected) -->
    <div id="threadView" style="display:none;flex:1;display:none;flex-direction:column;height:100%;">
      <div class="detail-header" id="detailHeader">
        <!-- filled dynamically -->
      </div>
      <div class="detail-messages" id="detailMessages">
        <div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>
      </div>
      <div id="typingIndicator" style="display:none;padding:0.3rem 1rem;font-size:0.78rem;color:var(--muted);font-style:italic;"></div>
      <div class="reply-box" id="replyBox">
        <div class="reply-box-controls">
          <label><input type="checkbox" id="internalToggle"> 🔒 Internal note</label>
          <div style="flex:1;"></div>
        </div>
        <textarea id="replyBody" placeholder="Write a reply…" rows="3"></textarea>
        <div class="attach-chips" id="attachChips"></div>
        <input type="file" id="attachFileInput" multiple style="display:none;" onchange="handleAttachFiles(this.files)">
        <div class="reply-box-actions">
          <button class="btn btn-gold btn-sm" onclick="sendReply()">Send Reply</button>
          <button class="btn-attach" onclick="document.getElementById('attachFileInput').click()">📎 Attach</button>
          <button class="btn btn-outline btn-sm" onclick="markResolved()">✅ Resolve</button>
        </div>
      </div>
    </div>
  </div>

<%- include('partials/shell-globals') %>
<script src="https://js.pusher.com/8.3.0/pusher.min.js"></script>

<script>
const token = localStorage.getItem('dl_token');
if (!token) window.location.href = '/login';

let allThreads = [];
let activeFilter = 'active';
let activeThreadId = null;
let firmUsers = [];
let attachedFiles = [];

// ── Pusher real-time + 30s polling fallback ───────────────────────────────────
setInterval(() => loadInbox(), 30000);

// Decode firmId from JWT (already verified server-side, just reading payload here)
const _jwtPayload = JSON.parse(atob(token.split('.')[1]));
const _firmId = _jwtPayload.firmId || _jwtPayload.id;

const _pusher = new Pusher('6ee61a25e438d5bc4751', {
  cluster: 'us2',
  authEndpoint: '/pusher/auth/staff?token=' + encodeURIComponent(token),
});
const _firmChannel = _pusher.subscribe(`private-firm-${_firmId}`);

_firmChannel.bind('pusher:subscription_succeeded', () => console.log('[pusher] subscribed'));
_firmChannel.bind('pusher:subscription_error', (e) => console.warn('[pusher] auth error:', e));

_firmChannel.bind('message-new', ({ threadId, senderType }) => {
  loadInbox();
  const replyBox = document.getElementById('replyBody');
  if (activeThreadId === threadId && !(replyBox && replyBox.value.trim()) && !_justSent && senderType !== 'staff') {
    loadThread(threadId, true);
  }
});
_firmChannel.bind('thread-new', () => loadInbox());

// When staff types, emit to the active thread's portal channel
let _staffTypingTimer = null;
document.addEventListener('input', (e) => {
  if (e.target.id !== 'replyBody' || !activeThreadId) return;
  clearTimeout(_staffTypingTimer);
  _staffTypingTimer = setTimeout(() => {
    // Need person_id for the portal channel — stored when thread loads
    if (window._activePersonId) {
      const portalCh = _pusher.channel(`private-portal-${_firmId}-${window._activePersonId}`);
      if (portalCh) portalCh.trigger('client-typing', { threadId: activeThreadId, name: 'Advisor' });
    }
  }, 300);
});
// ─────────────────────────────────────────────────────────────────────────────

async function apiFetch(url, opts = {}) {
  // If body is FormData, don't set Content-Type (browser sets multipart boundary)
  const isFormData = opts.body instanceof FormData;
  return fetch(url, {
    ...opts,
    headers: {
      'Authorization': 'Bearer ' + token,
      ...(isFormData ? {} : { 'Content-Type': 'application/json' }),
      ...(opts.headers || {}),
    },
  });
}

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function relTime(ts) {
  if (!ts) return '';
  const d = new Date(ts), diff = Date.now() - d;
  if (diff < 60000) return 'just now';
  if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
  if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
  if (diff < 604800000) return Math.floor(diff/86400000) + 'd ago';
  return d.toLocaleDateString();
}

function statusColor(s) {
  if (s === 'resolved') return '#4caf50';
  return '#c9a84c'; // active (open/waiting both show as active)
}

function displayStatus(s) {
  if (s === 'resolved') return 'Resolved';
  return 'Active';
}

let _inboxLoading = false;

// Load threads — silent refresh, no flash, no spinner on poll
async function dismissThread(threadId) {
  try {
    await apiFetch(`/api/messages/${threadId}/dismiss`, { method: 'POST' });
    allThreads = allThreads.filter(t => t.id !== threadId);
    if (activeThreadId === threadId) {
      activeThreadId = null;
      document.getElementById('threadView').style.display = 'none';
      document.getElementById('noThreadSelected').style.display = '';
    }
    renderInbox();
  } catch(e) { window.toast(e.message, 'error'); }
}

async function resolveThread(threadId) {
  try {
    await apiFetch(`/api/messages/${threadId}/status`, { method: 'PUT', body: JSON.stringify({ status: 'resolved' }) });
    allThreads = allThreads.filter(t => t.id !== threadId);
    if (activeThreadId === threadId) {
      activeThreadId = null;
      document.getElementById('threadView').style.display = 'none';
      document.getElementById('noThreadSelected').style.display = '';
    }
    renderInbox();
  } catch(e) { window.toast(e.message, 'error'); }
}

async function loadInbox(showSpinner = false) {
  if (_inboxLoading) return; // prevent concurrent fetches
  _inboxLoading = true;
  try {
    if (showSpinner) {
      document.getElementById('inboxList').innerHTML = '<div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>';
    }
    const all = activeFilter === 'resolved';
    const res = await apiFetch('/api/messages' + (all ? '?all=true' : ''));
    const freshThreads = await res.json();
    // Only re-render if data changed (avoid unnecessary DOM churn)
    const freshJson = JSON.stringify(freshThreads);
    if (freshJson !== JSON.stringify(allThreads)) {
      allThreads = freshThreads;
      renderInbox();
    }
    // Load firm users once if empty
    if (!firmUsers.length) {
      const usersRes = await apiFetch('/firms/team').catch(() => ({ json: () => [] }));
      try { firmUsers = await usersRes.json(); } catch(e) { firmUsers = []; }
    }
  } catch(e) {
    if (showSpinner) {
      document.getElementById('inboxList').innerHTML = '<div style="color:var(--muted);padding:1rem;font-size:0.85rem;">Failed to load inbox.</div>';
    }
  } finally {
    _inboxLoading = false;
  }
}

function setFilter(f, el) {
  activeFilter = f;
  allThreads = []; // force re-render on filter change
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  loadInbox(true); // show spinner on intentional filter switch
}

function filterThreads() {
  renderInbox();
}

function renderInbox() {
  const q = (document.getElementById('searchBox').value || '').toLowerCase();
  let threads = allThreads;

  // Apply filter — active = open or waiting, resolved = resolved
  if (activeFilter === 'resolved') threads = threads.filter(t => t.status === 'resolved');
  else threads = threads.filter(t => t.status !== 'resolved'); // active (default)

  // Search
  if (q) threads = threads.filter(t => {
    const name = ((t.person?.firstName || '') + ' ' + (t.person?.lastName || '')).toLowerCase();
    return name.includes(q) || (t.subject || '').toLowerCase().includes(q);
  });

  if (!threads.length) {
    document.getElementById('inboxList').innerHTML = '<div style="color:var(--muted);padding:1.5rem 1rem;font-size:0.85rem;">No threads found.</div>';
    return;
  }

  document.getElementById('inboxList').innerHTML = threads.map(t => {
    const name = esc((t.person?.firstName || '') + ' ' + (t.person?.lastName || ''));
    const companies = (t.companies || []).map(c => `<span class="co-tag">${esc(c.name)}</span>`).join('');
    const hasAttachments = t.hasAttachments;
    return `<div class="thread-card${t.id === activeThreadId ? ' active' : ''}" onclick="loadThread(${t.id})">
      <div class="thread-card-name">
        <span>${name}${hasAttachments ? ' 📎' : ''}</span>
        <span style="font-size:0.7rem;color:var(--muted);">${relTime(t.lastMessageAt)}</span>
      </div>
      <div class="thread-card-subject">${esc(t.subject || '(no subject)')}</div>
      <div class="thread-card-preview">${esc(t.lastPreview || '')}</div>
      <div class="thread-card-meta">
        <span class="status-badge ${t.status === 'resolved' ? 'resolved' : 'active'}">${t.status === 'resolved' ? 'Resolved' : 'Active'}</span>
        ${companies}
        ${t.unreadCount > 0 ? `<span class="unread-dot" title="${t.unreadCount} unread"></span>` : ''}
      </div>
      <div class="thread-card-actions" onclick="event.stopPropagation();">
        <button class="resolve-btn resolve-me" onclick="dismissThread(${t.id})" title="Remove from my inbox only">Resolve Me</button>
        <button class="resolve-btn resolve-all" onclick="resolveThread(${t.id})" title="Resolve for everyone">Resolve All</button>
      </div>
    </div>`;
  }).join('');
}

// Load thread detail
// silent=true means called from socket event — skip spinner/scroll jank if user is composing
async function loadThread(threadId, silent = false) {
  activeThreadId = threadId;
  renderInbox(); // re-render to highlight active

  document.getElementById('noThreadSelected').style.display = 'none';
  const tv = document.getElementById('threadView');
  tv.style.display = 'flex';
  tv.style.flexDirection = 'column';
  tv.style.flex = '1';
  tv.style.height = '100%';

  if (!silent) {
    document.getElementById('detailMessages').innerHTML = '<div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>';
    document.getElementById('detailHeader').innerHTML = '';
  }

  try {
    const res = await apiFetch(`/api/messages/${threadId}`);
    const data = await res.json();

    // Subscribe to this person's portal channel for typing indicators
    if (data.person?.id && data.person.id !== window._activePersonId) {
      window._activePersonId = data.person.id;
      const portalChName = `private-portal-${_firmId}-${data.person.id}`;
      if (!_pusher.channel(portalChName)) {
        const ch = _pusher.subscribe(portalChName);
        ch.bind('client-typing', ({ name }) => {
          const el = document.getElementById('typingIndicator');
          if (el) { el.textContent = `${name || 'Client'} is typing…`; el.style.display = 'block'; }
          clearTimeout(window._typingTimer);
          window._typingTimer = setTimeout(() => { if (el) el.style.display = 'none'; }, 3000);
        });
      } else {
        window._activePersonId = data.person.id;
      }
    }

    // Header
    const companies = (data.companies || []).map(c =>
      `<span class="co-tag-rm">${esc(c.company_name)} <button onclick="removeCompanyTag(${threadId}, ${c.company_id})">×</button></span>`
    ).join('');

    const assignOpts = (firmUsers.length ? firmUsers : []).map(u =>
      `<option value="${u.id}" ${data.assignedTo === u.id ? 'selected' : ''}>${esc(u.display_name || u.name)}</option>`
    ).join('');

    document.getElementById('detailHeader').innerHTML = `
      <div class="detail-header-left">
        <div class="detail-header-person">
          <a href="/crm/person/${data.person?.id}">${esc((data.person?.firstName||'')+' '+(data.person?.lastName||''))}</a>
          <span class="status-badge ${data.status === 'resolved' ? 'resolved' : 'active'}" style="margin-left:0.5rem;">${data.status === 'resolved' ? 'Resolved' : 'Active'}</span>
        </div>
        <div class="detail-header-subject">${esc(data.subject || '(no subject)')} · <span style="color:var(--gold);">${data.category}</span></div>
        ${companies ? `<div class="company-tags" id="companyTags-${threadId}">${companies}</div>` : ''}
      </div>

    `;

    // Messages — append-only in silent mode, full replace on initial load
    const msgs = data.messages || [];
    const msgContainer = document.getElementById('detailMessages');
    if (!msgs.length) {
      if (!silent) msgContainer.innerHTML = '<div style="color:var(--muted);padding:1rem;font-size:0.85rem;">No messages yet.</div>';
    } else if (silent) {
      // Append only new messages
      const existingIds = new Set([...msgContainer.querySelectorAll('[data-msg-id]')].map(el => parseInt(el.dataset.msgId)));
      let appended = false;
      for (const m of msgs) {
        if (!existingIds.has(m.id)) {
          const isStaff = m.senderType === 'staff';
          const isInternal = m.isInternal;
          const side = isStaff ? 'staff' : 'client';
          const bubbleClass = isInternal ? 'internal' : side;
          const attachmentsHtml = (m.attachments||[]).length > 0
            ? `<div class="msg-attachments">${m.attachments.map(a => `<a class="attachment-chip" href="#" onclick="downloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}</a>`).join('')}</div>` : '';
          msgContainer.insertAdjacentHTML('beforeend', `<div class="msg-bubble-wrap ${side}" data-msg-id="${m.id}">
            ${isInternal ? '<div class="msg-internal-label">🔒 Internal note</div>' : ''}
            <div class="msg-bubble ${bubbleClass}">${m.body ? esc(m.body).replace(/\n/g,'<br>') : ''}${attachmentsHtml}</div>
            <div class="msg-meta">${esc(m.senderName||'')} · ${relTime(m.createdAt)}</div>
          </div>`);
          appended = true;
        }
      }
      if (appended) msgContainer.scrollTop = msgContainer.scrollHeight;
    } else {
      msgContainer.innerHTML = msgs.map(m => {
        const isStaff = m.senderType === 'staff';
        const isInternal = m.isInternal;
        const side = isStaff ? 'staff' : 'client';
        const bubbleClass = isInternal ? 'internal' : side;
        const attachmentsHtml = (m.attachments || []).length > 0
          ? `<div class="msg-attachments">${(m.attachments).map(a => {
              const size = a.sizeBytes ? ' <span class="att-size">(' + formatBytes(a.sizeBytes) + ')</span>' : '';
              return `<a class="attachment-chip" href="#" onclick="downloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}${size}</a>`;
            }).join('')}</div>`
          : '';
        return `<div class="msg-bubble-wrap ${side}" data-msg-id="${m.id}">
          ${isInternal ? '<div class="msg-internal-label">🔒 Internal note</div>' : ''}
          <div class="msg-bubble ${bubbleClass}">${m.body ? esc(m.body).replace(/\n/g,'<br>') : ''}${attachmentsHtml}</div>
          <div class="msg-meta">${esc(m.senderName || '')} · ${relTime(m.createdAt)}</div>
        </div>`;
      }).join('');
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    if (!silent) {
      document.getElementById('replyBody').value = '';
      attachedFiles = [];
      renderAttachChips();
    }
  } catch(e) {
    document.getElementById('detailMessages').innerHTML = '<div style="color:var(--muted);padding:1rem;">Failed to load thread.</div>';
  }
}

function handleAttachFiles(fileList) {
  for (const f of Array.from(fileList)) {
    if (attachedFiles.length >= 8) { alert('Maximum 8 files per message'); break; }
    attachedFiles.push(f);
  }
  // Reset input so same file can be re-selected
  document.getElementById('attachFileInput').value = '';
  renderAttachChips();
}

function removeAttachFile(idx) {
  attachedFiles.splice(idx, 1);
  renderAttachChips();
}

function renderAttachChips() {
  const el = document.getElementById('attachChips');
  if (!el) return;
  el.innerHTML = attachedFiles.map((f, i) =>
    `<span class="attach-chip-input">📎 ${esc(f.name)} <button onclick="removeAttachFile(${i})">×</button></span>`
  ).join('');
}

function formatBytes(b) {
  if (!b) return '0 B';
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
  return (b/1048576).toFixed(1) + ' MB';
}

async function downloadAttachment(documentId) {
  try {
    const res = await apiFetch(`/api/messages/attachments/${documentId}/download`);
    const data = await res.json();
    if (data.url) window.open(data.url, '_blank');
    else alert('Download failed');
  } catch(e) { alert('Failed to download attachment'); }
}

async function sendReply() {
  if (!activeThreadId) return;
  const body = document.getElementById('replyBody').value.trim();
  if (!body && attachedFiles.length === 0) return;
  const isInternal = document.getElementById('internalToggle').checked;
  try {
    const fd = new FormData();
    fd.append('body', body);
    fd.append('is_internal', isInternal ? 'true' : 'false');
    attachedFiles.forEach(f => fd.append('files', f));
    await apiFetch(`/api/messages/${activeThreadId}/reply`, {
      method: 'POST',
      body: fd,
    });
    document.getElementById('replyBody').value = '';
    document.getElementById('internalToggle').checked = false;
    attachedFiles = [];
    renderAttachChips();
    _justSent = true;
    setTimeout(() => { _justSent = false; }, 3000);
    await loadThread(activeThreadId, true); // silent reload — no spinner
    await loadInbox();
  } catch(e) { alert('Failed to send reply'); }
}
let _justSent = false;

async function updateStatus(threadId, status) {
  await apiFetch(`/api/messages/${threadId}/status`, { method: 'PUT', body: JSON.stringify({ status }) });
  await loadInbox();
  // reload thread to reflect new status badge
  loadThread(threadId);
}

async function markResolved() {
  if (!activeThreadId) return;
  await updateStatus(activeThreadId, 'resolved');
}

async function assignThread(threadId, userId) {
  await apiFetch(`/api/messages/${threadId}/assign`, {
    method: 'PUT',
    body: JSON.stringify({ assigned_to: userId ? parseInt(userId) : null }),
  });
}

async function removeCompanyTag(threadId, companyId) {
  await apiFetch(`/api/messages/${threadId}/companies/${companyId}`, { method: 'DELETE' });
  loadThread(threadId);
}


// ── MOBILE SLIDE NAVIGATION ──────────────────────────────────────────────────
const _isMobile = () => window.innerWidth <= 600;

function openMobileThread() {
  if (!_isMobile()) return;
  document.getElementById('inboxPanel').classList.add('mobile-hidden');
  document.getElementById('detailPanel').classList.add('mobile-visible');
  document.getElementById('mobileBackBtn').style.display = 'flex';
  window.scrollTo(0, 0);
}

function closeMobileThread() {
  document.getElementById('inboxPanel').classList.remove('mobile-hidden');
  document.getElementById('detailPanel').classList.remove('mobile-visible');
  document.getElementById('mobileBackBtn').style.display = 'none';
  activeThreadId = null;
  renderInbox();
  window.scrollTo(0, 0);
}

// Patch loadThread to trigger mobile slide
const _origLoadThread = loadThread;
window._loadingThread = false;
// Override inline — we intercept after the call via a wrapper below:
const _loadThreadWithMobile = async (threadId, silent = false) => {
  await _origLoadThread(threadId, silent);
  if (!silent) openMobileThread();
};
// Replace global
window.loadThread = _loadThreadWithMobile;
// Re-bind inbox list clicks (renderInbox uses onclick="loadThread(...)" which reads window.loadThread)
// Works automatically since renderInbox references loadThread by name at call time.
// ─────────────────────────────────────────────────────────────────────────────

// ── SERVICE WORKER ────────────────────────────────────────────────────────────
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(() => {});
}
// ─────────────────────────────────────────────────────────────────────────────

// Initial load — show spinner on first load only
loadInbox(true);
</script>

