<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title %> — DarkLion Help</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0f1923; --shell: #141d26; --card: #1a2535; --charcoal: #1c2b3a;
      --gold: #c9a84c; --gold-light: #e2c068;
      --text: #e8edf2; --muted: #8fa3b8;
      --border: rgba(201,168,76,0.22);
      --green: #3ecf8e; --red: #f56565;
      --sidebar-w: 280px; --header-h: 58px;
    }
    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--navy); color: var(--text); min-height: 100vh; }

    /* === HEADER === */
    .help-header {
      position: fixed; top: 0; left: 0; right: 0; height: var(--header-h);
      background: var(--shell); border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 1rem; padding: 0 1.5rem;
      z-index: 100;
    }
    .help-header-logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
    .help-header-logo img { height: 28px; }
    .help-header-logo span { font-size: 1rem; font-weight: 700; color: var(--text); }
    .help-header-logo .badge { font-size: 0.65rem; font-weight: 700; color: var(--gold); background: rgba(201,168,76,0.12); border: 1px solid rgba(201,168,76,0.25); border-radius: 4px; padding: 0.1rem 0.4rem; margin-left: 0.3rem; }
    .help-header-search {
      flex: 1; max-width: 480px; margin-left: 2rem; position: relative;
    }
    .help-header-search input {
      width: 100%; height: 36px; background: var(--charcoal); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text); padding: 0 1rem 0 2.4rem;
      font-size: 0.88rem; outline: none; transition: border-color 0.2s;
    }
    .help-header-search input:focus { border-color: var(--gold); }
    .help-header-search input::placeholder { color: var(--muted); }
    .help-header-search .search-icon { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.85rem; pointer-events: none; }
    .help-header-back { margin-left: auto; font-size: 0.82rem; color: var(--muted); text-decoration: none; display: flex; align-items: center; gap: 0.4rem; }
    .help-header-back:hover { color: var(--gold); }

    /* === LAYOUT === */
    .help-layout { display: flex; padding-top: var(--header-h); min-height: 100vh; }

    /* === SIDEBAR === */
    .help-sidebar {
      width: var(--sidebar-w); flex-shrink: 0;
      position: fixed; top: var(--header-h); left: 0; bottom: 0;
      overflow-y: auto; background: var(--shell);
      border-right: 1px solid var(--border);
      padding: 1.25rem 0 2rem;
    }
    .help-sidebar::-webkit-scrollbar { width: 4px; }
    .help-sidebar::-webkit-scrollbar-thumb { background: rgba(201,168,76,0.2); border-radius: 2px; }
    .sidebar-section { margin-bottom: 0.25rem; }
    .sidebar-section-title {
      font-size: 0.68rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--muted); padding: 0.75rem 1.25rem 0.35rem;
    }
    .sidebar-link {
      display: block; padding: 0.42rem 1.25rem 0.42rem 1.5rem;
      font-size: 0.84rem; color: var(--muted); text-decoration: none;
      border-left: 3px solid transparent; transition: all 0.15s;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .sidebar-link:hover { color: var(--text); background: rgba(201,168,76,0.05); }
    .sidebar-link.active { color: var(--gold); border-left-color: var(--gold); background: rgba(201,168,76,0.07); font-weight: 600; }
    .sidebar-divider { height: 1px; background: var(--border); margin: 0.75rem 1.25rem; }

    /* === MAIN CONTENT === */
    .help-main {
      flex: 1; margin-left: var(--sidebar-w);
      max-width: 820px; padding: 2.5rem 3rem 5rem;
    }

    /* === HOME PAGE === */
    .help-home-hero { margin-bottom: 3rem; }
    .help-home-hero h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .help-home-hero p { font-size: 1rem; color: var(--muted); line-height: 1.6; }
    .help-module-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 3rem; }
    .help-module-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 10px;
      padding: 1.25rem 1.25rem 1rem; text-decoration: none; color: var(--text);
      transition: border-color 0.2s, transform 0.15s;
    }
    .help-module-card:hover { border-color: var(--gold); transform: translateY(-2px); }
    .help-module-card .card-icon { font-size: 1.6rem; margin-bottom: 0.6rem; }
    .help-module-card .card-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; }
    .help-module-card .card-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

    /* === ARTICLE === */
    .article-breadcrumb { font-size: 0.78rem; color: var(--muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
    .article-breadcrumb a { color: var(--muted); text-decoration: none; }
    .article-breadcrumb a:hover { color: var(--gold); }
    .article-breadcrumb .sep { opacity: 0.5; }
    .article-title { font-size: 1.7rem; font-weight: 800; margin-bottom: 0.5rem; line-height: 1.3; }
    .article-meta { font-size: 0.78rem; color: var(--muted); margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
    .article-body h2 { font-size: 1.15rem; font-weight: 700; margin: 2rem 0 0.75rem; padding-top: 0.5rem; }
    .article-body h3 { font-size: 0.95rem; font-weight: 700; color: var(--gold); margin: 1.5rem 0 0.5rem; }
    .article-body p { font-size: 0.9rem; line-height: 1.75; color: #c8d6e5; margin-bottom: 1rem; }
    .article-body ul, .article-body ol { padding-left: 1.5rem; margin-bottom: 1rem; }
    .article-body li { font-size: 0.9rem; line-height: 1.75; color: #c8d6e5; margin-bottom: 0.25rem; }
    .article-body strong { color: var(--text); font-weight: 700; }
    .article-body code { background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2); border-radius: 4px; padding: 0.1em 0.4em; font-size: 0.85em; color: var(--gold-light); font-family: 'Cascadia Code', 'Fira Code', monospace; }
    .article-body pre { background: var(--charcoal); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem; overflow-x: auto; }
    .article-body pre code { background: none; border: none; padding: 0; font-size: 0.83rem; color: #c8d6e5; }
    .article-body a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }
    .article-body hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

    /* Screenshots */
    .help-screenshot { margin: 1.5rem 0 2rem; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); background: var(--charcoal); }
    .help-screenshot img { display: block; width: 100%; height: auto; }
    .help-screenshot figcaption { padding: 0.6rem 1rem; font-size: 0.78rem; color: var(--muted); border-top: 1px solid var(--border); font-style: italic; }

    /* Callout boxes */
    .callout { border-radius: 8px; padding: 0.9rem 1.1rem; margin-bottom: 1.25rem; font-size: 0.88rem; line-height: 1.6; display: flex; gap: 0.65rem; }
    .callout-icon { flex-shrink: 0; font-size: 1rem; margin-top: 0.05rem; }
    .callout.info { background: rgba(62,207,142,0.08); border-left: 3px solid var(--green); color: #c8d6e5; }
    .callout.warning { background: rgba(237,137,54,0.1); border-left: 3px solid var(--orange, #ed8936); color: #c8d6e5; }
    .callout.tip { background: rgba(201,168,76,0.08); border-left: 3px solid var(--gold); color: #c8d6e5; }

    /* Step list */
    .step-list { counter-reset: steps; list-style: none; padding: 0; margin-bottom: 1rem; }
    .step-list li { counter-increment: steps; display: flex; gap: 1rem; margin-bottom: 1rem; font-size: 0.9rem; line-height: 1.7; color: #c8d6e5; }
    .step-list li::before { content: counter(steps); flex-shrink: 0; width: 26px; height: 26px; background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.3); color: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 800; margin-top: 0.2rem; }

    /* Article nav */
    .article-nav { display: flex; justify-content: space-between; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); gap: 1rem; }
    .article-nav a { text-decoration: none; font-size: 0.82rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; max-width: 45%; }
    .article-nav a:hover { color: var(--gold); }
    .article-nav .nav-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.7; }
    .article-nav .nav-title { font-size: 0.88rem; font-weight: 600; color: var(--text); }
    .article-nav a:hover .nav-title { color: var(--gold); }
    .article-nav .next { text-align: right; margin-left: auto; }

    /* Search results */
    .search-results { display: none; position: absolute; top: calc(100% + 4px); left: 0; right: 0; background: var(--card); border: 1px solid var(--border); border-radius: 8px; z-index: 200; max-height: 360px; overflow-y: auto; box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
    .search-result-item { display: block; padding: 0.7rem 1rem; text-decoration: none; border-bottom: 1px solid rgba(201,168,76,0.08); }
    .search-result-item:last-child { border-bottom: none; }
    .search-result-item:hover { background: rgba(201,168,76,0.06); }
    .search-result-title { font-size: 0.88rem; font-weight: 600; color: var(--text); margin-bottom: 0.15rem; }
    .search-result-section { font-size: 0.75rem; color: var(--muted); }
    .search-result-snippet { font-size: 0.78rem; color: var(--muted); margin-top: 0.15rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .search-empty { padding: 1.25rem; text-align: center; color: var(--muted); font-size: 0.85rem; }

    /* Responsive */
    @media (max-width: 768px) {
      .help-sidebar { display: none; }
      .help-main { margin-left: 0; padding: 1.5rem 1.25rem 4rem; }
      .help-header-search { display: none; }
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header class="help-header">
  <a href="/help" class="help-header-logo">
    <img src="/favicon.png" alt="DarkLion">
    <span>DarkLion</span>
    <span class="badge">Help</span>
  </a>
  <div class="help-header-search">
    <span class="search-icon">🔍</span>
    <input type="text" id="help-search" placeholder="Search documentation…" autocomplete="off">
    <div class="search-results" id="search-results"></div>
  </div>
  <a href="/dashboard" class="help-header-back">← Back to DarkLion</a>
</header>

<div class="help-layout">

  <!-- SIDEBAR -->
  <nav class="help-sidebar">
    <div class="sidebar-section">
      <div class="sidebar-section-title">Getting Started</div>
      <a href="/help" class="sidebar-link<%= currentSlug === 'home' ? ' active' : '' %>">Welcome to DarkLion</a>
      <a href="/help/article/what-is-darklion" class="sidebar-link<%= currentSlug === 'what-is-darklion' ? ' active' : '' %>">What Is DarkLion?</a>
      <a href="/help/article/key-concepts" class="sidebar-link<%= currentSlug === 'key-concepts' ? ' active' : '' %>">Key Concepts</a>
      <a href="/help/article/first-client" class="sidebar-link<%= currentSlug === 'first-client' ? ' active' : '' %>">Your First Client</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">CRM</div>
      <a href="/help/article/crm-overview" class="sidebar-link<%= currentSlug === 'crm-overview' ? ' active' : '' %>">CRM Overview</a>
      <a href="/help/article/relationships" class="sidebar-link<%= currentSlug === 'relationships' ? ' active' : '' %>">Relationships</a>
      <a href="/help/article/people" class="sidebar-link<%= currentSlug === 'people' ? ' active' : '' %>">People</a>
      <a href="/help/article/companies" class="sidebar-link<%= currentSlug === 'companies' ? ' active' : '' %>">Companies</a>
      <a href="/help/article/search" class="sidebar-link<%= currentSlug === 'search' ? ' active' : '' %>">Search</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Documents</div>
      <a href="/help/article/documents-overview" class="sidebar-link<%= currentSlug === 'documents-overview' ? ' active' : '' %>">Documents Overview</a>
      <a href="/help/article/uploading-documents" class="sidebar-link<%= currentSlug === 'uploading-documents' ? ' active' : '' %>">Uploading Documents</a>
      <a href="/help/article/delivering-to-clients" class="sidebar-link<%= currentSlug === 'delivering-to-clients' ? ' active' : '' %>">Delivering to Clients</a>
      <a href="/help/article/document-folders" class="sidebar-link<%= currentSlug === 'document-folders' ? ' active' : '' %>">Folder Structure</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Client Portal</div>
      <a href="/help/article/portal-overview" class="sidebar-link<%= currentSlug === 'portal-overview' ? ' active' : '' %>">Portal Overview</a>
      <a href="/help/article/inviting-clients" class="sidebar-link<%= currentSlug === 'inviting-clients' ? ' active' : '' %>">Inviting Clients</a>
      <a href="/help/article/what-clients-see" class="sidebar-link<%= currentSlug === 'what-clients-see' ? ' active' : '' %>">What Clients See</a>
      <a href="/help/article/client-financials" class="sidebar-link<%= currentSlug === 'client-financials' ? ' active' : '' %>">Client Financials Upload</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Pipelines</div>
      <a href="/help/article/pipelines-overview" class="sidebar-link<%= currentSlug === 'pipelines-overview' ? ' active' : '' %>">Pipelines Overview</a>
      <a href="/help/article/creating-pipelines" class="sidebar-link<%= currentSlug === 'creating-pipelines' ? ' active' : '' %>">Creating a Pipeline</a>
      <a href="/help/article/pipeline-cards" class="sidebar-link<%= currentSlug === 'pipeline-cards' ? ' active' : '' %>">Stages & Cards</a>
      <a href="/help/article/smart-triggers" class="sidebar-link<%= currentSlug === 'smart-triggers' ? ' active' : '' %>">Smart Triggers</a>
      <a href="/help/article/stage-actions" class="sidebar-link<%= currentSlug === 'stage-actions' ? ' active' : '' %>">Stage Actions</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Messaging</div>
      <a href="/help/article/messaging-overview" class="sidebar-link<%= currentSlug === 'messaging-overview' ? ' active' : '' %>">Messaging Overview</a>
      <a href="/help/article/staff-inbox" class="sidebar-link<%= currentSlug === 'staff-inbox' ? ' active' : '' %>">Staff Inbox</a>
      <a href="/help/article/sending-messages" class="sidebar-link<%= currentSlug === 'sending-messages' ? ' active' : '' %>">Sending to Clients</a>
      <a href="/help/article/internal-notes" class="sidebar-link<%= currentSlug === 'internal-notes' ? ' active' : '' %>">Internal Notes</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Tax Organizer</div>
      <a href="/help/article/organizer-overview" class="sidebar-link<%= currentSlug === 'organizer-overview' ? ' active' : '' %>">Organizer Overview</a>
      <a href="/help/article/sending-organizer" class="sidebar-link<%= currentSlug === 'sending-organizer' ? ' active' : '' %>">Sending to a Client</a>
      <a href="/help/article/reviewing-submissions" class="sidebar-link<%= currentSlug === 'reviewing-submissions' ? ' active' : '' %>">Reviewing Submissions</a>
    </div>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Other</div>
      <a href="/help/article/proposals" class="sidebar-link<%= currentSlug === 'proposals' ? ' active' : '' %>">Proposals</a>
      <a href="/help/article/bulk-send" class="sidebar-link<%= currentSlug === 'bulk-send' ? ' active' : '' %>">Bulk Send</a>
      <a href="/help/article/settings" class="sidebar-link<%= currentSlug === 'settings' ? ' active' : '' %>">Settings & Branding</a>
      <a href="/help/article/viktor-ai" class="sidebar-link<%= currentSlug === 'viktor-ai' ? ' active' : '' %>">Viktor AI</a>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="help-main">
    <%- body %>
  </main>

</div>

<script>
// === SEARCH ===
const searchIndex = <%- JSON.stringify(searchIndex) %>;
const input = document.getElementById('help-search');
const results = document.getElementById('search-results');

function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

input.addEventListener('input', () => {
  const q = input.value.trim().toLowerCase();
  if (!q || q.length < 2) { results.style.display = 'none'; return; }
  const matches = searchIndex.filter(a =>
    a.title.toLowerCase().includes(q) ||
    a.section.toLowerCase().includes(q) ||
    (a.keywords || []).some(k => k.toLowerCase().includes(q)) ||
    (a.body || '').toLowerCase().includes(q)
  ).slice(0, 8);
  if (!matches.length) {
    results.innerHTML = `<div class="search-empty">No results for "<strong>${escHtml(q)}</strong>"</div>`;
  } else {
    results.innerHTML = matches.map(a => {
      const bodyIdx = (a.body||'').toLowerCase().indexOf(q);
      const snippet = bodyIdx >= 0 ? '…' + escHtml(a.body.slice(Math.max(0,bodyIdx-30), bodyIdx+80)) + '…' : '';
      return `<a href="/help/article/${escHtml(a.slug)}" class="search-result-item">
        <div class="search-result-title">${escHtml(a.title)}</div>
        <div class="search-result-section">${escHtml(a.section)}</div>
        ${snippet ? `<div class="search-result-snippet">${snippet}</div>` : ''}
      </a>`;
    }).join('');
  }
  results.style.display = 'block';
});

document.addEventListener('click', e => {
  if (!e.target.closest('.help-header-search')) results.style.display = 'none';
});
input.addEventListener('keydown', e => {
  if (e.key === 'Escape') { results.style.display = 'none'; input.blur(); }
});
</script>
</body>
</html>
