<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
  .cs-container {
    max-width: 700px;
    margin: 4rem auto;
    padding: 0 1.5rem;
    text-align: center;
  }
  .cs-icon { font-size: 3.5rem; margin-bottom: 1rem; }
  .cs-title { font-size: 1.5rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; }
  .cs-desc { color: var(--muted); font-size: 0.95rem; line-height: 1.6; }
  .cs-tag { display: inline-block; background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2); color: var(--gold); border-radius: 6px; padding: 0.25rem 0.75rem; font-size: 0.78rem; font-weight: 600; margin-top: 1.5rem; }
</style>

<main class="main">
  <div style="flex:1;overflow-y:auto;padding:2rem;">
    <div class="cs-container">
      <div class="cs-icon">🗒️</div>
      <h2 class="cs-title">Conversation Summaries</h2>
      <p class="cs-desc">Daily AI-generated summaries of your firm's client conversations.<br>Get a concise digest of what was discussed, action items, and follow-ups — without reading every thread.</p>
      <span class="cs-tag">Coming Soon — Phase 2</span>
    </div>
  </div>
</main>

<%- include('partials/shell-globals') %>
<%- include('partials/shell-close') %>
