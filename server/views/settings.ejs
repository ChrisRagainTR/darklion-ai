<%- include('partials/shell-top', { title: 'Settings', activeNav: 'settings' }) %>
<%- include('partials/shell-globals') %>

<style>
  .settings-wrap { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem; }
  .settings-section { margin-bottom: 2.5rem; }
  .settings-section h2 { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--text); }
  .settings-section p { font-size: 0.82rem; color: var(--muted); margin-bottom: 1rem; }
  .domain-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 1rem; background: var(--charcoal); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 0.5rem; }
  .domain-row .domain-name { font-size: 0.88rem; font-weight: 600; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .domain-actions { display: flex; gap: 0.4rem; flex-shrink: 0; }
  .dns-info { background: rgba(201,168,76,0.06); border: 1px solid rgba(201,168,76,0.2); border-radius: 6px; padding: 0.6rem 0.85rem; font-size: 0.78rem; color: var(--muted); margin-top: 0.35rem; margin-bottom: 0.25rem; font-family: monospace; word-break: break-all; }
  .add-domain-row { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
  .add-domain-row .form-control { flex: 1; }
  .instructions { background: var(--charcoal); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; font-size: 0.82rem; color: var(--muted); line-height: 1.6; }
  .instructions ol { padding-left: 1.25rem; }
  .instructions li { margin-bottom: 0.35rem; }
  .instructions code { background: rgba(255,255,255,0.07); padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.85em; color: var(--text); }
  /* Settings tabs */
  .settings-tabs { display: flex; gap: 0.25rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border); }
  .settings-tab-btn { background: none; border: none; border-bottom: 2px solid transparent; padding: 0.6rem 1rem; font-size: 0.88rem; font-weight: 600; color: var(--muted); cursor: pointer; margin-bottom: -1px; transition: color 0.15s, border-color 0.15s; }
  .settings-tab-btn.active { color: var(--gold); border-bottom-color: var(--gold); }
  .settings-tab-btn:hover:not(.active) { color: var(--text); }
  .settings-tab-panel { display: none; }
  .settings-tab-panel.active { display: block; }
  /* API token table */
  .token-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; margin-top: 1rem; }
  .token-table th { text-align: left; padding: 0.4rem 0.75rem; border-bottom: 1px solid var(--border); color: var(--muted); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .token-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--text); vertical-align: middle; }
  .token-table td:first-child { font-weight: 600; }
  .token-copy-box { background: var(--charcoal); border: 1px solid var(--border); border-radius: 6px; padding: 0.6rem 0.85rem; font-family: monospace; font-size: 0.78rem; color: var(--gold); word-break: break-all; margin: 0.75rem 0; }
  .token-warning { background: rgba(245,101,101,0.08); border: 1px solid rgba(245,101,101,0.25); border-radius: 6px; padding: 0.5rem 0.85rem; font-size: 0.8rem; color: #f56565; margin-bottom: 0.75rem; }
</style>

<div class="settings-wrap">
  <h1 style="font-size:1.35rem;font-weight:800;margin-bottom:1.5rem;">⚙️ Settings</h1>

  <div class="settings-tabs">
    <button class="settings-tab-btn active" onclick="switchTab('branding')">🎨 Firm Branding</button>
    <button class="settings-tab-btn" onclick="switchTab('domains')">🌐 Custom Domains</button>
    <button class="settings-tab-btn" onclick="switchTab('api-keys')">🔑 API Keys</button>
    <button class="settings-tab-btn" onclick="switchTab('webdav'); loadWebdavToken()">💾 Drive Access</button>
  </div>

  <!-- ============ FIRM BRANDING ============ -->
  <div class="settings-tab-panel active" id="tab-branding">
    <div class="settings-section">
      <h2>🎨 Firm Branding</h2>
      <p>Customize how your firm appears in the client portal, proposals, and emails.</p>

      <!-- Logo -->
      <div style="margin-bottom:2rem;">
        <div style="font-size:0.82rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.75rem;">Firm Logo</div>
        <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
          <div id="logo-preview" style="width:120px;height:60px;background:var(--charcoal);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;">
            <span style="color:var(--muted);font-size:0.75rem;">No logo</span>
          </div>
          <div>
            <label class="btn btn-outline" style="cursor:pointer;display:inline-block;">
              📁 Choose Logo
              <input type="file" id="logo-input" accept="image/png,image/jpeg,image/webp,image/svg+xml" style="display:none;" onchange="uploadLogo(this)">
            </label>
            <div style="font-size:0.75rem;color:var(--muted);margin-top:0.4rem;">PNG, JPG, WebP or SVG. Recommended: 400×200px or wider, transparent background.</div>
          </div>
        </div>
      </div>

      <!-- Firm info form -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
        <div>
          <label class="form-label">Display Name</label>
          <input type="text" class="form-control" id="b-display-name" placeholder="Sentinel Wealth & Tax">
          <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">Shown in portal and proposals instead of your account name.</div>
        </div>
        <div>
          <label class="form-label">Tagline</label>
          <input type="text" class="form-control" id="b-tagline" placeholder="Retirement planning for life's next chapter">
        </div>
        <div>
          <label class="form-label">Contact Email</label>
          <input type="email" class="form-control" id="b-contact-email" placeholder="hello@sentinelwealth.co">
        </div>
        <div>
          <label class="form-label">Phone</label>
          <input type="tel" class="form-control" id="b-phone" placeholder="(239) 555-0100">
        </div>
        <div>
          <label class="form-label">Website</label>
          <input type="url" class="form-control" id="b-website" placeholder="https://sentinelwealth.co">
        </div>
        <div>
          <label class="form-label">Brand Color</label>
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <input type="color" id="b-color-picker" value="#C9A84C" style="width:42px;height:38px;padding:2px;background:var(--charcoal);border:1px solid var(--border);border-radius:6px;cursor:pointer;">
            <input type="text" class="form-control" id="b-primary-color" placeholder="#C9A84C" maxlength="7" style="flex:1;" oninput="syncColorPicker(this.value)">
          </div>
          <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">Used for portal buttons and accents.</div>
        </div>
      </div>

      <div style="margin-bottom:1.5rem;">
        <label class="form-label">Address</label>
        <textarea class="form-control" id="b-address" rows="2" placeholder="1234 Tamiami Trail N, Suite 200&#10;Naples, FL 34102"></textarea>
        <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">Shown on proposals and tax letters.</div>
      </div>

      <button class="btn btn-gold" onclick="saveBranding()">Save Branding</button>
    </div>
  </div><!-- end tab-branding -->

  <!-- ============ CUSTOM DOMAINS ============ -->
  <div class="settings-tab-panel" id="tab-domains">
    <div class="settings-section">
    <h2>🌐 Custom Domains</h2>
    <p>Let clients access proposals and the portal via your own domain (e.g. <code>my.sentineltax.co</code>) instead of darklion.ai.</p>

    <div id="domains-list">
      <div class="loading-state"><div class="loading-spinner"></div></div>
    </div>

    <div class="add-domain-row">
      <input type="text" class="form-control" id="new-domain-input" placeholder="e.g. my.sentineltax.co" autocomplete="off">
      <button class="btn btn-gold" onclick="addDomain()">+ Add Domain</button>
    </div>

    <div style="margin-top:1.5rem;">
      <div class="card-title" style="margin-bottom:0.5rem;">📋 Setup Instructions</div>
      <div class="instructions">
        <ol>
          <li><strong>Enter your domain below</strong> (e.g. <code>my.yourdomain.com</code>) — you'll get a TXT verification token and CNAME target.</li>
          <li><strong>Log in to your DNS provider</strong> (GoDaddy, Cloudflare, Namecheap, etc.) and add both records shown — the TXT record to verify ownership, and the CNAME record to point traffic to DarkLion.</li>
          <li><strong>In your Railway dashboard</strong>, go to your DarkLion service → Settings → Networking → Add Custom Domain → enter your domain. Railway will handle the SSL certificate automatically.</li>
          <li><strong>Click "Check Verification"</strong> once your DNS records have propagated. Usually under 30 minutes.</li>
          <li>Once verified, all proposal links for your firm will automatically use your custom domain. ✅</li>
        </ol>
      </div>
    </div>
  </div>
  </div><!-- end tab-domains -->

  <!-- ============ API KEYS ============ -->
  <div class="settings-tab-panel" id="tab-api-keys">
    <div class="settings-section">
      <h2>🔑 API Keys</h2>
      <p>API keys allow external services (like Viktor) to access all DarkLion APIs with full admin access. Store keys securely — they are shown only once.</p>

      <button class="btn btn-gold" onclick="openNewTokenModal()" style="margin-bottom:1rem;">+ Generate New Key</button>

      <div id="api-tokens-list">
        <div class="loading-state"><div class="loading-spinner"></div></div>
      </div>
    </div>
  </div><!-- end tab-api-keys -->

  <!-- ============ DRIVE ACCESS ============ -->
  <div class="settings-tab-panel" id="tab-webdav">
    <div class="settings-section">
      <h2>💾 DarkLion Drive Access</h2>
      <p style="color:var(--muted);margin-bottom:1.5rem;">Mount DarkLion as a network drive on your Windows or Mac computer. Generate a personal access token below — you'll use it as your password when setting up the drive. The token never expires and stays logged in.</p>

      <div style="background:var(--charcoal);border:1px solid var(--border);border-radius:10px;padding:1.5rem;margin-bottom:1.5rem;">
        <div style="font-weight:700;margin-bottom:0.75rem;">Your Drive Token</div>
        <div id="webdav-token-display" style="font-family:monospace;font-size:0.9rem;color:var(--gold);background:rgba(0,0,0,0.3);padding:0.6rem 1rem;border-radius:6px;margin-bottom:1rem;min-height:2.2rem;word-break:break-all;">Loading...</div>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <button class="btn btn-gold" onclick="generateWebdavToken()">🔄 Generate New Token</button>
          <button class="btn" id="webdav-copy-btn" onclick="copyWebdavToken()" style="display:none;">📋 Copy Token</button>
        </div>
        <div id="webdav-token-warning" style="display:none;margin-top:0.75rem;font-size:0.8rem;color:#e74c3c;">⚠️ Copy this token now — it won't be shown again in full.</div>
      </div>

      <div style="background:var(--charcoal);border:1px solid var(--border);border-radius:10px;padding:1.5rem;">
        <div style="font-weight:700;margin-bottom:1rem;">Setup Instructions</div>
        <div style="margin-bottom:1rem;">
          <div style="font-weight:600;color:var(--gold);margin-bottom:0.4rem;">🪟 Windows</div>
          <ol style="color:var(--muted);font-size:0.875rem;line-height:1.8;margin:0;padding-left:1.25rem;">
            <li>Open File Explorer → right-click <strong>This PC</strong> → <strong>Map network drive</strong></li>
            <li>Choose a drive letter (e.g. <strong>Z:</strong>)</li>
            <li>Folder: <code style="background:rgba(0,0,0,0.3);padding:0.1rem 0.4rem;border-radius:4px;">https://darklion.sentineltax.co/webdav</code></li>
            <li>Check <strong>"Reconnect at sign-in"</strong></li>
            <li>Check <strong>"Connect using different credentials"</strong></li>
            <li>Username: your email address &nbsp;|&nbsp; Password: your drive token above</li>
          </ol>
        </div>
        <div>
          <div style="font-weight:600;color:var(--gold);margin-bottom:0.4rem;">🍎 Mac</div>
          <ol style="color:var(--muted);font-size:0.875rem;line-height:1.8;margin:0;padding-left:1.25rem;">
            <li>Finder → <strong>Go</strong> menu → <strong>Connect to Server</strong> (⌘K)</li>
            <li>Server address: <code style="background:rgba(0,0,0,0.3);padding:0.1rem 0.4rem;border-radius:4px;">https://darklion.sentineltax.co/webdav</code></li>
            <li>Click <strong>Connect</strong> → enter your email and drive token</li>
            <li>Check <strong>"Remember this password"</strong> in Keychain</li>
          </ol>
        </div>
      </div>
    </div>
  </div><!-- end tab-webdav -->

</div>

<!-- New Token Modal -->
<div class="modal-overlay" id="new-token-modal" style="display:none;" onclick="if(event.target===this)closeNewTokenModal()">
  <div class="modal" style="max-width:420px;">
    <div class="modal-header">
      <div class="modal-title">Generate API Key</div>
      <button class="modal-close" onclick="closeNewTokenModal()">×</button>
    </div>
    <div class="modal-body">
      <div id="new-token-form-area">
        <label class="form-label">Key Name <span style="color:var(--muted);font-weight:400;">(e.g. Viktor, Zapier)</span></label>
        <input type="text" class="form-control" id="new-token-name" placeholder="Viktor" maxlength="60" autocomplete="off">
        <div style="margin-top:1rem;display:flex;gap:0.5rem;justify-content:flex-end;">
          <button class="btn btn-outline" onclick="closeNewTokenModal()">Cancel</button>
          <button class="btn btn-gold" onclick="submitNewToken()">Generate</button>
        </div>
      </div>
      <div id="new-token-reveal-area" style="display:none;">
        <div class="token-warning">⚠️ This token will not be shown again. Copy it now and store it somewhere safe.</div>
        <div class="token-copy-box" id="new-token-value"></div>
        <button class="btn btn-outline" style="width:100%;margin-bottom:0.75rem;" onclick="copyNewToken()">📋 Copy Token</button>
        <button class="btn btn-gold" style="width:100%;" onclick="closeNewTokenModal()">Done</button>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const API = '/firms';
let token = null;

async function apiFetch(path, opts = {}) {
  if (!token) {
    token = localStorage.getItem('dl_token');
    if (!token) { window.location = '/login'; return null; }
  }
  const res = await fetch(API + path, {
    ...opts,
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json', ...(opts.headers || {}) },
  });
  if (res.status === 401) { localStorage.removeItem('dl_token'); window.location = '/login'; return null; }
  return res;
}

function toast(msg, isError = false) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show' + (isError ? ' error' : '');
  setTimeout(() => el.className = 'toast', 3500);
}

async function loadDomains() {
  const res = await apiFetch('/domains');
  if (!res) return;
  const domains = await res.json();
  renderDomains(domains);
}

function renderDomains(domains) {
  const el = document.getElementById('domains-list');
  if (!domains.length) {
    el.innerHTML = '<div class="empty-state" style="padding:1.5rem 0;text-align:left;color:var(--muted);font-size:0.85rem;">No custom domains yet. Add one below.</div>';
    return;
  }
  el.innerHTML = domains.map(d => {
    const verified = !!d.verified_at;
    const badge = verified
      ? '<span class="badge badge-green">✓ Verified</span>'
      : '<span class="badge badge-orange">⏳ Pending</span>';
    // Extract subdomain part for DNS name field (e.g. "my.sentineltax.co" -> "my")
    const domainParts = d.domain.split('.');
    const subName = domainParts.length > 2 ? domainParts[0] : '@';
    // TXT record uses darklion name to avoid conflicting with the CNAME on same name
    const txtName = subName === '@' ? 'darklion' : 'darklion';
    const dnsBlock = !verified ? `
      <div class="dns-info" style="margin-top:0.75rem;">
        <div style="font-size:0.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem;">Step 1 — Add this DNS TXT record to verify ownership:</div>
        <div style="font-size:0.72rem;color:var(--muted);margin-bottom:0.5rem;">The TXT record uses a <code>darklion</code> prefix so it doesn't conflict with the CNAME record in Step 2.</div>
        <table style="width:100%;border-collapse:collapse;font-size:0.82rem;margin-bottom:0.75rem;">
          <thead>
            <tr style="background:rgba(255,255,255,0.04);">
              <th style="text-align:left;padding:5px 10px;border:1px solid var(--border);color:var(--muted);font-weight:600;width:20%;">Type</th>
              <th style="text-align:left;padding:5px 10px;border:1px solid var(--border);color:var(--muted);font-weight:600;width:20%;">Name</th>
              <th style="text-align:left;padding:5px 10px;border:1px solid var(--border);color:var(--muted);font-weight:600;">Value</th>
              <th style="width:40px;border:1px solid var(--border);"></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="padding:6px 10px;border:1px solid var(--border);font-family:monospace;">TXT</td>
              <td style="padding:6px 10px;border:1px solid var(--border);font-family:monospace;">${txtName}</td>
              <td style="padding:6px 10px;border:1px solid var(--border);font-family:monospace;word-break:break-all;">${d.verification_token}</td>
              <td style="padding:6px 10px;border:1px solid var(--border);text-align:center;">
                <button class="btn btn-outline btn-xs" onclick="copyToken('${d.verification_token}', this)" title="Copy value">📋</button>
              </td>
            </tr>
          </tbody>
        </table>
        <div style="font-size:0.75rem;color:var(--muted);margin-bottom:0.5rem;font-weight:700;">Step 2 — Add this CNAME record to point your domain at DarkLion:</div>
        <table style="width:100%;border-collapse:collapse;font-size:0.82rem;margin-bottom:0.75rem;">
          <thead>
            <tr style="background:rgba(255,255,255,0.04);">
              <th style="text-align:left;padding:5px 10px;border:1px solid var(--border);color:var(--muted);font-weight:600;width:20%;">Type</th>
              <th style="text-align:left;padding:5px 10px;border:1px solid var(--border);color:var(--muted);font-weight:600;width:20%;">Name</th>
              <th style="text-align:left;padding:5px 10px;border:1px solid var(--border);color:var(--muted);font-weight:600;">Value (points to)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="padding:6px 10px;border:1px solid var(--border);font-family:monospace;">CNAME</td>
              <td style="padding:6px 10px;border:1px solid var(--border);font-family:monospace;">${subName}</td>
              <td style="padding:6px 10px;border:1px solid var(--border);font-family:monospace;">darklion.ai</td>
            </tr>
          </tbody>
        </table>
        <div style="font-size:0.72rem;color:var(--muted);margin-bottom:0.75rem;">⚠️ DNS changes can take up to 24 hours to propagate, though usually under 30 minutes. After adding both records, click "Check Verification" below.</div>
      </div>
      <button class="btn btn-outline btn-xs" onclick="verifyDomain(${d.id}, this)">🔍 Check Verification</button>
    ` : '';
    return `
      <div class="domain-row" id="domain-row-${d.id}">
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <span class="domain-name">${d.domain}</span>
            ${badge}
          </div>
          ${dnsBlock}
        </div>
        <div class="domain-actions">
          <button class="btn btn-danger btn-xs" onclick="deleteDomain(${d.id}, '${d.domain}')">🗑 Remove</button>
        </div>
      </div>
    `;
  }).join('');
}

async function addDomain() {
  const input = document.getElementById('new-domain-input');
  const domain = input.value.trim();
  if (!domain) return toast('Enter a domain name', true);
  const res = await apiFetch('/domains', { method: 'POST', body: JSON.stringify({ domain }) });
  if (!res) return;
  if (res.ok) {
    input.value = '';
    toast('Domain added — add the DNS TXT record to verify');
    loadDomains();
  } else {
    const err = await res.json();
    toast(err.error || 'Failed to add domain', true);
  }
}

function copyToken(token, btn) {
  navigator.clipboard.writeText(token).then(() => {
    const orig = btn.textContent;
    btn.textContent = '✓ Copied!';
    btn.style.color = 'var(--green)';
    setTimeout(() => { btn.textContent = orig; btn.style.color = ''; }, 2000);
  }).catch(() => toast('Copy failed — select and copy manually', true));
}

async function verifyDomain(id, btn) {
  btn.disabled = true;
  btn.textContent = '⏳ Checking…';
  const res = await apiFetch(`/domains/${id}/verify`, { method: 'POST' });
  if (!res) return;
  const data = await res.json();
  toast(data.message || (data.verified ? 'Verified!' : 'Not verified yet'), !data.verified);
  if (data.verified) loadDomains();
  else { btn.disabled = false; btn.textContent = '🔍 Check Verification'; }
}

async function deleteDomain(id, domain) {
  if (!confirm(`Remove domain "${domain}"?`)) return;
  const res = await apiFetch(`/domains/${id}`, { method: 'DELETE' });
  if (!res) return;
  if (res.ok) { toast('Domain removed'); loadDomains(); }
  else { const err = await res.json(); toast(err.error || 'Failed to remove domain', true); }
}

// Settings tab switching
function switchTab(tab) {
  document.querySelectorAll('.settings-tab-btn').forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('onclick').includes(`'${tab}'`));
  });
  document.querySelectorAll('.settings-tab-panel').forEach(panel => {
    panel.classList.toggle('active', panel.id === `tab-${tab}`);
  });
  if (tab === 'api-keys') loadApiTokens();
  if (tab === 'branding') loadBranding();
}

// ==================== WEBDAV TOKEN ====================
let _webdavFullToken = null;

async function loadWebdavToken() {
  const el = document.getElementById('webdav-token-display');
  try {
    const res = await apiFetch('/firms/webdav-token');
    const data = await res.json();
    if (data.hasToken) {
      el.textContent = data.tokenPreview;
      document.getElementById('webdav-copy-btn').style.display = 'none';
    } else {
      el.textContent = 'No token yet — generate one below.';
      el.style.color = 'var(--muted)';
    }
  } catch(e) { el.textContent = 'Could not load token status.'; }
}

async function generateWebdavToken() {
  if (!confirm('Generate a new drive token? Your old token will stop working immediately.')) return;
  const el = document.getElementById('webdav-token-display');
  el.textContent = 'Generating...';
  try {
    const res = await apiFetch('/firms/webdav-token', { method: 'POST' });
    const data = await res.json();
    _webdavFullToken = data.token;
    el.textContent = data.token;
    el.style.color = 'var(--gold)';
    document.getElementById('webdav-copy-btn').style.display = '';
    document.getElementById('webdav-token-warning').style.display = '';
  } catch(e) { el.textContent = 'Failed to generate token. Try again.'; }
}

function copyWebdavToken() {
  if (!_webdavFullToken) return;
  navigator.clipboard.writeText(_webdavFullToken).then(() => {
    const btn = document.getElementById('webdav-copy-btn');
    btn.textContent = '✅ Copied!';
    setTimeout(() => { btn.textContent = '📋 Copy Token'; }, 2000);
  });
}

// ==================== BRANDING ====================
async function loadBranding() {
  const res = await apiFetch('/branding');
  if (!res || !res.ok) return;
  const b = await res.json();

  if (b.display_name) document.getElementById('b-display-name').value = b.display_name;
  if (b.tagline)       document.getElementById('b-tagline').value = b.tagline;
  if (b.contact_email) document.getElementById('b-contact-email').value = b.contact_email;
  if (b.phone)         document.getElementById('b-phone').value = b.phone;
  if (b.website)       document.getElementById('b-website').value = b.website;
  if (b.address)       document.getElementById('b-address').value = b.address;
  if (b.primary_color) {
    document.getElementById('b-primary-color').value = b.primary_color;
    document.getElementById('b-color-picker').value = b.primary_color;
  }
  if (b.logo_url) {
    const preview = document.getElementById('logo-preview');
    preview.innerHTML = `<img src="${b.logo_url}" style="max-width:100%;max-height:100%;object-fit:contain;">`;
  }
}

function syncColorPicker(hex) {
  if (/^#[0-9a-fA-F]{6}$/.test(hex)) {
    document.getElementById('b-color-picker').value = hex;
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const picker = document.getElementById('b-color-picker');
  if (picker) picker.addEventListener('input', () => {
    document.getElementById('b-primary-color').value = picker.value;
  });
});

async function uploadLogo(input) {
  const file = input.files[0];
  if (!file) return;

  const form = new FormData();
  form.append('logo', file);

  const t = localStorage.getItem('dl_token');
  const res = await fetch('/firms/branding/logo', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + t },
    body: form,
  });

  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    return toast(err.error || 'Logo upload failed', true);
  }

  const data = await res.json();
  const preview = document.getElementById('logo-preview');
  preview.innerHTML = `<img src="${data.logo_url}" style="max-width:100%;max-height:100%;object-fit:contain;">`;
  toast('Logo uploaded ✓');
}

async function saveBranding() {
  const body = {
    display_name:  document.getElementById('b-display-name').value.trim(),
    tagline:       document.getElementById('b-tagline').value.trim(),
    contact_email: document.getElementById('b-contact-email').value.trim(),
    phone:         document.getElementById('b-phone').value.trim(),
    website:       document.getElementById('b-website').value.trim(),
    address:       document.getElementById('b-address').value.trim(),
    primary_color: document.getElementById('b-primary-color').value.trim() || '#C9A84C',
  };

  const res = await apiFetch('/branding', { method: 'PUT', body: JSON.stringify(body) });
  if (!res) return;
  if (res.ok) {
    toast('Branding saved ✓');
  } else {
    const err = await res.json().catch(() => ({}));
    toast(err.error || 'Failed to save', true);
  }
}

// ==================== API TOKENS ====================
async function loadApiTokens() {
  const res = await apiFetch('/api-tokens');
  if (!res) return;
  const tokens = await res.json();
  const el = document.getElementById('api-tokens-list');
  if (!tokens.length) {
    el.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;padding:1rem 0;">No API keys yet. Generate one above.</div>';
    return;
  }
  el.innerHTML = `
    <table class="token-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Key Prefix</th>
          <th>Last Used</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        ${tokens.map(t => `
          <tr id="token-row-${t.id}">
            <td>${escHtml(t.name)}</td>
            <td><code style="font-family:monospace;font-size:0.82rem;">${escHtml(t.token_prefix)}</code></td>
            <td style="color:var(--muted);">${t.last_used_at ? new Date(t.last_used_at).toLocaleDateString() : 'Never'}</td>
            <td style="color:var(--muted);">${new Date(t.created_at).toLocaleDateString()}</td>
            <td><button class="btn btn-danger btn-xs" onclick="revokeToken(${t.id})">Revoke</button></td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  `;
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function openNewTokenModal() {
  document.getElementById('new-token-name').value = '';
  document.getElementById('new-token-form-area').style.display = '';
  document.getElementById('new-token-reveal-area').style.display = 'none';
  document.getElementById('new-token-modal').style.display = 'flex';
  setTimeout(() => document.getElementById('new-token-name').focus(), 50);
}

function closeNewTokenModal() {
  document.getElementById('new-token-modal').style.display = 'none';
  loadApiTokens();
}

async function submitNewToken() {
  const name = document.getElementById('new-token-name').value.trim();
  if (!name) return toast('Enter a name for this key', true);
  const res = await apiFetch('/api-tokens', { method: 'POST', body: JSON.stringify({ name }) });
  if (!res) return;
  if (!res.ok) { const err = await res.json(); return toast(err.error || 'Failed to create token', true); }
  const data = await res.json();
  document.getElementById('new-token-value').textContent = data.token;
  document.getElementById('new-token-form-area').style.display = 'none';
  document.getElementById('new-token-reveal-area').style.display = '';
}

function copyNewToken() {
  const val = document.getElementById('new-token-value').textContent;
  navigator.clipboard.writeText(val).then(() => toast('Token copied!')).catch(() => toast('Copy failed', true));
}

async function revokeToken(id) {
  if (!confirm('Revoke this API key? Any integrations using it will stop working immediately.')) return;
  const res = await apiFetch(`/api-tokens/${id}`, { method: 'DELETE' });
  if (!res) return;
  if (res.ok) { toast('API key revoked'); loadApiTokens(); }
  else { const err = await res.json(); toast(err.error || 'Failed to revoke key', true); }
}

// Init — branding is default tab
loadBranding();
</script>

