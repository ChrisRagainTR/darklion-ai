    // ── RIGHT COL: Quick Links panel ──
    const qlEl = document.getElementById('overview-quicklinks-panel');
    let qlHtml = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Quick Links</div>`;
    const links = [];

    if (c.qbo_connected) links.push(`<a href="https://qbo.intuit.com" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:0.5rem;color:var(--gold);font-size:0.84rem;padding:0.3rem 0;text-decoration:none;">💼 QuickBooks Online</a>`);
    if (!links.length) qlHtml += `<div style="color:var(--muted);font-size:0.82rem;font-style:italic;">No quick links configured.</div>`;
    else qlHtml += links.join('');
    qlEl.innerHTML = qlHtml;

    // ── CENTER COL: Pipeline History panel ──
    loadOverviewPipelineHistory();
  }

  async function loadOverviewPipelineHistory() {
    const panel = document.getElementById('overview-pipeline-panel');
    if (!panel) return;
    panel.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Pipeline History</div><div style="color:var(--muted);font-size:0.82rem;">Loading…</div>`;
    try {
      const res = await apiFetch(`/api/pipelines/completions?entity_type=company&entity_id=${companyId}`);
      const data = await res.json();
      const completions = data.completions || [];
      const activeJobs = data.active_jobs || [];
      let html = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Pipeline History</div>`;
      if (!completions.length && !activeJobs.length) {
        html += `<div style="color:var(--muted);font-size:0.82rem;font-style:italic;">No pipeline history yet.</div>`;
      } else {
        const rows = [];
        completions.forEach(c => {
          const yr = c.tax_year ? ` ${c.tax_year}` : '';
          const date = new Date(c.completed_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
          rows.push(`<div style="display:flex;align-items:center;gap:0.6rem;padding:0.4rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
            <span style="font-size:0.9rem;">✅</span>
            <span style="flex:1;font-size:0.82rem;font-weight:600;">${esc(c.pipeline_name)}${yr}</span>
            <span style="font-size:0.75rem;color:var(--muted);">${date}</span>
          </div>`);
        });
        activeJobs.forEach(j => {
          const yr = j.tax_year ? ` ${j.tax_year}` : '';
          const stage = j.current_stage_name ? ` → ${j.current_stage_name}` : '';
          rows.push(`<div style="display:flex;align-items:center;gap:0.6rem;padding:0.4rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
            <span style="font-size:0.9rem;">🔄</span>
