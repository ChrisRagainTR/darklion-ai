<div id="tab-workflow" class="tab-content">
  <div style="max-width:860px;padding:1.5rem 2rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
      <div style="font-size:1.05rem;font-weight:700;">Active Pipelines</div>
      <div style="display:flex;gap:0.5rem;">
        <button class="btn btn-sm" onclick="openFireTriggerModal()" style="background:rgba(201,168,76,0.1);color:var(--gold);border:1px solid rgba(201,168,76,0.25);font-size:0.78rem;">⚡ Fire Trigger</button>
        <button class="btn btn-gold btn-sm" onclick="openCreateCardModal()" style="font-size:0.78rem;">+ Create Card</button>
      </div>
    </div>
    <div id="workflow-loading" style="color:var(--muted);padding:2rem 0;">Loading…</div>
    <div id="workflow-list" style="display:none;"></div>

    <!-- Pipeline History -->
    <div style="margin-top:2rem;">
      <div style="font-size:1.05rem;font-weight:700;margin-bottom:1rem;">📋 Pipeline History</div>
      <div id="pipeline-history-loading" style="color:var(--muted);font-size:0.85rem;"></div>
      <div id="pipeline-history-list" style="display:none;"></div>
    </div>
  </div>
</div>

<!-- ➕ Create Card Modal (company) -->
<div class="modal-overlay hidden" id="create-card-modal" onclick="this.classList.add('hidden')">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:420px;">
    <h2 style="margin-bottom:0.25rem;">➕ Create Pipeline Card</h2>
    <p style="font-size:0.83rem;color:var(--muted);margin-bottom:1.25rem;">Add this company to any pipeline at any stage.</p>
    <div style="margin-bottom:0.85rem;">
      <label class="form-label" style="font-size:0.78rem;margin-bottom:0.35rem;display:block;">Pipeline</label>
      <select id="cc-pipeline-sel" class="form-control" style="font-size:0.85rem;width:100%;"></select>
    </div>
    <div style="margin-bottom:1rem;">
      <label class="form-label" style="font-size:0.78rem;margin-bottom:0.35rem;display:block;">Starting Stage</label>
      <select id="cc-stage-sel" class="form-control" style="font-size:0.85rem;width:100%;"></select>
    </div>
    <div id="cc-error" style="display:none;font-size:0.8rem;color:var(--red);margin-bottom:0.75rem;"></div>
    <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
      <button class="btn btn-outline" onclick="document.getElementById('create-card-modal').classList.add('hidden')">Cancel</button>
      <button class="btn btn-gold" onclick="submitCreateCard()">Create Card</button>
    </div>
  </div>
</div>

<!-- ⚡ Fire Trigger Modal (company) -->
<div class="modal-overlay hidden" id="fire-trigger-modal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:440px;">
    <h2 style="margin-bottom:0.25rem;">⚡ Fire Trigger</h2>
    <p style="font-size:0.82rem;color:var(--muted);margin-bottom:1.25rem;">Manually fire a trigger to move this company's pipeline card(s) to the configured stage.</p>
    <div class="form-group">
      <label>Trigger</label>
      <select class="form-control" id="ft-trigger-select">
        <option value="">— Loading triggers… —</option>
      </select>
    </div>
    <div id="ft-result" style="display:none;margin:0.75rem 0;padding:0.75rem 1rem;border-radius:8px;font-size:0.85rem;"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeFireTriggerModal()">Cancel</button>
      <button class="btn btn-gold" id="ft-submit" onclick="submitFireTrigger()">Fire ⚡</button>
    </div>
  </div>
</div>

<div id="tab-notes" class="tab-content">
  <div class="card" style="max-width:800px;margin:1.5rem;">
    <div class="card-title">Internal Notes</div>
    <textarea class="form-control" id="notes-ta-full" rows="12" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:0.75rem;">
      <button class="btn btn-gold btn-sm" onclick="autoSaveNotes(document.getElementById('notes-ta-full').value, true)">Save Notes</button>
      <div class="save-indicator" id="notes-saved-full"></div>
    </div>
  </div>
</div>

<!-- Bookkeeping Drilldown Overlay + Panel -->
<div class="bk-drilldown-overlay" id="bk-drilldown-overlay" onclick="bk_closeDrilldown()"></div>
<div class="bk-drilldown-panel" id="bk-drilldown-panel">
  <div class="bk-drilldown-header">
    <div>
      <h3 id="bk-dd-account-name">Account</h3>
      <div class="bk-dd-period" id="bk-dd-period"></div>
    </div>
    <button class="bk-drilldown-close" onclick="bk_closeDrilldown()">✕</button>
  </div>
  <div class="bk-drilldown-body" id="bk-drilldown-body">
    <div class="bk-drilldown-loading">Loading transactions…</div>
  </div>
</div>

<!-- Bookkeeping Day Drawer -->
<div class="bk-day-drawer-overlay" id="bk-day-drawer-overlay" onclick="bk_closeDayDrawer()"></div>
<div class="bk-day-drawer" id="bk-day-drawer">
  <div class="bk-day-drawer-header">
    <div>
      <div class="bk-day-drawer-title" id="bk-day-drawer-title">Day —</div>
    </div>
    <button class="bk-day-drawer-close" onclick="bk_closeDayDrawer()">×</button>
  </div>
  <div class="bk-day-drawer-progress">
    <div class="bk-day-drawer-prog-label" id="bk-day-drawer-prog-label">— of — retrieved</div>
    <div class="bk-day-drawer-prog-bar"><div class="bk-day-drawer-prog-fill" id="bk-day-drawer-prog-fill" style="width:0%"></div></div>
  </div>
  <div class="bk-day-drawer-body" id="bk-day-drawer-body">
    <div style="padding:2rem;text-align:center;color:var(--muted);">Loading…</div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
    <h2>Edit Company</h2>
    <div id="edit-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>
    <div class="form-group"><label>Company Name</label><input type="text" class="form-control" id="ef-name"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Entity Type</label>
        <select class="form-control" id="ef-entity-type">
          <option value="">— Select —</option><option value="llc">LLC</option><option value="s_corp">S-Corp</option>
          <option value="c_corp">C-Corp</option><option value="partnership">Partnership</option>
          <option value="sole_prop">Sole Prop</option><option value="trust">Trust</option>
          <option value="nonprofit">Non-Profit</option><option value="other">Other</option>
        </select>
      </div>
      <div class="form-group"><label>Tax Year End</label><input type="text" class="form-control" id="ef-tax-year-end" placeholder="12/31"></div>
    </div>
    <div class="form-group"><label>Status</label>
      <select class="form-control" id="ef-status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="dissolved">Dissolved</option></select>
    </div>
    <div class="form-group"><label>Billing Method</label>
      <select class="form-control" id="ef-billing-method">
        <option value="">— Select —</option>
        <option value="monthly_billing">Monthly Billing</option>
        <option value="client_invoice">Client Invoice</option>
      </select>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Bookkeeper</label>
        <select class="form-control" id="ef-bookkeeper"><option value="">— None —</option></select>
      </div>
      <div class="form-group"><label>Bookkeeping Service</label>
        <select class="form-control" id="ef-bookkeeping-service">
          <option value="none">None</option>
          <option value="bank_feed">Bank Feed</option>
          <option value="accrual">Accrual</option>
          <option value="client_prepared">Client Prepared</option>
        </select>
      </div>
    </div>
    <div style="border-top:1px solid var(--border);padding-top:1rem;margin-top:0.25rem;">
      <div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.75rem;">Address</div>
      <div class="form-group"><label>Street Address</label><input type="text" class="form-control" id="ef-addr1" placeholder="123 Main St"></div>
      <div class="form-group"><label>Line 2 <span style="color:var(--muted);font-weight:400;">(optional)</span></label><input type="text" class="form-control" id="ef-addr2" placeholder="Suite, Unit, etc."></div>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:0 0.75rem;">
        <div class="form-group"><label>City</label><input type="text" class="form-control" id="ef-city" placeholder="Naples"></div>
        <div class="form-group"><label>State</label><input type="text" class="form-control" id="ef-state" placeholder="FL" maxlength="2"></div>
        <div class="form-group"><label>ZIP</label><input type="text" class="form-control" id="ef-zip" placeholder="34108" maxlength="10"></div>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" id="ef-submit" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const companyId = location.pathname.split('/').pop();
  // Show success toast if redirected back from QBO connect
  if (new URLSearchParams(location.search).get('connected') === '1') {
    history.replaceState({}, '', location.pathname);
    setTimeout(() => { if (typeof window._shellToast === 'function') window._shellToast('QuickBooks connected successfully!'); }, 800);
  }
  const token = localStorage.getItem('dl_token');
  if (!token) window.location.href = '/login';

  let companyData = null;
  let bookkeepingRealm = null;
  const CURRENT_YEAR = new Date().getFullYear();

  function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }; }
  async function apiFetch(url, opts = {}) {
    const isFormData = opts.body instanceof FormData;
    const headers = isFormData
      ? { 'Authorization': 'Bearer ' + token, ...(opts.headers||{}) }
      : { ...authHeaders(), ...(opts.headers||{}) };
    const res = await fetch(url, { ...opts, headers });
    if (res.status === 401) window.location.href = '/login';
    return res;
  }
  function esc(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  const toast = (msg, type) => window._shellToast && window._shellToast(msg, type === 'error' ? 'error' : undefined);

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    const stbar = document.getElementById('subtab-bar');
    if (stbar) stbar.style.display = name === 'bookkeeping' ? '' : 'none';
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax(true);
    if (name === 'bookkeeping') {
      if (bookkeepingRealm) {
        bk_initBookkeeping();
      } else if (companyData) {
        // Had a realm_id before but tokens are gone = disconnected, needs reconnect
        bk_showConnectCard(companyData.realm_id && companyData.realm_id !== '');
      } else {
        window._bkPendingInit = true;
      }
    }
    if (name === 'communication') initCoComm();
    const mainEl = document.querySelector('.main');
    if (mainEl) mainEl.style.overflowY = (name === 'communication') ? 'hidden' : 'auto';
    if (name === 'organizers' && companyData && companyData.stanford_tax_url) {
      const orgEl = document.getElementById('org-stanford-link');
      if (orgEl) orgEl.innerHTML = `<a href="${esc(companyData.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">🔗 Open Stanford Tax →</a>`;
    }
    if (name === 'notes' && companyData) document.getElementById('notes-ta-full').value = companyData.notes || '';
    if (name === 'workflow') loadWorkflow();
  }

  async function loadWorkflow() {
    const loading = document.getElementById('workflow-loading');
    const list = document.getElementById('workflow-list');
    loading.style.display = ''; list.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/entity-jobs?entity_type=company&entity_id=${companyId}`);
      const jobs = await res.json();
      loading.style.display = 'none'; list.style.display = '';
      if (!jobs.length) {
        list.innerHTML = `<div style="text-align:center;padding:2.5rem 1rem;color:var(--muted);">
          <div style="font-size:2rem;margin-bottom:0.75rem;">📋</div>
          <div style="font-weight:600;font-size:0.95rem;margin-bottom:0.4rem;color:var(--text);">No active pipelines</div>
          <div style="font-size:0.84rem;">Workflows will appear here once this company is added to a pipeline.</div>
        </div>`;
        loadPipelineHistory(); return;
      }
      list.innerHTML = jobs.map(j => renderJobCard(j)).join('');
    } catch(e) { loading.textContent = 'Failed to load pipelines: ' + e.message; }
    loadPipelineHistory();
  }

  function renderJobCard(j) {
    const stageColor = j.stage_color || 'var(--gold)';
    const yearBadge = j.tax_year ? `<span style="font-size:0.72rem;background:rgba(255,255,255,0.06);border-radius:4px;padding:0.1rem 0.45rem;margin-left:0.5rem;color:var(--muted);">${j.tax_year}</span>` : '';
    const statusColor = j.job_status === 'blocked' ? 'var(--red)' : (j.job_status === 'waiting_client' || j.job_status === 'missing_info') ? 'var(--orange)' : 'var(--green)';
    const statusLabel = {active:'Active',waiting_client:'Waiting on Client',missing_info:'Missing Info',blocked:'Blocked',under_extension:'Under Extension',on_hold:'On Hold'}[j.job_status] || 'Active';
    const updateText = j.last_update ? (j.last_update.length > 80 ? j.last_update.substring(0,80)+'…' : j.last_update) : null;
    const updateDate = j.last_update_at ? new Date(j.last_update_at).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '';
    const lastUpdate = updateText ? `<div style="font-size:0.78rem;color:var(--muted);margin-top:0.25rem;">${esc(updateText)}<span style="font-size:0.72rem;color:rgba(143,163,184,0.5);margin-left:0.4rem;">${esc(j.last_update_author||'')}${updateDate ? ' · '+updateDate : ''}</span></div>` : '';

    const stages = j.stages || [];
    const curIdx = stages.findIndex(s => s.id === j.current_stage_id);
    const prevStage = curIdx > 0 ? stages[curIdx - 1] : null;
    const nextStage = curIdx < stages.length - 1 ? stages[curIdx + 1] : null;

    const prevBtn = prevStage
      ? `<button onclick="event.stopPropagation();moveJobStage(${j.id},'${esc(j.pipeline_name)}${j.tax_year?' '+j.tax_year:''}',${prevStage.id},'${esc(prevStage.name)}')" title="Move back to: ${esc(prevStage.name)}" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:0.3rem 0.6rem;cursor:pointer;color:var(--muted);font-size:0.75rem;display:flex;align-items:center;gap:0.3rem;white-space:nowrap;">← ${esc(prevStage.name)}</button>`
      : `<span style="width:0"></span>`;
    const nextBtn = nextStage
      ? `<button onclick="event.stopPropagation();moveJobStage(${j.id},'${esc(j.pipeline_name)}${j.tax_year?' '+j.tax_year:''}',${nextStage.id},'${esc(nextStage.name)}')" title="Move forward to: ${esc(nextStage.name)}" style="background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.25);border-radius:6px;padding:0.3rem 0.6rem;cursor:pointer;color:var(--gold);font-size:0.75rem;display:flex;align-items:center;gap:0.3rem;white-space:nowrap;">${esc(nextStage.name)} →</button>`
      : `<span style="font-size:0.72rem;color:rgba(255,255,255,0.2);">Final stage</span>`;

    return `<div class="workflow-job-card" style="flex-direction:column;align-items:stretch;gap:0.75rem;padding:1rem 1.25rem;cursor:default;" onclick="">
      <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
        <div style="flex:1;min-width:180px;">
          <div style="font-weight:700;font-size:0.95rem;">${esc(j.pipeline_name)}${yearBadge}</div>
          ${lastUpdate}
        </div>
        <div style="text-align:center;min-width:130px;">
          <div style="font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Current Stage</div>
          <div style="font-weight:700;color:${stageColor};font-size:0.88rem;">${esc(j.stage_name)}</div>
        </div>
        <div style="text-align:center;min-width:90px;">
          <div style="font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Status</div>
          <div style="font-weight:600;font-size:0.8rem;color:${statusColor};">${statusLabel}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;padding-top:0.5rem;border-top:1px solid rgba(255,255,255,0.05);">
        <div>${prevBtn}</div>
        <div style="font-size:0.72rem;color:rgba(255,255,255,0.2);">${curIdx + 1} / ${stages.length}</div>
        <div>${nextBtn}</div>
      </div>
    </div>`;
  }

  async function moveJobStage(jobId, pipelineName, stageId, stageName) {
    try {
      const res = await apiFetch(`/api/pipelines/jobs/${jobId}/move`, {
        method: 'POST',
        body: JSON.stringify({ stage_id: stageId, note: `Moved to "${stageName}" from company workflow tab` }),
      });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Move failed'); }
      if (typeof window.toast === 'function') window.toast(`Moved to "${stageName}"`);
      const wList = document.getElementById('workflow-list');
      const wLoad = document.getElementById('workflow-loading');
      if (wList) { wList.innerHTML = ''; wList.style.display = 'none'; }
      if (wLoad) wLoad.style.display = '';
      await loadWorkflow();
    } catch(e) {
      if (typeof window.toast === 'function') window.toast('Error: ' + e.message, 'error');
      else alert('Error: ' + e.message);
    }
  }

  async function loadPipelineHistory() {
    const loading = document.getElementById('pipeline-history-loading');
    const list = document.getElementById('pipeline-history-list');
    if (!loading || !list) return;
    loading.style.display = ''; list.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/completions?entity_type=company&entity_id=${companyId}`);
      const data = await res.json();
      loading.style.display = 'none'; list.style.display = '';
      const completions = data.completions || [];
      const activeJobs = data.active_jobs || [];
      if (!completions.length && !activeJobs.length) {
        list.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;">No pipeline history yet.</div>';
        return;
      }
      const rows = [];
      completions.forEach(c => {
        const yr = c.tax_year ? ` ${c.tax_year}` : '';
        const date = new Date(c.completed_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
        rows.push(`<div style="display:flex;align-items:center;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="font-size:1rem;">✅</span>
          <span style="flex:1;font-size:0.88rem;font-weight:600;">${esc(c.pipeline_name)}${yr}</span>
          <span style="font-size:0.78rem;color:var(--muted);">completed ${date}</span>
        </div>`);
      });
      activeJobs.forEach(j => {
        const yr = j.tax_year ? ` ${j.tax_year}` : '';
        const stage = j.current_stage_name ? ` → ${j.current_stage_name}` : '';
        rows.push(`<div style="display:flex;align-items:center;gap:0.75rem;padding:0.55rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="font-size:1rem;">🔄</span>
          <span style="flex:1;font-size:0.88rem;font-weight:600;">${esc(j.pipeline_name)}${yr}</span>
          <span style="font-size:0.78rem;color:var(--muted);">in progress${esc(stage)}</span>
        </div>`);
      });
      list.innerHTML = rows.join('') || '<div style="color:var(--muted);font-size:0.85rem;">No pipeline history yet.</div>';
    } catch(e) {
      loading.style.display = 'none'; list.style.display = '';
      list.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;">No pipeline history yet.</div>';
    }
  }

  // ── Create Card Modal ──────────────────────────────────
  let _allInstances = [];

  async function openCreateCardModal() {
    const modal = document.getElementById('create-card-modal');
    if (!modal) return;
    modal.classList.remove('hidden');
    const pipelineSel = document.getElementById('cc-pipeline-sel');
    const stageSel = document.getElementById('cc-stage-sel');
    pipelineSel.innerHTML = '<option value="">Loading pipelines…</option>';
    stageSel.innerHTML = '<option value="">Select pipeline first</option>';
    try {
      const res = await apiFetch('/api/pipelines/instances');
      _allInstances = await res.json();
      const companyInstances = _allInstances.filter(i => i.entity_type === 'company');
      if (!companyInstances.length) { pipelineSel.innerHTML = '<option value="">No company pipelines found</option>'; return; }
      pipelineSel.innerHTML = '<option value="">— Select pipeline —</option>' +
        companyInstances.map(i => `<option value="${i.id}">${esc(i.template_name)}${i.tax_year ? ' '+i.tax_year : ''}</option>`).join('');
      pipelineSel.onchange = async () => {
        const instId = pipelineSel.value;
        stageSel.innerHTML = '<option value="">Loading stages…</option>';
        if (!instId) { stageSel.innerHTML = '<option value="">Select pipeline first</option>'; return; }
        const r = await apiFetch(`/api/pipelines/instances/${instId}`);
        const data = await r.json();
        stageSel.innerHTML = '<option value="">— Select starting stage —</option>' +
          (data.stages || []).map(s => `<option value="${s.id}">${esc(s.name)}</option>`).join('');
      };
    } catch(e) { pipelineSel.innerHTML = `<option value="">Error: ${esc(e.message)}</option>`; }
  }

  async function submitCreateCard() {
    const instId = document.getElementById('cc-pipeline-sel').value;
    const stageId = document.getElementById('cc-stage-sel').value;
    const errEl = document.getElementById('cc-error');
    if (!instId || !stageId) { errEl.textContent = 'Select a pipeline and stage.'; errEl.style.display = 'block'; return; }
    errEl.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/instances/${instId}/jobs`, {
        method: 'POST',
        body: JSON.stringify({ entity_type: 'company', entity_id: companyId }),
      });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      const newJob = await res.json();
      if (newJob.current_stage_id !== parseInt(stageId)) {
        await apiFetch(`/api/pipelines/jobs/${newJob.id}/move`, {
          method: 'POST',
          body: JSON.stringify({ stage_id: parseInt(stageId), note: 'Placed at stage on card creation' }),
        });
      }
      document.getElementById('create-card-modal').classList.add('hidden');
      if (typeof window.toast === 'function') window.toast('Pipeline card created');
      const wList = document.getElementById('workflow-list');
      const wLoad = document.getElementById('workflow-loading');
      if (wList) { wList.innerHTML = ''; wList.style.display = 'none'; }
      if (wLoad) wLoad.style.display = '';
      loadWorkflow();
    } catch(e) { errEl.textContent = 'Error: ' + e.message; errEl.style.display = 'block'; }
  }

  // ── Fire Trigger Modal ─────────────────────────────────
  let availableTriggers = [];

  async function openFireTriggerModal() {
    const modal = document.getElementById('fire-trigger-modal');
    if (!modal) return;
    modal.classList.remove('hidden');
    document.getElementById('ft-result').style.display = 'none';
    const sel = document.getElementById('ft-trigger-select');
    sel.innerHTML = '<option value="">Loading…</option>';
    try {
      const res = await apiFetch('/api/pipeline-triggers');
      availableTriggers = await res.json();
      // Only show triggers relevant to companies (filter out portal/organizer triggers)
      const companyTriggers = availableTriggers.filter(t =>
        !['portal_first_login','portal_message_received','document_uploaded_by_client','organizer_submitted'].includes(t.key)
      );
      sel.innerHTML = '<option value="">— Select a trigger —</option>' +
        companyTriggers.map(t => `<option value="${t.key}">${esc(t.label)}</option>`).join('');
    } catch(e) { sel.innerHTML = `<option value="">Error: ${esc(e.message)}</option>`; }
  }

  function closeFireTriggerModal() {
    const modal = document.getElementById('fire-trigger-modal');
    if (modal) modal.classList.add('hidden');
  }

  async function submitFireTrigger() {
    const triggerKey = document.getElementById('ft-trigger-select').value;
    const resultEl = document.getElementById('ft-result');
    if (!triggerKey) { resultEl.style.cssText = 'display:block;background:rgba(231,76,60,0.1);color:#e74c3c;'; resultEl.textContent = 'Select a trigger first.'; return; }
    document.getElementById('ft-submit').disabled = true;
    resultEl.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipeline-triggers/fire`, {
        method: 'POST',
        body: JSON.stringify({ trigger_key: triggerKey, entity_type: 'company', entity_id: companyId }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      const moved = data.moved || [];
      resultEl.style.cssText = 'display:block;background:rgba(62,207,142,0.1);color:#3ecf8e;';
      resultEl.textContent = moved.length
        ? `✓ Moved ${moved.length} card(s): ${moved.map(m => `"${m.pipeline_name}" → ${m.to_stage}`).join(', ')}`
        : 'ℹ️ No cards moved — no pipeline stages are configured for this trigger on this company.';
      const wList = document.getElementById('workflow-list');
      const wLoad = document.getElementById('workflow-loading');
      if (wList) { wList.innerHTML = ''; wList.style.display = 'none'; }
      if (wLoad) wLoad.style.display = '';
      loadWorkflow();
    } catch(e) {
      resultEl.style.cssText = 'display:block;background:rgba(231,76,60,0.1);color:#e74c3c;';
      resultEl.textContent = 'Error: ' + e.message;
    }
    document.getElementById('ft-submit').disabled = false;
  }

  function switchSubtab(name, el) {
    document.querySelectorAll('.subtab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.subtab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const sc = document.getElementById('subtab-' + name);
    if (sc) sc.classList.add('active');
    bk_loadActiveSubtab(name);
  }

  async function loadCompany() {
    try {
      const res = await apiFetch(`/api/companies/${companyId}`);
      if (res.status === 404 || res.status === 403) { window.location.href = '/404'; return; }
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Error loading'; return; }
      companyData = await res.json();
      bookkeepingRealm = companyData.qbo_connected ? (companyData.realm_id || null) : null;
      renderHeader(companyData);
      renderOverview(companyData);
      // If bookkeeping tab was clicked before company loaded, init now
      if (window._bkPendingInit) {
        window._bkPendingInit = false;
        if (bookkeepingRealm) bk_initBookkeeping(); else bk_showConnectCard(companyData.realm_id && companyData.realm_id !== '');
      }
    } catch(e) {
      console.error('loadCompany error:', e);
      document.getElementById('entity-name').textContent = 'Error loading';
    }
  }

  const ENTITY_LABELS = {
    s_corp: 'S-Corporation', c_corp: 'C-Corporation', llc: 'LLC',
    partnership: 'Partnership', sole_prop: 'Sole Proprietorship',
    trust: 'Trust', nonprofit: 'Non-Profit', '1040': '1040 (Individual)',
    other: 'Other'
  };
  function etLabel(t) { return ENTITY_LABELS[t] || (t ? t.replace(/_/g,' ') : ''); }

  function renderHeader(c) {
    document.title = `${c.company_name} — DarkLion`;
    document.getElementById('entity-name').textContent = c.company_name || 'Unnamed Company';
    let html = `<span class="badge badge-muted">Company</span>`;
    if (c.entity_type) html += ` <span class="badge badge-muted">${esc(etLabel(c.entity_type))}</span>`;
    if (c.status === 'active') html += ` <span class="badge badge-green">Active</span>`;
    if (c.status === 'inactive') html += ` <span class="badge badge-muted">Inactive</span>`;
    if (c.status === 'dissolved') html += ` <span class="badge badge-red">Dissolved</span>`;
    if (c.qbo_connected) html += ` <span class="badge badge-green">QBO Connected</span>`;
    else if (c.realm_id && c.realm_id !== '') html += ` <span class="badge badge-red">QBO Disconnected</span>`;
    if (c.bookkeeping_service && c.bookkeeping_service !== 'none') {
      const bkLabel = { bank_feed: 'Bank Feed', accrual: 'Accrual', client_prepared: 'Client Prepared' }[c.bookkeeping_service] || c.bookkeeping_service;
      html += ` <span class="badge" style="background:rgba(74,144,217,0.15);color:#4a90d9;border:1px solid rgba(74,144,217,0.3);">📒 ${esc(bkLabel)}</span>`;
    }
    document.getElementById('entity-badges').innerHTML = html;
    const meta = [];
    if (c.relationship) {
      meta.push(`👥 <a href="/crm/relationship/${c.relationship.id}" style="color:var(--gold);text-decoration:none;">${esc(c.relationship.name)}</a>`);
      const relBtn = document.getElementById('entity-rel-btn');
      if (relBtn) { relBtn.textContent = `👥 ${c.relationship.name}`; relBtn.style.display = ''; relBtn.onclick = () => window.location.href = `/crm/relationship/${c.relationship.id}`; }
    }
    if (c.tax_year_end) meta.push(`Tax Year End: ${esc(c.tax_year_end)}`);
    const cityState = [c.city, c.state].filter(x => x && x.trim()).map(esc).join(', ');
    if (cityState) meta.push(`📍 ${cityState}`);
    document.getElementById('entity-meta').innerHTML = meta.join('  ·  ');
    // Track recent visit
    if (window.addRecentClient) window.addRecentClient({ _type:'company', id: c.id, _label: c.company_name || 'Unnamed', _sub: (c.relationship && c.relationship.name) || c.entity_type || 'Company' });
  }

  function renderOverview(c) {
