    peopleEl.innerHTML = peopleHtml;

    // ── LEFT COL: Tax Status panel ──
    const taxEl = document.getElementById('overview-tax-panel');
    taxEl.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;display:flex;align-items:center;justify-content:space-between;">
      <span>Tax Status</span>
      <a href="#" onclick="switchTab('tax',document.querySelector('[onclick*=\\'tax\\']'));return false;" style="font-size:0.72rem;color:var(--gold);">View all →</a>
    </div><div id="ov-tax-inner" style="color:var(--muted);font-size:0.82rem;">Loading…</div>`;
    apiFetch(`/api/tax-deliveries?company_id=${companyId}`).then(r=>r.json()).then(deliveries=>{
      const el = document.getElementById('ov-tax-inner');
      if (!el) return;
      if (!deliveries.length) { el.innerHTML = `<div style="color:var(--muted);font-size:0.82rem;font-style:italic;">No tax deliveries yet.</div>`; return; }
      const last3 = deliveries.slice(0,3);
      const STATUS_DOT = { draft:'#8fa3b8', sent:'#4a90d9', signed:'#3ecf8e', complete:'#3ecf8e', needs_changes:'#ed8936', approved:'#c9a84c' };
      const STATUS_LABEL = { draft:'Draft', sent:'Sent', signed:'Signed', complete:'Complete', needs_changes:'Needs Changes', approved:'Approved' };
      el.innerHTML = last3.map(d => {
        const dot = STATUS_DOT[d.status] || '#8fa3b8';
        const label = STATUS_LABEL[d.status] || d.status || '';
        return `<div style="display:flex;align-items:center;gap:0.6rem;padding:0.4rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="background:rgba(201,168,76,0.12);color:var(--gold);border-radius:4px;padding:0.1rem 0.4rem;font-size:0.72rem;font-weight:700;flex-shrink:0;">${esc(String(d.tax_year||''))}</span>
          <span style="flex:1;min-width:0;font-size:0.82rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(d.title||'Return')}</span>
