    guardEl.innerHTML = '';
    if (mainEl) mainEl.style.display = '';
    return true;
  }

  function bk_initBookkeeping() {
    // Get the active subtab name
    const activeSubtab = document.querySelector('.subtab-item.active');
    const name = activeSubtab ? activeSubtab.getAttribute('onclick').match(/'([^']+)'/)?.[1] : 'close-package';
    bk_loadActiveSubtab(name || 'close-package');
  }

  function bk_loadActiveSubtab(name) {
    if (name === 'close-package') bk_initClosePackage();
    else if (name === 'uncategorized') bk_initUncategorized();
    else if (name === 'variance') bk_initVariance();
    else if (name === 'liability') bk_initLiability();
    else if (name === 'payroll') bk_initPayroll();
    else if (name === 'statements') bk_initStatements();
    else if (name === 'stmt-calendar') bk_initCalendar();
  }

  // ── Helpers ──
  function bk_fmtCur(n) { return '$'+Math.abs(n).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:0}); }
  function bk_fmtCurSigned(n) { return (n>=0?'+':'-')+'$'+Math.abs(n).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:0}); }
  function bk_fmtPay(n) { return '$'+Number(n||0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); }
  function bk_parseScanData(scan) {
    if (!scan || !scan.result_data) return null;
    try { return typeof scan.result_data === 'string' ? JSON.parse(scan.result_data) : scan.result_data; }
    catch(e) { return null; }
  }
  function bk_lastDay(year, month) {
    const d = new Date(year, month, 0);
    return year+'-'+String(month).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
  }
  function bk_formatCurrency(n) {
    if (n === 0) return '$0.00';
    const abs = Math.abs(n);
    const formatted = '$' + abs.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
    return n < 0 ? `<span style="color:var(--red);">(${formatted})</span>` : formatted;
  }

  // ================================================================
  // CLOSE PACKAGE
  // ================================================================
  let bk_cpSelection = { type: 'month', startDate: null, endDate: null, label: '', period: '' };

  function bk_initClosePackage() {
    if (!bk_qboGuard('bk-cp-qbo-guard','bk-cp-main')) return;
    if (bk_cpInitialized) return;
    bk_cpInitialized = true;
    bk_populatePeriodSelectors();
    bk_loadLatestClosePackage();
  }

  function bk_populatePeriodSelectors() {
    const now = new Date();
    const cutoff = new Date(now.getFullYear(), now.getMonth() - 17, 1);
    let mhtml = '';
    for (const year of [now.getFullYear(), now.getFullYear()-1]) {
      mhtml += '<div class="period-year-label">'+year+'</div><div class="month-grid">';
      for (let m = 1; m <= 12; m++) {
        const d = new Date(year, m-1, 1);
        const val = year + '-' + String(m).padStart(2,'0');
        const short = d.toLocaleString('default',{month:'short'});
        const isCurrent = year === now.getFullYear() && m-1 === now.getMonth();
        const isFuture = d > now;
        const tooOld = d < cutoff;
        const disabled = isFuture || tooOld;
        mhtml += '<button class="month-btn'+(isCurrent?' current':'')+'"'+(disabled?' disabled style="opacity:0.3;cursor:default;"':'')+' data-period="'+val+'" onclick="'+(disabled?'':'bk_selectMonth(this,\''+val+'\')')+'">'+short+'</button>';
      }
      mhtml += '</div>';
    }
    document.getElementById('bk-month-grid-container').innerHTML = mhtml;

    let qhtml = '';
    for (const year of [now.getFullYear(), now.getFullYear()-1]) {
      qhtml += '<div class="period-year-label">'+year+'</div><div class="quarter-grid">';
      for (let q = 1; q <= 4; q++) {
        const sm = (q-1)*3 + 1; const em = q*3;
        const sd = year+'-'+String(sm).padStart(2,'0')+'-01';
        const ed = bk_lastDay(year, em);
        qhtml += '<button class="quarter-btn" onclick="bk_selectQuarter(this,'+q+','+year+',\''+sd+'\',\''+ed+'\')">Q'+q+'</button>';
      }
      qhtml += '</div>';
    }
    document.getElementById('bk-quarter-grid-container').innerHTML = qhtml;

    let yhtml = '';
    const cy = now.getFullYear();
    yhtml += '<button class="year-btn" onclick="bk_selectYear(this,'+cy+')">'+cy+' YTD</button>';
    yhtml += '<button class="year-btn" onclick="bk_selectYear(this,'+(cy-1)+')">'+(cy-1)+'</button>';
    yhtml += '<button class="year-btn" onclick="bk_selectYear(this,'+(cy-2)+')">'+(cy-2)+'</button>';
    document.getElementById('bk-year-grid-container').innerHTML = yhtml;

    const lastMonth = new Date(now.getFullYear(), now.getMonth()-1, 1);
    document.getElementById('bk-cp-date-from').value = lastMonth.getFullYear()+'-'+String(lastMonth.getMonth()+1).padStart(2,'0')+'-01';
    document.getElementById('bk-cp-date-to').value = bk_lastDay(lastMonth.getFullYear(), lastMonth.getMonth()+1);

    const curVal = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0');
    const curBtn = document.querySelector('#bk-month-grid-container .month-btn[data-period="'+curVal+'"]');
    if (curBtn) bk_selectMonth(curBtn, curVal, true);
  }

  function bk_showPeriodTab(tab, el) {
    document.querySelectorAll('#subtab-close-package .period-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('#subtab-close-package .period-panel').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('bk-pp-'+tab).classList.add('active');
  }

  function bk_clearPeriodBtns() {
    document.querySelectorAll('#bk-month-grid-container .month-btn, #bk-quarter-grid-container .quarter-btn, #bk-year-grid-container .year-btn').forEach(b => b.classList.remove('selected'));
  }

  function bk_selectMonth(btn, period, skipGenerate) {
    bk_clearPeriodBtns(); btn.classList.add('selected');
    const [y,m] = period.split('-').map(Number);
    const d = new Date(y, m-1, 1);
    bk_cpSelection = { type:'month', startDate:y+'-'+String(m).padStart(2,'0')+'-01', endDate:bk_lastDay(y,m), label:d.toLocaleString('default',{month:'long',year:'numeric'}), period };
    document.getElementById('bk-cp-selected-label').textContent = bk_cpSelection.label;
    if (!skipGenerate) bk_generateClosePackage();
  }

  function bk_selectQuarter(btn, q, year, sd, ed) {
    bk_clearPeriodBtns(); btn.classList.add('selected');
    bk_cpSelection = { type:'quarter', startDate:sd, endDate:ed, label:'Q'+q+' '+year, period:year+'-Q'+q };
    document.getElementById('bk-cp-selected-label').textContent = bk_cpSelection.label;
    bk_generateClosePackage();
  }

  function bk_selectYear(btn, year) {
    bk_clearPeriodBtns(); btn.classList.add('selected');
    const now = new Date();
    const isCurrentYear = year === now.getFullYear();
    bk_cpSelection = { type:'annual', startDate:year+'-01-01', endDate:isCurrentYear?bk_lastDay(now.getFullYear(),now.getMonth()+1):year+'-12-31', label:isCurrentYear?year+' YTD':String(year), period:String(year) };
    document.getElementById('bk-cp-selected-label').textContent = bk_cpSelection.label;
    bk_generateClosePackage();
  }

  function bk_applyCustomRange() {
    bk_clearPeriodBtns();
    const from = document.getElementById('bk-cp-date-from').value;
    const to = document.getElementById('bk-cp-date-to').value;
    if (!from || !to) { toast('Select both dates', 'error'); return; }
    if (from > to) { toast('Start date must be before end date', 'error'); return; }
    bk_cpSelection = { type:'custom', startDate:from, endDate:to, label:from+' to '+to, period:'custom' };
    document.getElementById('bk-cp-selected-label').textContent = bk_cpSelection.label;
    bk_generateClosePackage();
  }

  async function bk_generateClosePackage() {
    if (!bookkeepingRealm) return;
    if (!bk_cpSelection.startDate) { toast('Select a period first', 'error'); return; }
    document.getElementById('bk-cp-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Generating close package for '+esc(bk_cpSelection.label)+'…</div>';
    try {
      const body = { startDate:bk_cpSelection.startDate, endDate:bk_cpSelection.endDate, period:bk_cpSelection.period, label:bk_cpSelection.label };
      const data = await (await apiFetch('/api/companies/'+bookkeepingRealm+'/close-package',{method:'POST',body:JSON.stringify(body)})).json();
      if (data.error) throw new Error(data.error);
      const rd = bk_parseScanData(data) || data.report_data;
      const rdObj = typeof rd === 'string' ? JSON.parse(rd) : rd;
      document.getElementById('bk-cp-results').innerHTML = '<h3 style="font-size:0.92rem;margin-bottom:1rem;">'+esc(bk_cpSelection.label)+'</h3>' + bk_renderClosePackageBody(rdObj, data);
      toast('Close package generated for '+bk_cpSelection.label);
    } catch(e) {
      toast('Generation failed: '+e.message, 'error');
      document.getElementById('bk-cp-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed: '+esc(e.message)+'</div>';
    }
  }

  async function bk_loadLatestClosePackage() {
    if (!bookkeepingRealm) return;
    try {
      const resp = await apiFetch('/api/companies/'+bookkeepingRealm+'/close-packages');
      if (!resp.ok) return;
      const pkgs = await resp.json();
      if (!Array.isArray(pkgs) || pkgs.length === 0) return;
      const latest = pkgs[0];
      const rd = bk_parseScanData(latest) || latest.report_data;
      const rdObj = typeof rd === 'string' ? JSON.parse(rd) : rd;
      if (!rdObj) return;
      const btn = document.querySelector('#bk-month-grid-container .month-btn[data-period="'+latest.period+'"]');
      if (btn) bk_selectMonth(btn, latest.period, true);
      document.getElementById('bk-cp-results').innerHTML = '<h3 style="font-size:0.92rem;margin-bottom:1rem;">'+esc(rdObj.period||latest.period)+'</h3>' + bk_renderClosePackageBody(rdObj, latest);
    } catch(e) { console.error('bk_loadLatestClosePackage error:', e); }
  }

  function bk_renderClosePackageBody(rd, pkg) {
    if (!rd) return '<div style="color:var(--muted);padding:1rem;">No report data available.</div>';
    let html = '';
    if (rd.pnl) html += '<div class="report-section"><h3>Profit & Loss</h3>'+bk_renderQBReport(rd.pnl)+'</div>';
    if (rd.balanceSheet) html += '<div class="report-section"><h3>Balance Sheet</h3>'+bk_renderQBReport(rd.balanceSheet)+'</div>';
    if (rd.trialBalance) html += '<div class="report-section"><h3>Trial Balance</h3>'+bk_renderQBReport(rd.trialBalance)+'</div>';
    if (!rd.pnl && !rd.balanceSheet && !rd.trialBalance) html += '<div style="color:var(--muted);padding:1rem;text-align:center;">No report data available.</div>';
    html += '<div style="margin-top:0.75rem;text-align:right;"><span class="badge badge-pending" style="font-size:0.75rem;padding:0.2rem 0.6rem;">'+esc(pkg.status||'draft')+'</span></div>';
    return html;
  }

  function bk_renderQBReport(report) {
    if (!report?.Rows?.Row) {
      return '<div style="text-align:center;padding:1.5rem;color:var(--muted);">No report data available.</div>';
    }
    const columns = report.Columns?.Column || [];
    const colCount = Math.max(columns.length, 2);
    const dataCols = colCount - 1;
    const MONTH_MAP = {jan:1,feb:2,mar:3,apr:4,may:5,jun:6,jul:7,aug:8,sep:9,oct:10,nov:11,dec:12};
    function parseTitleDate(title) {
      if (!title) return { start: '', end: '' };
      const m = title.trim().match(/^([A-Za-z]{3})\s+(\d{4})$/);
      if (m) {
        const mo = MONTH_MAP[m[1].toLowerCase()];
        const yr = parseInt(m[2]);
        if (mo && yr) {
          const start = yr + '-' + String(mo).padStart(2,'0') + '-01';
          const lastD = new Date(yr, mo, 0).getDate();
          const end = yr + '-' + String(mo).padStart(2,'0') + '-' + String(lastD).padStart(2,'0');
          return { start, end };
        }
      }
      const yr = title.trim().match(/^(\d{4})$/);
      if (yr) return { start: yr[1]+'-01-01', end: yr[1]+'-12-31' };
      return { start: '', end: '' };
    }
    const colDates = columns.map(col => {
      const meta = col.MetaData || [];
      const start = meta.find(m => m.Name === 'StartDate')?.Value || '';
      const end   = meta.find(m => m.Name === 'EndDate')?.Value   || '';
      if (start && end) return { start, end };
      return parseTitleDate(col.ColTitle || '');
    });
    const firstColPct = dataCols <= 1 ? 60 : dataCols <= 3 ? 40 : dataCols <= 7 ? 30 : 25;
    const restPct = (100 - firstColPct) / dataCols;
    let html = '<div class="table-wrap"><table style="table-layout:fixed;width:100%;">';
    html += '<colgroup>';
    html += `<col style="width:${firstColPct}%">`;
    for (let i = 0; i < dataCols; i++) html += `<col style="width:${restPct.toFixed(2)}%">`;
    html += '</colgroup>';
    html += '<thead><tr>';
    for (let i = 0; i < colCount; i++) {
      const title = columns[i]?.ColTitle || (i === 0 ? '' : '');
      html += i === 0
        ? `<th style="text-align:left;">${esc(title)}</th>`
        : `<th class="amount" style="text-align:right;padding-right:1rem;">${esc(title)}</th>`;
    }
    html += '</tr></thead>';
    html += '<tbody>';
    html += bk_renderReportRows(report.Rows.Row, 0, colCount, colDates);
    html += '</tbody></table></div>';
    return html;
  }

  function bk_renderReportRows(rows, depth, colCount, colDates) {
    let html = '';
    for (const row of rows) {
      if (row.type === 'Section' || row.group) {
        if (row.Header?.ColData) {
          const name = row.Header.ColData[0]?.value || '';
          const pad = (depth * 1.2) + 1;
          html += `<tr class="report-row-header"><td style="padding-left:${pad}rem;">${esc(name)}</td>`;
          for (let i = 1; i < colCount; i++) html += '<td class="amount"></td>';
          html += '</tr>';
        }
        if (row.Rows?.Row) html += bk_renderReportRows(row.Rows.Row, depth + 1, colCount, colDates);
        if (row.Summary?.ColData) html += bk_renderDataRow(row.Summary.ColData, depth, true, colCount, colDates);
      } else if (row.ColData) {
        html += bk_renderDataRow(row.ColData, depth, false, colCount, colDates);
      }
    }
    return html;
  }

  function bk_renderDataRow(colData, depth, isTotal, colCount, colDates) {
    const cls = isTotal ? ' class="report-row-total"' : '';
    let html = `<tr${cls}>`;
    for (let i = 0; i < colCount; i++) {
      const val = colData[i]?.value ?? '';
      if (i === 0) {
        const pad = (depth * 1.2) + 1;
        html += `<td style="padding-left:${pad}rem;${isTotal ? 'font-weight:700;' : ''}">${esc(val)}</td>`;
      } else {
        const num = parseFloat(val);
        const display = isNaN(num) ? esc(val) : bk_formatCurrency(num);
        const colDate = colDates?.[i] || {};
        const sDate = colDate.start || bk_cpSelection?.startDate || '';
        const eDate = colDate.end   || bk_cpSelection?.endDate   || '';
        const accountName = colData[0]?.value || '';
        const drillable = !isNaN(num) && num !== 0 && sDate && eDate && !isTotal ? ' drillable' : '';
        const drillAttr = drillable
          ? ` data-account="${esc(accountName)}" data-start="${esc(sDate)}" data-end="${esc(eDate)}" onclick="bk_openDrilldown('${esc(accountName)}','${esc(sDate)}','${esc(eDate)}','${display.replace(/['"<>]/g,'')}')"` : '';
        html += `<td class="amount${drillable}"${drillAttr} style="padding-right:1rem;${isTotal ? 'font-weight:700;' : ''}">${display}</td>`;
      }
    }
    html += '</tr>';
    return html;
  }

  // ================================================================
  // UNCATEGORIZED
  // ================================================================
  function bk_initUncategorized() {
    if (!bk_qboGuard('bk-uncat-qbo-guard','bk-uncat-main')) return;
    if (bk_uncatLoaded) return;
    bk_uncatLoaded = true;
    bk_loadLatestUncategorized();
  }

  async function bk_runUncategorizedScan() {
    if (!bookkeepingRealm) { toast('No QBO connection', 'error'); return; }
    const btn = document.getElementById('bk-btn-uncat-scan');
    btn.disabled=true; btn.textContent='Scanning…';
    try {
      const data = await (await apiFetch('/api/companies/'+bookkeepingRealm+'/scan/uncategorized',{method:'POST'})).json();
      if (data.error) throw new Error(data.error);
      bk_renderUncatResults(data);
      toast('Scan complete: '+data.summary.flaggedCount+' flagged');
    } catch(e) { toast('Scan failed: '+e.message, 'error'); }
    btn.disabled=false; btn.textContent='Run Scan';
  }

  function bk_renderUncatResults(data) {
    const s = data.summary;
    document.getElementById('bk-uncat-stats').style.display='';
    document.getElementById('bk-uncat-flagged').textContent = s.flaggedCount;
    document.getElementById('bk-uncat-checked').textContent = s.checkedCount;
    document.getElementById('bk-uncat-total').textContent = '$'+Number(s.totalFlaggedAmount).toLocaleString();
    document.getElementById('bk-uncat-last-scan').textContent = 'Last scanned: ' + new Date().toLocaleString();
    let html = '';
    if (data.flagged?.length > 0) {
      html += '<h3 style="font-size:0.88rem;margin:1rem 0 0.5rem;color:var(--red);">Flagged Accounts</h3><div class="table-wrap"><table><thead><tr><th>Account</th><th>Balance</th><th>Transactions</th></tr></thead><tbody>';
      for (const f of data.flagged) {
        html += '<tr><td style="font-weight:600;">'+esc(f.name)+'</td><td style="color:var(--orange);">$'+Number(f.balance).toLocaleString()+'</td><td>'+f.transactionCount+'</td></tr>';
        if (f.transactions?.length > 0) {
          for (const t of f.transactions) {
            html += '<tr><td style="padding-left:2rem;color:var(--muted);font-size:0.8rem;">'+t.date+'</td><td style="font-size:0.8rem;">$'+Number(t.amount).toFixed(2)+'</td><td style="color:var(--muted);font-size:0.8rem;">'+esc(t.vendor)+' — '+esc(t.description)+'</td></tr>';
          }
        }
      }
      html += '</tbody></table></div>';
    }
    if (data.checked?.length > 0) {
      html += '<h3 style="font-size:0.88rem;margin:1.5rem 0 0.5rem;">All Checked Accounts</h3><div class="table-wrap"><table><thead><tr><th>Account</th><th>Balance</th><th>Status</th></tr></thead><tbody>';
      for (const c of data.checked) {
        html += '<tr><td>'+esc(c.name)+'</td><td>$'+Number(c.balance).toLocaleString()+'</td><td>'+(c.balance===0?'<span class="badge badge-ok">OK</span>':'<span class="badge badge-flag">Flagged</span>')+'</td></tr>';
      }
      html += '</tbody></table></div>';
    }
    document.getElementById('bk-uncat-results').innerHTML = html;
  }

  async function bk_loadLatestUncategorized() {
    if (!bookkeepingRealm) return;
    try {
      const scans = await (await apiFetch('/api/companies/'+bookkeepingRealm+'/scans')).json();
      const latest = Array.isArray(scans) ? scans.find(s => s.scan_type === 'uncategorized') : null;
      if (!latest) {
        // No cached data — auto-run scan
        bk_runUncategorizedScan();
        return;
      }
      const data = bk_parseScanData(latest);
      if (!data?.summary) { bk_runUncategorizedScan(); return; }
      document.getElementById('bk-uncat-last-scan').textContent = 'Last scanned: ' + new Date(latest.scanned_at).toLocaleString();
      bk_renderUncatResults(data);
    } catch(e) {}
  }

  // ================================================================
  // VARIANCE
  // ================================================================
  let bk_varSelectedMonth = null;

  function bk_initVariance() {
    if (!bk_qboGuard('bk-var-qbo-guard','bk-var-main')) return;
    if (bk_varInitialized) return;
    bk_varInitialized = true;
    bk_initVarianceMonthPicker();
    bk_loadLatestVariance();  // auto-runs scan if no cache
  }

  function bk_initVarianceMonthPicker() {
    const now = new Date();
    const container = document.getElementById('bk-var-month-btns');
    const months = [];
    for (let i = 0; i < 18; i++) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      months.push({ year: d.getFullYear(), month: d.getMonth() + 1, label: d.toLocaleString('default',{month:'short'})+' '+d.getFullYear() });
    }
    if (!bk_varSelectedMonth) bk_varSelectedMonth = { year: months[0].year, month: months[0].month };
    container.innerHTML = months.map(m => {
      const selected = bk_varSelectedMonth && bk_varSelectedMonth.year === m.year && bk_varSelectedMonth.month === m.month;
      return `<button class="var-month-btn${selected ? ' selected' : ''}" data-year="${m.year}" data-month="${m.month}" onclick="bk_selectVarMonth(this, ${m.year}, ${m.month})">${m.label}</button>`;
    }).join('');
  }

  function bk_selectVarMonth(btn, year, month) {
    document.querySelectorAll('#bk-var-month-btns .var-month-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    bk_varSelectedMonth = { year, month };
    bk_runVarianceScan();
  }

  async function bk_runVarianceScan() {
    if (!bookkeepingRealm) return;
    const selectedBtn = document.querySelector('#bk-var-month-btns .selected');
    const year = selectedBtn ? parseInt(selectedBtn.dataset.year) : (bk_varSelectedMonth?.year || new Date().getFullYear());
    const month = selectedBtn ? parseInt(selectedBtn.dataset.month) : (bk_varSelectedMonth?.month || new Date().getMonth() + 1);
    const thresholdPct = parseInt(document.getElementById('bk-var-threshold-pct').value) || 15;
    const thresholdAmt = parseInt(document.getElementById('bk-var-threshold-amt').value) || 500;
    document.getElementById('bk-var-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Running variance analysis…</div>';
    try {
      const data = await (await apiFetch('/api/companies/'+bookkeepingRealm+'/scan/variance', {method:'POST',body:JSON.stringify({year,month,thresholdPct,thresholdAmt})})).json();
      if (data.error) throw new Error(data.error);
      bk_renderVarianceResults(data);
      toast('Variance analysis complete — '+data.summary.flaggedCount+' flagged');
    } catch(e) {
      toast('Variance analysis failed: '+e.message, 'error');
      document.getElementById('bk-var-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed: '+esc(e.message)+'</div>';
    }
  }

  function bk_renderVarianceResults(data) {
    document.getElementById('bk-var-stats').style.display='';
    document.getElementById('bk-var-total').textContent = data.summary.totalAccounts;
    document.getElementById('bk-var-flagged').textContent = data.summary.flaggedCount;
    document.getElementById('bk-var-threshold').textContent = (data.thresholdPct||15)+'%';
    document.getElementById('bk-var-last-scan').textContent = 'Comparing '+data.period+' vs '+data.priorPeriod+' (MoM) and '+data.yoyPeriod+' (YoY)';
    const v = data.variances || [];
    if (v.length === 0) { document.getElementById('bk-var-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">No P&L data found.</div>'; return; }
    let html = '<div class="table-wrap"><table><thead><tr><th>Account</th><th class="amount">Current</th><th class="amount">Prior Mo</th><th class="amount">MoM $</th><th class="amount">MoM %</th><th class="amount">Prior Yr</th><th class="amount">YoY $</th><th class="amount">YoY %</th></tr></thead><tbody>';
    for (const r of v) {
      const isTotal = r.account.startsWith('TOTAL:');
      const rowCls = isTotal ? ' class="report-row-total"' : (r.flagged ? ' style="background:rgba(245,101,101,0.06);"' : '');
      const name = isTotal ? '<strong>'+esc(r.account)+'</strong>' : esc(r.account);
      function varColor(diff, isIncome, flagged) {
        if (!flagged) return '';
        if (isIncome === true) return diff > 0 ? 'color:var(--green);font-weight:700;' : 'color:var(--red);font-weight:700;';
        if (isIncome === false) return diff < 0 ? 'color:var(--green);font-weight:700;' : 'color:var(--red);font-weight:700;';
        return diff > 0 ? 'color:var(--red);font-weight:700;' : 'color:var(--green);font-weight:700;';
      }
      const momColor = varColor(r.momDiff, r.isIncome, r.momFlagged);
      const yoyColor = varColor(r.yoyDiff, r.isIncome, r.yoyFlagged);
      html += '<tr'+rowCls+'><td>'+name+'</td><td class="amount">'+bk_fmtCur(r.current)+'</td><td class="amount">'+bk_fmtCur(r.priorMonth)+'</td><td class="amount" style="'+momColor+'">'+bk_fmtCurSigned(r.momDiff)+'</td><td class="amount" style="'+momColor+'">'+(r.momPct>0?'+':'')+r.momPct+'%</td><td class="amount">'+bk_fmtCur(r.priorYearMonth)+'</td><td class="amount" style="'+yoyColor+'">'+bk_fmtCurSigned(r.yoyDiff)+'</td><td class="amount" style="'+yoyColor+'">'+(r.yoyPct>0?'+':'')+r.yoyPct+'%</td></tr>';
    }
    html += '</tbody></table></div>';
    document.getElementById('bk-var-results').innerHTML = html;
  }

  async function bk_loadLatestVariance() {
    if (!bookkeepingRealm) return;
    try {
      const resp = await apiFetch('/api/companies/'+bookkeepingRealm+'/scans?type=variance');
      if (!resp.ok) { bk_runVarianceScan(); return; }
      const scan = await resp.json();
      if (!scan?.result_data) { bk_runVarianceScan(); return; }
      const data = bk_parseScanData(scan);
      if (data) bk_renderVarianceResults(data);
      else bk_runVarianceScan();
    } catch(e) {}
  }

  // ================================================================
  // LIABILITY
  // ================================================================
  function bk_initLiability() {
    if (!bk_qboGuard('bk-liab-qbo-guard','bk-liab-main')) return;
    if (bk_liabLoaded) return;
    bk_liabLoaded = true;
    bk_loadLatestLiability();
  }

  async function bk_runLiabilityScan() {
    if (!bookkeepingRealm) { toast('No QBO connection', 'error'); return; }
    document.getElementById('bk-liab-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Scanning liability accounts…</div>';
    try {
      const data = await (await apiFetch('/api/companies/'+bookkeepingRealm+'/scan/liability', {method:'POST',body:'{}'})).json();
      if (data.error) throw new Error(data.error);
      bk_renderLiabilityResults(data);
      toast('Liability check complete — '+data.summary.flaggedCount+' issues found');
    } catch(e) {
      toast('Liability check failed: '+e.message, 'error');
      document.getElementById('bk-liab-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed: '+esc(e.message)+'</div>';
    }
  }

  function bk_renderLiabilityResults(data) {
    if (data.error) { document.getElementById('bk-liab-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">'+esc(data.error)+'</div>'; return; }
    if (data.message) { document.getElementById('bk-liab-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">'+esc(data.message)+'</div>'; return; }
    document.getElementById('bk-liab-stats').style.display='';
    document.getElementById('bk-liab-total').textContent = data.summary.totalAccounts;
    document.getElementById('bk-liab-flagged').textContent = data.summary.flaggedCount;
    document.getElementById('bk-liab-balance').textContent = '$'+Math.abs(data.summary.totalLiabilityBalance).toLocaleString();
    let html = '';
    if (data.flagged?.length > 0) {
      html += '<h3 style="font-size:0.88rem;margin:0 0 0.5rem;color:var(--red);">Issues Found</h3>';
      html += '<div class="table-wrap" style="margin-bottom:1.5rem;"><table><thead><tr><th>Account</th><th>Type</th><th>Subtype</th><th class="amount">Balance</th><th>Issues</th></tr></thead><tbody>';
      for (const a of data.flagged) {
        const issueHtml = a.issues.map(i => '<span class="badge '+(i.severity==='warning'?'badge-flag':'badge-pending')+'">'+esc(i.message)+'</span>').join(' ');
        html += '<tr style="background:rgba(245,101,101,0.06);"><td style="font-weight:600;">'+esc(a.name)+'</td><td style="color:var(--muted);font-size:0.78rem;">'+esc(a.accountType)+'</td><td style="color:var(--muted);font-size:0.78rem;">'+esc(a.subType||'')+'</td><td class="amount" style="color:var(--orange);font-weight:600;">$'+Number(a.balance).toLocaleString()+'</td><td>'+issueHtml+'</td></tr>';
      }
      html += '</tbody></table></div>';
    }
    if (data.checked?.length > 0) {
      html += '<h3 style="font-size:0.88rem;margin:0 0 0.5rem;">All Liability Accounts</h3>';
      html += '<div class="table-wrap"><table><thead><tr><th>Account</th><th>Type</th><th>Subtype</th><th class="amount">Balance</th><th>Status</th></tr></thead><tbody>';
      for (const a of data.checked) {
        const ok = a.issues.filter(i => i.severity !== 'info').length === 0;
        html += '<tr><td>'+esc(a.name)+'</td><td style="color:var(--muted);font-size:0.78rem;">'+esc(a.accountType)+'</td><td style="color:var(--muted);font-size:0.78rem;">'+esc(a.subType||'')+'</td><td class="amount">$'+Number(a.balance).toLocaleString()+'</td><td>'+(ok?'<span class="badge badge-ok">OK</span>':'<span class="badge badge-flag">'+a.issues.filter(i=>i.severity!=='info').length+' issue(s)</span>')+'</td></tr>';
      }
      html += '</tbody></table></div>';
    }
    document.getElementById('bk-liab-results').innerHTML = html || '<div style="text-align:center;padding:2rem;color:var(--muted);">No liability accounts found.</div>';
  }

  async function bk_loadLatestLiability() {
    if (!bookkeepingRealm) return;
    try {
      const resp = await apiFetch('/api/companies/'+bookkeepingRealm+'/scans?type=liability');
      if (!resp.ok) { bk_runLiabilityScan(); return; }
      const scan = await resp.json();
      if (!scan?.result_data) { bk_runLiabilityScan(); return; }
      const data = bk_parseScanData(scan);
      if (data) bk_renderLiabilityResults(data);
      else bk_runLiabilityScan();
    } catch(e) {}
  }

  // ================================================================
  // PAYROLL
  // ================================================================
  let bk_payrollSelectedMonth = null;

  function bk_initPayroll() {
    if (!bk_qboGuard('bk-payroll-qbo-guard','bk-payroll-main')) return;
    if (!companyData) return;
    const actionsEl = document.getElementById('bk-payroll-actions');
    if (!companyData.gusto_company_id) {
      // QBO connected but Gusto not connected
      document.getElementById('bk-payroll-stats').style.display = 'none';
      document.getElementById('bk-payroll-month-picker').style.display = 'none';
      actionsEl.innerHTML = '';
      document.getElementById('bk-payroll-results').innerHTML = `
        <div class="bk-payroll-alert">
          ⚠️ Payroll Verification requires both QuickBooks and Gusto to be connected.<br>
          <span style="margin-top:0.4rem;display:block;">QBO: Connected ✅ &nbsp;|&nbsp; Gusto: Not Connected — <a href="/connect">Connect Gusto</a></span>
        </div>`;
      return;
    }
    if (bk_payrollInitialized) return;
    bk_payrollInitialized = true;
    actionsEl.innerHTML = '<button class="btn btn-gold" onclick="bk_runPayrollScan()">Run Payroll Check</button>';
    bk_buildPayrollMonthPicker();
    document.getElementById('bk-payroll-month-picker').style.display = '';
    bk_loadLatestPayroll(true);
  }

  function bk_buildPayrollMonthPicker() {
    const now = new Date();
    const months = [];
    for (let i = 0; i < 24; i++) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      months.push({ year: d.getFullYear(), month: d.getMonth() + 1 });
    }
    if (!bk_payrollSelectedMonth) bk_payrollSelectedMonth = months[0];
    const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    document.getElementById('bk-payroll-months').innerHTML = months.map(m => {
      const active = bk_payrollSelectedMonth.year === m.year && bk_payrollSelectedMonth.month === m.month;
      return '<button class="month-btn'+(active?' active':'')+'" style="padding:0.3rem 0.7rem;font-size:0.75rem;border:1px solid var(--border);border-radius:6px;background:'+(active?'var(--gold)':'var(--charcoal)')+';color:'+(active?'var(--navy)':'var(--text)')+';cursor:pointer;font-weight:'+(active?'700':'400')+';" onclick="bk_selectPayrollMonth('+m.year+','+m.month+')">'+monthNames[m.month-1]+' '+m.year+'</button>';
    }).join('');
  }

  function bk_selectPayrollMonth(year, month) { bk_payrollSelectedMonth = { year, month }; bk_buildPayrollMonthPicker(); bk_runPayrollScan(); }

  async function bk_runPayrollScan() {
    if (!bookkeepingRealm) return;
    const btn = document.querySelector('#bk-payroll-actions button');
    if (btn) { btn.disabled = true; btn.textContent = 'Scanning…'; }
    document.getElementById('bk-payroll-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Running payroll verification…</div>';
    try {
      const body = bk_payrollSelectedMonth ? { year: bk_payrollSelectedMonth.year, month: bk_payrollSelectedMonth.month } : {};
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/scan/payroll', { method: 'POST', body: JSON.stringify(body) });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      bk_renderPayrollResults(data);
      toast('Payroll check complete — ' + data.summary.mismatchCount + ' mismatch(es)');
    } catch(e) {
      toast('Payroll check failed: ' + e.message, 'error');
      document.getElementById('bk-payroll-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed: ' + esc(e.message) + '</div>';
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Run Payroll Check'; }
    }
  }

  function bk_renderPayrollResults(data) {
    const s = data.summary || {};
    document.getElementById('bk-payroll-stats').style.display = '';
    document.getElementById('bk-pay-count').textContent = s.payrollCount || 0;
    document.getElementById('bk-pay-gross').textContent = bk_fmtPay(s.totalGrossPay);
    const mc = s.mismatchCount || 0;
    document.getElementById('bk-pay-mismatches').textContent = mc;
    document.getElementById('bk-pay-mismatches').style.color = mc > 0 ? 'var(--red)' : 'var(--green)';
    document.getElementById('bk-pay-period').textContent = 'Period: ' + (data.period || '');
    if (!data.payrolls?.length) {
      document.getElementById('bk-payroll-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">No processed payrolls found for this period.</div>';
      return;
    }
    let html = '<h3 style="font-size:0.88rem;margin:0 0 0.5rem;">Gusto vs QBO Comparison</h3>';
    html += '<div class="table-wrap"><table><thead><tr><th>Category</th><th class="amount">Gusto</th><th class="amount">QBO P&L</th><th class="amount">Difference</th><th>Status</th></tr></thead><tbody>';
    const qbo = data.qboComparison || {};
    const comparisons = [
      { label:'Salaries (Non-Officer)', gusto:s.salaryWages, qbo:qbo.salaries||0 },
      { label:'Officer Compensation', gusto:s.officerWages, qbo:qbo.officerComp||0 },
      { label:'Total Gross Wages', gusto:s.totalGrossPay, qbo:(qbo.salaries||0)+(qbo.officerComp||0) },
      { label:'Employer Payroll Taxes', gusto:s.totalEmployerTaxes, qbo:qbo.payrollTax||0 },
      { label:'Payroll Processing Fees', gusto:null, qbo:qbo.payrollFees||0 },
    ];
    for (const c of comparisons) {
      const diff = (c.gusto !== null && c.qbo !== null) ? c.gusto - c.qbo : null;
      const ok = diff === null || Math.abs(diff) <= 1;
      const rowStyle = !ok ? ' style="background:rgba(245,101,101,0.06);"' : '';
      html += '<tr'+rowStyle+'><td style="font-weight:600;">'+esc(c.label)+'</td><td class="amount">'+(c.gusto!==null?bk_fmtPay(c.gusto):'<span style="color:var(--muted);">—</span>')+'</td><td class="amount">'+(c.qbo!==null?bk_fmtPay(c.qbo):'<span style="color:var(--muted);">N/A</span>')+'</td><td class="amount">'+(diff!==null?bk_fmtPay(diff):'—')+'</td><td>'+(ok?'<span class="badge badge-ok">OK</span>':'<span class="badge badge-flag">Mismatch</span>')+'</td></tr>';
    }
    html += '</tbody></table></div>';
    html += '<h3 style="font-size:0.88rem;margin:1.5rem 0 0.5rem;">Gusto Period Totals</h3>';
    html += '<div class="table-wrap"><table><thead><tr><th>Metric</th><th class="amount">Amount</th></tr></thead><tbody>';
    html += '<tr><td>Gross Pay</td><td class="amount" style="font-weight:600;">'+bk_fmtPay(s.totalGrossPay)+'</td></tr>';
    html += '<tr><td>Employer Taxes</td><td class="amount">'+bk_fmtPay(s.totalEmployerTaxes)+'</td></tr>';
    html += '<tr><td>Employee Taxes</td><td class="amount">'+bk_fmtPay(s.totalEmployeeTaxes)+'</td></tr>';
    html += '<tr><td>Benefits</td><td class="amount">'+bk_fmtPay(s.totalBenefits)+'</td></tr>';
    html += '<tr><td>Net Pay</td><td class="amount" style="font-weight:600;">'+bk_fmtPay(s.totalNetPay)+'</td></tr>';
    html += '<tr><td>Employees</td><td class="amount">'+s.employeeCount+'</td></tr>';
    html += '</tbody></table></div>';
    html += '<h3 style="font-size:0.88rem;margin:1.5rem 0 0.5rem;">Payroll Runs</h3>';
    html += '<div class="table-wrap"><table><thead><tr><th>Check Date</th><th>Pay Period</th><th class="amount">Gross Pay</th><th class="amount">Employer Taxes</th><th class="amount">Net Pay</th><th>Employees</th></tr></thead><tbody>';
    for (const p of data.payrolls) {
      html += '<tr><td style="font-weight:600;">'+esc(p.checkDate)+'</td><td style="color:var(--muted);font-size:0.78rem;">'+esc(p.payPeriodStart)+' — '+esc(p.payPeriodEnd)+'</td><td class="amount">'+bk_fmtPay(p.grossPay)+'</td><td class="amount">'+bk_fmtPay(p.employerTaxes)+'</td><td class="amount">'+bk_fmtPay(p.netPay)+'</td><td>'+(p.employeeCount||0)+'</td></tr>';
    }
    html += '</tbody></table></div>';
    if (data.employees?.length > 0) {
      html += '<h3 style="font-size:0.88rem;margin:1.5rem 0 0.5rem;">Wages by Employee</h3>';
      html += '<p style="font-size:0.75rem;color:var(--muted);margin-bottom:0.5rem;">Tag officers to split wages into Salaries vs Officer Comp for QBO comparison.</p>';
      html += '<div class="table-wrap"><table><thead><tr><th>Employee</th><th>Officer</th><th>FLSA</th><th class="amount">Hours</th><th class="amount">Gross Pay</th><th class="amount">Net Pay</th></tr></thead><tbody>';
      for (const e of data.employees) {
        html += '<tr><td style="font-weight:600;">'+esc(e.name)+'</td><td style="text-align:center;"><input type="checkbox"'+(e.isOfficer?' checked':'')+' onchange="bk_toggleOfficer(\''+esc(e.employeeUuid)+'\',this.checked,\''+esc(e.name)+'\')" style="cursor:pointer;width:16px;height:16px;accent-color:var(--gold);"></td><td style="font-size:0.78rem;color:var(--muted);">'+esc(e.flsaStatus||'')+'</td><td class="amount">'+Number(e.hours||0).toFixed(1)+'</td><td class="amount">'+bk_fmtPay(e.grossPay)+'</td><td class="amount">'+bk_fmtPay(e.netPay)+'</td></tr>';
      }
      html += '</tbody></table></div>';
    }
    const portalUrl = data.gustoPortalUrl || 'https://app.gusto.com';
    html += '<div style="margin-top:1.5rem;padding:1.2rem;background:var(--card);border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;justify-content:space-between;"><div><span style="font-weight:600;">W-2s & Tax Documents</span><br><span style="font-size:0.78rem;color:var(--muted);">Access via Gusto portal</span></div><a href="'+portalUrl+'" target="_blank" class="btn btn-gold" style="white-space:nowrap;">Open Gusto Portal</a></div>';
    document.getElementById('bk-payroll-results').innerHTML = html;
  }

  async function bk_toggleOfficer(employeeUuid, isOfficer, name) {
    try {
      await apiFetch('/api/companies/' + bookkeepingRealm + '/employees/' + employeeUuid + '/officer', {
        method: 'POST', body: JSON.stringify({ is_officer: isOfficer, employee_name: name }),
      });
      toast((isOfficer ? 'Tagged' : 'Untagged') + ' ' + name + ' as officer');
    } catch(e) { toast('Failed to update officer status', 'error'); }
  }

  async function bk_loadLatestPayroll(autoRun) {
    if (!bookkeepingRealm) return;
    try {
      const resp = await apiFetch('/api/companies/' + bookkeepingRealm + '/scans?type=payroll');
      if (!resp.ok) return;
      const scan = await resp.json();
      if (!scan?.result_data) { if (autoRun) return bk_runPayrollScan(); return; }
      const data = bk_parseScanData(scan);
      if (data?.error) { if (autoRun) return bk_runPayrollScan(); return; }
      if (data) bk_renderPayrollResults(data);
    } catch(e) {
      document.getElementById('bk-payroll-results').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">No payroll scans yet.</div>';
    }
  }

  // ================================================================
  // STATEMENTS
  // ================================================================
  const BK_METHOD_LABELS = {
    qbo_pull: 'QBO Pull', portal: 'Portal Download', manual: 'Manual Download',
    email: 'Email', client_upload: 'Client Upload',
    qbo: 'QBO Pull', client: 'Client Upload'
  };

  function bk_stmtCurrentMonth() {
    const d = new Date();
    return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
  }

  function bk_initStatements() {
    if (!bk_qboGuard('bk-stmt-qbo-guard','bk-stmt-main')) return;
    bk_loadStatementsView();
  }

  async function bk_loadStatementsView() {
    const month = bk_stmtCurrentMonth();
    const wrapEl = document.getElementById('bk-stmt-table-wrap');
    wrapEl.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Loading…</div>';
    document.getElementById('bk-stmt-summary').style.display = 'none';

    if (companyData) {
      document.getElementById('bk-stmt-page-title').textContent = 'Statements — ' + (companyData.company_name || '');
    }

    try {
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/statements/accounts?month=' + encodeURIComponent(month));
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      const accounts = data.accounts || [];

      // Auto-save new QBO accounts
      const newAccounts = accounts.filter(a => a._new && !a.id);
      for (const a of newAccounts) {
        try {
          const saveRes = await apiFetch('/api/companies/' + bookkeepingRealm + '/statements', {
            method: 'POST',
            body: JSON.stringify({ account_name: a.account_name, institution: '', access_method: 'qbo_pull', statement_day: 1, qb_account_id: a.qb_account_id || '' })
          });
          if (saveRes.ok) { const saved = await saveRes.json(); a.id = saved.id; a._new = false; }
        } catch(e) {}
      }

      const savedAccounts = accounts.filter(a => a.id);
      const behind = savedAccounts.filter(a => (a.months_behind || 0) > 0);
      if (savedAccounts.length > 0) {
        document.getElementById('bk-stmt-subtitle').innerHTML = behind.length === 0
          ? 'All current <span style="color:var(--green)">✅</span>'
          : `<span style="color:var(--red)">${behind.length} account${behind.length > 1 ? 's' : ''} behind 🔴</span>`;
      }
      if (accounts.length > 0) {
        document.getElementById('bk-stmt-summary').style.display = '';
        document.getElementById('bk-stmt-stats-grid').innerHTML = `
          <div class="stat-card"><div class="stat-label">Total Accounts</div><div class="stat-value">${accounts.length}</div></div>
          <div class="stat-card"><div class="stat-label">Current</div><div class="stat-value green">${savedAccounts.length - behind.length}</div></div>
          <div class="stat-card"><div class="stat-label">Behind</div><div class="stat-value ${behind.length > 0 ? 'orange' : 'green'}">${behind.length}</div></div>`;
      }
      wrapEl.innerHTML = bk_renderStmtTable(accounts, bookkeepingRealm, month);
    } catch(e) {
      wrapEl.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed: ' + esc(e.message) + '</div>';
    }
  }

  function bk_renderStmtTable(accounts, realmId, month) {
    if (!accounts.length) {
      return '<div style="text-align:center;padding:2rem;color:var(--muted);">No accounts found. Add one manually or wait for QBO accounts to appear.</div>';
    }
    let html = `<div class="table-wrap"><table class="stmt-table">
      <thead><tr>
        <th>Account</th><th>Type</th><th>Method</th><th>Statement Day</th><th>Status</th><th>Actions</th>
      </tr></thead><tbody>`;
    for (const a of accounts) {
      const typeLabel = [a.accountType, a.accountSubType].filter(Boolean).join(' / ') || (a._manual ? 'Manual' : '—');
      const monthsBehind = a.months_behind || 0;
      let statusCell;
      if (!a.id) {
        statusCell = `<span style="color:var(--muted);font-size:0.75rem;">Not saved</span>`;
      } else if (!a.last_retrieved_month) {
        statusCell = `<span style="color:var(--muted);font-size:0.75rem;">No history</span>`;
      } else if (monthsBehind === 0) {
        statusCell = `<span style="color:var(--green);font-size:0.8rem;">✅ Current</span>`;
      } else if (monthsBehind === 1) {
        statusCell = `<span style="color:var(--orange);font-size:0.8rem;">🟠 1 month behind</span>`;
      } else {
        statusCell = `<span style="color:var(--red);font-size:0.8rem;">🔴 ${monthsBehind} months behind</span>`;
      }
      let markCurrentBtn = '';
      if (a.id && monthsBehind > 0) {
        const label = monthsBehind >= 3 ? `Clear ${monthsBehind}-Month Backlog` : 'Mark Current';
        markCurrentBtn = `<button class="btn btn-gold btn-sm" onclick="bk_markStmtCurrent('${realmId}',${a.id},this)">${label}</button>`;
      }
      const methodSel = Object.entries(BK_METHOD_LABELS).filter(([k]) => !['qbo','client'].includes(k)).map(([k,v]) =>
        `<option value="${k}"${(a.access_method||'qbo_pull')===k?' selected':''}>${v}</option>`
      ).join('');
      html += `<tr id="bk-stmtrow-${a.id || 'new'}">
        <td style="font-weight:500;">${esc(a.account_name)}</td>
        <td style="font-size:0.78rem;color:var(--muted);">${esc(typeLabel)}</td>
        <td>${a.id ? `<select class="stmt-select" onchange="bk_updateStmtMethod('${realmId}',${a.id},this)">${methodSel}</select>` : `<span style="color:var(--muted);font-size:0.78rem;">${esc(BK_METHOD_LABELS[a.access_method] || a.access_method || '—')}</span>`}</td>
        <td>${a.id ? `<input class="stmt-input stmt-day-input" type="number" min="1" max="31" value="${a.statement_day || 1}" style="width:60px;" onblur="bk_updateStmtDay('${realmId}',${a.id},this)">` : `<span style="color:var(--muted);">${a.statement_day || 1}</span>`}</td>
        <td>${statusCell}</td>
        <td style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;">
          ${markCurrentBtn}
          ${a._manual && a.id ? `<button class="btn-icon" onclick="bk_deleteStmtAccount('${realmId}',${a.id})" title="Delete">🗑</button>` : ''}
        </td>
      </tr>`;
    }
    html += `</tbody></table></div>`;
    return html;
  }

  async function bk_updateStmtMethod(realmId, id, selectEl) {
    try {
      const res = await apiFetch('/api/companies/' + realmId + '/statements/' + id, { method: 'PUT', body: JSON.stringify({ access_method: selectEl.value }) });
      if (!res.ok) throw new Error((await res.json()).error);
    } catch(e) { toast('Save failed: ' + e.message, 'error'); }
  }

  async function bk_updateStmtDay(realmId, id, inputEl) {
    const day = parseInt(inputEl.value) || 1;
    inputEl.value = Math.max(1, Math.min(31, day));
    try {
      const res = await apiFetch('/api/companies/' + realmId + '/statements/' + id, { method: 'PUT', body: JSON.stringify({ statement_day: parseInt(inputEl.value) }) });
      if (!res.ok) throw new Error((await res.json()).error);
    } catch(e) { toast('Save failed: ' + e.message, 'error'); }
  }

  async function bk_markStmtCurrent(realmId, id, btn) {
    btn.disabled = true;
    const origText = btn.textContent;
    btn.textContent = '…';
    try {
      const res = await apiFetch('/api/companies/' + realmId + '/statements/' + id + '/mark-current', { method: 'PUT', body: '{}' });
      if (!res.ok) throw new Error((await res.json()).error);
      toast('Account marked current — backlog cleared');
      await bk_loadStatementsView();
    } catch(e) {
      btn.disabled = false;
      btn.textContent = origText;
      toast('Failed: ' + e.message, 'error');
    }
  }

  async function bk_deleteStmtAccount(realmId, id) {
    if (!confirm('Delete this statement account?')) return;
    try {
      const res = await apiFetch('/api/companies/' + realmId + '/statements/' + id, { method: 'DELETE' });
      if (!res.ok) throw new Error((await res.json()).error);
      toast('Account deleted');
      await bk_loadStatementsView();
    } catch(e) { toast('Delete failed: ' + e.message, 'error'); }
  }

  function bk_showStmtAddForm() {
    document.getElementById('bk-stmt-add-form').style.display = '';
    document.getElementById('bk-stmt-new-name')?.focus();
  }

  function bk_hideStmtAddForm() {
    document.getElementById('bk-stmt-add-form').style.display = 'none';
    if (document.getElementById('bk-stmt-new-name')) document.getElementById('bk-stmt-new-name').value = '';
    if (document.getElementById('bk-stmt-new-inst')) document.getElementById('bk-stmt-new-inst').value = '';
    if (document.getElementById('bk-stmt-new-day')) document.getElementById('bk-stmt-new-day').value = '1';
  }

  async function bk_saveNewStmtAccount() {
    if (!bookkeepingRealm) { toast('No QBO connection', 'error'); return; }
    const name = document.getElementById('bk-stmt-new-name')?.value.trim();
    if (!name) { toast('Account name is required', 'error'); return; }
    const institution = document.getElementById('bk-stmt-new-inst')?.value.trim() || '';
    const method = document.getElementById('bk-stmt-new-method')?.value || 'portal';
    const day = parseInt(document.getElementById('bk-stmt-new-day')?.value || 1);
    try {
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/statements', {
        method: 'POST',
        body: JSON.stringify({ account_name: name, institution, access_method: method, statement_day: day })
      });
      if (!res.ok) throw new Error((await res.json()).error);
      toast('Account added');
      bk_hideStmtAddForm();
      await bk_loadStatementsView();
    } catch(e) { toast('Add failed: ' + e.message, 'error'); }
  }

  // ================================================================
  // STATEMENT CALENDAR
  // ================================================================
  let bk_calCurrentMonth = null;
  let bk_calDaysData = {};

  function bk_initCalendar() {
    if (!bk_qboGuard('bk-cal-qbo-guard','bk-cal-main')) return;
    if (!bk_calCurrentMonth) bk_calCurrentMonth = bk_stmtCurrentMonth();
    document.getElementById('bk-cal-month-display').textContent = bk_calMonthLabel(bk_calCurrentMonth);
    bk_loadCalendarView();
  }

  function bk_calMonthLabel(ym) {
    const [y, m] = ym.split('-');
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    return (months[parseInt(m)-1] || m) + ' ' + y;
  }

  function bk_calChangeMonth(delta) {
    const [y, m] = bk_calCurrentMonth.split('-').map(Number);
    const d = new Date(y, m - 1 + delta, 1);
    bk_calCurrentMonth = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
    document.getElementById('bk-cal-month-display').textContent = bk_calMonthLabel(bk_calCurrentMonth);
    bk_closeDayDrawer();
    bk_loadCalendarView();
  }

  async function bk_loadCalendarView() {
    if (!bookkeepingRealm) return;
    const month = bk_calCurrentMonth || bk_stmtCurrentMonth();
    const bodyEl = document.getElementById('bk-stmt-calendar-body');
    const statsEl = document.getElementById('bk-cal-stats');
    bodyEl.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);">Loading calendar…</div>';
    statsEl.style.display = 'none';

    try {
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/statements/calendar?month=' + encodeURIComponent(month));
      const data = await res.json();
      if (data.error) throw new Error(data.error);

      const days = data.days || [];
      bk_calDaysData = {};
      let total = 0, retrieved = 0;
      for (const d of days) {
        bk_calDaysData[d.day] = d;
        total += d.total;
        retrieved += d.retrieved;
      }
      const pending = total - retrieved;
      const pct = total > 0 ? Math.round(retrieved / total * 100) : 0;

      if (total > 0) {
        statsEl.style.display = '';
        document.getElementById('bk-cal-stats-grid').innerHTML = `
          <div class="stat-card"><div class="stat-label">This Month</div><div class="stat-value">${total}</div></div>
          <div class="stat-card"><div class="stat-label">Retrieved</div><div class="stat-value green">${retrieved}</div></div>
          <div class="stat-card"><div class="stat-label">Pending</div><div class="stat-value orange">${pending}</div></div>
          <div class="stat-card"><div class="stat-label">Complete</div><div class="stat-value">${pct}%</div></div>`;
        document.getElementById('bk-cal-pct-label').textContent = `${retrieved} of ${total} retrieved (${pct}%)`;
        document.getElementById('bk-cal-progress-fill').style.width = pct + '%';
      }

      let html = '<div class="cal-heatmap">';
      for (let day = 1; day <= 31; day++) {
        const d = bk_calDaysData[day];
        if (!d) {
          html += `<div class="cal-hm-day"><div class="cal-hm-num" style="color:rgba(143,163,184,0.3);">${day}</div></div>`;
        } else {
          let colorClass = 'all-pending';
          if (d.pending === 0) colorClass = 'all-retrieved';
          else if (d.retrieved > 0) colorClass = 'mixed';
          const pendBadge = d.pending > 0 ? `<span class="cal-hm-badge">🟠 ${d.pending}</span>` : '';
          const retBadge = d.retrieved > 0 ? `<span class="cal-hm-badge">✅ ${d.retrieved}</span>` : '';
          html += `<div class="cal-hm-day has-items ${colorClass}" onclick="bk_openDayDrawer(${day})" title="Day ${day}: ${d.total} statements">
            <div class="cal-hm-num">${day}</div>
            <div class="cal-hm-badges">${pendBadge}${retBadge}</div>
          </div>`;
        }
      }
      html += '</div>';
      bodyEl.innerHTML = html;
    } catch(e) {
      bodyEl.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--red);">Failed: ' + esc(e.message) + '</div>';
    }
  }

  function bk_openDayDrawer(day) {
    const d = bk_calDaysData[day];
    if (!d) return;
    const monthLabel = bk_calMonthLabel(bk_calCurrentMonth);
    document.getElementById('bk-day-drawer-title').textContent = `Day ${day} — ${monthLabel}`;
    bk_updateDrawerProgress(d);
    bk_renderDrawerItems(d, day);
    document.getElementById('bk-day-drawer-overlay').classList.add('open');
    document.getElementById('bk-day-drawer').classList.add('open');
  }

  function bk_closeDayDrawer() {
    document.getElementById('bk-day-drawer-overlay').classList.remove('open');
    document.getElementById('bk-day-drawer').classList.remove('open');
  }

  function bk_updateDrawerProgress(d) {
    const pct = d.total > 0 ? Math.round(d.retrieved / d.total * 100) : 0;
    document.getElementById('bk-day-drawer-prog-label').textContent = `${d.retrieved} of ${d.total} retrieved`;
    document.getElementById('bk-day-drawer-prog-fill').style.width = pct + '%';
  }

  function bk_renderDrawerItems(d, day) {
    if (!d || !d.items || d.items.length === 0) {
      document.getElementById('bk-day-drawer-body').innerHTML = '<div style="padding:2rem;text-align:center;color:var(--muted);">No statements for this day.</div>';
      return;
    }
    const sorted = [...d.items].sort((a, b) => {
      if (a.isRetrieved === b.isRetrieved) return 0;
      return a.isRetrieved ? 1 : -1;
    });
    let html = '';
    for (const item of sorted) {
      const methodLabel = BK_METHOD_LABELS[item.method] || item.method || '—';
      const retrievedDate = item.retrievedAt ? new Date(item.retrievedAt).toLocaleDateString() : '';
      html += `<div class="bk-day-drawer-row${item.isRetrieved ? ' retrieved' : ''}" id="bk-ddr-${item.id}">
        <div class="bk-dd-row-info">
          <div class="bk-dd-row-company">${esc(item.companyName || item.realmId)}</div>
          <div class="bk-dd-row-account">${esc(item.accountName)}</div>
        </div>
        <span class="bk-dd-row-method">${esc(methodLabel)}</span>
        <div class="bk-dd-row-action">
          ${item.isRetrieved
            ? `<span class="bk-dd-retrieved-date">✅ ${retrievedDate}</span>`
            : `<button class="bk-btn-dd-retrieve" onclick="bk_drawerMarkRetrieved('${item.realmId}',${item.id},${day})">✓</button>`
          }
        </div>
      </div>`;
    }
    document.getElementById('bk-day-drawer-body').innerHTML = html;
  }

  async function bk_drawerMarkRetrieved(realmId, id, day) {
    const btn = document.querySelector(`#bk-ddr-${id} .bk-btn-dd-retrieve`);
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    try {
      const res = await apiFetch('/api/companies/' + realmId + '/statements/' + id + '/retrieve', { method: 'POST', body: '{}' });
      if (!res.ok) throw new Error((await res.json()).error);
      const d = bk_calDaysData[day];
      if (d) {
        const item = d.items.find(i => i.id === id);
        if (item) { item.isRetrieved = true; item.retrievedAt = new Date().toISOString(); d.retrieved++; d.pending--; }
        bk_updateDrawerProgress(d);
        bk_renderDrawerItems(d, day);
        bk_refreshHeatmapBox(day, d);
      }
      toast('Marked as retrieved');
    } catch(e) {
      if (btn) { btn.disabled = false; btn.textContent = '✓'; }
      toast('Failed: ' + e.message, 'error');
    }
  }

  function bk_refreshHeatmapBox(day, d) {
    let total = 0, retrieved = 0;
    for (const dd of Object.values(bk_calDaysData)) { total += dd.total; retrieved += dd.retrieved; }
    const pct = total > 0 ? Math.round(retrieved / total * 100) : 0;
    const pending = total - retrieved;
    document.getElementById('bk-cal-stats-grid').innerHTML = `
      <div class="stat-card"><div class="stat-label">This Month</div><div class="stat-value">${total}</div></div>
      <div class="stat-card"><div class="stat-label">Retrieved</div><div class="stat-value green">${retrieved}</div></div>
      <div class="stat-card"><div class="stat-label">Pending</div><div class="stat-value orange">${pending}</div></div>
      <div class="stat-card"><div class="stat-label">Complete</div><div class="stat-value">${pct}%</div></div>`;
    document.getElementById('bk-cal-pct-label').textContent = `${retrieved} of ${total} retrieved (${pct}%)`;
    document.getElementById('bk-cal-progress-fill').style.width = pct + '%';
    const boxes = document.querySelectorAll('.cal-hm-day');
    for (const box of boxes) {
      if (box.getAttribute('onclick') === `bk_openDayDrawer(${day})`) {
        let colorClass = 'all-pending';
        if (d.pending === 0) colorClass = 'all-retrieved';
        else if (d.retrieved > 0) colorClass = 'mixed';
        box.className = `cal-hm-day has-items ${colorClass}`;
        const pendBadge = d.pending > 0 ? `<span class="cal-hm-badge">🟠 ${d.pending}</span>` : '';
        const retBadge = d.retrieved > 0 ? `<span class="cal-hm-badge">✅ ${d.retrieved}</span>` : '';
        box.innerHTML = `<div class="cal-hm-num">${day}</div><div class="cal-hm-badges">${pendBadge}${retBadge}</div>`;
        break;
      }
    }
  }

  // ================================================================
  // TRANSACTION DRILL-DOWN
  // ================================================================
  let bk_cachedAccounts = null;
  let bk_ddCurrentAccount = null;
  let bk_ddStartDate = null;
  let bk_ddEndDate = null;
  let bk_ddTransactions = [];

  function bk_openDrilldown(account, startDate, endDate, amount) {
    bk_ddCurrentAccount = account;
    bk_ddStartDate = startDate;
    bk_ddEndDate = endDate;
    document.getElementById('bk-dd-account-name').textContent = account + (amount ? ' — ' + amount : '');
    document.getElementById('bk-dd-period').textContent = startDate + ' to ' + endDate;
    document.getElementById('bk-drilldown-body').innerHTML = '<div class="bk-drilldown-loading">Loading transactions…</div>';
    document.getElementById('bk-drilldown-overlay').classList.add('open');
    document.getElementById('bk-drilldown-panel').classList.add('open');
    bk_loadDrilldownTransactions();
  }

  function bk_closeDrilldown() {
    document.getElementById('bk-drilldown-overlay').classList.remove('open');
    document.getElementById('bk-drilldown-panel').classList.remove('open');
  }

  async function bk_loadDrilldownTransactions() {
    try {
      const params = new URLSearchParams({ account: bk_ddCurrentAccount, startDate: bk_ddStartDate, endDate: bk_ddEndDate });
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/transactions/drilldown?' + params);
      bk_ddTransactions = await res.json();
      if (bk_ddTransactions.error) throw new Error(bk_ddTransactions.error);
      bk_renderDrilldownTable();
    } catch (e) {
      document.getElementById('bk-drilldown-body').innerHTML = '<div class="bk-drilldown-loading" style="color:var(--red);">Failed to load: ' + esc(e.message) + '</div>';
    }
  }

  function bk_renderDrilldownTable() {
    if (!bk_ddTransactions.length) {
      document.getElementById('bk-drilldown-body').innerHTML = '<div class="bk-drilldown-loading">No transactions found for this account and period.</div>';
      return;
    }
    let html = '<table class="bk-drilldown-table"><thead><tr><th>Date</th><th>Type</th><th>Name</th><th>Memo</th><th class="dd-amount">Amount</th><th></th></tr></thead><tbody>';
    bk_ddTransactions.forEach((t, i) => {
      const rawAmt = t.amount == null ? 0 : Number(t.amount);
      const amt = rawAmt >= 0 ? '$' + rawAmt.toLocaleString(undefined, {minimumFractionDigits:2}) : '<span style="color:var(--red);">($' + Math.abs(rawAmt).toLocaleString(undefined, {minimumFractionDigits:2}) + ')</span>';
      html += `<tr id="bk-ddr-txn-${i}">
        <td style="white-space:nowrap;">${esc(t.date)}</td>
        <td style="color:var(--muted);">${esc(t.type)}</td>
        <td>${esc(t.name)}</td>
        <td style="color:var(--muted);font-size:0.75rem;">${esc(t.memo)}</td>
        <td class="dd-amount">${amt}</td>
        <td><button class="bk-btn-recode" onclick="bk_showRecodeForm(${i})">Recode</button></td>
      </tr>
      <tr id="bk-ddr-recode-${i}" class="bk-recode-row" style="display:none;">
        <td colspan="6"><div id="bk-recode-form-${i}"></div></td>
      </tr>`;
    });
    html += '</tbody></table>';
    document.getElementById('bk-drilldown-body').innerHTML = html;
  }

  async function bk_getAccountsForRecode() {
    if (bk_cachedAccounts && bk_cachedAccounts.realmId === bookkeepingRealm) return bk_cachedAccounts.accounts;
    try {
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/accounts');
      const accounts = await res.json();
      bk_cachedAccounts = { realmId: bookkeepingRealm, accounts };
      return accounts;
    } catch (e) { return []; }
  }

  async function bk_showRecodeForm(idx) {
    document.querySelectorAll('[id^="bk-ddr-recode-"]').forEach(r => r.style.display = 'none');
    const recodeRow = document.getElementById('bk-ddr-recode-' + idx);
    recodeRow.style.display = '';
    const formEl = document.getElementById('bk-recode-form-' + idx);
    formEl.innerHTML = '<div style="color:var(--muted);font-size:0.78rem;padding:0.5rem;">Loading accounts…</div>';
    const accounts = await bk_getAccountsForRecode();
    if (!accounts.length) {
      formEl.innerHTML = '<div style="color:var(--red);font-size:0.78rem;padding:0.5rem;">Failed to load accounts</div>';
      return;
    }
    const byType = {};
    for (const a of accounts) {
      if (!a.active) continue;
      if (!byType[a.type]) byType[a.type] = [];
      byType[a.type].push(a);
    }
    let opts = '';
    for (const [type, accs] of Object.entries(byType)) {
      opts += `<optgroup label="${esc(type)}">`;
      for (const a of accs) {
        const selected = a.fullName === bk_ddCurrentAccount || a.name === bk_ddCurrentAccount ? ' selected' : '';
        opts += `<option value="${esc(a.fullName)}"${selected}>${esc(a.fullName)}</option>`;
      }
      opts += '</optgroup>';
    }
    formEl.innerHTML = `
      <div style="padding:0.5rem 0;">
        <div style="font-size:0.75rem;color:var(--muted);margin-bottom:0.35rem;">Recode to:</div>
        <select class="bk-recode-select" id="bk-recode-select-${idx}">${opts}</select>
        <div class="bk-recode-actions">
          <button class="bk-btn-recode-save" onclick="bk_saveRecode(${idx})">Save</button>
          <button class="bk-btn-recode-cancel" onclick="bk_cancelRecode(${idx})">Cancel</button>
        </div>
      </div>`;
  }

  function bk_cancelRecode(idx) {
    document.getElementById('bk-ddr-recode-' + idx).style.display = 'none';
  }

  async function bk_saveRecode(idx) {
    const t = bk_ddTransactions[idx];
    const newAccount = document.getElementById('bk-recode-select-' + idx)?.value;
    if (!newAccount) return;
    const btn = document.getElementById('bk-ddr-recode-' + idx).querySelector('.bk-btn-recode-save');
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    try {
      const res = await apiFetch('/api/companies/' + bookkeepingRealm + '/transactions/recode', {
        method: 'POST',
        body: JSON.stringify({ txnId: t.txnId, txnType: t.type, newAccount }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || JSON.stringify(data));
      bk_ddTransactions.splice(idx, 1);
      const recodeRow = document.getElementById('bk-ddr-recode-' + idx);
      const origRow = document.getElementById('bk-ddr-txn-' + idx);
      if (recodeRow) recodeRow.remove();
      if (origRow) origRow.remove();
      toast('✅ Recoded to ' + newAccount.split(':').pop() + ' — P&L refreshing in background…');
      setTimeout(() => { if (bk_cpInitialized) bk_generateClosePackage(); }, 800);
    } catch (e) {
      toast('Recode failed: ' + e.message, 'error');
      if (btn) { btn.disabled = false; btn.textContent = 'Save'; }
    }
  }


  // ── Communication JS (matches person CRM comm tab) ──
  let commCoId = null;
  let commCoActiveThreadId = null;
  let coCommAttachFiles = [];
  let coCommNewAttachFiles = [];

  function coCommShowEmpty() {
    document.getElementById('comm-co-no-thread').style.display = 'flex';
    document.getElementById('comm-co-compose-view').style.display = 'none';
    document.getElementById('comm-co-reply-box').style.display = 'none';
    document.getElementById('comm-co-detail-header').innerHTML = '';
    document.getElementById('comm-co-detail-messages').innerHTML = '';
    document.getElementById('comm-co-reply-body').value = '';
    commCoActiveThreadId = null;
  }
  function coCommShowDetail() {
    document.getElementById('comm-co-no-thread').style.display = 'none';
    document.getElementById('comm-co-compose-view').style.display = 'none';
    document.getElementById('comm-co-reply-box').style.display = '';
  }
  function coCommShowCompose() {
    document.getElementById('comm-co-no-thread').style.display = 'none';
    document.getElementById('comm-co-compose-view').style.display = 'flex';
    document.getElementById('comm-co-reply-box').style.display = 'none';
  }
  async function coCommOpenNew() {
    coCommShowCompose();
    document.getElementById('comm-co-new-body').value = '';
    coCommNewAttachFiles = [];
    renderCoNewCommAttachChips();
    // Check for portal users and show warning if none
    const warningEl = document.getElementById('comm-co-no-portal-warning');
    const sendBtn = document.getElementById('comm-co-send-btn');
    try {
      const res = await apiFetch(`/api/companies/${commCoId}`);
      const co = await res.json();
      const portalPeople = (co.people || []).filter(p => p.portal_enabled);
      if (portalPeople.length === 0) {
        warningEl.style.display = 'block';
        sendBtn.disabled = true;
        sendBtn.style.opacity = '0.4';
        sendBtn.style.cursor = 'not-allowed';
      } else {
        warningEl.style.display = 'none';
        sendBtn.disabled = false;
        sendBtn.style.opacity = '';
        sendBtn.style.cursor = '';
      }
    } catch(e) { /* non-fatal */ }
  }
  function coCommCloseNew() { coCommShowEmpty(); }

  // ── Template picker (company) ──
  let _coCommTemplates = null;
  async function coCommOpenTemplatePicker() {
    const overlay = document.getElementById('comm-co-tmpl-overlay');
    overlay.style.display = 'flex';
    document.getElementById('comm-co-tmpl-search').value = '';
    document.getElementById('comm-co-tmpl-list').innerHTML = '<div style="padding:1rem;text-align:center;color:var(--muted);">Loading…</div>';
    if (!_coCommTemplates) {
      try {
        const res = await apiFetch('/api/templates');
        _coCommTemplates = await res.json();
      } catch(e) { _coCommTemplates = []; }
    }
    coCommRenderTemplates(_coCommTemplates);
  }
  function coCommCloseTemplatePicker() {
    document.getElementById('comm-co-tmpl-overlay').style.display = 'none';
  }
  function coCommFilterTemplates(q) {
    if (!_coCommTemplates) return;
    const filtered = q ? _coCommTemplates.filter(t => t.name.toLowerCase().includes(q.toLowerCase()) || t.body.toLowerCase().includes(q.toLowerCase())) : _coCommTemplates;
    coCommRenderTemplates(filtered);
  }
  function coCommRenderTemplates(list) {
    const el = document.getElementById('comm-co-tmpl-list');
    if (!list.length) {
      el.innerHTML = '<div style="padding:1.5rem;text-align:center;color:var(--muted);font-style:italic;">No templates found</div>';
      return;
    }
    el.innerHTML = list.map(t => `
      <div style="padding:0.75rem 1.25rem;border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s;"
        onmouseover="this.style.background='rgba(201,168,76,0.07)'" onmouseout="this.style.background=''"
        onclick="coCommLoadTemplate(${t.id})">
        <div style="font-weight:600;font-size:0.88rem;margin-bottom:0.25rem;">${esc(t.name)}</div>
        <div style="font-size:0.78rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(t.body.slice(0,100))}${t.body.length>100?'…':''}</div>
      </div>`).join('');
  }
  function coResolveTemplateVars(body) {
    const c = companyData || {};
    const firmName = (() => { try { return JSON.parse(atob(localStorage.getItem('dl_token').split('.')[1])).firmName || ''; } catch(e) { return ''; } })();
    // For company page, use first portal-enabled person's name if available, else blank
    const firstPerson = (c.people || []).find(p => p.portal_enabled) || (c.people || [])[0] || {};
    return body
      .replace(/\{First Name\}/g, firstPerson.first_name || '')
      .replace(/\{Last Name\}/g, firstPerson.last_name || '')
      .replace(/\{Full Name\}/g, [firstPerson.first_name, firstPerson.last_name].filter(Boolean).join(' ') || '')
      .replace(/\{Company Name\}/g, c.company_name || '')
      .replace(/\{Firm Name\}/g, firmName);
  }

  function coCommLoadTemplate(id) {
    const t = _coCommTemplates && _coCommTemplates.find(x => x.id === id);
    if (!t) return;
    document.getElementById('comm-co-new-body').value = coResolveTemplateVars(t.body);
    coCommCloseTemplatePicker();
    document.getElementById('comm-co-new-body').focus();
  }

  function initCoComm() {
    commCoId = companyId;
    coCommShowEmpty();
    loadCoThreads();
  }

  function coRelTime(ts) {
    if (!ts) return ''; const d=new Date(ts); const diff=Date.now()-d;
    if (diff<60000) return 'just now'; if (diff<3600000) return Math.floor(diff/60000)+'m ago';
    if (diff<86400000) return Math.floor(diff/3600000)+'h ago'; return d.toLocaleDateString();
  }

  function coCommFormatBytes(b) {
    if (!b) return '0 B'; if (b<1024) return b+' B'; if (b<1048576) return (b/1024).toFixed(1)+' KB'; return (b/1048576).toFixed(1)+' MB';
  }

  async function loadCoThreads() {
    const el = document.getElementById('comm-co-threads');
    if (!el || !commCoId) return;
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div></div>';
    try {
      const res = await apiFetch(`/api/messages/company/${commCoId}`);
      const threads = await res.json();
      if (!threads.length) {
        el.innerHTML = '<div style="color:var(--muted);font-size:0.84rem;padding:1.5rem 1rem;text-align:center;">No messages yet.</div>';
        return;
      }
      el.innerHTML = threads.map(t => {
        const personName = t.person ? ((t.person.firstName||'')+' '+(t.person.lastName||'')).trim() : '';
        const statusColor = t.status === 'resolved' ? '#4caf50' : '#c9a84c';
        const statusLabel = t.status === 'resolved' ? 'Resolved' : 'Active';
        return `<div class="thread-card" id="comm-co-item-${t.id}" onclick="loadCoThread(${t.id})">
          <div class="thread-card-name">${esc(personName || t.subject || '(no subject)')}${t.unreadCount > 0 ? ` <span style="background:var(--gold);color:var(--navy);border-radius:10px;padding:0.05rem 0.35rem;font-size:0.65rem;font-weight:700;margin-left:0.3rem;">${t.unreadCount}</span>` : ''}</div>
          <div class="thread-card-preview">${esc(t.lastPreview||'')}</div>
          <div class="thread-card-meta">
            <span style="background:${statusColor};color:#fff;font-size:0.65rem;font-weight:700;padding:0.1rem 0.4rem;border-radius:3px;text-transform:uppercase;">${statusLabel}</span>
            <span>${coRelTime(t.lastMessageAt)}</span>
            ${t.unreadCount > 0 ? '<span class="unread-dot"></span>' : ''}
          </div>
        </div>`;
      }).join('');
    } catch(e) {
      el.innerHTML = '<div style="color:var(--muted);font-size:0.85rem;padding:1rem;">Failed to load.</div>';
    }
  }

  async function loadCoThread(threadId, silent = false) {
    commCoActiveThreadId = threadId;
    document.querySelectorAll('#comm-co-threads .thread-card').forEach(el => el.classList.remove('active'));
    const item = document.getElementById('comm-co-item-' + threadId);
    if (item) item.classList.add('active');
    if (!silent) {
      document.getElementById('comm-co-detail-messages').innerHTML = '<div style="display:flex;justify-content:center;padding:2rem;"><div class="spinner"></div></div>';
      document.getElementById('comm-co-detail-header').innerHTML = '';
    }
    coCommShowDetail();
    try {
      const res = await apiFetch(`/api/messages/${threadId}`);
      const data = await res.json();
      if (!silent) {
        document.getElementById('comm-co-detail-header').innerHTML = `
          <div class="detail-header-person">${esc((data.person?.firstName||'')+' '+(data.person?.lastName||''))}</div>
          <div class="detail-header-subject">${esc(data.subject||'(no subject)')} · <span style="color:var(--gold);font-size:0.75rem;">${data.category||''}</span></div>`;
      }
      const msgEl = document.getElementById('comm-co-detail-messages');
      const msgs = data.messages || [];
      function buildCoBubble(m) {
        const isInternal = m.isInternal, isStaff = m.senderType === 'staff';
        const side = isInternal ? 'internal' : isStaff ? 'staff' : 'client';
        const bubbleClass = isInternal ? 'internal' : side;
        const attachHtml = (m.attachments||[]).length > 0
          ? `<div class="msg-attachments">${m.attachments.map(a => `<a href="#" class="attachment-chip" onclick="coCommDownloadAttachment(${a.documentId});return false;">📎 ${esc(a.displayName)}</a>`).join('')}</div>` : '';
        return `<div class="msg-bubble-wrap ${side}" data-msg-id="${m.id}">
          ${isInternal ? '<div class="msg-internal-label">🔒 Internal note</div>' : ''}
          <div class="msg-bubble ${bubbleClass}">${esc(m.body||'').replace(/\n/g,'<br>')}${attachHtml}</div>
          <div class="msg-meta">${esc(m.senderName||'')} · ${coRelTime(m.createdAt)}</div>
        </div>`;
      }
      if (!msgs.length) {
        if (!silent) msgEl.innerHTML = '<div style="color:var(--muted);text-align:center;padding:2rem;">No messages yet.</div>';
      } else if (silent) {
        const existingIds = new Set([...msgEl.querySelectorAll('[data-msg-id]')].map(el => parseInt(el.dataset.msgId)));
        let appended = false;
        for (const m of msgs) { if (!existingIds.has(m.id)) { msgEl.insertAdjacentHTML('beforeend', buildCoBubble(m)); appended = true; } }
        if (appended) msgEl.scrollTop = msgEl.scrollHeight;
      } else {
        msgEl.innerHTML = msgs.map(buildCoBubble).join('');
        msgEl.scrollTop = msgEl.scrollHeight;
      }
    } catch(e) {
      if (!silent) document.getElementById('comm-co-detail-messages').innerHTML = '<div style="color:var(--muted);padding:1rem;">Failed to load.</div>';
    }
  }

  async function coCommSendReply() {
    const body = document.getElementById('comm-co-reply-body').value.trim();
    if (!commCoActiveThreadId) { toast('No thread selected', 'error'); return; }
    if (!body && coCommAttachFiles.length === 0) return;
    const isInternal = document.getElementById('comm-co-internal-toggle').checked;
    try {
      const fd = new FormData();
      fd.append('body', body);
      fd.append('is_internal', isInternal ? 'true' : 'false');
      coCommAttachFiles.forEach(f => fd.append('files', f));
      const replyRes = await apiFetch(`/api/messages/${commCoActiveThreadId}/reply`, { method: 'POST', body: fd });
      if (!replyRes.ok) { const d = await replyRes.json().catch(()=>({})); throw new Error(d.error || `Server error ${replyRes.status}`); }
      document.getElementById('comm-co-reply-body').value = '';
      document.getElementById('comm-co-internal-toggle').checked = false;
      coCommAttachFiles = [];
      renderCoCommAttachChips();
      await loadCoThread(commCoActiveThreadId, true); // silent — no spinner
      await loadCoThreads();
    } catch(e) { toast('Failed to send reply: ' + e.message, 'error'); }
  }

  async function coCommResolve() {
    if (!commCoActiveThreadId) return;
    await apiFetch(`/api/messages/${commCoActiveThreadId}/status`, { method:'PUT', body: JSON.stringify({ status: 'resolved' }) });
    coCommShowEmpty();
    await loadCoThreads();
  }

  async function coCommSendNew() {
    const body = document.getElementById('comm-co-new-body').value.trim();
    if (!body && coCommNewAttachFiles.length === 0) { toast('Message body is required', 'error'); return; }
    try {
      // Get portal-enabled people for this company
      const coRes = await apiFetch(`/api/companies/${commCoId}`);
      const co = await coRes.json();
      const people = (co.people || []).filter(p => p.portal_enabled);
      if (!people.length) { toast('No portal users on this company', 'error'); return; }
      let lastThreadId = null;
      for (const p of people) {
        const res = await apiFetch('/api/messages', { method:'POST', body: JSON.stringify({ person_id: p.person_id || p.id, subject: '', body, is_internal: false }) });
        const data = await res.json();
        if (data.threadId) lastThreadId = data.threadId;
      }
      document.getElementById('comm-co-new-body').value = '';
      coCommNewAttachFiles = [];
      renderCoNewCommAttachChips();
      coCommCloseNew();
      await loadCoThreads();
      if (lastThreadId) loadCoThread(lastThreadId);
      toast(`Message sent to ${people.length} ${people.length===1?'person':'people'}`);
    } catch(e) { toast('Failed to send: ' + e.message, 'error'); }
  }

  function handleCoCommAttach(fileList) {
    for (const f of Array.from(fileList)) { if (coCommAttachFiles.length >= 8) break; coCommAttachFiles.push(f); }
    document.getElementById('comm-co-attach-input').value = '';
    renderCoCommAttachChips();
  }
  window.handleCoCommAttach = handleCoCommAttach;

  function renderCoCommAttachChips() {
    const el = document.getElementById('comm-co-attach-chips');
    if (!el) return;
    el.innerHTML = coCommAttachFiles.map((f,i) => `<span class="attach-chip-input">📎 ${esc(f.name)} <button onclick="removeCoCommAttach(${i})">×</button></span>`).join('');
  }
  function removeCoCommAttach(idx) { coCommAttachFiles.splice(idx,1); renderCoCommAttachChips(); }
  window.removeCoCommAttach = removeCoCommAttach;

  function handleCoNewCommAttach(fileList) {
    for (const f of Array.from(fileList)) { if (coCommNewAttachFiles.length >= 8) break; coCommNewAttachFiles.push(f); }
    document.getElementById('comm-co-new-attach-input').value = '';
    renderCoNewCommAttachChips();
  }
  window.handleCoNewCommAttach = handleCoNewCommAttach;

  function renderCoNewCommAttachChips() {
    const el = document.getElementById('comm-co-new-attach-chips');
    if (!el) return;
    el.innerHTML = coCommNewAttachFiles.map((f,i) => `<span class="attach-chip-input">📎 ${esc(f.name)} <button onclick="removeCoNewCommAttach(${i})">×</button></span>`).join('');
  }
  function removeCoNewCommAttach(idx) { coCommNewAttachFiles.splice(idx,1); renderCoNewCommAttachChips(); }
  window.removeCoNewCommAttach = removeCoNewCommAttach;

  async function coCommDownloadAttachment(documentId) {
    try {
      const res = await apiFetch(`/api/messages/attachments/${documentId}/download`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
    } catch(e) { toast('Download failed', 'error'); }
  }
  window.coCommDownloadAttachment = coCommDownloadAttachment;

  // ── Attach Person Modal ──
  async function openAttachPersonModal() {
    if (!companyData) return;
    const relId = companyData.relationship_id;
    if (!relId) { toast('Company has no relationship assigned', 'error'); return; }
    try {
      const res = await apiFetch(`/api/relationships/${relId}/people`);
      const people = await res.json();
      const existing = (companyData.people || []).map(p => p.person_id);
      const available = people.filter(p => !existing.includes(p.id));
      if (!available.length) { toast('All people in this relationship are already attached', 'error'); return; }
      const opts = available.map(p => `<option value="${p.id}">${esc((p.first_name||'')+' '+(p.last_name||''))}</option>`).join('');
      const html = `<div class="modal-overlay open" id="attach-person-modal" onclick="if(event.target===this)this.remove()">
        <div class="modal" onclick="event.stopPropagation()" style="max-width:400px;">
          <h2 style="margin-bottom:1rem;">Attach Person to Company</h2>
          <div class="form-group"><label>Person</label><select id="ap-person" class="form-control">${opts}</select></div>
          <div class="form-group"><label>Access Level</label>
            <select id="ap-access" class="form-control">
              <option value="full">Full (upload + message)</option>
              <option value="view">View only</option>
              <option value="sign">Sign only</option>
            </select>
          </div>
          <div class="form-group"><label>Ownership % (optional)</label><input type="number" id="ap-ownership" class="form-control" placeholder="e.g. 50" min="0" max="100" step="0.01"></div>
          <div class="modal-actions">
            <button class="btn btn-outline" onclick="document.getElementById('attach-person-modal').remove()">Cancel</button>
            <button class="btn btn-gold" onclick="submitAttachPerson()">Attach</button>
          </div>
        </div></div>`;
      document.body.insertAdjacentHTML('beforeend', html);
    } catch(e) { toast('Failed to load people: ' + e.message, 'error'); }
  }
  window.openAttachPersonModal = openAttachPersonModal;

  async function submitAttachPerson() {
    const personId = parseInt(document.getElementById('ap-person').value);
    const accessLevel = document.getElementById('ap-access').value;
    const ownershipPct = document.getElementById('ap-ownership').value;
    try {
      const res = await apiFetch(`/api/people/${personId}/company-access`, {
        method: 'POST',
        body: JSON.stringify({ company_id: companyId, access_level: accessLevel, ownership_pct: ownershipPct || null })
      });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      document.getElementById('attach-person-modal').remove();
      toast('Person attached successfully');
      await loadCompany();
    } catch(e) { toast('Failed: ' + e.message, 'error'); }
  }
  window.submitAttachPerson = submitAttachPerson;

  loadCompany();
</script>

<!-- Tax Summary Modal -->
<div class="tax-summary-modal hidden" id="tax-summary-modal">
  <div class="tax-summary-box" onclick="event.stopPropagation()">
    <div class="tsm-header">
      <div>
        <h2 id="tsm-title">Tax Summary</h2>
        <div id="tsm-subtitle" style="font-size:0.8rem;color:rgba(255,255,255,0.65);margin-top:0.2rem;"></div>
      </div>
      <button class="tsm-close" onclick="closeTaxSummary()">✕</button>
    </div>
    <div class="tsm-body" id="tsm-body">
      <div class="tsm-processing">
        <div class="tsm-spinner"></div>
        <div>Analyzing return with Claude…</div>
        <div style="font-size:0.75rem;opacity:0.6;">This takes about 30–60 seconds</div>
      </div>
    </div>
    <div class="tsm-footer" id="tsm-footer" style="display:none;">
      <button class="btn btn-outline btn-sm" id="tsm-reanalyze-btn" onclick="retrySummary(_tsmPendingDeliveryId)" style="margin-right:auto;">↺ Re-analyze</button>
      <button class="btn btn-outline btn-sm" onclick="closeTaxSummary()">Close</button>
      <button class="btn btn-gold" id="tsm-send-btn" onclick="confirmAndSendDelivery()" style="display:none;">Send to Client →</button>
    </div>
  </div>
</div>

<!-- Move Document Modal -->
<div class="modal-overlay" id="move-doc-modal" onclick="closeMoveDocModal()">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:380px;">
    <h2>Move Document</h2>
    <div class="form-group">
      <label>Tax Year</label>
      <select id="move-doc-year" class="form-control">
        <% for (let y = new Date().getFullYear(); y >= new Date().getFullYear() - 8; y--) { %>
          <option value="<%= y %>"><%= y %></option>
        <% } %>
      </select>
    </div>
    <div class="form-group">
      <label>Section</label>
      <select id="move-doc-section" class="form-control">
        <option value="firm_uploaded">Delivered by Advisor</option>
        <option value="client_uploaded">Client Uploaded</option>
      </select>
    </div>
    <div class="form-group">
      <label>Category</label>
      <select id="move-doc-category" class="form-control">
        <option value="tax">Tax</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeMoveDocModal()">Cancel</button>
      <button class="btn-submit" onclick="submitMoveDoc()">Move</button>
    </div>
  </div>
</div>

