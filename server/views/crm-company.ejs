<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
  .subtab-bar { background: var(--navy); border-bottom: 1px solid var(--border); display: flex; gap: 0; padding: 0 1.5rem; overflow-x: auto; }
  .subtab-item { padding: 0.45rem 0.9rem; cursor: pointer; font-size: 0.78rem; font-weight: 500; color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none; }
  .subtab-item:hover { color: var(--text); }
  .subtab-item.active { color: var(--gold); border-bottom-color: var(--gold); font-weight: 600; }
  .subtab-content { display: none; }
  .subtab-content.active { display: block; }
  .detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .detail-grid { grid-template-columns: 1fr; padding: 0.75rem; gap: 0.75rem; } }
  .info-row { display: flex; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.86rem; }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); width: 140px; flex-shrink: 0; font-size: 0.8rem; }
  .info-val { flex: 1; }
  .save-indicator { font-size: 0.75rem; color: var(--green); margin-top: 0.3rem; height: 1rem; }
  .placeholder-section { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; color: var(--muted); text-align: center; }
  .ph-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .ph-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .ph-desc { font-size: 0.86rem; }

  /* ── Tax tab ── */
  .delivery-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem; margin-bottom: 1rem; display: flex; align-items: flex-start; gap: 1rem; }
  .delivery-card:hover { border-color: rgba(201,168,76,0.3); }
  .delivery-info { flex: 1; min-width: 0; }
  .delivery-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.2rem; }
  .delivery-meta { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.5rem; }
  .delivery-signers { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .signer-chip { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; padding: 0.2rem 0.55rem; border-radius: 20px; border: 1px solid var(--border); background: var(--charcoal); }
  .signer-chip.signed { border-color: rgba(62,207,142,0.4); color: var(--green); }
  .signer-chip.pending { color: var(--muted); }
  .signer-chip.needs-changes { border-color: rgba(237,137,54,0.4); color: var(--orange); }
  .delivery-actions { display: flex; gap: 0.5rem; flex-shrink: 0; flex-wrap: wrap; }
  .status-pill { display: inline-flex; align-items: center; padding: 0.2rem 0.65rem; border-radius: 20px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .status-draft { background: rgba(143,163,184,0.12); color: var(--muted); }
  .status-sent { background: rgba(74,144,217,0.12); color: #4a90d9; }
  .status-signed { background: rgba(62,207,142,0.12); color: var(--green); }
  .status-complete { background: rgba(62,207,142,0.2); color: var(--green); border: 1px solid rgba(62,207,142,0.3); }
  .status-needs_changes { background: rgba(237,137,54,0.12); color: var(--orange); }
  .status-approved { background: rgba(201,168,76,0.12); color: var(--gold); }

  /* ── File drop zone (portal-matched) ── */
  .file-drop { border: 2px dashed var(--border); border-radius: 9px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; color: var(--muted); font-size: 0.88rem; position: relative; }
  .file-drop:hover, .file-drop.drag-over { border-color: var(--gold); background: rgba(201,168,76,0.04); }
  .file-drop input[type="file"] { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .selected-file { margin-top: 0.5rem; font-size: 0.8rem; color: var(--gold); font-weight: 600; }
  .upload-err { font-size: 0.8rem; color: var(--red); margin-top: 0.5rem; }
  .upload-msg { font-size: 0.8rem; color: var(--green); margin-top: 0.5rem; }

  /* ── Bookkeeping ── */
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem; }
  .stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1.1rem; }
  .stat-label { font-size: 0.7rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
  .stat-value { font-size: 1.6rem; font-weight: 800; }
  .stat-value.gold { color: var(--gold); }
  .stat-value.green { color: var(--green); }
  .stat-value.orange { color: var(--orange); }
  .stat-value.red { color: var(--red); }
  .stat-sub { font-size: 0.75rem; color: var(--muted); margin-top: 0.2rem; }
  .table-wrap { background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: auto; max-height: 70vh; scrollbar-width: thin; scrollbar-color: rgba(201,168,76,0.4) transparent; }
  .table-wrap table { width: 100%; border-collapse: collapse; }
  .table-wrap th { font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; text-align: left; padding: 0.85rem 1rem; border-bottom: 1px solid var(--border); background: var(--card); position: sticky; top: 0; z-index: 10; }
  .table-wrap th:first-child, .table-wrap td:first-child { position: sticky; left: 0; background: var(--card); z-index: 2; box-shadow: 2px 0 6px rgba(0,0,0,0.25); }
  .table-wrap tr:hover td:first-child { background: color-mix(in srgb, var(--card) 95%, var(--gold) 5%); }
  .report-row-header td:first-child { background: rgba(201,168,76,0.06) !important; }
  .table-wrap td { padding: 0.7rem 1rem; font-size: 0.85rem; border-bottom: 1px solid rgba(201,168,76,0.07); vertical-align: middle; }
  .table-wrap tr:last-child td { border-bottom: none; }
  .table-wrap tr:hover td { background: rgba(201,168,76,0.03); }
  td.amount, th.amount { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
  td.amount.drillable { cursor: pointer; transition: color 0.15s; }
  td.amount.drillable:hover { color: var(--gold-light) !important; text-decoration: underline; }
  .badge-pending { background: rgba(237,137,54,0.12); color: var(--orange); }
  .badge-flag { background: rgba(245,101,101,0.12); color: var(--red); }
  .badge-ok { background: rgba(62,207,142,0.12); color: var(--green); }
  .badge-warning { background: rgba(237,137,54,0.12); color: var(--orange); }
  .period-picker { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; }
  .period-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  .period-tab { padding: 0.5rem 1rem; font-size: 0.78rem; font-weight: 600; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none; }
  .period-tab:hover { color: var(--text); }
  .period-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
  .period-panel { display: none; }
  .period-panel.active { display: block; }
  .month-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 0.35rem; margin-bottom: 0.75rem; }
  .month-btn { padding: 0.4rem 0.15rem; font-size: 0.72rem; font-weight: 600; background: var(--charcoal); border: 1px solid var(--border); color: var(--muted); border-radius: 5px; cursor: pointer; transition: all 0.15s; text-align: center; white-space: nowrap; }
  .month-btn:hover { border-color: var(--gold); color: var(--text); }
  .month-btn.selected { background: var(--gold); color: var(--navy); border-color: var(--gold); }
  .month-btn.current { border-color: var(--green); }
  .quarter-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; }
  .quarter-btn { padding: 0.6rem 0.5rem; font-size: 0.82rem; font-weight: 700; background: var(--charcoal); border: 1px solid var(--border); color: var(--muted); border-radius: 8px; cursor: pointer; transition: all 0.15s; text-align: center; }
  .quarter-btn:hover { border-color: var(--gold); color: var(--text); }
  .quarter-btn.selected { background: var(--gold); color: var(--navy); border-color: var(--gold); }
  .year-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
  .year-btn { padding: 0.6rem 0.5rem; font-size: 0.82rem; font-weight: 700; background: var(--charcoal); border: 1px solid var(--border); color: var(--muted); border-radius: 8px; cursor: pointer; transition: all 0.15s; text-align: center; }
  .year-btn:hover { border-color: var(--gold); color: var(--text); }
  .year-btn.selected { background: var(--gold); color: var(--navy); border-color: var(--gold); }
  .date-range-row { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
  .date-range-row label { font-size: 0.78rem; font-weight: 600; color: var(--muted); }
  .date-range-row input[type="date"] { background: var(--charcoal); border: 1px solid var(--border); color: var(--text); padding: 0.4rem 0.6rem; border-radius: 6px; font-size: 0.82rem; }
  .period-year-label { font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
  .period-actions { display: flex; gap: 1rem; align-items: center; margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .period-actions .selected-label { flex: 1; font-size: 0.82rem; color: var(--muted); min-width: 0; }
  .period-actions .selected-label strong { color: var(--gold); }
  .report-section { margin-top: 1.5rem; }
  .report-section h3 { font-size: 0.88rem; margin-bottom: 0.75rem; }
  .workflow-job-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; cursor: pointer; transition: border-color 0.15s; }
  .workflow-job-card:hover { border-color: var(--gold); }
  .report-section .table-wrap { margin-bottom: 1rem; }
  .report-row-header td { font-weight: 700; color: var(--gold); background: rgba(201,168,76,0.04); }
  .report-row-total td { font-weight: 700; border-top: 2px solid var(--border); }
  .variance-controls { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap; }
  .var-ctrl-label { font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
  .var-month-scroll { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .var-month-btn { padding: 0.3rem 0.55rem; font-size: 0.72rem; font-weight: 600; background: var(--charcoal); border: 1px solid var(--border); color: var(--muted); border-radius: 5px; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .var-month-btn:hover { border-color: var(--gold); color: var(--text); }
  .var-month-btn.selected { background: var(--gold); color: var(--navy); border-color: var(--gold); }
  .var-threshold-input { width: 75px; background: var(--charcoal); border: 1px solid var(--border); color: var(--text); padding: 0.4rem 0.6rem; border-radius: 6px; font-size: 0.82rem; }
  .var-amt-input { width: 90px; background: var(--charcoal); border: 1px solid var(--border); color: var(--text); padding: 0.4rem 0.6rem; border-radius: 6px; font-size: 0.82rem; }
  .bk-drilldown-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 400; }
  .bk-drilldown-overlay.open { display: block; }
  .bk-drilldown-panel { position: fixed; top: 0; right: -560px; width: 560px; max-width: 96vw; height: 100vh; background: var(--charcoal); border-left: 2px solid var(--gold); z-index: 401; display: flex; flex-direction: column; transition: right 0.3s ease; overflow: hidden; box-shadow: -10px 0 40px rgba(0,0,0,0.4); }
  .bk-drilldown-panel.open { right: 0; }
  .bk-drilldown-header { padding: 1rem 1.2rem; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; flex-shrink: 0; }
  .bk-drilldown-header h3 { font-size: 0.9rem; font-weight: 800; color: var(--gold); line-height: 1.3; }
  .bk-dd-period { font-size: 0.72rem; color: var(--muted); margin-top: 0.2rem; }
  .bk-drilldown-close { background: none; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; flex-shrink: 0; padding: 0.1rem 0.3rem; transition: color 0.15s; }
  .bk-drilldown-close:hover { color: var(--text); }
  .bk-drilldown-body { flex: 1; overflow-y: auto; padding: 0.5rem 0; }
  .bk-drilldown-loading { text-align: center; padding: 3rem; color: var(--muted); font-size: 0.85rem; }
  .bk-drilldown-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .bk-drilldown-table th { font-size: 0.67rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; padding: 0.4rem 0.5rem; border-bottom: 1px solid var(--border); text-align: left; position: sticky; top: 0; background: var(--charcoal); }
  .bk-drilldown-table td { padding: 0.4rem 0.5rem; border-bottom: 1px solid rgba(201,168,76,0.06); vertical-align: middle; }
  .bk-drilldown-table tr:last-child td { border-bottom: none; }
  .bk-drilldown-table tr:hover td { background: rgba(201,168,76,0.04); }
  .bk-drilldown-table .dd-amount { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
  .bk-btn-recode { background: transparent; border: 1px solid var(--border); color: var(--muted); padding: 0.18rem 0.5rem; border-radius: 4px; font-size: 0.68rem; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .bk-btn-recode:hover { border-color: var(--gold); color: var(--gold); }
  .bk-recode-row { background: rgba(201,168,76,0.04); }
  .bk-recode-row td { padding: 0.5rem 0.75rem; }
  .bk-recode-select { background: var(--navy); border: 1px solid var(--border); color: var(--text); padding: 0.3rem 0.5rem; border-radius: 5px; font-size: 0.78rem; width: 100%; margin-bottom: 0.35rem; }
  .bk-recode-select:focus { border-color: var(--gold); outline: none; }
  .bk-recode-actions { display: flex; gap: 0.5rem; }
  .bk-btn-recode-save { background: var(--gold); color: var(--navy); border: none; border-radius: 5px; padding: 0.3rem 0.7rem; font-size: 0.75rem; font-weight: 700; cursor: pointer; }
  .bk-btn-recode-save:hover { background: var(--gold-light); }
  .bk-btn-recode-cancel { background: transparent; border: 1px solid var(--border); color: var(--muted); border-radius: 5px; padding: 0.3rem 0.7rem; font-size: 0.75rem; cursor: pointer; }
  .stmt-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .stmt-table th { font-size: 0.68rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border); text-align: left; background: rgba(0,0,0,0.15); }
  .stmt-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid rgba(201,168,76,0.06); vertical-align: middle; }
  .stmt-table tr:last-child td { border-bottom: none; }
  .stmt-table tr:hover td { background: rgba(201,168,76,0.03); }
  .stmt-select { background: var(--charcoal); border: 1px solid var(--border); color: var(--text); padding: 0.3rem 0.5rem; border-radius: 5px; font-size: 0.78rem; }
  .stmt-select:focus { border-color: var(--gold); outline: none; }
  .stmt-input { background: var(--charcoal); border: 1px solid var(--border); color: var(--text); padding: 0.3rem 0.5rem; border-radius: 5px; font-size: 0.78rem; }
  .stmt-input:focus { border-color: var(--gold); outline: none; }
  .stmt-day-input { width: 54px; }
  .btn-icon { background: transparent; border: none; cursor: pointer; color: var(--muted); font-size: 0.85rem; padding: 0.15rem 0.3rem; transition: color 0.15s; }
  .btn-icon:hover { color: var(--red); }
  .cal-heatmap { display: grid; grid-template-columns: repeat(auto-fill, minmax(72px, 1fr)); gap: 0.5rem; }
  .cal-hm-day { background: var(--card); border: 2px solid transparent; border-radius: 8px; padding: 0.45rem 0.5rem; cursor: default; transition: border-color 0.15s, transform 0.1s; min-height: 62px; display: flex; flex-direction: column; align-items: flex-start; justify-content: space-between; }
  .cal-hm-day.has-items { cursor: pointer; }
  .cal-hm-day.has-items:hover { transform: scale(1.04); }
  .cal-hm-day.all-retrieved { border-color: rgba(62,207,142,0.4); background: rgba(62,207,142,0.05); }
  .cal-hm-day.all-pending { border-color: rgba(237,137,54,0.5); background: rgba(237,137,54,0.05); }
  .cal-hm-day.mixed { border-color: rgba(201,168,76,0.5); background: rgba(201,168,76,0.04); }
  .cal-hm-num { font-size: 1.1rem; font-weight: 700; line-height: 1; color: var(--muted); }
  .cal-hm-day.has-items .cal-hm-num { color: var(--text); }
  .cal-hm-badges { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.3rem; font-size: 0.65rem; line-height: 1; }
  .cal-hm-badge { display: inline-flex; align-items: center; gap: 0.15rem; }
  .cal-progress-wrap { margin-top: 0.5rem; background: var(--card); border-radius: 4px; height: 6px; overflow: hidden; }
  .cal-progress-fill { height: 100%; background: var(--gold); border-radius: 4px; transition: width 0.4s; }
  .bk-day-drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 410; }
  .bk-day-drawer-overlay.open { display: block; }
  .bk-day-drawer { position: fixed; top: 0; right: -420px; width: 400px; max-width: 100vw; height: 100vh; background: var(--charcoal); border-left: 1px solid var(--border); z-index: 411; display: flex; flex-direction: column; transition: right 0.3s cubic-bezier(0.4,0,0.2,1); box-shadow: -8px 0 40px rgba(0,0,0,0.4); }
  .bk-day-drawer.open { right: 0; }
  .bk-day-drawer-header { padding: 1rem 1.2rem; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; justify-content: space-between; flex-shrink: 0; }
  .bk-day-drawer-title { font-size: 1rem; font-weight: 700; color: var(--gold); }
  .bk-day-drawer-close { background: none; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; padding: 0.1rem 0.3rem; line-height: 1; }
  .bk-day-drawer-close:hover { color: var(--text); }
  .bk-day-drawer-progress { padding: 0.75rem 1.2rem; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .bk-day-drawer-prog-label { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.4rem; }
  .bk-day-drawer-prog-bar { background: var(--card); border-radius: 4px; height: 6px; overflow: hidden; }
  .bk-day-drawer-prog-fill { height: 100%; background: var(--gold); border-radius: 4px; transition: width 0.3s; }
  .bk-day-drawer-body { flex: 1; overflow-y: auto; padding: 0.5rem 0; }
  .bk-day-drawer-row { display: grid; grid-template-columns: 1fr auto auto; gap: 0.5rem; align-items: center; padding: 0.55rem 1.2rem; border-bottom: 1px solid rgba(201,168,76,0.06); font-size: 0.8rem; }
  .bk-day-drawer-row:last-child { border-bottom: none; }
  .bk-day-drawer-row.retrieved { opacity: 0.6; }
  .bk-dd-row-info { min-width: 0; }
  .bk-dd-row-company { font-weight: 600; color: var(--text); font-size: 0.78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .bk-dd-row-account { color: var(--muted); font-size: 0.72rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .bk-dd-row-method { font-size: 0.68rem; background: rgba(201,168,76,0.12); color: var(--gold); padding: 0.15rem 0.4rem; border-radius: 4px; white-space: nowrap; flex-shrink: 0; }
  .bk-dd-row-action { flex-shrink: 0; }
  .bk-btn-dd-retrieve { background: transparent; border: 1px solid rgba(62,207,142,0.5); color: #3ecf8e; border-radius: 5px; cursor: pointer; font-size: 0.75rem; padding: 0.2rem 0.5rem; transition: background 0.15s; white-space: nowrap; }
  .bk-btn-dd-retrieve:hover { background: rgba(62,207,142,0.15); }
  .bk-btn-dd-retrieve:disabled { opacity: 0.5; cursor: default; }
  .bk-dd-retrieved-date { font-size: 0.7rem; color: #3ecf8e; white-space: nowrap; }
  .bk-payroll-alert { background: rgba(237,137,54,0.1); border: 1px solid rgba(237,137,54,0.4); border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem; font-size: 0.86rem; color: var(--orange); display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .bk-payroll-alert a { color: var(--gold); text-decoration: underline; cursor: pointer; }
  .connect-qbo-prompt { text-align: center; padding: 3rem 2rem; color: var(--muted); }
  .connect-qbo-prompt h3 { color: var(--text); margin: 0.75rem 0 0.5rem; }
  .connect-qbo-prompt p { font-size: 0.86rem; margin-bottom: 1.5rem; }

  /* ── Docs tab — portal-matched styles ── */
