  <div class="bk-day-drawer-progress">
    <div class="bk-day-drawer-prog-label" id="bk-day-drawer-prog-label">— of — retrieved</div>
    <div class="bk-day-drawer-prog-bar"><div class="bk-day-drawer-prog-fill" id="bk-day-drawer-prog-fill" style="width:0%"></div></div>
  </div>
  <div class="bk-day-drawer-body" id="bk-day-drawer-body">
    <div style="padding:2rem;text-align:center;color:var(--muted);">Loading…</div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
    <h2>Edit Company</h2>
    <div id="edit-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>
    <div class="form-group"><label>Company Name</label><input type="text" class="form-control" id="ef-name"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Entity Type</label>
        <select class="form-control" id="ef-entity-type">
          <option value="">— Select —</option><option value="llc">LLC</option><option value="s_corp">S-Corp</option>
          <option value="c_corp">C-Corp</option><option value="partnership">Partnership</option>
          <option value="sole_prop">Sole Prop</option><option value="trust">Trust</option>
          <option value="nonprofit">Non-Profit</option><option value="other">Other</option>
        </select>
      </div>
      <div class="form-group"><label>Tax Year End</label><input type="text" class="form-control" id="ef-tax-year-end" placeholder="12/31"></div>
    </div>
    <div class="form-group"><label>Stanford Tax URL</label><input type="url" class="form-control" id="ef-stanford"></div>
    <div class="form-group"><label>Status</label>
      <select class="form-control" id="ef-status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="dissolved">Dissolved</option></select>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Bookkeeper</label>
        <select class="form-control" id="ef-bookkeeper"><option value="">— None —</option></select>
      </div>
      <div class="form-group"><label>Bookkeeping Service</label>
        <select class="form-control" id="ef-bookkeeping-service">
          <option value="none">None</option>
          <option value="bank_feed">Bank Feed</option>
          <option value="accrual">Accrual</option>
          <option value="client_prepared">Client Prepared</option>
        </select>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" id="ef-submit" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const companyId = location.pathname.split('/').pop();
  const token = localStorage.getItem('dl_token');
  if (!token) window.location.href = '/login';

  let companyData = null;
  let bookkeepingRealm = null;
  const CURRENT_YEAR = new Date().getFullYear();

  function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }; }
  async function apiFetch(url, opts = {}) {
    const isFormData = opts.body instanceof FormData;
    const headers = isFormData
      ? { 'Authorization': 'Bearer ' + token, ...(opts.headers||{}) }
      : { ...authHeaders(), ...(opts.headers||{}) };
    const res = await fetch(url, { ...opts, headers });
    if (res.status === 401) window.location.href = '/login';
    return res;
  }
  function esc(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  const toast = (msg, type) => window._shellToast && window._shellToast(msg, type === 'error' ? 'error' : undefined);

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    const stbar = document.getElementById('subtab-bar');
    if (stbar) stbar.style.display = name === 'bookkeeping' ? '' : 'none';
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax(true);
    if (name === 'bookkeeping') {
      if (bookkeepingRealm) bk_initBookkeeping();
      else { /* wait for company to load, then init */ window._bkPendingInit = true; }

    }
    if (name === 'communication') initCoComm();
    const mainEl = document.querySelector('.main');
    if (mainEl) mainEl.style.overflowY = (name === 'communication') ? 'hidden' : 'auto';
    if (name === 'organizers' && companyData && companyData.stanford_tax_url) {
      const orgEl = document.getElementById('org-stanford-link');
      if (orgEl) orgEl.innerHTML = `<a href="${esc(companyData.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">🔗 Open Stanford Tax →</a>`;
    }
    if (name === 'notes' && companyData) document.getElementById('notes-ta-full').value = companyData.notes || '';
    if (name === 'workflow') loadWorkflow();
  }

  async function loadWorkflow() {
    const loading = document.getElementById('workflow-loading');
    const list = document.getElementById('workflow-list');
    loading.style.display = ''; list.style.display = 'none';
    try {
      const res = await apiFetch(`/api/pipelines/entity-jobs?entity_type=company&entity_id=${companyId}`);
      const jobs = await res.json();
      loading.style.display = 'none'; list.style.display = '';
      if (!jobs.length) { list.innerHTML = '<div style="color:var(--muted);">This company is not in any pipelines yet.</div>'; return; }
      list.innerHTML = jobs.map(j => {
        const stageColor = j.stage_color || 'var(--gold)';
        const yearBadge = j.tax_year ? `<span style="font-size:0.72rem;background:rgba(255,255,255,0.06);border-radius:4px;padding:0.1rem 0.45rem;margin-left:0.5rem;color:var(--muted);">${j.tax_year}</span>` : '';
        const statusColor = j.job_status === 'blocked' ? 'var(--red)' : (j.job_status === 'waiting_client' || j.job_status === 'missing_info') ? 'var(--orange)' : 'var(--green)';
        const statusLabel = {active:'Active',waiting_client:'Waiting on Client',missing_info:'Missing Info',blocked:'Blocked',under_extension:'Under Extension',on_hold:'On Hold'}[j.job_status] || 'Active';
        const updateText = j.last_update ? (j.last_update.length > 80 ? j.last_update.substring(0,80)+'…' : j.last_update) : null;
        const updateDate = j.last_update_at ? new Date(j.last_update_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '';
        const updateAuthor = j.last_update_author || '';
        const lastUpdate = updateText ? `<div style="font-size:0.78rem;color:var(--muted);margin-top:0.3rem;">${esc(updateText)}<span style="font-size:0.72rem;color:rgba(143,163,184,0.6);margin-left:0.4rem;">— ${esc(updateAuthor)}${updateDate ? ', '+updateDate : ''}</span></div>` : '';
        return `<div class="workflow-job-card" onclick="window.location.href='/pipelines?job=${j.id}'">
          <div style="flex:1;min-width:180px;"><div style="font-weight:700;font-size:0.95rem;">${esc(j.pipeline_name)}${yearBadge}</div>${lastUpdate}</div>
          <div style="text-align:center;min-width:140px;"><div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Current Stage</div><div style="font-weight:700;color:${stageColor};font-size:0.9rem;">${esc(j.stage_name)}</div></div>
          <div style="text-align:center;min-width:100px;"><div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Status</div><div style="font-weight:600;font-size:0.82rem;color:${statusColor};">${statusLabel}</div></div>
          ${j.assigned_name ? `<div style="text-align:center;min-width:80px;"><div style="font-size:0.68rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Assigned</div><div style="font-size:0.82rem;">${esc(j.assigned_name)}</div></div>` : ''}
        </div>`;
      }).join('');
    } catch(e) { loading.textContent = 'Failed to load pipelines: ' + e.message; }
  }

  function switchSubtab(name, el) {
    document.querySelectorAll('.subtab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.subtab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const sc = document.getElementById('subtab-' + name);
    if (sc) sc.classList.add('active');
    bk_loadActiveSubtab(name);
  }

  async function loadCompany() {
    try {
      const res = await apiFetch(`/api/companies/${companyId}`);
      if (res.status === 404 || res.status === 403) { window.location.href = '/404'; return; }
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Error loading'; return; }
      companyData = await res.json();
      bookkeepingRealm = companyData.realm_id || null;
      renderHeader(companyData);
      renderOverview(companyData);
      // If bookkeeping tab was clicked before company loaded, init now
      if (window._bkPendingInit) { window._bkPendingInit = false; bk_initBookkeeping(); }
    } catch(e) {
      console.error('loadCompany error:', e);
      document.getElementById('entity-name').textContent = 'Error loading';
    }
  }

  const ENTITY_LABELS = {
    s_corp: 'S-Corporation', c_corp: 'C-Corporation', llc: 'LLC',
    partnership: 'Partnership', sole_prop: 'Sole Proprietorship',
    trust: 'Trust', nonprofit: 'Non-Profit', '1040': '1040 (Individual)',
    other: 'Other'
  };
  function etLabel(t) { return ENTITY_LABELS[t] || (t ? t.replace(/_/g,' ') : ''); }

  function renderHeader(c) {
    document.title = `${c.company_name} — DarkLion`;
    document.getElementById('entity-name').textContent = c.company_name || 'Unnamed Company';
    let html = `<span class="badge badge-muted">Company</span>`;
    if (c.entity_type) html += ` <span class="badge badge-muted">${esc(etLabel(c.entity_type))}</span>`;
    if (c.status === 'active') html += ` <span class="badge badge-green">Active</span>`;
    if (c.status === 'inactive') html += ` <span class="badge badge-muted">Inactive</span>`;
    if (c.status === 'dissolved') html += ` <span class="badge badge-red">Dissolved</span>`;
    if (c.realm_id) html += ` <span class="badge badge-green">QBO Connected</span>`;
    if (c.bookkeeping_service && c.bookkeeping_service !== 'none') {
      const bkLabel = { bank_feed: 'Bank Feed', accrual: 'Accrual', client_prepared: 'Client Prepared' }[c.bookkeeping_service] || c.bookkeeping_service;
      html += ` <span class="badge" style="background:rgba(74,144,217,0.15);color:#4a90d9;border:1px solid rgba(74,144,217,0.3);">📒 ${esc(bkLabel)}</span>`;
    }
    document.getElementById('entity-badges').innerHTML = html;
    const meta = [];
    if (c.relationship) meta.push(`👥 <a href="/crm/relationship/${c.relationship.id}" style="color:var(--gold);text-decoration:none;">${esc(c.relationship.name)}</a>`);
    if (c.tax_year_end) meta.push(`Tax Year End: ${esc(c.tax_year_end)}`);
    document.getElementById('entity-meta').innerHTML = meta.join('  ·  ');
    // Track recent visit
    if (window.addRecentClient) window.addRecentClient({ _type:'company', id: c.id, _label: c.company_name || 'Unnamed', _sub: (c.relationship && c.relationship.name) || c.entity_type || 'Company' });
  }

  function renderOverview(c) {
    document.getElementById('notes-ta').value = c.notes || '';

    // ── TOP LEFT: Company Details panel ──
    const detailsEl = document.getElementById('overview-details-panel');
    let detailsHtml = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Company Details</div>`;
    detailsHtml += `<div class="info-row"><span class="info-label">Entity Type</span><span class="info-val">${esc(etLabel(c.entity_type) || '—')}</span></div>`;
    detailsHtml += `<div class="info-row"><span class="info-label">Status</span><span class="info-val">${esc(c.status || 'active')}</span></div>`;
    detailsHtml += `<div class="info-row"><span class="info-label">Tax Year End</span><span class="info-val">${esc(c.tax_year_end || '—')}</span></div>`;
    if (c.stanford_tax_url) {
      detailsHtml += `<div class="info-row"><span class="info-label">Stanford Tax</span><span class="info-val"><a href="${esc(c.stanford_tax_url)}" target="_blank" rel="noopener" style="color:var(--gold);">Open →</a></span></div>`;
    }
    detailsEl.innerHTML = detailsHtml;

    // ── TOP RIGHT: People panel ──
    const peopleEl = document.getElementById('overview-people-panel');
    const people = c.people || [];
    let peopleHtml = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;display:flex;align-items:center;justify-content:space-between;">
      <span>People</span>
      <button class="btn btn-gold btn-sm" onclick="openAttachPersonModal()" style="font-size:0.72rem;padding:0.25rem 0.65rem;">+ Person</button>
    </div>`;
    if (!people.length) {
      peopleHtml += `<div style="color:var(--muted);font-size:0.84rem;padding:0.5rem 0;">No people attached.</div>`;
    } else {
      peopleHtml += `<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">`;
      people.forEach(p => {
        const initials = ((p.first_name||'').charAt(0)+(p.last_name||'').charAt(0)).toUpperCase() || '?';
        const accessLabel = { full:'Full', view:'View', sign:'Sign' }[p.access_level] || (p.access_level || '');
        peopleHtml += `<div style="background:var(--charcoal);border:1px solid var(--border);border-radius:8px;padding:0.6rem 0.75rem;display:flex;align-items:flex-start;gap:0.55rem;position:relative;">
          <div style="width:32px;height:32px;border-radius:5px;background:rgba(201,168,76,0.18);color:var(--gold);font-weight:700;font-size:0.88rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">${initials}</div>
          <div style="min-width:0;flex:1;">
            <div style="font-weight:600;font-size:0.84rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><a href="/crm/person/${p.person_id}" style="color:var(--text);text-decoration:none;">${esc(p.first_name)} ${esc(p.last_name)}</a></div>
            ${p.email ? `<div style="font-size:0.73rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(p.email)}</div>` : ''}
            ${accessLabel ? `<div style="font-size:0.68rem;margin-top:0.2rem;"><span style="background:rgba(201,168,76,0.12);color:var(--gold);border-radius:4px;padding:0.1rem 0.35rem;font-weight:600;">${esc(accessLabel)}</span></div>` : ''}
          </div>
          <button onclick="detachPerson(${p.person_id})" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.75rem;padding:0;line-height:1;flex-shrink:0;" title="Remove">✕</button>
        </div>`;
      });
      peopleHtml += `</div>`;
    }
    peopleEl.innerHTML = peopleHtml;

    // ── LEFT COL: Tax Status panel ──
    const taxEl = document.getElementById('overview-tax-panel');
    taxEl.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;display:flex;align-items:center;justify-content:space-between;">
      <span>Tax Status</span>
      <a href="#" onclick="switchTab('tax',document.querySelector('[onclick*=\\'tax\\']'));return false;" style="font-size:0.72rem;color:var(--gold);">View all →</a>
    </div><div id="ov-tax-inner" style="color:var(--muted);font-size:0.82rem;">Loading…</div>`;
    apiFetch(`/api/tax-deliveries?company_id=${companyId}`).then(r=>r.json()).then(deliveries=>{
      const el = document.getElementById('ov-tax-inner');
      if (!el) return;
      if (!deliveries.length) { el.innerHTML = `<div style="color:var(--muted);font-size:0.82rem;font-style:italic;">No tax deliveries yet.</div>`; return; }
      const last3 = deliveries.slice(0,3);
      const STATUS_DOT = { draft:'#8fa3b8', sent:'#4a90d9', signed:'#3ecf8e', complete:'#3ecf8e', needs_changes:'#ed8936', approved:'#c9a84c' };
      const STATUS_LABEL = { draft:'Draft', sent:'Sent', signed:'Signed', complete:'Complete', needs_changes:'Needs Changes', approved:'Approved' };
      el.innerHTML = last3.map(d => {
        const dot = STATUS_DOT[d.status] || '#8fa3b8';
        const label = STATUS_LABEL[d.status] || d.status || '';
        return `<div style="display:flex;align-items:center;gap:0.6rem;padding:0.4rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="background:rgba(201,168,76,0.12);color:var(--gold);border-radius:4px;padding:0.1rem 0.4rem;font-size:0.72rem;font-weight:700;flex-shrink:0;">${esc(String(d.tax_year||''))}</span>
          <span style="flex:1;min-width:0;font-size:0.82rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(d.title||'Return')}</span>
          <span style="display:flex;align-items:center;gap:0.3rem;font-size:0.75rem;flex-shrink:0;"><span style="width:7px;height:7px;border-radius:50%;background:${dot};display:inline-block;flex-shrink:0;"></span>${esc(label)}</span>
        </div>`;
      }).join('');
    }).catch(()=>{ const el=document.getElementById('ov-tax-inner'); if(el) el.innerHTML='<span style="color:var(--muted);">—</span>'; });

    // ── LEFT COL: Recent Messages panel ──
    const msgsEl = document.getElementById('overview-messages-panel');
    msgsEl.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;display:flex;align-items:center;justify-content:space-between;">
      <span>Recent Messages</span>
      <a href="#" onclick="switchTab('communication',document.querySelector('[onclick*=\\'communication\\']'));return false;" style="font-size:0.72rem;color:var(--gold);">View all →</a>
    </div><div id="ov-msgs-inner" style="color:var(--muted);font-size:0.82rem;">Loading…</div>`;
    apiFetch(`/api/messages/company/${companyId}`).then(r=>r.json()).then(threads=>{
      const el = document.getElementById('ov-msgs-inner');
      if (!el) return;
      if (!threads.length) { el.innerHTML=`<div style="color:var(--muted);font-size:0.82rem;font-style:italic;">No messages yet.</div>`; return; }
      const last3 = threads.slice(0,3);
      function relTime(ts) { if(!ts) return ''; const d=new Date(ts); const diff=Date.now()-d; if(diff<60000) return 'just now'; if(diff<3600000) return Math.floor(diff/60000)+'m ago'; if(diff<86400000) return Math.floor(diff/3600000)+'h ago'; return d.toLocaleDateString(); }
      el.innerHTML = last3.map(t => {
        const personName = t.person ? ((t.person.firstName||'')+' '+(t.person.lastName||'')).trim() : '';
        return `<div style="padding:0.4rem 0;border-bottom:1px solid rgba(255,255,255,0.04);cursor:pointer;" onclick="switchTab('communication',document.querySelector('[onclick*=\\'communication\\']'));setTimeout(()=>loadCoThread(${t.id}),200);">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
            <span style="font-size:0.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(personName || t.subject || '(no subject)')}</span>
            <span style="font-size:0.72rem;color:var(--muted);flex-shrink:0;">${relTime(t.lastMessageAt)}</span>
          </div>
          <div style="font-size:0.76rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(t.lastPreview||t.subject||'')}</div>
        </div>`;
      }).join('');
    }).catch(()=>{ const el=document.getElementById('ov-msgs-inner'); if(el) el.innerHTML='<span style="color:var(--muted);">—</span>'; });

    // ── CENTER COL: Bookkeeping panel ──
    const bkEl = document.getElementById('overview-bookkeeping-panel');
    bkEl.innerHTML = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.75rem;">Bookkeeping</div>
      <div class="form-group" style="margin-bottom:0.75rem;">
        <label style="font-size:0.78rem;color:var(--muted);display:block;margin-bottom:0.3rem;">Bookkeeper</label>
        <select class="form-control" id="ov-bk-bookkeeper" style="width:100%;"><option value="">— None assigned —</option></select>
      </div>
      <div class="form-group" style="margin-bottom:0.75rem;">
        <label style="font-size:0.78rem;color:var(--muted);display:block;margin-bottom:0.3rem;">Bookkeeping Service</label>
        <select class="form-control" id="ov-bk-service" style="width:100%;">
          <option value="none">None</option>
          <option value="bank_feed">Bank Feed</option>
          <option value="accrual">Accrual</option>
          <option value="client_prepared">Client Prepared</option>
        </select>
      </div>
      <button class="btn btn-gold btn-sm" onclick="saveBookkeepingSettings()" style="margin-bottom:0.75rem;">Save</button>
      <div id="ov-bk-save-msg" style="font-size:0.75rem;color:var(--green);height:1rem;margin-bottom:0.5rem;"></div>
      <div style="border-top:1px solid var(--border);padding-top:0.65rem;margin-top:0.25rem;">
        <div style="font-size:0.75rem;font-weight:600;color:var(--muted);margin-bottom:0.4rem;">QuickBooks Online</div>
        ${c.realm_id
          ? `<div style="display:flex;align-items:center;gap:0.5rem;"><span class="badge badge-green">Connected</span>${c.last_sync_at ? `<span style="font-size:0.75rem;color:var(--muted);">Last sync: ${new Date(c.last_sync_at).toLocaleDateString()}</span>` : ''}</div>`
          : `<span style="font-size:0.82rem;color:var(--muted);">Not connected</span>`
        }
      </div>`;
    // Populate bookkeeper select
    apiFetch('/firms/team').then(r=>r.json()).then(team=>{
      const sel = document.getElementById('ov-bk-bookkeeper');
      if (!sel) return;
      (Array.isArray(team) ? team : (team.members||[])).forEach(m => {
        const opt = document.createElement('option');
        opt.value = m.id || m.user_id || '';
        opt.textContent = (m.name || m.display_name || (m.first_name+' '+m.last_name) || m.email || 'Team member');
        if (c.bookkeeper_id && String(opt.value) === String(c.bookkeeper_id)) opt.selected = true;
        sel.appendChild(opt);
      });
    }).catch(()=>{});
    // Set service
    const svcSel = document.getElementById('ov-bk-service');
    if (svcSel && c.bookkeeping_service) svcSel.value = c.bookkeeping_service;

    // ── RIGHT COL: Quick Links panel ──
    const qlEl = document.getElementById('overview-quicklinks-panel');
    let qlHtml = `<div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.6rem;">Quick Links</div>`;
    const links = [];
