    if (e) e.stopPropagation();
    _moveDocId = id;
    const modal = document.getElementById('move-doc-modal');
    if (!modal) return;
    document.getElementById('move-doc-year').value = currentYear || String(new Date().getFullYear() - 1);
    document.getElementById('move-doc-section').value = currentSection || 'firm_uploaded';
    document.getElementById('move-doc-category').value = currentCategory || 'tax';
    modal.classList.add('open');
  }
  function closeMoveDocModal() {
    const modal = document.getElementById('move-doc-modal');
    if (modal) modal.classList.remove('open');
    _moveDocId = null;
  }
  async function submitMoveDoc() {
    if (!_moveDocId) return;
    const year = document.getElementById('move-doc-year').value;
    const section = document.getElementById('move-doc-section').value;
    const category = document.getElementById('move-doc-category').value;
    try {
      const res = await apiFetch(`/api/documents/${_moveDocId}`, { method: 'PUT', body: JSON.stringify({ year, folder_section: section, folder_category: category }) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Document moved');
      closeMoveDocModal();
      reloadDocs();
    } catch(e) { toast(e.message, 'error'); }
  }

