<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
  .subtab-bar { background: var(--navy); border-bottom: 1px solid var(--border); display: flex; gap: 0; padding: 0 1.5rem; overflow-x: auto; }
  .subtab-item { padding: 0.45rem 0.9rem; cursor: pointer; font-size: 0.78rem; font-weight: 500; color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none; }
  .subtab-item:hover { color: var(--text); }
  .subtab-item.active { color: var(--gold); border-bottom-color: var(--gold); font-weight: 600; }
  .subtab-content { display: none; }
  .subtab-content.active { display: block; }
  .detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
  .info-row { display: flex; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.86rem; }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); width: 140px; flex-shrink: 0; font-size: 0.8rem; }
  .info-val { flex: 1; }
  .save-indicator { font-size: 0.75rem; color: var(--green); margin-top: 0.3rem; height: 1rem; }
  .placeholder-section { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; color: var(--muted); text-align: center; }
  .ph-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .ph-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .ph-desc { font-size: 0.86rem; }
</style>

<main class="main">

<div class="entity-header">
  <a href="/crm/companies" class="entity-back">← Companies</a>
  <div class="entity-header-content">
    <div class="entity-name" id="entity-name">Loading…</div>
    <div class="entity-badges" id="entity-badges"></div>
    <div class="entity-meta" id="entity-meta"></div>
  </div>
  <div class="entity-actions">
    <button class="btn btn-outline btn-sm" onclick="openEditModal()">Edit</button>
  </div>
</div>

<div class="tab-bar">
  <div class="tab-item active" onclick="switchTab('overview', this)">Overview</div>
  <div class="tab-item" onclick="switchTab('docs', this)">Docs</div>
  <div class="tab-item" onclick="switchTab('tax', this)">Tax</div>
  <div class="tab-item" onclick="switchTab('bookkeeping', this)">Bookkeeping</div>
  <div class="tab-item" onclick="switchTab('communication', this)">Communication</div>
  <div class="tab-item" onclick="switchTab('organizers', this)">Organizers</div>
  <div class="tab-item" onclick="switchTab('workflow', this)">Workflow</div>
  <div class="tab-item" onclick="switchTab('notes', this)">Notes</div>
</div>

<div class="subtab-bar" id="subtab-bar" style="display:none;">
  <div class="subtab-item active" onclick="switchSubtab('close-package', this)">Close Package</div>
  <div class="subtab-item" onclick="switchSubtab('uncategorized', this)">Uncategorized</div>
  <div class="subtab-item" onclick="switchSubtab('variance', this)">P&amp;L Variance</div>
  <div class="subtab-item" onclick="switchSubtab('liability', this)">Liability Health</div>
  <div class="subtab-item" onclick="switchSubtab('payroll', this)">Payroll Check</div>
  <div class="subtab-item" onclick="switchSubtab('statements', this)">Statements</div>
</div>

<div id="tab-overview" class="tab-content active">
  <div class="detail-grid">
    <div id="overview-left"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>
    <div id="overview-right">
      <div class="card">
        <div class="card-title">Internal Notes</div>
        <textarea class="form-control" id="notes-ta" rows="6" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
        <div class="save-indicator" id="notes-saved"></div>
      </div>
    </div>
  </div>
</div>

<div id="tab-docs" class="tab-content">
  <div id="docs-content"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>
</div>

<div id="tab-tax" class="tab-content">
  <div id="tax-content"><div class="loading-state"><div class="loading-spinner"></div></div></div>
</div>

<div id="tab-bookkeeping" class="tab-content" style="padding:1.5rem;">
  <div id="subtab-close-package" class="subtab-content active"><div class="empty-state">Close Package — coming soon</div></div>
  <div id="subtab-uncategorized" class="subtab-content"><div class="empty-state">Uncategorized Scanner — coming soon</div></div>
  <div id="subtab-variance" class="subtab-content"><div class="empty-state">P&amp;L Variance — coming soon</div></div>
  <div id="subtab-liability" class="subtab-content"><div class="empty-state">Liability Health — coming soon</div></div>
  <div id="subtab-payroll" class="subtab-content"><div class="empty-state">Payroll Check — coming soon</div></div>
  <div id="subtab-statements" class="subtab-content"><div class="empty-state">Statements — coming soon</div></div>
</div>

<div id="tab-communication" class="tab-content">
  <div class="empty-state">Communication — coming soon</div>
</div>

<div id="tab-organizers" class="tab-content">
  <div class="placeholder-section"><div class="ph-icon">📝</div><div class="ph-title">Organizers</div><div class="ph-desc">Coming soon.</div></div>
</div>

<div id="tab-workflow" class="tab-content">
  <div class="placeholder-section"><div class="ph-icon">⚙️</div><div class="ph-title">Pipelines</div><div class="ph-desc">Pipeline jobs for this company will appear here.</div></div>
</div>

<div id="tab-notes" class="tab-content">
  <div class="card" style="max-width:800px;margin:1.5rem;">
    <div class="card-title">Internal Notes</div>
    <textarea class="form-control" id="notes-ta-full" rows="12" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:0.75rem;">
      <button class="btn btn-gold btn-sm" onclick="autoSaveNotes(document.getElementById('notes-ta-full').value, true)">Save Notes</button>
      <div class="save-indicator" id="notes-saved-full"></div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
    <h2>Edit Company</h2>
    <div id="edit-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>
    <div class="form-group"><label>Company Name</label><input type="text" class="form-control" id="ef-name"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Entity Type</label>
        <select class="form-control" id="ef-entity-type">
          <option value="">— Select —</option><option value="llc">LLC</option><option value="s_corp">S-Corp</option>
          <option value="c_corp">C-Corp</option><option value="partnership">Partnership</option>
          <option value="sole_prop">Sole Prop</option><option value="trust">Trust</option>
          <option value="nonprofit">Non-Profit</option><option value="other">Other</option>
        </select>
      </div>
      <div class="form-group"><label>Tax Year End</label><input type="text" class="form-control" id="ef-tax-year-end" placeholder="12/31"></div>
    </div>
    <div class="form-group"><label>Stanford Tax URL</label><input type="url" class="form-control" id="ef-stanford"></div>
    <div class="form-group"><label>Status</label>
      <select class="form-control" id="ef-status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="dissolved">Dissolved</option></select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const companyId = location.pathname.split('/').pop();
  const token = localStorage.getItem('dl_token');
  if (!token) window.location.href = '/login';

  let companyData = null;

  function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }; }
  async function apiFetch(url, opts = {}) {
    const res = await fetch(url, { ...opts, headers: { ...authHeaders(), ...(opts.headers||{}) } });
    if (res.status === 401) window.location.href = '/login';
    return res;
  }
  function esc(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function toast(msg, type='success') { window.toast(msg, type === 'error' ? 'error' : undefined); }

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    const stbar = document.getElementById('subtab-bar');
    if (stbar) stbar.style.display = name === 'bookkeeping' ? '' : 'none';
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax();
    if (name === 'notes' && companyData) document.getElementById('notes-ta-full').value = companyData.notes || '';
  }

  function switchSubtab(name, el) {
    document.querySelectorAll('.subtab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.subtab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const sc = document.getElementById('subtab-' + name);
    if (sc) sc.classList.add('active');
  }

  async function loadCompany() {
    try {
      const res = await apiFetch(`/api/companies/${companyId}`);
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Not Found'; return; }
      companyData = await res.json();
      renderHeader(companyData);
      renderOverview(companyData);
    } catch(e) {
      document.getElementById('entity-name').textContent = 'Error loading';
    }
  }

  function renderHeader(c) {
    document.title = `${c.company_name} — DarkLion`;
    document.getElementById('entity-name').textContent = c.company_name || 'Unnamed Company';
    let html = `<span class="badge badge-muted">Company</span>`;
    if (c.entity_type) html += ` <span class="badge badge-muted">${esc(c.entity_type)}</span>`;
    if (c.status === 'active') html += ` <span class="badge badge-green">Active</span>`;
    if (c.status === 'inactive') html += ` <span class="badge badge-muted">Inactive</span>`;
    if (c.status === 'dissolved') html += ` <span class="badge badge-red">Dissolved</span>`;
    if (c.realm_id) html += ` <span class="badge badge-green">QBO Connected</span>`;
    document.getElementById('entity-badges').innerHTML = html;
    const meta = [];
    if (c.relationship) meta.push(`👥 <a href="/crm/relationship/${c.relationship.id}" style="color:var(--gold);text-decoration:none;">${esc(c.relationship.name)}</a>`);
    if (c.tax_year_end) meta.push(`Tax Year End: ${esc(c.tax_year_end)}`);
    document.getElementById('entity-meta').innerHTML = meta.join('  ·  ');
  }

  function renderOverview(c) {
    document.getElementById('notes-ta').value = c.notes || '';
    const left = document.getElementById('overview-left');
    let html = `<div class="card">
      <div class="card-title">Company Details</div>
      <div class="info-row"><span class="info-label">Entity Type</span><span class="info-val">${esc(c.entity_type || '—')}</span></div>
      <div class="info-row"><span class="info-label">Status</span><span class="info-val">${esc(c.status || 'active')}</span></div>
      <div class="info-row"><span class="info-label">Tax Year End</span><span class="info-val">${esc(c.tax_year_end || '—')}</span></div>
      <div class="info-row"><span class="info-label">QBO</span><span class="info-val">${c.realm_id ? '<span class="badge badge-green">Connected</span>' : '<span class="badge badge-muted">Not Connected</span>'}</span></div>
      ${c.last_sync_at ? `<div class="info-row"><span class="info-label">Last Sync</span><span class="info-val" style="color:var(--muted);font-size:0.82rem;">${new Date(c.last_sync_at).toLocaleDateString()}</span></div>` : ''}
    </div>`;

    if (c.stanford_tax_url) {
      html += `<div class="card" style="display:flex;align-items:center;gap:1rem;">
        <div style="flex:1;min-width:0;"><div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">Stanford Tax</div><div style="font-size:0.82rem;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(c.stanford_tax_url)}</div></div>
        <a href="${esc(c.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">Open →</a>
      </div>`;
    }

    const people = c.people || [];
    html += `<div class="card">
      <div class="card-title" style="display:flex;align-items:center;justify-content:space-between;">
        <span>People</span>
        <button class="btn btn-gold btn-sm" onclick="openAttachPersonModal()">+ Attach</button>
      </div>`;
    if (!people.length) {
      html += `<div style="color:var(--muted);font-size:0.84rem;padding:0.5rem 0;">No people attached.</div>`;
    } else {
      people.forEach(p => {
        const initials = ((p.first_name||'').charAt(0)+(p.last_name||'').charAt(0)).toUpperCase() || '?';
        html += `<div class="person-row">
          <div class="person-avatar">${initials}</div>
          <div class="person-info">
            <div class="person-name"><a href="/crm/person/${p.person_id}" style="color:var(--text);text-decoration:none;">${esc(p.first_name)} ${esc(p.last_name)}</a></div>
            <div class="person-meta">${p.email ? esc(p.email) : ''}</div>
          </div>
          <button class="btn btn-ghost btn-xs" onclick="window.location.href='/crm/person/${p.person_id}'">→</button>
          <button class="btn btn-danger btn-xs" onclick="detachPerson(${p.person_id})">✕</button>
        </div>`;
      });
    }
    html += `</div>`;
    left.innerHTML = html;
  }

  async function loadDocs() {
    const el = document.getElementById('docs-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading documents…</div></div>';
    try {
      const res = await apiFetch(`/api/documents?owner_type=company&owner_id=${companyId}`);
      const docs = await res.json();
      if (!docs.length) { el.innerHTML = '<div class="empty-state">No documents yet.</div>'; return; }
      el.innerHTML = docs.map(d => `<div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.04);">
        <div style="flex:1;min-width:0;font-size:0.86rem;font-weight:600;">${esc(d.display_name||'Untitled')}</div>
        <span class="badge badge-muted">${esc(d.folder_category||'')}</span>
        <span style="font-size:0.78rem;color:var(--muted);">${d.year||''}</span>
        <button class="btn btn-ghost btn-xs" onclick="downloadDoc(${d.id})">⬇</button>
      </div>`).join('');
    } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load documents.</div>'; }
  }

  async function downloadDoc(id) {
    try {
      const res = await apiFetch(`/api/documents/${id}/url`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
    } catch(e) { toast('Failed to get download link', 'error'); }
  }

  async function loadTax() {
    const el = document.getElementById('tax-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="empty-state">No tax returns on file.</div>';
  }

  async function autoSaveNotes(val, force) {
    if (!companyData) return;
    try {
      await apiFetch(`/api/companies/${companyId}`, { method: 'PUT', body: JSON.stringify({ notes: val }) });
      const ind = document.getElementById('notes-saved') || document.getElementById('notes-saved-full');
      if (ind) { ind.textContent = 'Saved'; setTimeout(() => { ind.textContent = ''; }, 2000); }
    } catch(e) {}
  }

  function openEditModal() {
    if (!companyData) return;
    document.getElementById('ef-name').value = companyData.company_name || '';
    document.getElementById('ef-entity-type').value = companyData.entity_type || '';
    document.getElementById('ef-tax-year-end').value = companyData.tax_year_end || '';
    document.getElementById('ef-stanford').value = companyData.stanford_tax_url || '';
    document.getElementById('ef-status').value = companyData.status || 'active';
    document.getElementById('edit-modal').classList.add('open');
  }
  function closeModal() { document.getElementById('edit-modal').classList.remove('open'); }

  async function submitEdit() {
    const body = {
      company_name: document.getElementById('ef-name').value.trim(),
      entity_type: document.getElementById('ef-entity-type').value,
      tax_year_end: document.getElementById('ef-tax-year-end').value.trim(),
      stanford_tax_url: document.getElementById('ef-stanford').value.trim(),
      status: document.getElementById('ef-status').value,
    };
    try {
      const res = await apiFetch(`/api/companies/${companyId}`, { method: 'PUT', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error||'Failed'); }
      closeModal();
      toast('Company updated');
      await loadCompany();
    } catch(e) { document.getElementById('edit-error').textContent = e.message; document.getElementById('edit-error').style.display = ''; }
  }

  async function detachPerson(personId) {
    if (!confirm('Remove this person from the company?')) return;
    try {
      await apiFetch(`/api/companies/${companyId}/people/${personId}`, { method: 'DELETE' });
      toast('Person removed');
      await loadCompany();
    } catch(e) { toast('Failed to remove', 'error'); }
  }

  async function openAttachPersonModal() {
    if (!companyData) return;
    const relId = companyData.relationship_id;
    if (!relId) { toast('Company has no relationship assigned', 'error'); return; }
    try {
      const res = await apiFetch(`/api/relationships/${relId}/people`);
      const people = await res.json();
      const existing = (companyData.people || []).map(p => p.person_id);
      const available = people.filter(p => !existing.includes(p.id));
      if (!available.length) { toast('All people already attached', 'error'); return; }
      const opts = available.map(p => `<option value="${p.id}">${esc((p.first_name||'')+' '+(p.last_name||''))}</option>`).join('');
      const modal = document.createElement('div');
      modal.className = 'modal-overlay open';
      modal.innerHTML = `<div class="modal" onclick="event.stopPropagation()" style="max-width:380px;">
        <h2>Attach Person</h2>
        <div class="form-group"><label>Person</label><select class="form-control" id="ap-person">${opts}</select></div>
        <div class="form-group"><label>Access Level</label>
          <select class="form-control" id="ap-access"><option value="view">View</option><option value="full">Full</option><option value="sign">Sign</option></select>
        </div>
        <div class="modal-actions">
          <button class="btn btn-outline" onclick="this.closest('.modal-overlay').remove()">Cancel</button>
          <button class="btn btn-gold" onclick="submitAttachPerson(this)">Attach</button>
        </div>
      </div>`;
      document.body.appendChild(modal);
    } catch(e) { toast('Failed to load people', 'error'); }
  }

  async function submitAttachPerson(btn) {
    const modal = btn.closest('.modal-overlay');
    const personId = document.getElementById('ap-person').value;
    const access = document.getElementById('ap-access').value;
    try {
      const res = await apiFetch(`/api/companies/${companyId}/people`, { method: 'POST', body: JSON.stringify({ person_id: parseInt(personId), access_level: access }) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error||'Failed'); }
      modal.remove();
      toast('Person attached');
      await loadCompany();
    } catch(e) { toast(e.message, 'error'); }
  }

  loadCompany();
</script>

<%- include('partials/shell-close') %>
