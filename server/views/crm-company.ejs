<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
  .subtab-bar { background: var(--navy); border-bottom: 1px solid var(--border); display: flex; gap: 0; padding: 0 1.5rem; overflow-x: auto; }
  .subtab-item { padding: 0.45rem 0.9rem; cursor: pointer; font-size: 0.78rem; font-weight: 500; color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: all 0.15s; background: none; border-top: none; border-left: none; border-right: none; }
  .subtab-item:hover { color: var(--text); }
  .subtab-item.active { color: var(--gold); border-bottom-color: var(--gold); font-weight: 600; }
  .subtab-content { display: none; }
  .subtab-content.active { display: block; }
  .detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
  .info-row { display: flex; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.86rem; }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); width: 140px; flex-shrink: 0; font-size: 0.8rem; }
  .info-val { flex: 1; }
  .save-indicator { font-size: 0.75rem; color: var(--green); margin-top: 0.3rem; height: 1rem; }
  .placeholder-section { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 2rem; color: var(--muted); text-align: center; }
  .ph-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .ph-title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .ph-desc { font-size: 0.86rem; }

  /* ── Tax tab ── */
  .delivery-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem; margin-bottom: 1rem; display: flex; align-items: flex-start; gap: 1rem; }
  .delivery-card:hover { border-color: rgba(201,168,76,0.3); }
  .delivery-info { flex: 1; min-width: 0; }
  .delivery-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.2rem; }
  .delivery-meta { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.5rem; }
  .delivery-signers { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .signer-chip { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; padding: 0.2rem 0.55rem; border-radius: 20px; border: 1px solid var(--border); background: var(--charcoal); }
  .signer-chip.signed { border-color: rgba(62,207,142,0.4); color: var(--green); }
  .signer-chip.pending { color: var(--muted); }
  .signer-chip.needs-changes { border-color: rgba(237,137,54,0.4); color: var(--orange); }
  .delivery-actions { display: flex; gap: 0.5rem; flex-shrink: 0; flex-wrap: wrap; }
  .status-pill { display: inline-flex; align-items: center; padding: 0.2rem 0.65rem; border-radius: 20px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .status-draft { background: rgba(143,163,184,0.12); color: var(--muted); }
  .status-sent { background: rgba(74,144,217,0.12); color: #4a90d9; }
  .status-signed { background: rgba(62,207,142,0.12); color: var(--green); }
  .status-complete { background: rgba(62,207,142,0.2); color: var(--green); border: 1px solid rgba(62,207,142,0.3); }
  .status-needs_changes { background: rgba(237,137,54,0.12); color: var(--orange); }
  .status-approved { background: rgba(201,168,76,0.12); color: var(--gold); }

  /* ── File drop zone (portal-matched) ── */
  .file-drop { border: 2px dashed var(--border); border-radius: 9px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; color: var(--muted); font-size: 0.88rem; position: relative; }
  .file-drop:hover, .file-drop.drag-over { border-color: var(--gold); background: rgba(201,168,76,0.04); }
  .file-drop input[type="file"] { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .selected-file { margin-top: 0.5rem; font-size: 0.8rem; color: var(--gold); font-weight: 600; }
  .upload-err { font-size: 0.8rem; color: var(--red); margin-top: 0.5rem; }
  .upload-msg { font-size: 0.8rem; color: var(--green); margin-top: 0.5rem; }

  /* ── Docs tab — portal-matched styles ── */
  .docs-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; padding: 1.5rem; }
  @media (max-width: 900px) { .docs-layout { grid-template-columns: 1fr; } }
  .docs-col-title { font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; }
  .year-folder { background: var(--card); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .year-header { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1.1rem; cursor: pointer; user-select: none; transition: background 0.15s; }
  .year-header:hover { background: rgba(255,255,255,0.03); }
  .year-header .yr-label { font-weight: 700; font-size: 0.95rem; color: var(--text); display: flex; align-items: center; gap: 0.5rem; }
  .yr-count { font-size: 0.72rem; background: rgba(201,168,76,0.12); color: var(--gold); border: 1px solid rgba(201,168,76,0.25); border-radius: 20px; padding: 0.1rem 0.5rem; font-weight: 600; }
  .yr-chevron { color: var(--muted); font-size: 0.8rem; transition: transform 0.2s; }
  .year-folder.open .yr-chevron { transform: rotate(180deg); }
  .year-body { display: none; border-top: 1px solid var(--border); }
  .year-folder.open .year-body { display: block; }
  .cat-section-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); padding: 0.6rem 1.1rem 0.3rem; font-weight: 700; border-left: 3px solid var(--gold); background: rgba(201,168,76,0.04); }
  .doc-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 1.1rem; border-top: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
  .doc-row:hover { background: rgba(255,255,255,0.03); }
  .doc-info { flex: 1; min-width: 0; }
  .doc-name { font-weight: 600; font-size: 0.9rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: pointer; }
  .doc-name:hover { color: var(--gold); }
  .doc-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
  .doc-badge { font-size: 0.68rem; border-radius: 20px; padding: 0.1rem 0.45rem; font-weight: 600; }
  .doc-badge-type { background: rgba(138,143,168,0.12); color: var(--muted); border: 1px solid rgba(138,143,168,0.2); }
  .doc-badge-viewed { background: rgba(62,207,142,0.1); color: var(--green); border: 1px solid rgba(62,207,142,0.25); }
  .btn-dl { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 0.78rem; border-radius: 6px; padding: 0.3rem 0.65rem; cursor: pointer; transition: border-color 0.2s, color 0.2s; flex-shrink: 0; white-space: nowrap; }
  .btn-dl:hover { border-color: var(--gold); color: var(--gold); }
  .cat-empty-msg { color: var(--muted); font-size: 0.82rem; font-style: italic; padding: 0.4rem 1.1rem; }
</style>

<main class="main">

<div class="entity-header">
  <a href="/crm/companies" class="entity-back">← Companies</a>
  <div class="entity-header-content">
    <div class="entity-name" id="entity-name">Loading…</div>
    <div class="entity-badges" id="entity-badges"></div>
    <div class="entity-meta" id="entity-meta"></div>
  </div>
  <div class="entity-actions">
    <button class="btn btn-outline btn-sm" onclick="openEditModal()">Edit</button>
  </div>
</div>

<div class="tab-bar">
  <div class="tab-item active" onclick="switchTab('overview', this)">Overview</div>
  <div class="tab-item" onclick="switchTab('docs', this)">Docs</div>
  <div class="tab-item" onclick="switchTab('tax', this)">Tax</div>
  <div class="tab-item" onclick="switchTab('bookkeeping', this)">Bookkeeping</div>
  <div class="tab-item" onclick="switchTab('communication', this)">Communication</div>
  <div class="tab-item" onclick="switchTab('organizers', this)">Organizers</div>
  <div class="tab-item" onclick="switchTab('workflow', this)">Workflow</div>
  <div class="tab-item" onclick="switchTab('notes', this)">Notes</div>
</div>

<div class="subtab-bar" id="subtab-bar" style="display:none;">
  <div class="subtab-item active" onclick="switchSubtab('close-package', this)">Close Package</div>
  <div class="subtab-item" onclick="switchSubtab('uncategorized', this)">Uncategorized</div>
  <div class="subtab-item" onclick="switchSubtab('variance', this)">P&amp;L Variance</div>
  <div class="subtab-item" onclick="switchSubtab('liability', this)">Liability Health</div>
  <div class="subtab-item" onclick="switchSubtab('payroll', this)">Payroll Check</div>
  <div class="subtab-item" onclick="switchSubtab('statements', this)">Statements</div>
</div>

<div id="tab-overview" class="tab-content active">
  <div class="detail-grid">
    <div id="overview-left"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>
    <div id="overview-right">
      <div class="card">
        <div class="card-title">Internal Notes</div>
        <textarea class="form-control" id="notes-ta" rows="6" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
        <div class="save-indicator" id="notes-saved"></div>
      </div>
    </div>
  </div>
</div>

<div id="tab-docs" class="tab-content">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem 0;">
    <span style="font-size:0.84rem;color:var(--muted);">Company documents</span>
    <button class="btn btn-gold btn-sm" onclick="openUploadModal()">↑ Upload Document</button>
  </div>
  <div id="docs-content"><div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div></div>

  <!-- Upload Modal (portal-matched) -->
  <div class="modal-overlay" id="upload-modal">
    <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
      <h2>Upload Document</h2>
      <div class="form-group">
        <label>Tax Year</label>
        <select class="form-control" id="upload-year"></select>
      </div>
      <div class="form-group">
        <label>Category</label>
        <select class="form-control" id="upload-doc-type">
          <option value="tax">🧾 Tax</option>
          <option value="bookkeeping">📒 Bookkeeping</option>
          <option value="private">🔒 Private</option>
          <option value="other">📎 Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Section</label>
        <select class="form-control" id="upload-section">
          <option value="firm_uploaded">Delivered by Advisor</option>
          <option value="private">Private (staff only)</option>
        </select>
      </div>
      <div class="form-group">
        <label>File</label>
        <div class="file-drop" id="upload-file-drop">
          <input type="file" id="upload-file-input">
          <span id="upload-drop-text">Click to select or drag a file here</span>
          <div class="selected-file" id="upload-selected-name"></div>
        </div>
      </div>
      <div class="upload-err" id="upload-error" style="display:none;"></div>
      <div class="upload-msg" id="upload-msg" style="display:none;"></div>
      <div class="modal-actions">
        <button class="btn btn-outline" id="upload-cancel-btn">Cancel</button>
        <button class="btn btn-gold" id="upload-submit-btn" disabled>Upload</button>
      </div>
    </div>
  </div>
</div>

<div id="tab-tax" class="tab-content">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem 0;">
    <span style="font-size:0.84rem;color:var(--muted);">Tax return deliveries &amp; e-signatures</span>
    <button class="btn btn-gold btn-sm" onclick="openNewDeliveryModal()">+ New Delivery</button>
  </div>
  <div id="tax-content" style="padding:1.5rem;"></div>

  <!-- New Delivery Modal -->
  <div class="modal-overlay" id="new-delivery-modal">
    <div class="modal" onclick="event.stopPropagation()" style="max-width:520px;">
      <h2>New Tax Delivery</h2>
      <div id="delivery-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
        <div class="form-group"><label>Tax Year *</label><input type="text" class="form-control" id="nd-year" placeholder="2024"></div>
        <div class="form-group"><label>Title</label><input type="text" class="form-control" id="nd-title" placeholder="e.g. 2024 Individual Return"></div>
      </div>
      <div class="form-group"><label>Intro Note (shown to client)</label><textarea class="form-control" id="nd-intro" rows="3" placeholder="Please review and sign your tax return…"></textarea></div>
      <div class="form-group"><label>Review Document (PDF for client to review)</label>
        <select class="form-control" id="nd-review-doc"><option value="">— Select document —</option></select>
      </div>
      <div class="form-group"><label>Signature Document (PDF to sign)</label>
        <select class="form-control" id="nd-sig-doc"><option value="">— Select document —</option></select>
      </div>
      <div class="form-group"><label>Signers</label>
        <div id="nd-signers-list" style="display:flex;flex-direction:column;gap:0.4rem;"></div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-outline" onclick="closeDeliveryModal()">Cancel</button>
        <button class="btn btn-gold" onclick="submitNewDelivery()">Create Draft</button>
      </div>
    </div>
  </div>
</div>

<div id="tab-bookkeeping" class="tab-content" style="padding:1.5rem;">
  <div id="subtab-close-package" class="subtab-content active"><div class="empty-state">Close Package — coming soon</div></div>
  <div id="subtab-uncategorized" class="subtab-content"><div class="empty-state">Uncategorized Scanner — coming soon</div></div>
  <div id="subtab-variance" class="subtab-content"><div class="empty-state">P&amp;L Variance — coming soon</div></div>
  <div id="subtab-liability" class="subtab-content"><div class="empty-state">Liability Health — coming soon</div></div>
  <div id="subtab-payroll" class="subtab-content"><div class="empty-state">Payroll Check — coming soon</div></div>
  <div id="subtab-statements" class="subtab-content"><div class="empty-state">Statements — coming soon</div></div>
</div>

<div id="tab-communication" class="tab-content">
  <div class="empty-state">Communication — coming soon</div>
</div>

<div id="tab-organizers" class="tab-content">
  <div class="placeholder-section"><div class="ph-icon">📝</div><div class="ph-title">Organizers</div><div class="ph-desc">Coming soon.</div></div>
</div>

<div id="tab-workflow" class="tab-content">
  <div class="placeholder-section"><div class="ph-icon">⚙️</div><div class="ph-title">Pipelines</div><div class="ph-desc">Pipeline jobs for this company will appear here.</div></div>
</div>

<div id="tab-notes" class="tab-content">
  <div class="card" style="max-width:800px;margin:1.5rem;">
    <div class="card-title">Internal Notes</div>
    <textarea class="form-control" id="notes-ta-full" rows="12" placeholder="Internal staff notes…" onblur="autoSaveNotes(this.value)"></textarea>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:0.75rem;">
      <button class="btn btn-gold btn-sm" onclick="autoSaveNotes(document.getElementById('notes-ta-full').value, true)">Save Notes</button>
      <div class="save-indicator" id="notes-saved-full"></div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:480px;">
    <h2>Edit Company</h2>
    <div id="edit-error" style="display:none;color:var(--red);font-size:0.82rem;margin-bottom:0.75rem;"></div>
    <div class="form-group"><label>Company Name</label><input type="text" class="form-control" id="ef-name"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0 1rem;">
      <div class="form-group"><label>Entity Type</label>
        <select class="form-control" id="ef-entity-type">
          <option value="">— Select —</option><option value="llc">LLC</option><option value="s_corp">S-Corp</option>
          <option value="c_corp">C-Corp</option><option value="partnership">Partnership</option>
          <option value="sole_prop">Sole Prop</option><option value="trust">Trust</option>
          <option value="nonprofit">Non-Profit</option><option value="other">Other</option>
        </select>
      </div>
      <div class="form-group"><label>Tax Year End</label><input type="text" class="form-control" id="ef-tax-year-end" placeholder="12/31"></div>
    </div>
    <div class="form-group"><label>Stanford Tax URL</label><input type="url" class="form-control" id="ef-stanford"></div>
    <div class="form-group"><label>Status</label>
      <select class="form-control" id="ef-status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="dissolved">Dissolved</option></select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-gold" onclick="submitEdit()">Save Changes</button>
    </div>
  </div>
</div>

<%- include('partials/shell-globals') %>

<script>
  const companyId = location.pathname.split('/').pop();
  const token = localStorage.getItem('dl_token');
  if (!token) window.location.href = '/login';

  let companyData = null;

  function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }; }
  async function apiFetch(url, opts = {}) {
    const res = await fetch(url, { ...opts, headers: { ...authHeaders(), ...(opts.headers||{}) } });
    if (res.status === 401) window.location.href = '/login';
    return res;
  }
  function esc(s) { if (s == null) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function toast(msg, type='success') { window.toast(msg, type === 'error' ? 'error' : undefined); }

  function switchTab(name, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const tc = document.getElementById('tab-' + name);
    if (tc) tc.classList.add('active');
    const stbar = document.getElementById('subtab-bar');
    if (stbar) stbar.style.display = name === 'bookkeeping' ? '' : 'none';
    if (name === 'docs') loadDocs();
    if (name === 'tax') loadTax();
    if (name === 'notes' && companyData) document.getElementById('notes-ta-full').value = companyData.notes || '';
  }

  function switchSubtab(name, el) {
    document.querySelectorAll('.subtab-item').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.subtab-content').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    const sc = document.getElementById('subtab-' + name);
    if (sc) sc.classList.add('active');
  }

  async function loadCompany() {
    try {
      const res = await apiFetch(`/api/companies/${companyId}`);
      if (!res.ok) { document.getElementById('entity-name').textContent = 'Not Found'; return; }
      companyData = await res.json();
      renderHeader(companyData);
      renderOverview(companyData);
    } catch(e) {
      document.getElementById('entity-name').textContent = 'Error loading';
    }
  }

  function renderHeader(c) {
    document.title = `${c.company_name} — DarkLion`;
    document.getElementById('entity-name').textContent = c.company_name || 'Unnamed Company';
    let html = `<span class="badge badge-muted">Company</span>`;
    if (c.entity_type) html += ` <span class="badge badge-muted">${esc(c.entity_type)}</span>`;
    if (c.status === 'active') html += ` <span class="badge badge-green">Active</span>`;
    if (c.status === 'inactive') html += ` <span class="badge badge-muted">Inactive</span>`;
    if (c.status === 'dissolved') html += ` <span class="badge badge-red">Dissolved</span>`;
    if (c.realm_id) html += ` <span class="badge badge-green">QBO Connected</span>`;
    document.getElementById('entity-badges').innerHTML = html;
    const meta = [];
    if (c.relationship) meta.push(`👥 <a href="/crm/relationship/${c.relationship.id}" style="color:var(--gold);text-decoration:none;">${esc(c.relationship.name)}</a>`);
    if (c.tax_year_end) meta.push(`Tax Year End: ${esc(c.tax_year_end)}`);
    document.getElementById('entity-meta').innerHTML = meta.join('  ·  ');
  }

  function renderOverview(c) {
    document.getElementById('notes-ta').value = c.notes || '';
    const left = document.getElementById('overview-left');
    let html = `<div class="card">
      <div class="card-title">Company Details</div>
      <div class="info-row"><span class="info-label">Entity Type</span><span class="info-val">${esc(c.entity_type || '—')}</span></div>
      <div class="info-row"><span class="info-label">Status</span><span class="info-val">${esc(c.status || 'active')}</span></div>
      <div class="info-row"><span class="info-label">Tax Year End</span><span class="info-val">${esc(c.tax_year_end || '—')}</span></div>
      <div class="info-row"><span class="info-label">QBO</span><span class="info-val">${c.realm_id ? '<span class="badge badge-green">Connected</span>' : '<span class="badge badge-muted">Not Connected</span>'}</span></div>
      ${c.last_sync_at ? `<div class="info-row"><span class="info-label">Last Sync</span><span class="info-val" style="color:var(--muted);font-size:0.82rem;">${new Date(c.last_sync_at).toLocaleDateString()}</span></div>` : ''}
    </div>`;

    if (c.stanford_tax_url) {
      html += `<div class="card" style="display:flex;align-items:center;gap:1rem;">
        <div style="flex:1;min-width:0;"><div style="font-size:0.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">Stanford Tax</div><div style="font-size:0.82rem;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(c.stanford_tax_url)}</div></div>
        <a href="${esc(c.stanford_tax_url)}" target="_blank" rel="noopener" class="btn btn-gold btn-sm">Open →</a>
      </div>`;
    }

    const people = c.people || [];
    html += `<div class="card">
      <div class="card-title" style="display:flex;align-items:center;justify-content:space-between;">
        <span>People</span>
        <button class="btn btn-gold btn-sm" onclick="openAttachPersonModal()">+ Attach</button>
      </div>`;
    if (!people.length) {
      html += `<div style="color:var(--muted);font-size:0.84rem;padding:0.5rem 0;">No people attached.</div>`;
    } else {
      people.forEach(p => {
        const initials = ((p.first_name||'').charAt(0)+(p.last_name||'').charAt(0)).toUpperCase() || '?';
        html += `<div class="person-row">
          <div class="person-avatar">${initials}</div>
          <div class="person-info">
            <div class="person-name"><a href="/crm/person/${p.person_id}" style="color:var(--text);text-decoration:none;">${esc(p.first_name)} ${esc(p.last_name)}</a></div>
            <div class="person-meta">${p.email ? esc(p.email) : ''}</div>
          </div>
          <button class="btn btn-ghost btn-xs" onclick="window.location.href='/crm/person/${p.person_id}'">→</button>
          <button class="btn btn-danger btn-xs" onclick="detachPerson(${p.person_id})">✕</button>
        </div>`;
      });
    }
    html += `</div>`;
    left.innerHTML = html;
  }

  function docTypeBadge(mimeType, displayName) {
    const mime = (mimeType || '').toLowerCase();
    const name = (displayName || '').toLowerCase();
    const ext = name.includes('.') ? name.split('.').pop() : '';
    let label, color;
    if (mime === 'application/pdf' || ext === 'pdf') { label = 'PDF'; color = '#e53e3e'; }
    else if (mime.includes('spreadsheet') || mime.includes('excel') || ext === 'xlsx' || ext === 'xls' || ext === 'csv') { label = ext === 'csv' ? 'CSV' : 'Excel'; color = '#38a169'; }
    else if (mime.includes('word') || ext === 'docx' || ext === 'doc') { label = 'Word'; color = '#3182ce'; }
    else if (mime.includes('presentation') || mime.includes('powerpoint') || ext === 'pptx' || ext === 'ppt') { label = 'PPT'; color = '#dd6b20'; }
    else if (mime.startsWith('image/') || ['jpg','jpeg','png','gif','webp','heic'].includes(ext)) { label = 'Image'; color = '#805ad5'; }
    else if (mime.includes('zip') || ext === 'zip') { label = 'ZIP'; color = '#718096'; }
    else if (mime.startsWith('text/') || ext === 'txt') { label = 'TXT'; color = '#718096'; }
    else { label = ext ? ext.toUpperCase().slice(0,4) : 'FILE'; color = '#718096'; }
    return `<span style="flex-shrink:0;padding:0.15rem 0.4rem;border-radius:4px;font-size:0.65rem;font-weight:700;color:#fff;background:${color};letter-spacing:0.03em;">${label}</span>`;
  }

  function formatBytes(b) {
    if (!b) return '';
    if (b < 1024) return b + ' B';
    if (b < 1024*1024) return (b/1024).toFixed(1) + ' KB';
    return (b/(1024*1024)).toFixed(1) + ' MB';
  }

  const DOC_CATS_FIRM   = [
    { key: 'tax',         label: 'Tax',         icon: '🧾' },
    { key: 'bookkeeping', label: 'Bookkeeping',  icon: '📒' },
    { key: 'private',     label: 'Private',      icon: '🔒' },
    { key: 'other',       label: 'Other',        icon: '📎' },
  ];
  const DOC_CATS_CLIENT = [
    { key: 'tax',         label: 'Tax',         icon: '🧾' },
    { key: 'bookkeeping', label: 'Bookkeeping',  icon: '📒' },
    { key: 'other',       label: 'Other',        icon: '📎' },
  ];

  function buildDocsColumn(sectionDocs, title, icon, cats) {
    cats = cats || DOC_CATS_FIRM;
    const CURRENT_YEAR = new Date().getFullYear();
    // Fixed year list: current year back to 2018
    const allYears = [];
    for (let y = CURRENT_YEAR; y >= 2018; y--) allYears.push(String(y));
    const recentYears = allYears.slice(0, 2);
    const priorYears  = allYears.slice(2);

    // Index docs
    const byYearCat = {};
    sectionDocs.forEach(d => {
      const y   = d.year || String(CURRENT_YEAR);
      const cat = d.folder_category || d.doc_type || 'other';
      if (!byYearCat[y]) byYearCat[y] = {};
      if (!byYearCat[y][cat]) byYearCat[y][cat] = [];
      byYearCat[y][cat].push(d);
    });

    const colKey = title.replace(/\s/g, '');

    function renderOneYear(yr, openByDefault) {
      const yrDocs = sectionDocs.filter(d => (d.year || String(CURRENT_YEAR)) === yr);
      const openClass = openByDefault ? ' open' : '';
      return `<div class="year-folder${openClass}">
        <div class="year-header" onclick="this.closest('.year-folder').classList.toggle('open')">
          <span class="yr-label">📅 ${yr} <span class="yr-count">${yrDocs.length}</span></span>
          <span class="yr-chevron">▼</span>
        </div>
        <div class="year-body">
          ${cats.map(cat => {
            const files = (byYearCat[yr] || {})[cat.key] || [];
            return `<div class="cat-section-label">${cat.icon} ${cat.label} (${files.length})</div>
            ${files.length === 0
              ? `<div class="cat-empty-msg">No ${cat.label.toLowerCase()} documents for ${yr}</div>`
              : files.map(f => `<div class="doc-row">
                  ${docTypeBadge(f.mime_type, f.display_name)}
                  <div class="doc-info">
                    <div class="doc-name" onclick="downloadDoc(${f.id})">${esc(f.display_name||'Untitled')}</div>
                    <div class="doc-badges">
                      ${f.viewed_at ? '<span class="doc-badge doc-badge-viewed">✓ Viewed</span>' : ''}
                      ${f.size_bytes ? `<span class="doc-badge doc-badge-type">${formatBytes(f.size_bytes)}</span>` : ''}
                    </div>
                  </div>
                  <button class="btn-dl" onclick="downloadDoc(${f.id})">⬇ Download</button>
                </div>`).join('')
            }`;
          }).join('')}
        </div>
      </div>`;
    }

    const priorCount = priorYears.reduce((n,y) => n + sectionDocs.filter(d => (d.year||String(CURRENT_YEAR)) === y).length, 0);

    let html = `<div class="docs-col-title">${icon} ${title} <span style="font-size:0.75rem;font-weight:400;color:var(--muted);">(${sectionDocs.length})</span></div>`;
    recentYears.forEach(y => { html += renderOneYear(y, true); });
    html += `<div class="year-folder">
      <div class="year-header" onclick="this.closest('.year-folder').classList.toggle('open')">
        <span class="yr-label">📂 Prior Years <span class="yr-count">${priorCount}</span></span>
        <span class="yr-chevron">▼</span>
      </div>
      <div class="year-body">
        ${priorYears.map(y => renderOneYear(y, false)).join('')}
      </div>
    </div>`;
    return html;
  }

  let docsData = [];

  async function loadDocs() {
    const el = document.getElementById('docs-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/documents?owner_type=company&owner_id=${companyId}`);
      docsData = await res.json();
      renderDocs();
    } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load documents.</div>'; }
  }

  function renderDocs() {
    const el = document.getElementById('docs-content');
    const firmDocs = docsData.filter(d => (d.folder_section || 'firm_uploaded') === 'firm_uploaded');
    const clientDocs = docsData.filter(d => d.folder_section === 'client_uploaded');
    el.innerHTML = `<div class="docs-layout">
      <div>${buildDocsColumn(firmDocs, 'Delivered by Advisor', '📁', DOC_CATS_FIRM)}</div>
      <div>${buildDocsColumn(clientDocs, 'Uploaded by Client', '📤', DOC_CATS_CLIENT)}</div>
    </div>`;
  }


  // ── Upload modal wiring (portal-matched) ──
  (function() {
    var modal    = document.getElementById('upload-modal');
    var yearSel  = document.getElementById('upload-year');
    var fileDrop = document.getElementById('upload-file-drop');
    var fileInput= document.getElementById('upload-file-input');
    var submitBtn= document.getElementById('upload-submit-btn');
    var cancelBtn= document.getElementById('upload-cancel-btn');
    var errEl    = document.getElementById('upload-error');
    var msgEl    = document.getElementById('upload-msg');
    if (!modal) return;

    var _uploadFile = null;
    var CY = new Date().getFullYear();
    for (var y = CY; y >= 2018; y--) {
      var o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      if (y === CY - 1) o.selected = true;
      yearSel.appendChild(o);
    }

    function setFile(f) {
      _uploadFile = f;
      document.getElementById('upload-selected-name').textContent = f.name;
      submitBtn.disabled = false;
    }

    fileDrop.addEventListener('click', function() { fileInput.click(); });
    fileDrop.addEventListener('dragover', function(e) { e.preventDefault(); fileDrop.classList.add('drag-over'); });
    fileDrop.addEventListener('dragleave', function() { fileDrop.classList.remove('drag-over'); });
    fileDrop.addEventListener('drop', function(e) { e.preventDefault(); fileDrop.classList.remove('drag-over'); if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files[0]) setFile(fileInput.files[0]); });
    cancelBtn.addEventListener('click', function() { window.closeUploadModal(); });
    modal.addEventListener('click', function(e) { if (e.target === modal) window.closeUploadModal(); });

    submitBtn.addEventListener('click', async function() {
      if (!_uploadFile) return;
      submitBtn.disabled = true; submitBtn.textContent = 'Uploading...';
      errEl.style.display = 'none'; msgEl.style.display = 'none';
      try {
        var fd = new FormData();
        fd.append('file', _uploadFile);
        fd.append('owner_type', 'company');
        fd.append('owner_id', companyId);
        fd.append('year', yearSel.value);
        fd.append('doc_type', document.getElementById('upload-doc-type').value);
        fd.append('folder_category', document.getElementById('upload-doc-type').value);
        fd.append('folder_section', document.getElementById('upload-section').value);
        var res = await fetch('/api/documents/upload', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token }, body: fd });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');
        msgEl.textContent = 'Uploaded!'; msgEl.style.display = 'block';
        var el = document.getElementById('docs-content');
        delete el.dataset.loaded; loadDocs();
        setTimeout(function() { window.closeUploadModal(); toast('Document uploaded'); }, 1000);
      } catch(e2) {
        errEl.textContent = e2.message; errEl.style.display = 'block';
        submitBtn.disabled = false; submitBtn.textContent = 'Upload';
      }
    });

    window.openUploadModal = function(preloadFile) {
      _uploadFile = null;
      document.getElementById('upload-selected-name').textContent = '';
      submitBtn.disabled = true; submitBtn.textContent = 'Upload';
      errEl.style.display = 'none'; msgEl.style.display = 'none';
      modal.classList.add('open');
      if (preloadFile) setFile(preloadFile);
    };
    window.closeUploadModal = function() { modal.classList.remove('open'); };
  })();

  async function downloadDoc(id) {
    try {
      const res = await apiFetch(`/api/documents/${id}/url`);
      const data = await res.json();
      if (data.url) window.open(data.url, '_blank');
    } catch(e) { toast('Failed to get download link', 'error'); }
  }

  async function loadTax() {
    const el = document.getElementById('tax-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="empty-state">No tax returns on file.</div>';
  }

  // ── TAX DELIVERIES ────────────────────────────────────────────────────────

  async function loadTax() {
    const el = document.getElementById('tax-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/tax-deliveries?company_id=${companyId}`);
      const deliveries = await res.json();
      renderTaxDeliveries(deliveries);
    } catch(e) { el.innerHTML = '<div class="empty-state" style="padding:2rem;text-align:center;color:var(--muted);">Failed to load.</div>'; }
  }

  function statusPill(status) {
    return `<span class="status-pill status-${status}">${(status||'draft').replace(/_/g,' ')}</span>`;
  }

  function renderTaxDeliveries(deliveries) {
    const el = document.getElementById('tax-content');
    if (!deliveries.length) {
      el.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--muted);">
        <div style="font-size:2.5rem;margin-bottom:1rem;">📄</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:0.5rem;">No tax deliveries yet</div>
        <div style="font-size:0.84rem;margin-bottom:1.5rem;">Create a delivery to send the tax return for review and e-signature</div>
        <button class="btn btn-gold" onclick="openNewDeliveryModal()">+ New Delivery</button>
      </div>`;
      return;
    }
    el.innerHTML = deliveries.map(d => {
      const signers = d.signers || [];
      const signerChips = signers.map(s => {
        const name = esc(s.person_name || ('Person #' + s.person_id));
        if (s.signed_at) return '<span class="signer-chip signed">✓ ' + name + '</span>';
        if (s.needs_changes_at) return '<span class="signer-chip needs-changes">↩ ' + name + '</span>';
        return '<span class="signer-chip pending">⏳ ' + name + '</span>';
      }).join('');
      return '<div class="delivery-card">' +
        '<div class="delivery-info">' +
          '<div class="delivery-title">' + esc(d.title || d.tax_year + ' Tax Return') + ' ' + statusPill(d.status) + '</div>' +
          '<div class="delivery-meta">Tax Year: ' + esc(d.tax_year) + ' · Created ' + new Date(d.created_at).toLocaleDateString() + '</div>' +
          (signerChips ? '<div class="delivery-signers">' + signerChips + '</div>' : '') +
        '</div>' +
        '<div class="delivery-actions">' +
          (d.status === 'draft' ? '<button class="btn btn-gold btn-sm" onclick="sendDelivery(' + d.id + ')">Send →</button>' : '') +
          (d.status === 'draft' ? '<button class="btn btn-outline btn-sm" onclick="deleteDelivery(' + d.id + ')">Delete</button>' : '') +
          (d.status === 'complete' ? '<button class="btn btn-outline btn-sm" onclick="downloadSigned(' + d.id + ')">⬇ Signed</button>' : '') +
        '</div>' +
      '</div>';
    }).join('');
  }

  async function openNewDeliveryModal() {
    const docsRes = await apiFetch('/api/documents?owner_type=company&owner_id=' + companyId);
    const docs = await docsRes.json();
    const pdfDocs = docs.filter(d => d.mime_type && d.mime_type.includes('pdf'));
    const opts = '<option value="">— None —</option>' + pdfDocs.map(d => '<option value="' + d.id + '">' + esc(d.display_name || 'Untitled') + ' (' + (d.year || '') + ')</option>').join('');
    document.getElementById('nd-review-doc').innerHTML = opts;
    document.getElementById('nd-sig-doc').innerHTML = opts;
    const people = (companyData && companyData.people) || [];
    document.getElementById('nd-signers-list').innerHTML = people.length
      ? people.map(p => '<label style="display:flex;align-items:center;gap:0.5rem;font-size:0.84rem;cursor:pointer;"><input type="checkbox" name="nd-signer" value="' + p.person_id + '" checked> ' + esc(p.first_name) + ' ' + esc(p.last_name) + (p.email ? ' <span style="color:var(--muted);font-size:0.75rem;">(' + esc(p.email) + ')</span>' : '') + '</label>').join('')
      : '<div style="color:var(--muted);font-size:0.82rem;">No people attached to this company.</div>';
    document.getElementById('nd-year').value = String(new Date().getFullYear() - 1);
    document.getElementById('delivery-error').style.display = 'none';
    document.getElementById('new-delivery-modal').classList.add('open');
  }

  function closeDeliveryModal() { document.getElementById('new-delivery-modal').classList.remove('open'); }

  async function submitNewDelivery() {
    const year = document.getElementById('nd-year').value.trim();
    if (!year) { document.getElementById('delivery-error').textContent = 'Tax year is required'; document.getElementById('delivery-error').style.display = ''; return; }
    const signerIds = Array.from(document.querySelectorAll('input[name="nd-signer"]:checked')).map(i => parseInt(i.value));
    const body = {
      company_id: parseInt(companyId),
      tax_year: year,
      title: document.getElementById('nd-title').value.trim(),
      intro_note: document.getElementById('nd-intro').value.trim(),
      review_doc_id: document.getElementById('nd-review-doc').value ? parseInt(document.getElementById('nd-review-doc').value) : null,
      signature_doc_id: document.getElementById('nd-sig-doc').value ? parseInt(document.getElementById('nd-sig-doc').value) : null,
      signer_person_ids: signerIds,
    };
    try {
      const res = await apiFetch('/api/tax-deliveries', { method: 'POST', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      closeDeliveryModal();
      toast('Delivery created');
      const el = document.getElementById('tax-content');
      delete el.dataset.loaded;
      loadTax();
    } catch(e) { document.getElementById('delivery-error').textContent = e.message; document.getElementById('delivery-error').style.display = ''; }
  }

  async function sendDelivery(id) {
    if (!confirm('Send this tax return to the client for review and signature?')) return;
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/send', { method: 'POST', body: '{}' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Delivery sent to client');
      const el = document.getElementById('tax-content');
      delete el.dataset.loaded;
      loadTax();
    } catch(e) { toast(e.message, 'error'); }
  }

  async function deleteDelivery(id) {
    if (!confirm('Delete this draft delivery?')) return;
    try {
      await apiFetch('/api/tax-deliveries/' + id, { method: 'DELETE' });
      toast('Deleted');
      const el = document.getElementById('tax-content');
      delete el.dataset.loaded;
      loadTax();
    } catch(e) { toast(e.message, 'error'); }
  }

  async function downloadSigned(id) {
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/download-signature');
      const d = await res.json();
      if (d.url) window.open(d.url, '_blank');
    } catch(e) { toast('Failed to download', 'error'); }
  }

  async function autoSaveNotes(val, force) {
    if (!companyData) return;
    try {
      await apiFetch(`/api/companies/${companyId}`, { method: 'PUT', body: JSON.stringify({ notes: val }) });
      const ind = document.getElementById('notes-saved') || document.getElementById('notes-saved-full');
      if (ind) { ind.textContent = 'Saved'; setTimeout(() => { ind.textContent = ''; }, 2000); }
    } catch(e) {}
  }

  function openEditModal() {
    if (!companyData) return;
    document.getElementById('ef-name').value = companyData.company_name || '';
    document.getElementById('ef-entity-type').value = companyData.entity_type || '';
    document.getElementById('ef-tax-year-end').value = companyData.tax_year_end || '';
    document.getElementById('ef-stanford').value = companyData.stanford_tax_url || '';
    document.getElementById('ef-status').value = companyData.status || 'active';
    document.getElementById('edit-modal').classList.add('open');
  }
  function closeModal() { document.getElementById('edit-modal').classList.remove('open'); }

  async function submitEdit() {
    const body = {
      company_name: document.getElementById('ef-name').value.trim(),
      entity_type: document.getElementById('ef-entity-type').value,
      tax_year_end: document.getElementById('ef-tax-year-end').value.trim(),
      stanford_tax_url: document.getElementById('ef-stanford').value.trim(),
      status: document.getElementById('ef-status').value,
    };
    try {
      const res = await apiFetch(`/api/companies/${companyId}`, { method: 'PUT', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error||'Failed'); }
      closeModal();
      toast('Company updated');
      await loadCompany();
    } catch(e) { document.getElementById('edit-error').textContent = e.message; document.getElementById('edit-error').style.display = ''; }
  }

  async function detachPerson(personId) {
    if (!confirm('Remove this person from the company?')) return;
    try {
      await apiFetch(`/api/companies/${companyId}/people/${personId}`, { method: 'DELETE' });
      toast('Person removed');
      await loadCompany();
    } catch(e) { toast('Failed to remove', 'error'); }
  }

  async function openAttachPersonModal() {
    if (!companyData) return;
    const relId = companyData.relationship_id;
    if (!relId) { toast('Company has no relationship assigned', 'error'); return; }
    try {
      const res = await apiFetch(`/api/relationships/${relId}/people`);
      const people = await res.json();
      const existing = (companyData.people || []).map(p => p.person_id);
      const available = people.filter(p => !existing.includes(p.id));
      if (!available.length) { toast('All people already attached', 'error'); return; }
      const opts = available.map(p => `<option value="${p.id}">${esc((p.first_name||'')+' '+(p.last_name||''))}</option>`).join('');
      const modal = document.createElement('div');
      modal.className = 'modal-overlay open';
      modal.innerHTML = `<div class="modal" onclick="event.stopPropagation()" style="max-width:380px;">
        <h2>Attach Person</h2>
        <div class="form-group"><label>Person</label><select class="form-control" id="ap-person">${opts}</select></div>
        <div class="form-group"><label>Access Level</label>
          <select class="form-control" id="ap-access"><option value="view">View</option><option value="full">Full</option><option value="sign">Sign</option></select>
        </div>
        <div class="modal-actions">
          <button class="btn btn-outline" onclick="this.closest('.modal-overlay').remove()">Cancel</button>
          <button class="btn btn-gold" onclick="submitAttachPerson(this)">Attach</button>
        </div>
      </div>`;
      document.body.appendChild(modal);
    } catch(e) { toast('Failed to load people', 'error'); }
  }

  async function submitAttachPerson(btn) {
    const modal = btn.closest('.modal-overlay');
    const personId = document.getElementById('ap-person').value;
    const access = document.getElementById('ap-access').value;
    try {
      const res = await apiFetch(`/api/companies/${companyId}/people`, { method: 'POST', body: JSON.stringify({ person_id: parseInt(personId), access_level: access }) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error||'Failed'); }
      modal.remove();
      toast('Person attached');
      await loadCompany();
    } catch(e) { toast(e.message, 'error'); }
  }

  // ── Page-wide drag-and-drop (opens upload modal when Docs tab active) ──
  (function() {
    let dragCounter = 0;
    const dragOverlay = document.createElement('div');
    dragOverlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(201,168,76,0.08);border:3px dashed var(--gold);pointer-events:none;align-items:center;justify-content:center;font-size:1.5rem;color:var(--gold);font-weight:700;';
    dragOverlay.textContent = '📄 Drop to upload document';
    document.body.appendChild(dragOverlay);

    function isDocsTabActive() {
      const t = document.getElementById('tab-docs');
      return t && t.classList.contains('active');
    }

    document.addEventListener('dragenter', function(e) {
      if (!isDocsTabActive()) return;
      dragCounter++;
      dragOverlay.style.display = 'flex';
    });
    document.addEventListener('dragleave', function(e) {
      if (!isDocsTabActive()) return;
      dragCounter--;
      if (dragCounter <= 0) { dragCounter = 0; dragOverlay.style.display = 'none'; }
    });
    document.addEventListener('dragover', function(e) {
      if (!isDocsTabActive()) return;
      e.preventDefault();
    });
    document.addEventListener('drop', function(e) {
      if (!isDocsTabActive()) return;
      e.preventDefault();
      dragCounter = 0;
      dragOverlay.style.display = 'none';
      const file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (!file) return;
      window.openUploadModal(file);
    });
  })();

  loadCompany();
</script>

