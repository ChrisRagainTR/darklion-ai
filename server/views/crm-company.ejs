      <span>Recent Messages</span>
      <a href="#" onclick="switchTab('communication',document.querySelector('[onclick*=\\'communication\\']'));return false;" style="font-size:0.72rem;color:var(--gold);">View all →</a>
    </div><div id="ov-msgs-inner" style="color:var(--muted);font-size:0.82rem;">Loading…</div>`;
    apiFetch(`/api/messages/company/${companyId}`).then(r=>r.json()).then(threads=>{
      const el = document.getElementById('ov-msgs-inner');
      if (!el) return;
      if (!threads.length) { el.innerHTML=`<div style="color:var(--muted);font-size:0.82rem;font-style:italic;">No messages yet.</div>`; return; }
      const last3 = threads.slice(0,3);
      function relTime(ts) { if(!ts) return ''; const d=new Date(ts); const diff=Date.now()-d; if(diff<60000) return 'just now'; if(diff<3600000) return Math.floor(diff/60000)+'m ago'; if(diff<86400000) return Math.floor(diff/3600000)+'h ago'; return d.toLocaleDateString(); }
      el.innerHTML = last3.map(t => {
        const personName = t.person ? ((t.person.firstName||'')+' '+(t.person.lastName||'')).trim() : '';
        return `<div style="padding:0.4rem 0;border-bottom:1px solid rgba(255,255,255,0.04);cursor:pointer;" onclick="switchTab('communication',document.querySelector('[onclick*=\\'communication\\']'));setTimeout(()=>loadCoThread(${t.id}),200);">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
