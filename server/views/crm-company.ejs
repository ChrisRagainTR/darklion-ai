                        <button class="btn btn-ghost btn-xs" style="color:var(--red)" onclick="deleteDoc(${f.id},event)" title="Delete">🗑</button>
                      </div>
                    </div>`).join('')}</div>
                          </div>`;
                        }).join('');
                      })()
                    : files.map(f => `<div class="doc-row" data-docid="${f.id}">
                      ${docTypeBadge(f.mime_type, f.display_name)}
                      <div class="doc-info">
                        <div class="doc-name doc-name-link" data-docid="${f.id}" style="cursor:pointer;text-decoration:underline;text-underline-offset:2px;">${esc((f.display_name||'Untitled').replace(/_/g,' ').trim())}</div>
                        <div class="doc-badges">
                          ${statusBadge}
                          ${f.size_bytes ? `<span class="doc-badge doc-badge-type">${formatBytes(f.size_bytes)}</span>` : ''}
                          ${f.created_at ? `<span style="font-size:0.67rem;color:var(--muted);opacity:0.7;">${new Date(f.created_at).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit',timeZone:'America/New_York',timeZoneName:'short'})}</span>` : ''}
                        </div>
                        <div id="move-panel-${f.id}" style="display:none;margin-top:0.4rem;padding:0.4rem;background:rgba(201,168,76,0.06);border-radius:5px;">
                          <span style="font-size:0.72rem;color:var(--muted);margin-right:0.3rem;">Move to:</span>
                          <select id="mv-year-${f.id}" style="background:var(--charcoal);border:1px solid var(--border);color:var(--text);padding:0.2rem 0.4rem;border-radius:4px;font-size:0.75rem;margin-right:0.3rem;">
                            ${(() => { const yr = new Date().getFullYear(); let opts = ''; for(let y2=yr;y2>=2018;y2--) opts+=`<option value="${y2}"${String(f.year||'')==String(y2)?' selected':''}>${y2}</option>`; return opts; })()}
                          </select>
                          <select id="mv-sec-${f.id}" style="background:var(--charcoal);border:1px solid var(--border);color:var(--text);padding:0.2rem 0.4rem;border-radius:4px;font-size:0.75rem;margin-right:0.3rem;">
                            <option value="firm_uploaded"${(f.folder_section||'firm_uploaded')==='firm_uploaded'?' selected':''}>Advisor</option>
                            <option value="client_uploaded"${f.folder_section==='client_uploaded'?' selected':''}>Client</option>
                          </select>
                          <select id="mv-cat-${f.id}" style="background:var(--charcoal);border:1px solid var(--border);color:var(--text);padding:0.2rem 0.4rem;border-radius:4px;font-size:0.75rem;margin-right:0.3rem;">
                            <option value="tax"${(f.folder_category||'tax')==='tax'?' selected':''}>Tax</option>
                            <option value="other"${(f.folder_category||'tax')==='other'?' selected':''}>Other</option>
                          </select>
                          <button onclick="saveDocMove(${f.id})" style="background:var(--gold);color:var(--navy);border:none;border-radius:4px;padding:0.2rem 0.55rem;font-size:0.75rem;font-weight:700;cursor:pointer;">Save</button>
                          <button onclick="document.getElementById('move-panel-${f.id}').style.display='none'" style="background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:4px;padding:0.2rem 0.45rem;font-size:0.75rem;cursor:pointer;margin-left:0.2rem;">✕</button>
                        </div>
                      </div>
                      <div style="display:flex;gap:0.4rem;flex-shrink:0;align-items:center;">
                        <button class="btn-dl" data-docid="${f.id}">⬇</button>
                        <button class="btn btn-ghost btn-xs" onclick="event.stopPropagation();var p=document.getElementById('move-panel-${f.id}');p.style.display=p.style.display==='none'?'block':'none'" title="Move">↕</button>
                        <button class="btn btn-ghost btn-xs" style="color:var(--red)" onclick="deleteDoc(${f.id},event)" title="Delete">🗑</button>
                      </div>
                    </div>`).join('')}
              </div>
            </div>`;  // close cat-folder
          }).join('')}
        </div>
      </div>`;
    }

    // Show recent 2 years open, rest collapsed, all years always shown
    const _recentYrs = allYears.slice(0, 2);
    const _priorYrs = allYears.slice(2);
    const _priorCount = _priorYrs.reduce((n,y) => n + sectionDocs.filter(d => (d.year||String(CURRENT_YEAR)) === y).length, 0);
    let html = `<div class="docs-col-title">${icon} ${title} <span style="font-size:0.75rem;font-weight:400;color:var(--muted);">(${sectionDocs.length})</span></div>`;
    _recentYrs.forEach(y => { html += renderOneYear(y, true); });
    html += `<div class="year-folder" style="margin-bottom:0.4rem;">
      <div class="year-header">
        <span class="yr-label">📂 Prior Years <span class="yr-count">${_priorCount}</span></span>
        <span class="yr-chevron">▼</span>
      </div>
      <div class="year-body" style="padding-left:0.5rem;">
        ${_priorYrs.map(y => renderOneYear(y, false)).join('')}
      </div>
    </div>`;
    return html;
  }

  let docsData = [];

  async function loadDocs() {
    const el = document.getElementById('docs-content');
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/documents?owner_type=company&owner_id=${companyId}`);
      docsData = await res.json();
      renderDocs();
    } catch(e) { el.innerHTML = '<div class="empty-state">Failed to load documents.</div>'; }
  }

  function renderDocs() {
    const el = document.getElementById('docs-content');
    const firmDocs = docsData.filter(d => (d.folder_section || 'firm_uploaded') === 'firm_uploaded');
    const clientDocs = docsData.filter(d => d.folder_section === 'client_uploaded');
    el.innerHTML = `<div class="docs-layout">
      <div>${buildDocsColumn(firmDocs, 'Delivered by Advisor', '📁', DOC_CATS_FIRM)}</div>
      <div>${buildDocsColumn(clientDocs, 'Uploaded by Client', '📤', DOC_CATS_CLIENT)}</div>
    </div>`;
    // Wire year folder toggles — event delegation so BK account sub-folders work
    el.addEventListener('click', e => {
      const hdr = e.target.closest('.year-header');
      if (hdr && el.contains(hdr)) {
        e.stopPropagation();
        hdr.closest('.year-folder').classList.toggle('open');
      }
    });
    // Wire doc name click to open
    el.querySelectorAll('.doc-name-link').forEach(nameEl => {
      nameEl.addEventListener('click', e => {
        e.stopPropagation();
        downloadDoc(parseInt(nameEl.dataset.docid));
      });
    });
    // Wire download buttons
    el.querySelectorAll('.btn-dl').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        downloadDoc(parseInt(btn.dataset.docid), btn);
      });
    });
  }


  // ── Tax Financials (Send to Tax Prep) ──
  (function() {
    var tfModal = document.getElementById('tax-financials-modal');
    var tfYear  = document.getElementById('tf-year');
    var tfBtn   = document.getElementById('tf-submit-btn');
    var tfErr   = document.getElementById('tf-error');
    var tfOk    = document.getElementById('tf-success');
    if (!tfModal || !tfYear) return;

    // Populate year dropdown
    var CY = new Date().getFullYear();
    for (var y = CY - 1; y >= 2020; y--) {
      var o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      if (y === CY - 1) o.selected = true;
      tfYear.appendChild(o);
    }

    window.openTaxFinancialsModal = function() {
      tfErr.style.display = 'none'; tfOk.style.display = 'none';
      tfBtn.disabled = false; tfBtn.textContent = 'Generate & Save';
      tfModal.classList.add('open');
    };
    window.closeTaxFinancialsModal = function() { tfModal.classList.remove('open'); };

    window.submitTaxFinancials = async function() {
      tfErr.style.display = 'none'; tfOk.style.display = 'none';
      tfBtn.disabled = true; tfBtn.textContent = 'Generating…';
      try {
        // Need realmId — get from bookkeepingRealm or company data
        var realm = bookkeepingRealm || companyData.realm_id;
        if (!realm) { tfErr.textContent = 'No QuickBooks connection found for this company.'; tfErr.style.display = ''; tfBtn.disabled = false; tfBtn.textContent = 'Generate & Save'; return; }
        var res = await apiFetch('/api/companies/' + realm + '/tax-financials', {
          method: 'POST',
          body: JSON.stringify({ year: parseInt(tfYear.value) })
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to generate');
        tfOk.textContent = '✓ Saved to Docs → Tax folder';
        tfOk.style.display = '';
        tfBtn.textContent = 'Done';
        // Close modal, switch to docs tab, force-refresh list
        setTimeout(function() {
          closeTaxFinancialsModal();
          // Clear the loaded cache so loadDocs re-fetches
          var docsEl = document.getElementById('docs-content');
          if (docsEl) delete docsEl.dataset.loaded;
          // Switch to docs tab
          var docsTab = document.querySelector('.tab-item[onclick*="docs"]');
          if (docsTab) docsTab.click();
          else loadDocs();
        }, 1500);
      } catch(e) {
        tfErr.textContent = e.message;
        tfErr.style.display = '';
        tfBtn.disabled = false; tfBtn.textContent = 'Generate & Save';
      }
    };
  })();

  // ── Upload modal wiring (portal-matched) ──
  (function() {
    var modal    = document.getElementById('upload-modal');
    var yearSel  = document.getElementById('upload-year');
    var fileDrop = document.getElementById('upload-file-drop');
    var fileInput= document.getElementById('upload-file-input');
    var submitBtn= document.getElementById('upload-submit-btn');
    var cancelBtn= document.getElementById('upload-cancel-btn');
    var errEl    = document.getElementById('upload-error');
    var msgEl    = document.getElementById('upload-msg');
    if (!modal) return;

    var _uploadFile = null;
    var CY = new Date().getFullYear();
    for (var y = CY; y >= 2018; y--) {
      var o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      if (y === CY - 1) o.selected = true;
      yearSel.appendChild(o);
    }

    function setFile(f) {
      _uploadFile = f;
      document.getElementById('upload-selected-name').textContent = f.name;
      submitBtn.disabled = false;
    }

    fileDrop.addEventListener('click', function() { fileInput.click(); });
    fileDrop.addEventListener('dragover', function(e) { e.preventDefault(); fileDrop.classList.add('drag-over'); });
    fileDrop.addEventListener('dragleave', function() { fileDrop.classList.remove('drag-over'); });
    fileDrop.addEventListener('drop', function(e) { e.preventDefault(); fileDrop.classList.remove('drag-over'); if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files[0]) setFile(fileInput.files[0]); });
    cancelBtn.addEventListener('click', function() { window.closeUploadModal(); });
    modal.addEventListener('click', function(e) { if (e.target === modal) window.closeUploadModal(); });

    submitBtn.addEventListener('click', async function() {
      if (!_uploadFile) return;
      submitBtn.disabled = true; submitBtn.textContent = 'Uploading...';
      errEl.style.display = 'none'; msgEl.style.display = 'none';
      try {
        var fd = new FormData();
        fd.append('file', _uploadFile);
        fd.append('owner_type', 'company');
        fd.append('owner_id', companyId);
        fd.append('year', yearSel.value);
        fd.append('doc_type', document.getElementById('upload-doc-type').value);
        fd.append('folder_category', document.getElementById('upload-doc-type').value);
        fd.append('folder_section', document.getElementById('upload-section').value);
        var res = await fetch('/api/documents/upload', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token }, body: fd });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Upload failed');
        msgEl.textContent = 'Uploaded!'; msgEl.style.display = 'block';
        var el = document.getElementById('docs-content');
        delete el.dataset.loaded; loadDocs();
        setTimeout(function() { window.closeUploadModal(); toast('Document uploaded'); }, 1000);
      } catch(e2) {
        errEl.textContent = e2.message; errEl.style.display = 'block';
        submitBtn.disabled = false; submitBtn.textContent = 'Upload';
      }
    });

    window.openUploadModal = function(preloadFile) {
      _uploadFile = null;
      document.getElementById('upload-selected-name').textContent = '';
      submitBtn.disabled = true; submitBtn.textContent = 'Upload';
      errEl.style.display = 'none'; msgEl.style.display = 'none';
      modal.classList.add('open');
      if (preloadFile) setFile(preloadFile);
    };
    window.closeUploadModal = function() { modal.classList.remove('open'); };
  })();

  async function downloadDoc(id, btn) {
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    try {
      const res = await apiFetch(`/api/documents/${id}/url`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      if (data.url) window.open(data.url, '_blank');
    } catch(e) { toast('Download failed: ' + e.message, 'error'); }
    if (btn) { btn.disabled = false; btn.textContent = '⬇'; }
  }

  function reloadDocs() {
    const el = document.getElementById('docs-content');
    if (el) delete el.dataset.loaded;
    loadDocs();
  }

  async function deleteDoc(id, e) {
    if (e) e.stopPropagation();
    if (!await window.dlConfirm('Delete this document? This cannot be undone.', {title:'Delete Document', confirmLabel:'Delete', danger:true, icon:'🗑️'})) return;
    try {
      const res = await apiFetch(`/api/documents/${id}`, { method: 'DELETE' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Document deleted');
      reloadDocs();
    } catch(e) { toast(e.message, 'error'); }
  }

  let _moveDocId = null;
  function openMoveDocModal(id, currentSection, currentCategory, e, currentYear) {
    if (e) e.stopPropagation();
    _moveDocId = id;
    const modal = document.getElementById('move-doc-modal');
    if (!modal) { console.error('move-doc-modal not found in DOM'); return; }
    const yearEl    = document.getElementById('move-doc-year');
    const sectionEl = document.getElementById('move-doc-section');
    const catEl     = document.getElementById('move-doc-category');
    if (!yearEl || !sectionEl || !catEl) { console.error('move-doc-modal fields missing'); return; }
    yearEl.value    = currentYear    || String(new Date().getFullYear() - 1);
    sectionEl.value = currentSection || 'firm_uploaded';
    catEl.value     = currentCategory || 'tax';
    modal.style.display = 'flex'; // force-show regardless of class
    modal.classList.add('open');
  }
  function closeMoveDocModal() {
    const modal = document.getElementById('move-doc-modal');
    if (modal) { modal.classList.remove('open'); modal.style.display = ''; }
    _moveDocId = null;
  }
  function closeMoveDocModal() {
    const modal = document.getElementById('move-doc-modal');
    if (modal) modal.classList.remove('open');
    _moveDocId = null;
  }
  async function saveDocMove(id) {
    const year    = document.getElementById(`mv-year-${id}`).value;
    const section = document.getElementById(`mv-sec-${id}`).value;
    const category = document.getElementById(`mv-cat-${id}`).value;
    try {
      const res = await apiFetch(`/api/documents/${id}`, { method: 'PUT', body: JSON.stringify({ year, folder_section: section, folder_category: category }) });
      if (!res.ok) { const d = await res.json().catch(()=>({})); throw new Error(d.error || 'Error ' + res.status); }
      const doc = docsData.find(d => d.id === id);
      if (doc) { doc.year = year; doc.folder_section = section; doc.folder_category = category; }
      toast('Document moved');
      document.getElementById(`move-panel-${id}`).style.display = 'none';
      reloadDocs();
    } catch(e) { toast('Move failed: ' + e.message, 'error'); }
  }

  async function submitMoveDoc() {
    if (!_moveDocId) return;
    const year = document.getElementById('move-doc-year').value;
    const section = document.getElementById('move-doc-section').value;
    const category = document.getElementById('move-doc-category').value;
    try {
      const res = await apiFetch(`/api/documents/${_moveDocId}`, { method: 'PUT', body: JSON.stringify({ year, folder_section: section, folder_category: category }) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Document moved');
      closeMoveDocModal();
      reloadDocs();
    } catch(e) { toast(e.message, 'error'); }
  }

  // ── TAX DELIVERIES ────────────────────────────────────────────────────────

  async function loadTax(force) {
    const el = document.getElementById('tax-content');
    if (el.dataset.loaded && !force) return;
    el.dataset.loaded = '1';
    el.innerHTML = '<div class="loading-state"><div class="loading-spinner"></div><div>Loading…</div></div>';
    try {
      const res = await apiFetch(`/api/tax-deliveries?company_id=${companyId}`);
      const deliveries = await res.json();
      renderTaxDeliveries(deliveries);
    } catch(e) { el.innerHTML = '<div class="empty-state" style="padding:2rem;text-align:center;color:var(--muted);">Failed to load.</div>'; }
  }

  function statusPill(status) {
    return `<span class="status-pill status-${status}">${(status||'draft').replace(/_/g,' ')}</span>`;
  }

  function renderTaxDeliveries(deliveries) {
    const el = document.getElementById('tax-content');
    if (!deliveries.length) {
      el.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--muted);">
        <div style="font-size:2.5rem;margin-bottom:1rem;">📄</div>
        <div style="font-weight:700;color:var(--text);margin-bottom:0.5rem;">No tax deliveries yet</div>
        <div style="font-size:0.84rem;margin-bottom:1.5rem;">Create a delivery to send the tax return for review and e-signature</div>
        <button class="btn btn-gold" onclick="openNewDeliveryModal()">+ New Delivery</button>
      </div>`;
      return;
    }
    el.innerHTML = deliveries.map(d => {
      const signers = d.signers || [];
      const signerChips = signers.map(s => {
        const name = esc(s.person_name || ('Person #' + s.person_id));
        if (s.signed_at) return '<span class="signer-chip signed">✓ ' + name + '</span>';
        if (s.needs_changes_at) return '<span class="signer-chip needs-changes">↩ ' + name + '</span>';
        return '<span class="signer-chip pending">⏳ ' + name + '</span>';
      }).join('');
      const signedDocLinks = signers.filter(s => s.signed_doc_id).map(s =>
        '<button class="btn btn-outline btn-sm" onclick="downloadDeliveryDoc(' + s.signed_doc_id + ')" title="Signed by ' + esc(s.person_name) + '">⬇ Signed (' + esc((s.person_name||'').split(' ')[0]) + ')</button>'
      ).join('');
      const reviewDocLink = d.review_doc_id && d.status !== 'draft'
        ? '<button class="btn btn-outline btn-sm" onclick="downloadDeliveryDoc(' + d.review_doc_id + ')">📄 Review Copy</button>'
        : '';
      return '<div class="delivery-card" style="flex-direction:column;">' +
        '<div style="display:flex;align-items:flex-start;gap:1rem;flex-wrap:wrap;">' +
          '<div class="delivery-info">' +
            '<div class="delivery-title">' + esc(d.title || d.tax_year + ' Tax Return') + ' ' + statusPill(d.status) + '</div>' +
            '<div class="delivery-meta">Tax Year: ' + esc(d.tax_year) + ' · Created ' + new Date(d.created_at).toLocaleDateString() + '</div>' +
            (signerChips ? '<div class="delivery-signers">' + signerChips + '</div>' : '') +
          '</div>' +
          '<div class="delivery-actions">' +
            (d.status === 'draft' ? '<button class="btn btn-gold btn-sm" onclick="sendDelivery(' + d.id + ')">Send →</button>' : '') +
            (d.status === 'draft' ? '<button class="btn btn-outline btn-sm" onclick="deleteDelivery(' + d.id + ')">Delete</button>' : '') +
            (['sent','approved','needs_changes'].includes(d.status) ? '<button class="btn btn-outline btn-sm" onclick="cancelDelivery(' + d.id + ')" style="color:var(--orange);border-color:var(--orange);">↩ Cancel & Revise</button>' : '') +
            '' +
          '</div>' +
        '</div>' +
        ((signedDocLinks || reviewDocLink) ? '<div style="display:flex;gap:0.5rem;flex-wrap:wrap;padding-top:0.75rem;margin-top:0.75rem;border-top:1px solid var(--border);">' + reviewDocLink + signedDocLinks + '</div>' : '') +
      '</div>';
    }).join('');
  }

    let _ndAllDocs = [];
  async function openNewDeliveryModal() {
    // Populate year dropdown
    const yearSel = document.getElementById('nd-year');
    const cy = new Date().getFullYear();
    yearSel.innerHTML = '';
    for (let y = cy - 1; y >= cy - 6; y--) {
      const o = document.createElement('option');
      o.value = String(y); o.textContent = String(y);
      yearSel.appendChild(o);
    }
    yearSel.value = String(cy - 1);
    document.getElementById('nd-title').value = String(cy - 1) + ' Tax Return Delivery';
    const introEl = document.getElementById('nd-intro');
    if (introEl && !introEl.value) {
      const coName = (companyData && companyData.company_name) || 'your company';
      introEl.value = 'Dear Client,\n\nThe ' + String(cy - 1) + ' tax return for ' + coName + ' has been prepared and is ready for your review. Please take a moment to carefully review all information for accuracy.\n\nOnce you have reviewed the return, you will have the opportunity to either approve it and provide your electronic signature, or request changes if anything needs to be corrected.\n\nIf you have any questions prior to signing, please don\'t hesitate to reach out to our office directly.\n\nThank you for trusting Sentinel Wealth & Tax with your tax preparation.';
    }

    // Load all company docs
    try {
      const docsRes = await apiFetch('/api/documents?owner_type=company&owner_id=' + companyId);
      _ndAllDocs = await docsRes.json();
    } catch(e) { _ndAllDocs = []; }
    ndFilterDocsByYear();

    const people = (companyData && companyData.people) || [];
    document.getElementById('nd-signers-list').innerHTML = people.length
      ? people.map(p => '<label style="display:flex;align-items:center;gap:0.5rem;font-size:0.84rem;cursor:pointer;"><input type="checkbox" name="nd-signer" value="' + p.person_id + '" checked> ' + esc(p.first_name) + ' ' + esc(p.last_name) + (p.email ? ' <span style="color:var(--muted);font-size:0.75rem;">(' + esc(p.email) + ')</span>' : '') + '</label>').join('')
      : '<div style="color:var(--muted);font-size:0.82rem;">No people attached to this company.</div>';
    document.getElementById('delivery-error').style.display = 'none';
    document.getElementById('new-delivery-modal').classList.add('open');
  }

  function ndFilterDocsByYear() {
    const year = document.getElementById('nd-year').value;
    const filtered = _ndAllDocs.filter(d =>
      (d.year || '') === year &&
      (d.folder_section === 'firm_uploaded' || !d.folder_section) &&
      (d.folder_category === 'tax') &&
      d.mime_type && d.mime_type.includes('pdf')
    );
    // Also include PDFs from firm_uploaded tax folder without year filter if none found
    const opts = '<option value="">— None —</option>' + filtered.map(d =>
      '<option value="' + d.id + '">' + esc(d.display_name || 'Untitled') + '</option>'
    ).join('');
    const fallbackMsg = filtered.length === 0 ? '<option value="" disabled>No Tax PDFs found for ' + year + '</option>' : '';
    document.getElementById('nd-review-doc').innerHTML = filtered.length ? opts : '<option value="">— No Tax PDFs for ' + year + ' —</option>';
    document.getElementById('nd-sig-doc').innerHTML = filtered.length ? opts : '<option value="">— No Tax PDFs for ' + year + ' —</option>';
  }

  function closeDeliveryModal() { document.getElementById('new-delivery-modal').classList.remove('open'); }

  async function submitNewDelivery() {
    const year = document.getElementById('nd-year').value.trim();
    if (!year) { document.getElementById('delivery-error').textContent = 'Tax year is required'; document.getElementById('delivery-error').style.display = ''; return; }
    const signerIds = Array.from(document.querySelectorAll('input[name="nd-signer"]:checked')).map(i => parseInt(i.value));
    const body = {
      company_id: parseInt(companyId),
      tax_year: year,
      title: document.getElementById('nd-title').value.trim(),
      intro_note: document.getElementById('nd-intro').value.trim(),
      review_doc_id: document.getElementById('nd-review-doc').value ? parseInt(document.getElementById('nd-review-doc').value) : null,
      signature_doc_id: document.getElementById('nd-sig-doc').value ? parseInt(document.getElementById('nd-sig-doc').value) : null,
      signer_person_ids: signerIds,
    };
    try {
      const res = await apiFetch('/api/tax-deliveries', { method: 'POST', body: JSON.stringify(body) });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      closeDeliveryModal();
      toast('Delivery created');
      loadTax(true);
    } catch(e) { document.getElementById('delivery-error').textContent = e.message; document.getElementById('delivery-error').style.display = ''; }
  }

  async function downloadDeliveryDoc(docId) {
    try {
      const res = await apiFetch(`/api/documents/${docId}/download`);
      if (!res.ok) { toast('Failed to get download link', 'error'); return; }
      const { url } = await res.json();
      window.open(url, '_blank');
    } catch(e) { toast(e.message, 'error'); }
  }

  async function cancelDelivery(id) {
    if (!await window.dlConfirm('Cancel this delivery and revert to draft?', {title:'Cancel Delivery', confirmLabel:'Cancel', danger:true, icon:'↩'})) return;
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/cancel', { method: 'POST' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Cancelled — returned to draft');
      loadTax(true);
    } catch(e) { toast(e.message, 'error'); }
  }

  async function sendDelivery(id) {
    // Companies skip the Tax Return Summary — that's for individual returns only
    if (!await window.dlConfirm('Send this tax return to the client for review and e-signature?', {title:'Send Tax Return', confirmLabel:'Send', icon:'📤'})) return;
    try {
      const res = await apiFetch('/api/tax-deliveries/' + id + '/send', { method: 'POST', body: '{}' });
      if (!res.ok) { const d = await res.json(); throw new Error(d.error || 'Failed'); }
      toast('Delivery sent to client');
      const el = document.getElementById('tax-content');
      delete el.dataset.loaded;
      loadTax();
    } catch(e) { toast(e.message, 'error'); }
  }

  // ── Tax Summary Modal ──
  let _tsmPendingDeliveryId = null;
  let _tsmPollTimer = null;

  function openTaxSummary(deliveryId, opts) {
    const sendAfter = opts && opts.sendAfter;
    _tsmPendingDeliveryId = deliveryId;
    const modal = document.getElementById('tax-summary-modal');
    const body = document.getElementById('tsm-body');
    const footer = document.getElementById('tsm-footer');
    const sendBtn = document.getElementById('tsm-send-btn');
    modal.classList.add('open');
    body.innerHTML = '<div class="tsm-processing"><div class="tsm-spinner"></div><div>Loading summary…</div></div>';
    footer.style.display = 'none';
    if (sendAfter) sendBtn.style.display = ''; else sendBtn.style.display = 'none';

    apiFetch('/api/tax-deliveries/' + deliveryId + '/summary').then(function(r) { return r.json(); }).then(function(s) {
      if (s.status === 'completed' && s.data) {
        renderTaxSummary(s.data);
        footer.style.display = '';
      } else if (s.status === 'processing') {
        showSummaryProcessing();
        pollSummary(deliveryId);
      } else {
        apiFetch('/api/tax-deliveries/' + deliveryId + '/generate-summary', { method: 'POST' })
          .then(function() { showSummaryProcessing(); pollSummary(deliveryId); })
          .catch(function(e) { showSummaryError(e.message); });
      }
    }).catch(function(e) { showSummaryError(e.message); });
  }

  function showSummaryProcessing() {
    document.getElementById('tsm-body').innerHTML = '<div class="tsm-processing"><div class="tsm-spinner"></div><div style="font-weight:600;">Analyzing return with Claude…</div><div style="font-size:0.75rem;opacity:0.6;">This usually takes 30–60 seconds</div></div>';
    document.getElementById('tsm-footer').style.display = 'none';
  }

  function showSummaryError(msg, deliveryId) {
    var retryBtn = deliveryId ? '<button class="btn btn-gold btn-sm" style="margin-top:1rem;" onclick="retrySummary(' + deliveryId + ')">↺ Retry</button>' : '';
    document.getElementById('tsm-body').innerHTML = '<div style="padding:2rem;text-align:center;color:var(--red,#f56565);"><div style="font-size:1.5rem;margin-bottom:0.5rem;">⚠️</div><div style="font-weight:700;">Failed to generate summary</div><div style="font-size:0.8rem;margin-top:0.4rem;color:var(--muted);">' + esc(msg || 'Unknown error') + '</div>' + retryBtn + '</div>';
    document.getElementById('tsm-footer').style.display = '';
  }

  function retrySummary(deliveryId) {
    var sendAfter = document.getElementById('tsm-send-btn') && document.getElementById('tsm-send-btn').style.display !== 'none';
    apiFetch('/api/tax-deliveries/' + deliveryId + '/generate-summary', { method: 'POST' })
      .then(function() { showSummaryProcessing(); pollSummary(deliveryId); })
      .catch(function(e) { showSummaryError(e.message, deliveryId); });
  }

  function pollSummary(deliveryId) {
    if (_tsmPollTimer) clearInterval(_tsmPollTimer);
    _tsmPollTimer = setInterval(function() {
      apiFetch('/api/tax-deliveries/' + deliveryId + '/summary').then(function(r) { return r.json(); }).then(function(s) {
        if (s.status === 'completed' && s.data) {
          clearInterval(_tsmPollTimer);
          renderTaxSummary(s.data);
          document.getElementById('tsm-footer').style.display = '';
        } else if (s.status === 'error') {
          clearInterval(_tsmPollTimer);
          showSummaryError(s.error || 'Claude analysis failed — check Railway logs for details.', deliveryId);
          document.getElementById('tsm-footer').style.display = '';
        }
      }).catch(function() {});
    }, 3000);
  }

  function closeTaxSummary() {
    if (_tsmPollTimer) clearInterval(_tsmPollTimer);
    document.getElementById('tax-summary-modal').classList.add('hidden');
    _tsmPendingDeliveryId = null;
  }

  function confirmAndSendDelivery() {
    if (!_tsmPendingDeliveryId) return;
    var id = _tsmPendingDeliveryId;
    closeTaxSummary();
    apiFetch('/api/tax-deliveries/' + id + '/send', { method: 'POST', body: '{}' }).then(function(res) {
      if (!res.ok) return res.json().then(function(d) { throw new Error(d.error || 'Failed'); });
      toast('Delivery sent to client');
      var el = document.getElementById('tax-content');
      if (el) delete el.dataset.loaded;
      if (typeof loadTax === 'function') loadTax(true);
    }).catch(function(e) { toast(e.message, 'error'); });
  }

  function fmt$(n) {
    if (n === null || n === undefined) return '—';
    var abs = Math.abs(n);
    var formatted = '$' + Math.round(abs).toLocaleString();
    return n < 0 ? '(' + formatted + ')' : formatted;
  }

  function renderTaxSummary(d) {
    var title = document.getElementById('tsm-title');
    var subtitle = document.getElementById('tsm-subtitle');
    if (title) title.textContent = (d.client && d.client.tax_year ? d.client.tax_year + ' ' : '') + 'Tax Return Summary';
    if (subtitle) subtitle.textContent = (d.client ? (d.client.names || '') + ' · ' + (d.client.filing_status || '') : '');

    var refundColor = d.is_refund ? 'var(--green,#3ecf8e)' : 'var(--red,#f56565)';
    var refundLabel = d.is_refund ? 'Refund' : 'Balance Due';

    var html = '<div class="tsm-stat-row">' +
      '<div class="tsm-stat"><div class="tsm-stat-val">' + fmt$(d.total_income) + '</div><div class="tsm-stat-label">Total Income</div></div>' +
      '<div class="tsm-stat"><div class="tsm-stat-val">' + fmt$(d.taxable_income) + '</div><div class="tsm-stat-label">Taxable Income</div></div>' +
      '<div class="tsm-stat"><div class="tsm-stat-val">' + fmt$(d.total_tax) + '</div><div class="tsm-stat-label">Total Federal Tax</div></div>' +
      '<div class="tsm-stat"><div class="tsm-stat-val" style="color:' + refundColor + '">' + fmt$(d.refund_or_owed_amount) + '</div><div class="tsm-stat-label">' + refundLabel + '</div></div>' +
      '</div>';

    // Rate pills
    html += '<div><div class="tsm-section-title">Tax Rates</div><div class="tsm-rate-row">';
    html += '<div class="tsm-rate-pill">Effective Rate: <strong>' + (d.effective_rate || 0) + '%</strong></div>';
    html += '<div class="tsm-rate-pill">Marginal Bracket: <strong>' + (d.marginal_bracket || 0) + '%</strong></div>';
    if (d.key_stats && d.key_stats.capital_loss_carryover) html += '<div class="tsm-rate-pill">Cap Loss C/O: <strong>' + fmt$(d.key_stats.capital_loss_carryover) + '</strong></div>';
    if (d.social_security && d.social_security.percent_taxable) html += '<div class="tsm-rate-pill">SS Taxable: <strong>' + d.social_security.percent_taxable + '%</strong></div>';
    html += '</div></div>';

    // Income sources
    if (d.income_sources && d.income_sources.length) {
      html += '<div><div class="tsm-section-title">📊 Income Breakdown</div><table class="tsm-table"><thead><tr><th>Source</th><th style="text-align:right">Amount</th></tr></thead><tbody>';
      d.income_sources.forEach(function(s) {
        html += '<tr><td>' + esc(s.source) + (s.note ? ' <span style="color:var(--muted);font-size:0.75em">(' + esc(s.note) + ')</span>' : '') + '</td><td>' + fmt$(s.amount) + '</td></tr>';
      });
      html += '<tr><td><strong>Total Income (AGI)</strong></td><td><strong>' + fmt$(d.adjusted_gross_income || d.total_income) + '</strong></td></tr></tbody></table></div>';
    }

    // Tax Computation — two-column layout
    html += '<div><div class="tsm-section-title">🧾 Tax Computation</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">';
    // Left: deductions
    html += '<table class="tsm-table"><tbody>';
    html += '<tr><td>Adjusted Gross Income</td><td>' + fmt$(d.adjusted_gross_income || d.total_income) + '</td></tr>';
    (d.deductions || []).forEach(function(ded) {
      html += '<tr><td style="color:var(--green,#3ecf8e)">' + esc(ded.name) + '</td><td style="color:var(--green,#3ecf8e)">(' + fmt$(ded.amount) + ')</td></tr>';
    });
    html += '<tr style="border-top:1px solid var(--border)"><td><strong>Taxable Income</strong></td><td><strong>' + fmt$(d.taxable_income) + '</strong></td></tr>';
    html += '</tbody></table>';
    // Right: tax calc
    html += '<table class="tsm-table"><tbody>';
    html += '<tr><td>Federal Income Tax</td><td>' + fmt$(d.tax_before_credits) + '</td></tr>';
    if (d.credits > 0) html += '<tr><td style="color:var(--green,#3ecf8e)">Less: Credits</td><td style="color:var(--green,#3ecf8e)">(' + fmt$(d.credits) + ')</td></tr>';
    html += '<tr><td><strong>Total Tax</strong></td><td><strong>' + fmt$(d.total_tax) + '</strong></td></tr>';
    html += '<tr><td style="color:var(--muted)">Less: Payments &amp; Withholding</td><td style="color:var(--muted)">(' + fmt$(d.total_payments) + ')</td></tr>';
    var refColor = d.is_refund ? 'var(--green,#3ecf8e)' : 'var(--red,#f56565)';
    html += '<tr style="border-top:1px solid var(--border)"><td style="color:' + refColor + '"><strong>' + (d.is_refund ? 'Refund' : 'Balance Due') + '</strong></td><td style="color:' + refColor + '"><strong>' + fmt$(d.refund_or_owed_amount) + '</strong></td></tr>';
    html += '</tbody></table>';
    html += '</div></div>';

    // Savings highlights
    if (d.savings_highlights && d.savings_highlights.length) {
      html += '<div><div class="tsm-section-title">💰 How We Saved You Money</div><div class="tsm-savings-grid">';
      d.savings_highlights.forEach(function(s) {
        html += '<div class="tsm-savings-card"><div class="tsm-savings-amount">' + esc(s.amount) + '</div><div class="tsm-savings-title">' + esc(s.title) + '</div><div class="tsm-savings-desc">' + esc(s.description) + '</div></div>';
      });
      html += '</div></div>';
    }

    // Strategies
    if (d.strategies && d.strategies.length) {
      html += '<div><div class="tsm-section-title">🔭 Forward-Looking Strategies</div><div class="tsm-strategies-grid">';
      d.strategies.forEach(function(s) {
        html += '<div class="tsm-strategy-card"><div class="tsm-strategy-title">' + esc(s.title) + (s.category ? '<span class="tsm-strategy-badge ' + s.category + '">' + s.category + '</span>' : '') + '</div>';
        if (s.potential_savings) html += '<div class="tsm-strategy-savings">Potential savings: ' + esc(s.potential_savings) + '</div>';
        html += '<div class="tsm-strategy-desc">' + esc(s.description) + '</div></div>';
      });
      html += '</div></div>';
    }

    // Estimated payments
    if (d.estimated_payments_required && (d.federal_estimated_payments && d.federal_estimated_payments.length || d.state_estimated_payments && d.state_estimated_payments.length)) {
      html += '<div><div class="tsm-section-title">📅 Estimated Tax Payments</div>';
      if (d.federal_estimated_payments && d.federal_estimated_payments.length) {
        html += '<div style="font-size:0.78rem;font-weight:700;color:var(--text);margin-bottom:0.4rem;">Federal</div><table class="tsm-est-table"><thead><tr><th>Quarter</th><th>Due Date</th><th>Amount</th><th>Method</th></tr></thead><tbody>';
        d.federal_estimated_payments.forEach(function(p) {
          html += '<tr><td>' + esc(p.quarter) + '</td><td>' + esc(p.due_date) + '</td><td style="font-weight:600;color:var(--gold)">' + esc(p.amount) + '</td><td style="color:var(--muted)">' + esc(p.method || '') + '</td></tr>';
        });
        html += '</tbody></table>';
      }
      if (d.state_estimated_payments && d.state_estimated_payments.length) {
        html += '<div style="font-size:0.78rem;font-weight:700;color:var(--text);margin:0.75rem 0 0.4rem;">State</div><table class="tsm-est-table"><thead><tr><th>State</th><th>Quarter</th><th>Due Date</th><th>Amount</th></tr></thead><tbody>';
        d.state_estimated_payments.forEach(function(p) {
          html += '<tr><td>' + esc(p.state) + '</td><td>' + esc(p.quarter) + '</td><td>' + esc(p.due_date) + '</td><td style="font-weight:600;color:var(--gold)">' + esc(p.amount) + '</td></tr>';
        });
        html += '</tbody></table>';
      }
      html += '</div>';
    }

    // YOY comparison
    if (d.prior_year_comparison) {
      var yoy = d.prior_year_comparison;
      var nonZero = (yoy.items || []).filter(function(item) { return item.prior_year !== 0 || item.current_year !== 0; });
      var totalRows = ['Total Income','Total Adjusted Gross Income','Taxable Income','Total Tax','Effective tax rate (%)'];
      html += '<div><div class="tsm-section-title">📊 Year-Over-Year (' + esc(yoy.prior_tax_year) + ' → ' + esc(yoy.current_tax_year) + ')</div>';
      if (yoy.highlights && yoy.highlights.length) {
        html += '<div style="margin-bottom:0.75rem;">';
        yoy.highlights.forEach(function(h) {
          var arrow = h.direction === 'increase' ? '▲' : h.direction === 'decrease' ? '▼' : h.direction === 'new' ? '✦' : '✕';
          var color = h.direction === 'increase' ? 'var(--red,#f56565)' : h.direction === 'decrease' ? 'var(--green,#3ecf8e)' : 'var(--gold,#c9a84c)';
          html += '<span class="tsm-highlight-pill"><span style="color:' + color + ';font-weight:700">' + arrow + '</span> <span style="font-weight:600">' + esc(h.title) + '</span></span>';
        });
        html += '</div>';
      }
      html += '<table class="tsm-yoy-table"><thead><tr><th>Line Item</th><th>' + esc(yoy.prior_tax_year) + '</th><th>' + esc(yoy.current_tax_year) + '</th><th>Change</th></tr></thead><tbody>';
      nonZero.forEach(function(item) {
        var isTotal = totalRows.indexOf(item.label) >= 0;
        var isRate = item.label.indexOf('rate') >= 0 || item.label.indexOf('Rate') >= 0;
        var fmtV = function(v) { if (v === null || v === undefined) return '—'; return isRate ? v + '%' : fmt$(v); };
        var diffColor = item.difference > 0 ? 'var(--red,#f56565)' : item.difference < 0 ? 'var(--green,#3ecf8e)' : 'var(--muted)';
        var diffStr = item.difference !== null ? (item.difference > 0 ? '+' : '') + (isRate ? parseFloat(item.difference).toFixed(2) + '%' : fmt$(item.difference)) : '—';
        html += '<tr' + (isTotal ? ' class="total-row"' : '') + '><td>' + esc(item.label) + '</td><td>' + fmtV(item.prior_year) + '</td><td>' + fmtV(item.current_year) + '</td><td style="color:' + diffColor + '">' + diffStr + '</td></tr>';
      });
      html += '</tbody></table></div>';
    }

    // Carryovers
    if (d.carryovers && d.carryovers.length) {
      html += '<div><div class="tsm-section-title">Carryovers</div><div style="display:flex;flex-wrap:wrap;gap:0.5rem;">';
      d.carryovers.forEach(function(c) { html += '<div class="tsm-rate-pill">' + esc(c.item) + ': <strong>' + esc(c.amount) + '</strong></div>'; });
      html += '</div></div>';
    }

    document.getElementById('tsm-body').innerHTML = html;
    document.getElementById('tsm-footer').style.display = '';
  }

