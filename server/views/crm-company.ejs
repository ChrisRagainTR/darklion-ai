  // ── Page-wide drag-and-drop (opens upload modal when Docs tab active) ──
  (function() {
    let dragCounter = 0;
    const dragOverlay = document.createElement('div');
    dragOverlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(201,168,76,0.08);border:3px dashed var(--gold);pointer-events:none;align-items:center;justify-content:center;font-size:1.5rem;color:var(--gold);font-weight:700;';
    dragOverlay.textContent = '📄 Drop to upload document';
    document.body.appendChild(dragOverlay);

    function isDocsTabActive() {
      const t = document.getElementById('tab-docs');
      return t && t.classList.contains('active');
    }

    document.addEventListener('dragenter', function(e) {
      if (!isDocsTabActive()) return;
      dragCounter++;
      dragOverlay.style.display = 'flex';
    });
    document.addEventListener('dragleave', function(e) {
      if (!isDocsTabActive()) return;
      dragCounter--;
      if (dragCounter <= 0) { dragCounter = 0; dragOverlay.style.display = 'none'; }
    });
    document.addEventListener('dragover', function(e) {
      if (!isDocsTabActive()) return;
      e.preventDefault();
    });
    document.addEventListener('drop', function(e) {
      if (!isDocsTabActive()) return;
      e.preventDefault();
      dragCounter = 0;
      dragOverlay.style.display = 'none';
      const file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (!file) return;
      window.openUploadModal(file);
    });
  })();

  // ── Bookkeeping JS ──
  const BK_QBO_NOT_CONNECTED_HTML = '<div style="padding:2rem;text-align:center;color:var(--muted);"><div style="font-size:2rem;margin-bottom:0.75rem;">🔌</div><div style="font-weight:600;color:var(--text);margin-bottom:0.5rem;">QuickBooks Not Connected</div><div style="font-size:0.84rem;">Connect QuickBooks Online to enable bookkeeping features.</div><a href="/connect" class="btn btn-gold" style="margin-top:1rem;display:inline-flex;">Connect QBO →</a></div>';
  let bk_cpInitialized = false;
  let bk_uncatLoaded = false;
  let bk_varInitialized = false;
  let bk_liabLoaded = false;
  let bk_payrollInitialized = false;
  let bk_stmtInitialized = false;
  let bk_calInitialized = false;

  function bk_qboGuard(guardElId, mainElId) {
    const guardEl = document.getElementById(guardElId);
    const mainEl = document.getElementById(mainElId);
    if (!bookkeepingRealm) {
      guardEl.innerHTML = BK_QBO_NOT_CONNECTED_HTML;
      if (mainEl) mainEl.style.display = 'none';
      return false;
