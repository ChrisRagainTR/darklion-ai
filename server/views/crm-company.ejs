  async function bk_runUncategorizedScan() {
    if (!bookkeepingRealm) { toast('No QBO connection', 'error'); return; }
    const btn = document.getElementById('bk-btn-uncat-scan');
    btn.disabled=true; btn.textContent='Scanning…';
    try {
      const data = await (await apiFetch('/api/companies/'+bookkeepingRealm+'/scan/uncategorized',{method:'POST'})).json();
      if (data.error) throw new Error(data.error);
      bk_renderUncatResults(data);
