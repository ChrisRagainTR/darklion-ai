                            ${(() => { const yr = new Date().getFullYear(); let opts = ''; for(let y2=yr;y2>=2018;y2--) opts+=`<option value="${y2}"${String(f.year||'')==String(y2)?' selected':''}>${y2}</option>`; return opts; })()}
                          </select>
                          <select id="mv-sec-${f.id}" style="background:var(--charcoal);border:1px solid var(--border);color:var(--text);padding:0.2rem 0.4rem;border-radius:4px;font-size:0.75rem;margin-right:0.3rem;">
                            <option value="firm_uploaded"${(f.folder_section||'firm_uploaded')==='firm_uploaded'?' selected':''}>Advisor</option>
                            <option value="client_uploaded"${f.folder_section==='client_uploaded'?' selected':''}>Client</option>
