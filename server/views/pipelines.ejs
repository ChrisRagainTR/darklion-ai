<%- include('partials/shell-top', { title: title, activeNav: activeNav }) %>

<style>
    /* ── PIPELINE LIST ── */
    #view-list { padding: 1.5rem 2rem; }
    .list-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .list-title { font-size: 1.25rem; font-weight: 800; }
    .pipeline-table { width: 100%; border-collapse: collapse; }
    .pipeline-table th { font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; padding: 0.5rem 1rem; text-align: left; border-bottom: 1px solid var(--border); }
    .pipeline-table td { padding: 0.85rem 1rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .pipeline-table tbody tr:last-child td { border-bottom: none; }
    .pipeline-table tbody tr:hover td { background: rgba(255,255,255,0.015); }
    .pipeline-name-link { color: var(--gold); text-decoration: none; font-weight: 600; font-size: 0.95rem; cursor: pointer; background: none; border: none; padding: 0; font-family: inherit; }
    .pipeline-name-link:hover { color: var(--gold-light); text-decoration: underline; }
    .pipeline-meta-cell { color: var(--muted); font-size: 0.85rem; }
    .pipeline-jobs-cell { font-size: 0.85rem; font-weight: 600; color: var(--text); }
    .pipeline-entity-badge { display: inline-block; font-size: 0.68rem; padding: 0.1rem 0.45rem; border-radius: 4px; background: rgba(255,255,255,0.06); color: var(--muted); text-transform: capitalize; }
    .table-empty { text-align: center; padding: 3rem 1rem; color: var(--muted); }
    .table-empty p { font-size: 0.9rem; margin-top: 0.5rem; }

    /* dot menu */
    .dot-menu-wrap { position: relative; display: flex; justify-content: flex-end; }
    .dot-menu-btn { background: none; border: none; color: var(--muted); cursor: pointer; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 1.2rem; transition: all 0.15s; line-height: 1; }
    .dot-menu-btn:hover { color: var(--text); background: rgba(255,255,255,0.06); }
    .dot-menu-dropdown { display: none; position: absolute; right: 0; top: calc(100% + 2px); background: var(--charcoal); border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); z-index: 150; min-width: 140px; overflow: hidden; }
    .dot-menu-dropdown.open { display: block; }
    .dot-menu-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; font-size: 0.85rem; color: var(--text); cursor: pointer; transition: background 0.1s; border: none; background: none; width: 100%; text-align: left; font-family: inherit; }
    .dot-menu-item:hover { background: rgba(201,168,76,0.07); }
    .dot-menu-item.danger { color: var(--red); }
    .dot-menu-divider { height: 1px; background: var(--border); }

    /* ── BOARD VIEW ── */
    #view-board { display: flex; flex-direction: column; min-height: calc(100vh - 56px); }

    .board-header { position: sticky; top: 56px; z-index: 80; background: rgba(15,25,35,0.97); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 1rem; padding: 0.65rem 1.5rem; flex-shrink: 0; }
    .board-back-btn { flex-shrink: 0; }
    .board-title { font-size: 1rem; font-weight: 700; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
    .board-header-right { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }
    .year-select { background: var(--charcoal); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 0.3rem 0.6rem; font-size: 0.85rem; cursor: pointer; }
    .year-select:focus { outline: none; border-color: var(--gold); }
    #edit-stages-btn.active { color: var(--gold); border-color: var(--gold); }

    /* Stage editor */
    .stage-editor-wrap { background: rgba(22,32,48,0.95); border-bottom: 1px solid var(--border); padding: 1rem 1.5rem; flex-shrink: 0; }
    .stage-editor-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
    .stage-editor-top h3 { font-size: 0.72rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .stages-list { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.75rem; max-width: 640px; }
    .stage-row { display: flex; align-items: center; gap: 0.6rem; background: var(--input-bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.75rem; cursor: grab; }
    .stage-row.drag-over-stage { border-color: var(--gold); background: rgba(201,168,76,0.06); }
    .stage-drag-handle { color: var(--muted); cursor: grab; font-size: 0.9rem; }
    .stage-color-swatch { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; cursor: pointer; border: 1px solid rgba(255,255,255,0.1); }
    .stage-name-input { flex: 1; background: transparent; border: none; color: var(--text); font-size: 0.85rem; outline: none; min-width: 0; }
    .stage-name-input:focus { color: var(--gold); }
    .stage-terminal-label { font-size: 0.72rem; color: var(--muted); display: flex; align-items: center; gap: 0.3rem; cursor: pointer; white-space: nowrap; }
    .stage-terminal-label input { accent-color: var(--gold); }
    .stage-delete-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.85rem; padding: 0.1rem 0.3rem; border-radius: 4px; transition: all 0.15s; }
    .stage-delete-btn:hover { color: var(--red); background: rgba(245,101,101,0.1); }

    /* Kanban */
    .board-container { flex: 1; overflow-x: auto; padding: 1.25rem 1.5rem 2rem; }
    .kanban-board { display: flex; gap: 1rem; align-items: flex-start; }
    .kanban-col { min-width: 260px; max-width: 280px; flex-shrink: 0; background: rgba(28,43,58,0.6); border-radius: 8px; border: 1px solid var(--border); display: flex; flex-direction: column; }
    .kanban-col.drag-over { background: rgba(201,168,76,0.07); border-color: var(--gold); }
    .kanban-col-header { padding: 0.7rem 1rem 0.6rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
    .col-stage-name { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; flex: 1; }
    .col-count { font-size: 0.7rem; background: rgba(255,255,255,0.1); border-radius: 10px; padding: 0.1rem 0.45rem; color: var(--muted); flex-shrink: 0; }
    /* Key: independently scrollable cards column */
    .kanban-cards { padding: 0.5rem; overflow-y: auto; max-height: 65vh; min-height: 40px; }
    .col-footer { padding: 0.5rem; border-top: 1px solid var(--border); flex-shrink: 0; }
    .col-add-btn { width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.35rem; padding: 0.4rem 0.5rem; font-size: 0.78rem; font-weight: 600; color: var(--muted); background: none; border: 1px dashed var(--border); border-radius: 5px; cursor: pointer; transition: all 0.15s; font-family: inherit; }
    .col-add-btn:hover { color: var(--gold); border-color: rgba(201,168,76,0.5); background: rgba(201,168,76,0.04); }

    /* Add job form inside a column */
    .add-job-form { display: flex; flex-direction: column; gap: 0.4rem; }
    .add-job-form input { width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text); border-radius: 5px; padding: 0.4rem 0.6rem; font-size: 0.8rem; font-family: inherit; }
    .add-job-form input:focus { outline: none; border-color: var(--gold); }
    .add-job-search-results { background: #13222f; border: 1px solid var(--border); border-radius: 5px; max-height: 160px; overflow-y: auto; }
    .add-job-result { padding: 0.4rem 0.6rem; font-size: 0.8rem; cursor: pointer; transition: background 0.1s; }
    .add-job-result:hover { background: rgba(201,168,76,0.08); }
    .add-job-cancel { font-size: 0.75rem; color: var(--muted); background: none; border: none; cursor: pointer; width: 100%; padding: 0.2rem; font-family: inherit; text-align: center; }
    .add-job-cancel:hover { color: var(--text); }

    /* ── JOB CARD ── */
    .job-card { background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 0.65rem 0.75rem; margin-bottom: 0.5rem; cursor: pointer; transition: all 0.15s; user-select: none; }
    .job-card:last-child { margin-bottom: 0; }
    .job-card:hover { border-color: rgba(201,168,76,0.4); box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
    .job-card.dragging { opacity: 0.4; }
    .job-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.4rem; margin-bottom: 0.3rem; }
    .job-entity { font-size: 0.88rem; font-weight: 600; color: var(--text); flex: 1; min-width: 0; word-break: break-word; }
    .priority-badge { font-size: 0.62rem; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 700; text-transform: uppercase; flex-shrink: 0; margin-top: 0.1rem; }
    .priority-badge.high { background: rgba(237,137,54,0.2); color: var(--orange); }
    .priority-badge.urgent { background: rgba(245,101,101,0.2); color: var(--red); }
    .job-notes-preview { font-size: 0.75rem; color: var(--muted); margin-bottom: 0.3rem; line-height: 1.4; }
    .job-card-meta { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
    .job-days { font-size: 0.7rem; color: var(--muted); }
    .job-due { font-size: 0.7rem; color: var(--orange); }
    .job-due.overdue { color: var(--red); }
    .assignee-avatar { width: 22px; height: 22px; border-radius: 50%; background: rgba(201,168,76,0.2); color: var(--gold); font-size: 0.62rem; font-weight: 700; display: flex; align-items: center; justify-content: center; margin-left: auto; flex-shrink: 0; }
    .job-status-badge { display: inline-block; font-size: 0.62rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 4px; margin-top: 0.15rem; text-transform: uppercase; letter-spacing: 0.03em; }
    .job-status-badge.waiting_client { background: rgba(234,179,8,0.2); color: #eab308; }
    .job-status-badge.missing_info   { background: rgba(234,88,12,0.2); color: #f97316; }
    .job-status-badge.blocked        { background: rgba(239,68,68,0.2); color: #ef4444; }
    .job-status-badge.under_extension{ background: rgba(59,130,246,0.2); color: #60a5fa; }
    .job-status-badge.on_hold        { background: rgba(148,163,184,0.15); color: #94a3b8; }
    .job-card[data-status="waiting_client"]  { border-left: 3px solid #eab308; }
    .job-card[data-status="missing_info"]    { border-left: 3px solid #f97316; }
    .job-card[data-status="blocked"]         { border-left: 3px solid #ef4444; }
    .job-card[data-status="under_extension"] { border-left: 3px solid #60a5fa; }
    .job-card[data-status="on_hold"]         { border-left: 3px solid #94a3b8; }

    /* ── JOB DETAIL PANEL ── */
    .job-panel-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 200; display: none; }
    .job-panel-overlay.open { display: block; }
    .job-panel { position: fixed; top: 0; right: -480px; width: 460px; bottom: 0; background: var(--charcoal); border-left: 1px solid var(--border); display: flex; flex-direction: column; z-index: 210; transition: right 0.25s ease; overflow: hidden; }
    .job-panel.open { right: 0; }
    .job-panel-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 1rem; }
    .job-panel-title { flex: 1; font-size: 1.05rem; font-weight: 700; }
    .job-panel-close { background: none; border: none; color: var(--muted); font-size: 1.2rem; cursor: pointer; padding: 0.2rem; line-height: 1; }
    .job-panel-close:hover { color: var(--text); }
    .job-panel-body { flex: 1; overflow-y: auto; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .panel-field label { display: block; font-size: 0.72rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem; }
    .panel-field select, .panel-field textarea, .panel-field input[type=date], .panel-field input[type=text] { width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 0.45rem 0.7rem; font-size: 0.85rem; }
    .panel-field select:focus, .panel-field textarea:focus, .panel-field input:focus { outline: none; border-color: var(--gold); }
    .panel-field textarea { resize: vertical; min-height: 80px; font-family: inherit; }
    .panel-entity-link { color: var(--gold); text-decoration: none; font-size: 0.82rem; }
    .panel-entity-link:hover { text-decoration: underline; }
    .history-timeline { display: flex; flex-direction: column; gap: 0.6rem; }
    .history-item { display: flex; gap: 0.75rem; align-items: flex-start; }
    .history-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 0.4rem; }
    .history-content { flex: 1; }
    .history-stages { font-size: 0.8rem; color: var(--text); }
    .history-stages span { color: var(--gold); }
    .history-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
    .history-note { font-size: 0.75rem; color: var(--muted); font-style: italic; margin-top: 0.15rem; }

    /* ── MODALS ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 300; display: none; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--charcoal); border: 1px solid var(--border); border-radius: 10px; padding: 1.75rem; width: 100%; max-width: 440px; position: relative; }
    .modal h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 1.25rem; }
    .modal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--muted); font-size: 1.1rem; cursor: pointer; }
    .modal-close:hover { color: var(--text); }
    .form-group { margin-bottom: 0.9rem; }
    .form-group label { display: block; font-size: 0.75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.3rem; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 0.5rem 0.75rem; font-size: 0.9rem; font-family: inherit; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--gold); }
    .form-group textarea { resize: vertical; }
    .form-hint { font-size: 0.72rem; color: var(--muted); margin-top: 0.25rem; }

    /* ── BUTTONS ── */
    .btn { padding: 0.45rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; font-family: inherit; }
    .btn-primary { background: var(--gold); color: var(--navy); }
    .btn-primary:hover { background: var(--gold-light); }
    .btn-sm { padding: 0.3rem 0.65rem; font-size: 0.78rem; }
    .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--muted); }
    .btn-ghost:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }
    .btn-danger { background: rgba(245,101,101,0.15); border: 1px solid rgba(245,101,101,0.3); color: var(--red); }
    .btn-danger:hover { background: rgba(245,101,101,0.25); }
    .btn-modal-row { display: flex; gap: 0.6rem; justify-content: flex-end; margin-top: 1.25rem; }

    /* ── UTILITIES ── */
    .hidden { display: none !important; }
    .loading { color: var(--muted); font-size: 0.85rem; padding: 1rem 0; }
    .section-label { font-size: 0.72rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.6rem; }
    .board-loading { display: flex; align-items: center; justify-content: center; flex: 1; color: var(--muted); font-size: 0.9rem; }
    .board-empty { text-align: center; padding: 4rem 2rem; color: var(--muted); }
    .board-empty .empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .board-empty p { font-size: 0.9rem; margin-bottom: 0.5rem; }

    @media (max-width: 700px) {
      .job-panel { width: 100%; right: -100%; }
      .modal { margin: 1rem; }
      #view-list { padding: 1rem; }
    }
</style>


    <!-- ═══════════════ PIPELINE LIST VIEW ═══════════════ -->
    <div id="view-list">
      <div class="list-header">
        <div class="list-title">Pipelines</div>
        <button class="btn btn-primary btn-sm" onclick="openCreatePipelineModal()">+ New Pipeline</button>
      </div>
      <table class="pipeline-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Active Jobs</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="pipeline-table-body">
          <tr><td colspan="4"><div class="loading">Loading…</div></td></tr>
        </tbody>
      </table>
    </div>

    <!-- ═══════════════ BOARD VIEW ═══════════════ -->
    <div id="view-board" class="hidden">
      <!-- Board sub-header -->
      <div class="board-header">
        <button class="btn btn-ghost btn-sm board-back-btn" onclick="goToList()">← Pipelines</button>
        <div class="board-title" id="board-title">Loading…</div>
        <div class="board-header-right">
          <select class="year-select" id="year-select" onchange="onYearChange(this.value)"></select>
          <button class="btn btn-ghost btn-sm" id="edit-stages-btn" onclick="toggleStageEditor()">✏ Edit Stages</button>
        </div>
      </div>

      <!-- Inline stage editor (hidden by default) -->
      <div class="stage-editor-wrap hidden" id="stage-editor">
        <div class="stage-editor-top">
          <h3>Stages — drag to reorder</h3>
          <button class="btn btn-ghost btn-sm" onclick="addStage()">+ Add Stage</button>
        </div>
        <div class="stages-list" id="stages-list"></div>
      </div>

      <!-- Kanban area -->
      <div class="board-container" id="board-container">
        <div class="board-loading">Loading board…</div>
      </div>
    </div>

  </div><!-- /main -->

  <!-- ── JOB DETAIL PANEL ── -->
  <div class="job-panel-overlay" id="job-panel-overlay" onclick="closeJobPanel()"></div>
  <div class="job-panel" id="job-panel">
    <div class="job-panel-header">
      <div class="job-panel-title" id="panel-entity-name">Job Details</div>
      <button class="job-panel-close" onclick="closeJobPanel()">✕</button>
    </div>
    <div class="job-panel-body" id="panel-body">
      <div class="loading">Loading…</div>
    </div>
  </div>

  <!-- ── CREATE PIPELINE MODAL ── -->
  <div class="modal-overlay" id="create-pipeline-modal">
    <div class="modal">
      <button class="modal-close" onclick="closeModal('create-pipeline-modal')">✕</button>
      <h3>New Pipeline</h3>
      <div class="form-group">
        <label>Name</label>
        <input type="text" id="cp-name" placeholder="e.g. Individual Tax Returns" />
      </div>
      <div class="form-group">
        <label>Entity Type</label>
        <select id="cp-entity-type">
          <option value="company">Company</option>
          <option value="person">Person</option>
          <option value="relationship">Relationship</option>
        </select>
      </div>
      <div class="form-group">
        <label>Description (optional)</label>
        <textarea id="cp-description" rows="2" placeholder="What is this pipeline for?"></textarea>
      </div>
      <div class="btn-modal-row">
        <button class="btn btn-ghost" onclick="closeModal('create-pipeline-modal')">Cancel</button>
        <button class="btn btn-primary" onclick="submitCreatePipeline()">Create Pipeline</button>
      </div>
    </div>
  </div>

  <script>
  (function() {
    'use strict';

    // ─── AUTH ───────────────────────────────────────
    const token = localStorage.getItem('dl_token');
    if (!token) { window.location.href = '/login'; return; }

    // ─── STATE ───────────────────────────────────────
    let templates = [];
    let teamMembers = [];
    let currentTemplate = null;   // full template object
    let currentInstance = null;   // current instance (year) object
    let currentInstanceData = null; // { template, stages, jobs, ... }
    let openJobId = null;
    let panelSaveTimer = null;
    let stageEditorOpen = false;
    let dragSrcStage = null;

    // ─── UTILS ───────────────────────────────────────
    function esc(s) {
      return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function formatDate(d) {
      if (!d) return '';
      return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }
    function daysAgo(ts) {
      if (!ts) return 0;
      return Math.floor((Date.now() - new Date(ts).getTime()) / 86400000);
    }
    function initials(name) {
      if (!name) return '?';
      const parts = name.trim().split(/\s+/);
      return parts.length === 1 ? parts[0][0].toUpperCase() : (parts[0][0] + parts[parts.length-1][0]).toUpperCase();
    }
    function entityUrl(type, id) {
      if (type === 'company') return `/crm/company/${id}`;
      if (type === 'person') return `/crm/person/${id}`;
      if (type === 'relationship') return `/crm/relationship/${id}`;
      return '#';
    }
    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    window.closeModal = closeModal;

    // Year list: current year ± 2
    function buildYearOptions(selectedYear) {
      const cur = new Date().getFullYear();
      let html = '';
      for (let y = cur + 1; y >= cur - 3; y--) {
        html += `<option value="${y}" ${y == selectedYear ? 'selected' : ''}>${y}</option>`;
      }
      return html;
    }

    // ─── API ─────────────────────────────────────────
    async function api(method, path, body) {
      const opts = { method, headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token } };
      if (body !== undefined) opts.body = JSON.stringify(body);
      const r = await fetch('/api/pipelines' + path, opts);
      if (r.status === 401) { localStorage.removeItem('dl_token'); window.location.href = '/login'; throw new Error('Unauthorized'); }
      if (!r.ok) { const e = await r.json().catch(() => ({})); throw new Error(e.error || 'Request failed'); }
      return r.json();
    }

    // ─── TEAM ────────────────────────────────────────
    async function loadTeam() {
      try {
        const r = await fetch('/firms/team', { headers: { 'Authorization': 'Bearer ' + token } });
        if (r.ok) teamMembers = await r.json();
      } catch (_) {}
    }

    // ─── VIEW SWITCHING ──────────────────────────────
    function showView(id) {
      document.getElementById('view-list').classList.toggle('hidden', id !== 'view-list');
      document.getElementById('view-board').classList.toggle('hidden', id !== 'view-board');
    }

    window.goToList = function() {
      currentTemplate = null;
      currentInstance = null;
      currentInstanceData = null;
      stageEditorOpen = false;
      document.getElementById('stage-editor').classList.add('hidden');
      document.getElementById('edit-stages-btn').classList.remove('active');
      showView('view-list');
      loadPipelineList();
    };

    // ─── PIPELINE LIST ───────────────────────────────
    async function loadPipelineList() {
      const tbody = document.getElementById('pipeline-table-body');
      tbody.innerHTML = '<tr><td colspan="4"><div class="loading">Loading…</div></td></tr>';
      try {
        templates = await api('GET', '/templates');
        if (!templates.length) {
          tbody.innerHTML = `<tr><td colspan="4"><div class="table-empty"><div style="font-size:2rem">📋</div><p style="font-weight:600;margin-top:0.5rem;">No pipelines yet</p><p>Create your first pipeline to get started.</p></div></td></tr>`;
          return;
        }
        tbody.innerHTML = templates.map(t => `
          <tr>
            <td>
              <button class="pipeline-name-link" onclick="openPipeline(${t.id})">${esc(t.name)}</button>
            </td>
            <td class="pipeline-meta-cell">
              <span class="pipeline-entity-badge">${esc(t.entity_type)}</span>
              ${t.description ? `<span style="margin-left:0.5rem;font-size:0.8rem;color:var(--muted)">${esc(t.description)}</span>` : ''}
            </td>
            <td class="pipeline-jobs-cell">${t.stage_count} stage${t.stage_count !== 1 ? 's' : ''}</td>
            <td>
              <div class="dot-menu-wrap">
                <button class="dot-menu-btn" onclick="toggleDotMenu(event, ${t.id})">⋯</button>
                <div class="dot-menu-dropdown" id="dot-menu-${t.id}">
                  <button class="dot-menu-item" onclick="openPipeline(${t.id}); closeDotMenus()">📋 Open Board</button>
                  <div class="dot-menu-divider"></div>
                  <button class="dot-menu-item danger" onclick="deletePipeline(${t.id})">🗑 Delete</button>
                </div>
              </div>
            </td>
          </tr>
        `).join('');
      } catch (e) {
        tbody.innerHTML = `<tr><td colspan="4"><div class="loading" style="color:var(--red)">Failed to load: ${esc(e.message)}</div></td></tr>`;
      }
    }

    function toggleDotMenu(e, id) {
      e.stopPropagation();
      const menu = document.getElementById('dot-menu-' + id);
      const isOpen = menu.classList.contains('open');
      closeDotMenus();
      if (!isOpen) menu.classList.add('open');
    }
    function closeDotMenus() {
      document.querySelectorAll('.dot-menu-dropdown.open').forEach(m => m.classList.remove('open'));
    }
    window.toggleDotMenu = toggleDotMenu;
    window.closeDotMenus = closeDotMenus;
    document.addEventListener('click', closeDotMenus);

    window.deletePipeline = async function(id) {
      closeDotMenus();
      if (!confirm('Delete this pipeline? All instances and jobs will be lost.')) return;
      try {
        await api('DELETE', `/templates/${id}`);
        loadPipelineList();
      } catch (err) { alert('Failed: ' + err.message); }
    };

    // ─── OPEN PIPELINE → BOARD ───────────────────────
    window.openPipeline = async function(templateId) {
      showView('view-board');
      document.getElementById('board-title').textContent = 'Loading…';
      document.getElementById('board-container').innerHTML = '<div class="board-loading">Loading…</div>';

      try {
        currentTemplate = await api('GET', `/templates/${templateId}`);
        document.getElementById('board-title').textContent = currentTemplate.name;

        // Build year selector — default to current year
        const curYear = new Date().getFullYear();
        document.getElementById('year-select').innerHTML = buildYearOptions(curYear);

        // Ensure instance for this year
        await ensureAndLoadInstance(templateId, curYear);
      } catch (e) {
        document.getElementById('board-container').innerHTML = `<div class="board-empty"><div class="empty-icon">⚠️</div><p>Failed to load pipeline: ${esc(e.message)}</p></div>`;
      }
    };

    window.onYearChange = async function(year) {
      if (!currentTemplate) return;
      document.getElementById('board-container').innerHTML = '<div class="board-loading">Loading…</div>';
      await ensureAndLoadInstance(currentTemplate.id, parseInt(year));
    };

    async function ensureAndLoadInstance(templateId, year) {
      try {
        currentInstance = await api('POST', `/templates/${templateId}/ensure-instance`, { year });
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
        if (stageEditorOpen) renderStageEditor();
      } catch (e) {
        document.getElementById('board-container').innerHTML = `<div class="board-empty"><div class="empty-icon">⚠️</div><p>Failed to load board: ${esc(e.message)}</p></div>`;
      }
    }

    // ─── KANBAN RENDER ───────────────────────────────
    function renderKanban() {
      if (!currentInstanceData) return;
      const { stages, jobs } = currentInstanceData;
      const container = document.getElementById('board-container');

      if (!stages || stages.length === 0) {
        container.innerHTML = `<div class="board-empty"><div class="empty-icon">🔧</div><p style="font-weight:600">No stages yet</p><p>Click "Edit Stages" to add stages to this pipeline.</p></div>`;
        return;
      }

      const byStage = {};
      stages.forEach(s => { byStage[s.id] = []; });
      jobs.forEach(j => {
        if (byStage[j.current_stage_id]) byStage[j.current_stage_id].push(j);
        else if (stages[0]) byStage[stages[0].id].push(j);
      });

      let html = '<div class="kanban-board">';
      stages.forEach(stage => {
        const stageJobs = byStage[stage.id] || [];
        const color = stage.color || '#c9a84c';
        const cardsHtml = stageJobs.map(j => renderJobCard(j)).join('');
        html += `
          <div class="kanban-col" data-stage-id="${stage.id}"
            ondragover="event.preventDefault(); this.classList.add('drag-over')"
            ondragleave="this.classList.remove('drag-over')"
            ondrop="handleDrop(event, ${stage.id})">
            <div class="kanban-col-header">
              <div class="col-stage-name" style="color:${color}">${esc(stage.name)}</div>
              <span class="col-count">${stageJobs.length}</span>
            </div>
            <div class="kanban-cards" id="stage-cards-${stage.id}">${cardsHtml}</div>
            <div class="col-footer">
              <div id="add-job-wrap-${stage.id}">
                <button class="col-add-btn" onclick="showAddJobForm(${stage.id})">＋ Add</button>
              </div>
            </div>
          </div>`;
      });
      html += '</div>';
      container.innerHTML = html;
      attachDragEvents();
    }

    const JOB_STATUS_LABELS = {
      waiting_client:  '🟡 Waiting on Client',
      missing_info:    '🟠 Missing Info',
      blocked:         '🔴 Blocked',
      under_extension: '🔵 Under Extension',
      on_hold:         '⚫ On Hold',
    };

    function renderJobCard(job) {
      const priority = job.priority || 'normal';
      const notesPreview = (job.notes || '').substring(0, 60) + ((job.notes || '').length > 60 ? '…' : '');
      const days = daysAgo(job.updated_at || job.created_at);
      const dueStr = job.due_date ? formatDate(job.due_date) : '';
      const isOverdue = job.due_date && new Date(job.due_date) < new Date();
      const assignName = job.assigned_name || job.assigned_full_name || '';
      const status = job.job_status || 'active';
      const statusAttr = status !== 'active' ? ` data-status="${status}"` : '';
      const statusBadge = status !== 'active' && JOB_STATUS_LABELS[status]
        ? `<div><span class="job-status-badge ${status}">${JOB_STATUS_LABELS[status]}</span></div>` : '';
      const priorityBadge = (priority === 'high' || priority === 'urgent')
        ? `<span class="priority-badge ${priority}">${priority}</span>` : '';

      return `<div class="job-card" data-job-id="${job.id}" draggable="true" onclick="openJobPanel(${job.id})"${statusAttr}>
        <div class="job-card-top">
          <div class="job-entity">${esc(job.entity_name || `#${job.entity_id}`)}</div>
          ${priorityBadge}
        </div>
        ${statusBadge}
        ${notesPreview ? `<div class="job-notes-preview">${esc(notesPreview)}</div>` : ''}
        <div class="job-card-meta">
          <span class="job-days">${days}d</span>
          ${dueStr ? `<span class="job-due${isOverdue ? ' overdue' : ''}">📅 ${dueStr}</span>` : ''}
          ${assignName ? `<div class="assignee-avatar" title="${esc(assignName)}">${initials(assignName)}</div>` : ''}
        </div>
      </div>`;
    }

    function attachDragEvents() {
      document.querySelectorAll('.job-card[draggable]').forEach(card => {
        card.addEventListener('dragstart', e => {
          e.dataTransfer.setData('jobId', card.dataset.jobId);
          setTimeout(() => card.classList.add('dragging'), 0);
        });
        card.addEventListener('dragend', () => card.classList.remove('dragging'));
      });
    }

    window.handleDrop = async function(e, stageId) {
      e.preventDefault();
      e.currentTarget.classList.remove('drag-over');
      const jobId = e.dataTransfer.getData('jobId');
      if (!jobId) return;
      try {
        await api('POST', `/jobs/${jobId}/move`, { stage_id: stageId, note: '' });
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { alert('Failed to move job: ' + err.message); }
    };

    // ─── ADD JOB ─────────────────────────────────────
    window.showAddJobForm = function(stageId) {
      const wrap = document.getElementById(`add-job-wrap-${stageId}`);
      const entityType = currentInstanceData?.template?.entity_type || 'company';
      wrap.innerHTML = `
        <div class="add-job-form">
          <input type="text" placeholder="Search ${esc(entityType)} by name…"
            id="add-job-search-${stageId}" autocomplete="off"
            oninput="searchEntities(this.value, ${stageId}, '${entityType}')" />
          <div class="add-job-search-results hidden" id="add-job-results-${stageId}"></div>
          <button class="add-job-cancel" onclick="cancelAddJob(${stageId})">Cancel</button>
        </div>`;
      document.getElementById(`add-job-search-${stageId}`).focus();
    };

    window.cancelAddJob = function(stageId) {
      const wrap = document.getElementById(`add-job-wrap-${stageId}`);
      wrap.innerHTML = `<button class="col-add-btn" onclick="showAddJobForm(${stageId})">＋ Add</button>`;
    };

    let entitySearchTimer = null;
    window.searchEntities = function(query, stageId, entityType) {
      clearTimeout(entitySearchTimer);
      const resultsEl = document.getElementById(`add-job-results-${stageId}`);
      if (!query.trim()) { resultsEl.classList.add('hidden'); return; }
      entitySearchTimer = setTimeout(async () => {
        try {
          const r = await fetch(`/api/search?q=${encodeURIComponent(query)}`, { headers: { 'Authorization': 'Bearer ' + token } });
          if (!r.ok) return;
          const data = await r.json();
          let items = [];
          if (entityType === 'company') items = data.companies || [];
          else if (entityType === 'person') items = data.people || [];
          else items = data.relationships || [];

          if (!items.length) {
            resultsEl.innerHTML = '<div class="add-job-result" style="color:var(--muted)">No results</div>';
            resultsEl.classList.remove('hidden');
            return;
          }
          resultsEl.innerHTML = items.map(item => {
            const name = item.company_name || item.name || `${item.first_name || ''} ${item.last_name || ''}`.trim();
            return `<div class="add-job-result" onclick="addJobFromSearch(${item.id}, '${entityType}', '${esc(name).replace(/'/g,"\\'")}', ${stageId})">${esc(name)}</div>`;
          }).join('');
          resultsEl.classList.remove('hidden');
        } catch (_) {}
      }, 250);
    };

    window.addJobFromSearch = async function(entityId, entityType, entityName, stageId) {
      try {
        await api('POST', `/instances/${currentInstance.id}/jobs`, { entity_type: entityType, entity_id: entityId, notes: '', priority: 'normal' });
        // Reload and move to target stage if not first
        const fresh = await api('GET', `/instances/${currentInstance.id}`);
        const added = fresh.jobs.find(j => j.entity_id == entityId && j.entity_type === entityType && j.current_stage_id !== stageId);
        if (added) await api('POST', `/jobs/${added.id}/move`, { stage_id: stageId, note: 'Initial placement' });
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { alert('Failed to add job: ' + err.message); }
    };

    // ─── STAGE EDITOR ────────────────────────────────
    window.toggleStageEditor = function() {
      stageEditorOpen = !stageEditorOpen;
      document.getElementById('stage-editor').classList.toggle('hidden', !stageEditorOpen);
      document.getElementById('edit-stages-btn').classList.toggle('active', stageEditorOpen);
      if (stageEditorOpen) renderStageEditor();
    };

    function renderStageEditor() {
      if (!currentTemplate) return;
      const stages = currentTemplate.stages || [];
      const list = document.getElementById('stages-list');

      if (!stages.length) {
        list.innerHTML = '<p style="color:var(--muted);font-size:0.82rem;padding:0.25rem 0;">No stages yet. Add one below.</p>';
        return;
      }

      list.innerHTML = stages.map(s => `
        <div class="stage-row" data-stage-id="${s.id}" draggable="true"
          ondragstart="stageDragStart(event, ${s.id})"
          ondragover="event.preventDefault(); this.classList.add('drag-over-stage')"
          ondragleave="this.classList.remove('drag-over-stage')"
          ondrop="stageDrop(event, ${s.id})">
          <span class="stage-drag-handle" title="Drag to reorder">⠿</span>
          <div class="stage-color-swatch" style="background:${s.color || '#c9a84c'}" onclick="openStageColorPicker(${s.id})"></div>
          <input type="color" id="stage-color-${s.id}" value="${s.color || '#c9a84c'}" style="display:none"
            oninput="updateStageColorSwatch(${s.id}, this.value)"
            onchange="saveStageColor(${s.id}, this.value)" />
          <input class="stage-name-input" type="text" value="${esc(s.name)}" placeholder="Stage name"
            onblur="saveStageField(${s.id}, 'name', this.value)" />
          <label class="stage-terminal-label">
            <input type="checkbox" ${s.is_terminal ? 'checked' : ''} onchange="saveStageField(${s.id}, 'is_terminal', this.checked)" />
            Done
          </label>
          <button class="stage-delete-btn" onclick="deleteStage(${s.id})" title="Delete">🗑</button>
        </div>`).join('');
    }

    window.openStageColorPicker = function(stageId) { document.getElementById(`stage-color-${stageId}`)?.click(); };
    window.updateStageColorSwatch = function(stageId, color) {
      const row = document.querySelector(`.stage-row[data-stage-id="${stageId}"] .stage-color-swatch`);
      if (row) row.style.background = color;
    };
    window.saveStageColor = async function(stageId, color) { await saveStageField(stageId, 'color', color); };

    window.saveStageField = async function(stageId, field, value) {
      if (!currentTemplate) return;
      const stage = currentTemplate.stages.find(s => s.id == stageId);
      if (!stage) return;
      try {
        const update = { name: stage.name, position: stage.position, color: stage.color, is_terminal: stage.is_terminal };
        update[field] = value;
        const updated = await api('PUT', `/templates/${currentTemplate.id}/stages/${stageId}`, update);
        Object.assign(stage, updated);
        // Refresh kanban column headers
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { console.error('Stage save error:', err); }
    };

    window.addStage = async function() {
      const name = prompt('Stage name:');
      if (!name || !name.trim()) return;
      try {
        const position = (currentTemplate?.stages?.length) || 0;
        const stage = await api('POST', `/templates/${currentTemplate.id}/stages`, { name: name.trim(), position, color: '#c9a84c', is_terminal: false });
        currentTemplate.stages.push(stage);
        renderStageEditor();
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { alert('Failed to add stage: ' + err.message); }
    };

    window.deleteStage = async function(stageId) {
      if (!confirm('Delete this stage? Jobs here will move to the first stage.')) return;
      try {
        await api('DELETE', `/templates/${currentTemplate.id}/stages/${stageId}`);
        currentTemplate.stages = currentTemplate.stages.filter(s => s.id !== stageId);
        renderStageEditor();
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { alert('Failed to delete stage: ' + err.message); }
    };

    window.stageDragStart = function(e, stageId) {
      dragSrcStage = stageId;
      e.dataTransfer.setData('stageId', stageId);
    };

    window.stageDrop = async function(e, targetStageId) {
      e.preventDefault();
      e.currentTarget.classList.remove('drag-over-stage');
      const srcId = parseInt(e.dataTransfer.getData('stageId'));
      if (srcId === targetStageId || !currentTemplate) return;
      const stages = currentTemplate.stages;
      const srcIdx = stages.findIndex(s => s.id === srcId);
      const tgtIdx = stages.findIndex(s => s.id === targetStageId);
      if (srcIdx < 0 || tgtIdx < 0) return;
      const [moved] = stages.splice(srcIdx, 1);
      stages.splice(tgtIdx, 0, moved);
      try {
        await api('PUT', `/templates/${currentTemplate.id}/stages/reorder`, { stageIds: stages.map(s => s.id) });
        stages.forEach((s, i) => s.position = i);
        renderStageEditor();
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { alert('Failed to reorder: ' + err.message); }
    };

    // ─── JOB DETAIL PANEL ────────────────────────────
    window.openJobPanel = async function(jobId) {
      openJobId = jobId;
      document.getElementById('job-panel-overlay').classList.add('open');
      document.getElementById('job-panel').classList.add('open');
      document.getElementById('panel-body').innerHTML = '<div class="loading">Loading…</div>';
      document.getElementById('panel-entity-name').textContent = 'Job Details';
      await renderJobPanel(jobId);
    };

    window.closeJobPanel = function() {
      document.getElementById('job-panel-overlay').classList.remove('open');
      document.getElementById('job-panel').classList.remove('open');
      openJobId = null;
      clearTimeout(panelSaveTimer);
    };

    async function renderJobPanel(jobId) {
      try {
        const job = currentInstanceData?.jobs?.find(j => j.id == jobId);
        if (!job) return;
        const stages = currentInstanceData?.stages || [];
        const history = await api('GET', `/jobs/${jobId}/history`);

        document.getElementById('panel-entity-name').textContent = job.entity_name || `Job #${job.id}`;

        const stageOpts = stages.map(s =>
          `<option value="${s.id}" ${s.id == job.current_stage_id ? 'selected' : ''}>${esc(s.name)}</option>`
        ).join('');

        const teamOpts = '<option value="">— Unassigned —</option>' +
          teamMembers.map(m =>
            `<option value="${m.id}" ${m.id == job.assigned_to ? 'selected' : ''}>${esc(m.display_name || m.name)}</option>`
          ).join('');

        const histHtml = history.length ? history.map(h => {
          const from = h.from_stage_name || 'Start';
          const to = h.to_stage_name || '?';
          const who = h.moved_by_name || h.moved_by_full_name || 'System';
          const when = new Date(h.moved_at).toLocaleString();
          return `<div class="history-item">
            <div class="history-dot"></div>
            <div class="history-content">
              <div class="history-stages">${esc(from)} → <span>${esc(to)}</span></div>
              <div class="history-meta">${esc(who)} · ${when}</div>
              ${h.note ? `<div class="history-note">${esc(h.note)}</div>` : ''}
            </div>
          </div>`;
        }).join('') : '<p style="color:var(--muted);font-size:0.8rem;">No movement history yet.</p>';

        const dueDateVal = job.due_date ? job.due_date.split('T')[0] : '';
        const entityLink = entityUrl(job.entity_type, job.entity_id);

        document.getElementById('panel-body').innerHTML = `
          <div class="panel-field">
            <label>Entity</label>
            <a class="panel-entity-link" href="${entityLink}" target="_blank">${esc(job.entity_name || `#${job.entity_id}`)}</a>
          </div>
          <div class="panel-field">
            <label>Stage</label>
            <select id="panel-stage" onchange="panelMoveStage(${jobId}, this.value)">${stageOpts}</select>
          </div>
          <div class="panel-field">
            <label>Status</label>
            <select id="panel-job-status" onchange="panelSaveField(${jobId})">
              <option value="active" ${(job.job_status || 'active') === 'active' ? 'selected' : ''}>Active</option>
              <option value="waiting_client" ${job.job_status === 'waiting_client' ? 'selected' : ''}>🟡 Waiting on Client</option>
              <option value="missing_info" ${job.job_status === 'missing_info' ? 'selected' : ''}>🟠 Missing Info</option>
              <option value="blocked" ${job.job_status === 'blocked' ? 'selected' : ''}>🔴 Blocked</option>
              <option value="under_extension" ${job.job_status === 'under_extension' ? 'selected' : ''}>🔵 Under Extension</option>
              <option value="on_hold" ${job.job_status === 'on_hold' ? 'selected' : ''}>⚫ On Hold</option>
            </select>
          </div>
          <div class="panel-field">
            <label>Priority</label>
            <select id="panel-priority" onchange="panelSaveField(${jobId})">
              <option value="normal" ${(job.priority || 'normal') === 'normal' ? 'selected' : ''}>Normal</option>
              <option value="high" ${job.priority === 'high' ? 'selected' : ''}>High</option>
              <option value="urgent" ${job.priority === 'urgent' ? 'selected' : ''}>Urgent</option>
            </select>
          </div>
          <div class="panel-field">
            <label>Assigned To</label>
            <select id="panel-assigned" onchange="panelSaveField(${jobId})">${teamOpts}</select>
          </div>
          <div class="panel-field">
            <label>Due Date</label>
            <input type="date" id="panel-due" value="${dueDateVal}" onchange="panelSaveField(${jobId})" />
          </div>
          <div class="panel-field">
            <label>Notes</label>
            <textarea id="panel-notes" rows="4" oninput="panelScheduleSave(${jobId})">${esc(job.notes || '')}</textarea>
          </div>
          <div>
            <div class="section-label">Movement History</div>
            <div class="history-timeline">${histHtml}</div>
          </div>
          <div style="display:flex;gap:0.6rem;margin-top:0.5rem;">
            <button class="btn btn-danger btn-sm" onclick="deleteJob(${jobId})">Delete Job</button>
          </div>
        `;
      } catch (e) {
        document.getElementById('panel-body').innerHTML = `<p style="color:var(--red)">Failed to load: ${esc(e.message)}</p>`;
      }
    }

    window.panelMoveStage = async function(jobId, stageId) {
      try {
        await api('POST', `/jobs/${jobId}/move`, { stage_id: parseInt(stageId), note: '' });
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
        await renderJobPanel(jobId);
      } catch (err) { alert('Failed to move: ' + err.message); }
    };

    window.panelSaveField = async function(jobId) {
      try {
        const priority  = document.getElementById('panel-priority')?.value;
        const assigned  = document.getElementById('panel-assigned')?.value;
        const due       = document.getElementById('panel-due')?.value;
        const notes     = document.getElementById('panel-notes')?.value;
        const jobStatus = document.getElementById('panel-job-status')?.value || 'active';
        await api('PUT', `/jobs/${jobId}`, { priority, assigned_to: assigned || null, due_date: due || null, notes, job_status: jobStatus });
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { console.error('panel save error:', err); }
    };

    window.panelScheduleSave = function(jobId) {
      clearTimeout(panelSaveTimer);
      panelSaveTimer = setTimeout(() => panelSaveField(jobId), 800);
    };

    window.deleteJob = async function(jobId) {
      if (!confirm('Delete this job? This cannot be undone.')) return;
      try {
        await api('DELETE', `/jobs/${jobId}`);
        closeJobPanel();
        currentInstanceData = await api('GET', `/instances/${currentInstance.id}`);
        renderKanban();
      } catch (err) { alert('Failed to delete: ' + err.message); }
    };

    // ─── CREATE PIPELINE MODAL ───────────────────────
    window.openCreatePipelineModal = function() {
      document.getElementById('cp-name').value = '';
      document.getElementById('cp-entity-type').value = 'company';
      document.getElementById('cp-description').value = '';
      openModal('create-pipeline-modal');
    };

    window.submitCreatePipeline = async function() {
      const name = document.getElementById('cp-name').value.trim();
      const entityType = document.getElementById('cp-entity-type').value;
      const description = document.getElementById('cp-description').value.trim();
      if (!name) { alert('Name is required'); return; }
      try {
        const tmpl = await api('POST', '/templates', { name, entity_type: entityType, description });
        closeModal('create-pipeline-modal');
        // Open the new pipeline immediately
        await openPipeline(tmpl.id);
      } catch (err) { alert('Failed: ' + err.message); }
    };

    // ─── INIT ────────────────────────────────────────
    async function init() {
      await loadTeam();
      showView('view-list');
      await loadPipelineList();
    }

    init();
  })();
  </script>

