{
  "name": "darklion-print-agent",
  "version": "1.0.0",
  "description": "DarkLion Print Agent — routes print jobs to DarkLion document management",
  "author": "DarkLion AI",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:win": "electron-forge make --platform win32 --arch x64"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "electron": "^28.3.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": false,
        "name": "DarkLion Print Agent",
        "executableName": "DarkLionPrintAgent",
        "extraResource": [
          "../installer/printer-setup.ps1",
          "../installer/printer-remove.ps1",
          "../shared/config.js"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "DarkLionPrintAgent",
            "setupExe": "DarkLionPrintAgent_Setup_1.0.0.exe",
            "noMsi": true
          }
        }
      ]
    }
  }
}
