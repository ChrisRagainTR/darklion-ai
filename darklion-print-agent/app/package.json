{
  "name": "darklion-print-agent",
  "version": "1.0.0",
  "description": "DarkLion Print Agent - routes print jobs to DarkLion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "form-data": "^4.0.0",
    "keytar": "^7.9.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "ai.darklion.printagent",
    "productName": "DarkLion Print Agent",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": "nsis",
      "icon": "renderer/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "renderer/icon.ico",
      "uninstallerIcon": "renderer/icon.ico"
    }
  }
}
