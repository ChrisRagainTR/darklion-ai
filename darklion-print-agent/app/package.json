{
  "name": "darklion-print-agent",
  "version": "1.0.0",
  "description": "DarkLion Print Agent — routes print jobs to DarkLion document management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:dir": "electron-builder --dir --x64"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "ai.darklion.printagent",
    "productName": "DarkLion Print Agent",
    "copyright": "Copyright © 2025 DarkLion AI",
    "directories": {
      "output": "../dist",
      "buildResources": "renderer"
    },
    "asar": false,
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../installer/printer-setup.ps1",
        "to": "installer/printer-setup.ps1"
      },
      {
        "from": "../installer/printer-remove.ps1",
        "to": "installer/printer-remove.ps1"
      },
      {
        "from": "../shared",
        "to": "shared"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "DarkLionPrintAgent_Setup_${version}.exe",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "runAfterFinish": true,
      "include": "../installer/nsis-extra.nsh"
    }
  }
}
