# QuickBooks OAuth
QB_CLIENT_ID=AB3RdDDHj9ybjqlto5E637DCeN84nKKz5HypgTd5cDDLXi1a6d
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REDIRECT_URI=https://your-domain.com/callback.html

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=8080

# Database (optional — defaults to ./darklion.db)
# DB_PATH=/data/darklion.db

# Dashboard auth (omit DASH_PASS to disable auth in dev)
DASH_USER=admin
DASH_PASS=your_dashboard_password

# SSL (optional — only needed for self-hosted, cloud platforms handle SSL)
# SSL_CERT=/path/to/fullchain.pem
# SSL_KEY=/path/to/privkey.pem
