# QuickBooks OAuth
QB_CLIENT_ID=AB3RdDDHj9ybjqlto5E637DCeN84nKKz5HypgTd5cDDLXi1a6d
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REDIRECT_URI=https://darklion.ai/callback.html

# Anthropic (for AI categorization + vendor research)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=8080
NODE_ENV=production

# PostgreSQL (Neon free tier recommended: https://neon.tech)
DATABASE_URL=postgresql://user:pass@host:5432/darklion

# ===== MULTI-FIRM JWT AUTH (required) =====
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_chars_random_string

# Dashboard auth (legacy fallback for dev — can remove in production)
DASH_USER=admin
DASH_PASS=your_dashboard_password

# Email notifications (optional — via Resend)
# RESEND_API_KEY=re_xxxxx
# NOTIFY_EMAIL=you@example.com
# EMAIL_FROM=DarkLion <darklion@sentineladvisors.co>

# App URL (used in email links)
APP_URL=https://darklion.ai
