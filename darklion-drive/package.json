{
  "name": "darklion-drive",
  "version": "1.0.0",
  "description": "DarkLion Drive — mount your DarkLion documents as a Windows drive letter",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "ai.darklion.drive",
    "productName": "DarkLion Drive",
    "copyright": "Copyright © 2024 DarkLion AI",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeaderIcon": null,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DarkLion Drive"
    },
    "files": [
      "app/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "DarkLionDrive_Setup_${version}.exe"
  }
}
